@using Microsoft.AspNetCore.Components.Authorization
@inject IConfiguration Configuration
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=20260319" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=20260319" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=20260319" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=20260319" />
    <link rel="stylesheet" href="@Assets["lib/fontawesome/css/all.min.css"]" />
    <link rel="stylesheet" href="_content/MudBlazor/MudBlazor.min.css" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["Shink.styles.css"]" />
    <ImportMap />
    <HeadOutlet />
</head>

<body>
    <CascadingAuthenticationState>
        <Routes />
    </CascadingAuthenticationState>
    <ReconnectModal />

    @if (IsPostHogConfigured)
    {
        <script id="posthog-config" data-api-key="@PostHogProjectApiKey" data-host-url="@PostHogHostUrl"></script>
        <script>
            (function () {
                if (window.posthog) {
                    return;
                }

                var configElement = document.getElementById("posthog-config");
                if (!configElement) {
                    return;
                }

                var apiKey = configElement.getAttribute("data-api-key");
                var hostUrl = configElement.getAttribute("data-host-url");
                if (!apiKey || !hostUrl) {
                    return;
                }

                var script = document.createElement("script");
                script.async = true;
                script.src = hostUrl.replace(/\/+$/, "") + "/static/array.js";
                script.onload = function () {
                    if (!window.posthog) {
                        return;
                    }

                    window.posthog.init(apiKey, {
                        api_host: hostUrl,
                        person_profiles: "identified_only",
                        capture_pageview: true,
                        capture_pageleave: true
                    });
                };

                document.head.appendChild(script);
            })();
        </script>
    }

    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    private string? PostHogProjectApiKey => Configuration["PostHog:ProjectApiKey"];
    private string? PostHogHostUrl => Configuration["PostHog:HostUrl"];
    private bool IsPostHogConfigured =>
        !string.IsNullOrWhiteSpace(PostHogProjectApiKey) &&
        !string.IsNullOrWhiteSpace(PostHogHostUrl);
}
