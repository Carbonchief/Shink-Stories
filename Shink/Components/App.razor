@using Microsoft.AspNetCore.Components.Authorization
@using Shink.Services
@implements IDisposable
@inject IConfiguration Configuration
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager NavigationManager
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=20260319" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=20260319" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=20260319" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=20260319" />
    <link rel="stylesheet" href="@Assets["lib/fontawesome/css/all.min.css"]" />
    <link rel="stylesheet" href="_content/MudBlazor/MudBlazor.min.css" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["Shink.styles.css"]" />
    <link rel="stylesheet" href="@Assets["css/app-shell.css"]" />
    <ImportMap AdditionalAttributes="ImportMapAttributes" />
    <HeadOutlet />
</head>

<body data-posthog-api-key="@PostHogProjectApiKey" data-posthog-host-url="@PostHogHostUrl">
    <section id="unsupported-browser-fallback" class="unsupported-browser-fallback" hidden aria-live="polite">
        <div class="unsupported-browser-card">
            <img class="unsupported-browser-logo" src="/branding/schink-logo-text.png" alt="Schink Stories" />
            <h1>Hierdie blaaier word nie meer volledig ondersteun nie.</h1>
            <p>
                Schink Stories gebruik moderne webfunksies vir veilige aanmelding, klankafspeel en bladsy-interaksies.
                Jou huidige blaaier kan dit nie betroubaar doen nie.
            </p>
            <p id="unsupported-browser-detail" class="unsupported-browser-detail">
                Werk asseblief jou blaaier op en probeer weer.
            </p>
            <div class="unsupported-browser-steps" aria-label="Volgende stappe">
                <div class="unsupported-browser-step">Werk Safari op na weergawe 15 of nuwer as jy op iPhone, iPad of Mac is.</div>
                <div class="unsupported-browser-step">Of gebruik die nuutste weergawe van Chrome, Edge of Firefox.</div>
                <div class="unsupported-browser-step">As jou toestel te oud is om op te dateer, probeer asseblief op 'n nuwer toestel.</div>
            </div>
            <p class="unsupported-browser-english">
                This browser is too old for secure sign-in and audio playback. Please update your browser and try again.
            </p>
        </div>
    </section>

    <div id="app-shell-root">
        <CascadingValue Name="CspNonce" Value="@_cspNonce">
            <CascadingAuthenticationState>
                @if (IsKaraktersRoute)
                {
                    <ErrorBoundary @ref="_karaktersErrorBoundary">
                        <ChildContent>
                            <Routes />
                        </ChildContent>
                        <ErrorContent Context="exception">
                            <section class="route-error-fallback" aria-live="assertive">
                                <div class="route-error-card">
                                    <p class="route-error-kicker">Karakters fout</p>
                                    <h1>Hierdie blad het op 'n fout geloop.</h1>
                                    <p>Neem asseblief 'n skermgreep van die besonderhede hieronder sodat ons die presiese fout kan sien.</p>
                                    <div class="route-error-chip">@exception.GetType().FullName</div>
                                    @if (!string.IsNullOrWhiteSpace(exception.Message))
                                    {
                                        <p>@exception.Message</p>
                                    }
                                    <details class="route-error-details" open>
                                        <summary>Volledige fout</summary>
                                        <pre>@exception.ToString()</pre>
                                    </details>
                                    <div class="route-error-actions">
                                        <button type="button" class="route-error-button" @onclick="RecoverKaraktersRoute">Probeer weer</button>
                                        <button type="button" class="route-error-link" @onclick="ReloadCurrentRoute">Herlaai blad</button>
                                    </div>
                                </div>
                            </section>
                        </ErrorContent>
                    </ErrorBoundary>
                }
                else
                {
                    <Routes />
                }
            </CascadingAuthenticationState>
        </CascadingValue>
        <ReconnectModal />
    </div>

    <script src="@Assets["js/browser-support.js"]" defer></script>
    <script src="@Assets["js/app-shell.js"]" defer></script>
</body>

</html>

@code {
    private ErrorBoundary? _karaktersErrorBoundary;
    private PostHogSettings? _postHogSettings;
    private string? _cspNonce;

    private PostHogSettings PostHogSettings =>
        _postHogSettings ??= PostHogSettings.FromConfiguration(Configuration);

    private IReadOnlyDictionary<string, object>? ImportMapAttributes =>
        string.IsNullOrWhiteSpace(_cspNonce)
            ? null
            : new Dictionary<string, object>
            {
                ["nonce"] = _cspNonce
            };

    private string? PostHogProjectApiKey => PostHogSettings.ProjectApiKey;
    private string? PostHogHostUrl => PostHogSettings.HostUrl;
    private bool IsKaraktersRoute => string.Equals(GetCurrentRoutePath(), "/karakters", StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        _cspNonce ??= CspConstants.GetNonce(HttpContextAccessor.HttpContext);
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _karaktersErrorBoundary?.Recover();
        _ = InvokeAsync(StateHasChanged);
    }

    private string GetCurrentRoutePath()
    {
        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var path = relativePath.Split(['?', '#'], 2)[0];
        return string.IsNullOrWhiteSpace(path)
            ? "/"
            : "/" + path.TrimStart('/');
    }

    private void RecoverKaraktersRoute()
    {
        _karaktersErrorBoundary?.Recover();
        StateHasChanged();
    }

    private void ReloadCurrentRoute()
    {
        NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }
}
