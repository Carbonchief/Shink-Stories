        _dotNetReference?.Dispose();
    }

    private static string NormalizeImageContentType(IBrowserFile file) =>
        file.ContentType?.Trim().ToLowerInvariant() switch
        {
            "image/jpeg" or "image/jpg" => "image/jpeg",
            "image/png" => "image/png",
            "image/webp" => "image/webp",
            _ => Path.GetExtension(file.Name).Trim().ToLowerInvariant() switch
            {
                ".jpg" or ".jpeg" => "image/jpeg",
                ".png" => "image/png",
                ".webp" => "image/webp",
                _ => file.ContentType ?? string.Empty
            }
        };

    private static bool IsSupportedImageContentType(string normalizedContentType) =>
        normalizedContentType is "image/jpeg" or "image/png" or "image/webp";

    private static string ResolveSafeImageExtension(string fileName)
    {
        var extension = Path.GetExtension(fileName)?.Trim().ToLowerInvariant();
        return extension switch
        {
            ".jpg" or ".jpeg" => extension,
            ".png" => ".png",
            ".webp" => ".webp",
            _ => ".png"
        };
    }

    private static string? ResolvePreviewImageUrl(string? imagePath)
    {
        if (string.IsNullOrWhiteSpace(imagePath))
        {
            return null;
        }

        var candidate = imagePath.Trim();
        if (candidate.StartsWith("data:image/", StringComparison.OrdinalIgnoreCase))
        {
            return candidate;
        }

        if (Uri.TryCreate(candidate, UriKind.Absolute, out var absoluteUri))
        {
            return string.Equals(absoluteUri.Scheme, Uri.UriSchemeHttp, StringComparison.OrdinalIgnoreCase) ||
                   string.Equals(absoluteUri.Scheme, Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase)
                ? StoryItem.RewriteImagePathForBrowser(absoluteUri.ToString())
                : null;
        }

        if (candidate.StartsWith("//", StringComparison.Ordinal))
        {
            return null;
        }

        if (candidate.StartsWith("~/", StringComparison.Ordinal))
        {
            candidate = $"/{candidate[2..]}";
        }

        var normalizedPath = candidate.StartsWith("/", StringComparison.Ordinal)
            ? candidate
            : $"/{candidate.TrimStart('/')}";

        return StoryItem.RewriteImagePathForBrowser(normalizedPath);
    }

    private sealed class EditableBlogPost
    {
        public Guid? PostId { get; set; }
        public string Title { get; set; } = string.Empty;
        public string Slug { get; set; } = string.Empty;
        public bool HasManualSlug { get; set; }
        public string? Summary { get; set; }
        public string ContentMarkdown { get; set; } = string.Empty;
        public string? FeaturedImageUrl { get; set; }
        public string? FeaturedImagePreviewUrl { get; set; }
        public IBrowserFile? FeaturedImageFile { get; set; }
        public string? FeaturedImageFileName { get; set; }
        public string? AuthorName { get; set; }
        public string? CategoryName { get; set; }
        public string TagsText { get; set; } = string.Empty;
        public bool IsPublished { get; set; }
        public string? PublishedAtLocal { get; set; }
        public DateTimeOffset? CreatedAt { get; set; }
        public DateTimeOffset? UpdatedAt { get; set; }
        public string? SeoTitle { get; set; }
        public string? SeoDescription { get; set; }

        public string SlugPreview => string.IsNullOrWhiteSpace(Slug) ? BuildEffectiveSlug(null, Title) : Slug;

        public static EditableBlogPost CreateEmpty() =>
            new()
            {
                IsPublished = false
            };

        public static EditableBlogPost From(AdminBlogPostRecord post) =>
            new()
            {
                PostId = post.PostId,
                Title = post.Title,
                Slug = post.Slug,
                HasManualSlug = true,
                Summary = post.Summary,
                ContentMarkdown = post.ContentMarkdown,
                FeaturedImageUrl = post.FeaturedImageUrl,
                FeaturedImagePreviewUrl = ResolvePreviewImageUrl(post.FeaturedImageUrl),
                AuthorName = post.AuthorName,
                CategoryName = post.CategoryName,
                TagsText = string.Join(", ", post.Tags.Select(tag => tag.Name)),
                IsPublished = post.IsPublished,
                PublishedAtLocal = post.PublishedAt?.ToLocalTime().ToString("yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture),
                CreatedAt = post.CreatedAt,
                UpdatedAt = post.UpdatedAt,
                SeoTitle = post.SeoTitle,
                SeoDescription = post.SeoDescription
            };
    }
