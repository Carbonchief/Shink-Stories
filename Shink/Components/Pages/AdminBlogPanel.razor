    private async Task CleanupReplacedImageAssetAsync(string? originalPath, string? updatedPath)
    {
        if (AdminManagedImageAssetHelper.AreEquivalent(originalPath, updatedPath))
        {
            return;
        }

        await DeleteManagedImageAssetAsync(originalPath);
    }

    private async Task DeleteManagedImageAssetAsync(string? imagePath)
    {
        var r2ObjectKey = AdminManagedImageAssetHelper.TryResolveR2ObjectKey(
            imagePath,
            CloudflareR2OptionsAccessor.Value.PublicBaseUrl);
        if (!string.IsNullOrWhiteSpace(r2ObjectKey))
        {
            await StoryMediaStorageService.DeleteObjectIfExistsAsync(r2ObjectKey);
            return;
        }

        var localFilePath = AdminManagedImageAssetHelper.TryResolveLocalUploadedFilePath(
            imagePath,
            WebHostEnvironment.WebRootPath);
        if (string.IsNullOrWhiteSpace(localFilePath))
        {
            return;
        }

        try
        {
            if (File.Exists(localFilePath))
            {
                File.Delete(localFilePath);
            }
        }
        catch (Exception exception) when (exception is IOException or UnauthorizedAccessException)
        {
            Logger.LogWarning(exception, "Failed to delete managed blog image asset {ImagePath}.", imagePath);
        }
    }

