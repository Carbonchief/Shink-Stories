@using System.Globalization
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using Microsoft.Extensions.Options
@implements IAsyncDisposable
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IBlogAdminService BlogAdminService
@inject IBlogContentRenderer BlogContentRenderer
@inject IStoryMediaStorageService StoryMediaStorageService
@inject IWebHostEnvironment WebHostEnvironment
@inject IJSRuntime JSRuntime
@inject ILogger<AdminBlogPanel> Logger
@inject IOptions<CloudflareR2Options> CloudflareR2OptionsAccessor

<section class="admin-section">
    <div class="admin-section-head">
        <div class="admin-search">
            <input class="blog-admin-search"
                   type="search"
                   @bind="PostSearch"
                   @bind:event="oninput"
                   placeholder="@T("Soek titel of slug", "Search title or slug")" />

            <select class="blog-admin-filter" @bind="StatusFilter">
                <option value="all">@T("Alle statusse", "All statuses")</option>
                <option value="draft">@T("Konsepte", "Drafts")</option>
                <option value="published">@T("Gepubliseer", "Published")</option>
                <option value="scheduled">@T("Geskeduleer", "Scheduled")</option>
            </select>

            <MudButton Class="blog-admin-new-action-btn"
                       Variant="Variant.Outlined"
                       Color="Color.Primary"
                       OnClick="BeginCreatePost"
                       aria-label='@T("Nuwe blog", "New post")'
                       title='@T("Nuwe blog", "New post")'>
                <i class="fa-solid fa-plus" aria-hidden="true"></i>
            </MudButton>

            <MudButton Class="admin-btn admin-btn-secondary admin-icon-btn"
                       Variant="Variant.Outlined"
                       Color="Color.Primary"
                       OnClick="() => ReloadAsync()"
                       aria-label='@T("Herlaai", "Refresh")'
                       title='@T("Herlaai", "Refresh")'>
                <i class="fa-solid fa-arrows-rotate" aria-hidden="true"></i>
                <span class="sr-only">@T("Herlaai", "Refresh")</span>
            </MudButton>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <p class="admin-feedback is-error">@ErrorMessage</p>
    }
    else if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <p class="admin-feedback is-success">@StatusMessage</p>
    }

    @if (IsLoading)
    {
        <section class="admin-state">
            <h2>@T("Laai blog plasings...", "Loading blog posts...")</h2>
        </section>
    }
    else
    {
        <div class="blog-admin-layout">
            <aside class="blog-admin-list">
                <div class="blog-admin-list-header">
                    <span>@FilteredPosts.Count @T("plasings", "posts")</span>
                </div>

                @if (FilteredPosts.Count == 0)
                {
                    <p class="blog-admin-empty">@T("Geen blog plasings pas by jou soektog nie.", "No blog posts match your search.")</p>
                }
                else
                {
                    @foreach (var post in FilteredPosts)
                    {
                        var isSelected = Editor?.PostId == post.PostId;
                        <button type="button"
                                class="blog-admin-list-item @(isSelected ? "is-selected" : null)"
                                @onclick="() => SelectPost(post)">
                            <span class="blog-admin-list-copy">
                                <span class="blog-admin-list-title">@post.Title</span>
                                <span class="blog-admin-list-meta">@post.Slug</span>
                                <span class="blog-admin-list-status">@BuildStatusLabel(post.IsPublished, post.PublishedAt)</span>
                            </span>

                            <span class="blog-admin-list-date">@FormatAdminDate(post.UpdatedAt)</span>
                        </button>
                    }
                }
            </aside>

            <section class="blog-admin-editor">
                @if (Editor is null)
                {
                    <div class="blog-admin-empty-state">
                        <h3>@T("Kies 'n blog plasing", "Choose a blog post")</h3>
                        <p>@T("Maak links 'n bestaande plasing oop of skep 'n nuwe een.", "Open an existing post on the left or create a new one.")</p>
                    </div>
                }
                else
                {
                    <div class="blog-admin-editor-head">
                        <div>
                            <h3>@(IsNewPost ? T("Nuwe blog plasing", "New blog post") : Editor.Title)</h3>
                            <p>@Editor.SlugPreview</p>
                        </div>

                        <div class="blog-admin-editor-actions">
                            @if (!IsNewPost)
                            {
                                <button type="button"
                                        class="blog-admin-btn blog-admin-btn-secondary"
                                        @onclick="TogglePublishedStateAsync"
                                        disabled="@IsSaving">
                                    @(Editor.IsPublished
                                        ? T("Ontpubliseer", "Unpublish")
                                        : T("Publiseer nou", "Publish now"))
                                </button>

                                <button type="button"
                                        class="blog-admin-btn blog-admin-btn-danger"
                                        @onclick="DeletePostAsync"
                                        disabled="@IsDeleting">
                                    @(IsDeleting ? T("Verwyder...", "Deleting...") : T("Verwyder", "Delete"))
                                </button>
                            }

                            <button type="button"
                                    class="blog-admin-btn"
                                    @onclick="SavePostAsync"
                                    disabled="@IsSaving">
                                @(IsSaving ? T("Stoor...", "Saving...") : T("Stoor blog", "Save post"))
                            </button>
                        </div>
                    </div>

                    <div class="blog-admin-form-grid">
                        <section class="blog-admin-card">
                            <h4>@T("Basies", "Basics")</h4>

                            <label class="blog-admin-field">
                                <span>@T("Titel", "Title")</span>
                                <input type="text" value="@Editor.Title" @oninput="OnTitleChanged" />
                            </label>

                            <label class="blog-admin-field">
                                <span>@T("Slug", "Slug")</span>
                                <input type="text" value="@Editor.Slug" @oninput="OnSlugChanged" />
                            </label>

                            <label class="blog-admin-field">
                                <span>@T("Opsomming", "Summary")</span>
                                <textarea rows="4" @bind="Editor.Summary"></textarea>
                            </label>

                            <div class="blog-admin-field-row">
                                <label class="blog-admin-field">
                                    <span>@T("Skrywer", "Author")</span>
                                    <input type="text" @bind="Editor.AuthorName" />
                                </label>

                                <label class="blog-admin-field">
                                    <span>@T("Kategorie", "Category")</span>
                                    <input type="text" @bind="Editor.CategoryName" list="blog-admin-category-options" />
                                    <datalist id="blog-admin-category-options">
                                        @foreach (var category in Categories)
                                        {
                                            <option value="@category.Name"></option>
                                        }
                                    </datalist>
                                </label>
                            </div>

                            <label class="blog-admin-field">
                                <span>@T("Etikette", "Tags")</span>
                                <input type="text"
                                       @bind="Editor.TagsText"
                                       placeholder="@T("Byvoorbeeld: ouerskap, luister, stories", "For example: parenting, listening, stories")" />
                            </label>

                            @if (ParsedTags.Count > 0)
                            {
                                <div class="blog-admin-tag-preview">
                                    @foreach (var tag in ParsedTags)
                                    {
                                        <span class="blog-admin-tag">@tag</span>
                                    }
                                </div>
                            }
                        </section>

                        <section class="blog-admin-card">
                            <h4>@T("Publisering en SEO", "Publishing and SEO")</h4>

                            <label class="blog-admin-checkbox">
                                <input type="checkbox" @bind="Editor.IsPublished" />
                                <span>@T("Gepubliseer", "Published")</span>
                            </label>

                            <label class="blog-admin-field">
                                <span>@T("Publiseer op", "Publish on")</span>
                                <input type="datetime-local" value="@Editor.PublishedAtLocal" @onchange="OnPublishedAtChanged" />
                            </label>

                            <p class="blog-admin-hint">
                                @T(
                                    "Laat die datum leeg om onmiddellik te publiseer wanneer die plasing as gepubliseer gemerk is.",
                                    "Leave the date empty to publish immediately when the post is marked as published.")
                            </p>

                            <label class="blog-admin-field">
                                <span>@T("SEO titel", "SEO title")</span>
                                <input type="text" @bind="Editor.SeoTitle" />
                            </label>

                            <label class="blog-admin-field">
                                <span>@T("SEO beskrywing", "SEO description")</span>
                                <textarea rows="3" @bind="Editor.SeoDescription"></textarea>
                            </label>

                            <dl class="blog-admin-summary">
                                <div>
                                    <dt>@T("Geskep", "Created")</dt>
                                    <dd>@(Editor.CreatedAt is null ? "-" : FormatAdminDate(Editor.CreatedAt.Value))</dd>
                                </div>
                                <div>
                                    <dt>@T("Laas gewysig", "Last updated")</dt>
                                    <dd>@(Editor.UpdatedAt is null ? "-" : FormatAdminDate(Editor.UpdatedAt.Value))</dd>
                                </div>
                            </dl>
                        </section>

                        <section class="blog-admin-card">
                            <h4>@T("Hoofprent", "Featured image")</h4>

                            @if (!string.IsNullOrWhiteSpace(Editor.FeaturedImagePreviewUrl))
                            {
                                <div class="blog-admin-image-preview-wrap">
                                    <img class="blog-admin-image-preview"
                                         src="@Editor.FeaturedImagePreviewUrl"
                                         alt="@T("Blog prent voorskou", "Blog image preview")"
                                         onerror="this.onerror=null;this.src='/branding/schink-logo-green.png';" />
                                    @if (CanRemoveFeaturedImage())
                                    {
                                        <button type="button"
                                                class="blog-admin-image-remove"
                                                @onclick="RemoveFeaturedImageAsync"
                                                aria-label='@T("Verwyder hoofprent", "Remove featured image")'
                                                title='@T("Verwyder hoofprent", "Remove featured image")'>
                                            <i class="fa-solid fa-trash-can" aria-hidden="true"></i>
                                        </button>
                                    }
                                </div>
                            }

                            <label class="blog-admin-field">
                                <span>@T("Hoofprent URL of pad", "Featured image URL or path")</span>
                                <input type="text" @bind="Editor.FeaturedImageUrl" />
                            </label>

                            <label class="blog-admin-file-picker">
                                <span>@T("Laai nuwe prent op", "Upload new image")</span>
                                <InputFile OnChange="OnFeaturedImageSelectedAsync" accept="image/png,image/jpeg,image/webp" />
                            </label>

                            @if (!string.IsNullOrWhiteSpace(Editor.FeaturedImageFileName))
                            {
                                <p class="blog-admin-hint">
                                    @T($"Geselekteerde lêer: {Editor.FeaturedImageFileName}", $"Selected file: {Editor.FeaturedImageFileName}")
                                </p>
                            }
                        </section>

                        <section class="blog-admin-card blog-admin-card-content">
                            <div class="blog-admin-card-head">
                                <div>
                                    <h4>@T("Inhoud", "Content")</h4>
                                    <p>@T("Gebruik die nutsbalk om ryk teks te formateer. Die inhoud word veilig vir die publieke blog gerender.", "Use the toolbar to format rich text. The content is safely rendered for the public blog.")</p>
                                </div>
                            </div>

                            <div class="blog-admin-rich-editor-shell" @ref="_richTextEditorShell">
                                <div class="blog-admin-rich-toolbar"
                                     role="toolbar"
                                     aria-label="@T("Rykteks nutsbalk", "Rich text toolbar")"
                                     data-editor-label="@T("Blog inhoud redigeerder", "Blog content editor")">
                                    <span class="ql-formats">
                                        <button type="button"
                                                class="ql-undo"
                                                title="@T("Ontdoen", "Undo")"
                                                aria-label="@T("Ontdoen", "Undo")">
                                            <i class="fa-solid fa-rotate-left" aria-hidden="true"></i>
                                        </button>
                                        <button type="button"
                                                class="ql-redo"
                                                title="@T("Herdoen", "Redo")"
                                                aria-label="@T("Herdoen", "Redo")">
                                            <i class="fa-solid fa-rotate-right" aria-hidden="true"></i>
                                        </button>
                                    </span>

                                    <span class="ql-formats">
                                        <button type="button"
                                                class="ql-bold"
                                                title="@T("Vet", "Bold")"
                                                aria-label="@T("Vet", "Bold")"></button>
                                        <button type="button"
                                                class="ql-italic"
                                                title="@T("Kursief", "Italic")"
                                                aria-label="@T("Kursief", "Italic")"></button>
                                        <button type="button"
                                                class="ql-underline"
                                                title="@T("Onderstreep", "Underline")"
                                                aria-label="@T("Onderstreep", "Underline")"></button>
                                        <button type="button"
                                                class="ql-strike"
                                                title="@T("Deurstreep", "Strikethrough")"
                                                aria-label="@T("Deurstreep", "Strikethrough")"></button>
                                    </span>

                                    <span class="ql-formats">
                                        <button type="button"
                                                class="ql-header"
                                                value="2"
                                                title="@T("Opskrif 2", "Heading 2")"
                                                aria-label="@T("Opskrif 2", "Heading 2")"></button>
                                        <button type="button"
                                                class="ql-header"
                                                value="3"
                                                title="@T("Opskrif 3", "Heading 3")"
                                                aria-label="@T("Opskrif 3", "Heading 3")"></button>
                                        <button type="button"
                                                class="ql-blockquote"
                                                title="@T("Aanhaling", "Block quote")"
                                                aria-label="@T("Aanhaling", "Block quote")"></button>
                                    </span>

                                    <span class="ql-formats">
                                        <button type="button"
                                                class="ql-list"
                                                value="ordered"
                                                title="@T("Genommerde lys", "Numbered list")"
                                                aria-label="@T("Genommerde lys", "Numbered list")"></button>
                                        <button type="button"
                                                class="ql-list"
                                                value="bullet"
                                                title="@T("Kolpunte lys", "Bullet list")"
                                                aria-label="@T("Kolpunte lys", "Bullet list")"></button>
                                    </span>

                                    <span class="ql-formats">
                                        <button type="button"
                                                class="ql-link"
                                                title="@T("Skakel", "Link")"
                                                aria-label="@T("Skakel", "Link")"></button>
                                        <button type="button"
                                                class="ql-clean"
                                                title="@T("Wis formatering", "Clear formatting")"
                                                aria-label="@T("Wis formatering", "Clear formatting")"></button>
                                    </span>
                                </div>

                                <div class="blog-admin-markdown-editor"
                                     data-placeholder="@T("Tik of plak jou blog inhoud hier.", "Type or paste your blog content here.")"></div>
                            </div>
                        </section>

                        <section class="blog-admin-card blog-admin-card-preview">
                            <div class="blog-admin-card-head">
                                <div>
                                    <h4>@T("Voorskou", "Preview")</h4>
                                    <p>@T("Die voorskou wys die gesanitiseerde HTML wat op die werf sal verskyn.", "The preview shows the sanitized HTML that will appear on the site.")</p>
                                </div>
                            </div>

                            <div class="blog-admin-preview">
                                <h2>@(string.IsNullOrWhiteSpace(Editor.Title) ? T("Jou blog titel", "Your blog title") : Editor.Title)</h2>
                                @if (!string.IsNullOrWhiteSpace(Editor.Summary))
                                {
                                    <p class="blog-admin-preview-summary">@Editor.Summary</p>
                                }
                                <div class="blog-admin-preview-body">@PreviewMarkup</div>
                            </div>
                        </section>
                    </div>
                }
            </section>
        </div>
    }
</section>

@code {
    private const long MaxImageUploadBytes = 10 * 1024 * 1024;

    [Parameter]
    public string CurrentLanguageCode { get; set; } = "af";

    private IReadOnlyList<AdminBlogPostRecord> Posts { get; set; } = Array.Empty<AdminBlogPostRecord>();
    private IReadOnlyList<BlogCategoryItem> Categories { get; set; } = Array.Empty<BlogCategoryItem>();
    private EditableBlogPost? Editor { get; set; }
    private string? SignedInEmail { get; set; }
    private string? PostSearch { get; set; }
    private string StatusFilter { get; set; } = "all";
    private bool IsLoading { get; set; } = true;
    private bool IsSaving { get; set; }
    private bool IsDeleting { get; set; }
    private string? ErrorMessage { get; set; }
    private string? StatusMessage { get; set; }
    private ElementReference _richTextEditorShell;
    private IJSObjectReference? _richTextEditorModule;
    private DotNetObjectReference<AdminBlogPanel>? _dotNetReference;
    private bool _richTextEditorSyncPending = true;

    private bool IsNewPost => Editor?.PostId is not Guid postId || postId == Guid.Empty;

    private bool IsR2UploadConfigured =>
        !string.IsNullOrWhiteSpace(CloudflareR2OptionsAccessor.Value.AccountId) &&
        !string.IsNullOrWhiteSpace(CloudflareR2OptionsAccessor.Value.BucketName) &&
        !string.IsNullOrWhiteSpace(CloudflareR2OptionsAccessor.Value.AccessKeyId) &&
        !string.IsNullOrWhiteSpace(CloudflareR2OptionsAccessor.Value.SecretAccessKey) &&
        !string.IsNullOrWhiteSpace(CloudflareR2OptionsAccessor.Value.PublicBaseUrl);

    private IReadOnlyList<string> ParsedTags =>
        Editor is null ? Array.Empty<string>() : ParseTags(Editor.TagsText);

    private MarkupString PreviewMarkup =>
        new(BlogContentRenderer.RenderHtml(Editor?.ContentMarkdown));

    private IReadOnlyList<AdminBlogPostRecord> FilteredPosts =>
        Posts
            .Where(MatchesStatusFilter)
            .Where(MatchesSearch)
            .OrderByDescending(post => post.UpdatedAt)
            .ThenByDescending(post => post.PublishedAt ?? DateTimeOffset.MinValue)
            .ThenBy(post => post.Title, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        SignedInEmail = authState.User.FindFirst(ClaimTypes.Email)?.Value
                        ?? authState.User.Identity?.Name;

        await ReloadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Editor is null || !_richTextEditorSyncPending)
        {
            return;
        }

        _richTextEditorModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>(
            "import",
            "/Components/Pages/AdminBlogPanel.razor.js");

        _dotNetReference ??= DotNetObjectReference.Create(this);
        var renderedHtml = BlogContentRenderer.RenderHtml(Editor.ContentMarkdown);
        await _richTextEditorModule.InvokeVoidAsync(
            "syncRichTextEditor",
            _richTextEditorShell,
            _dotNetReference,
            renderedHtml);

        _richTextEditorSyncPending = false;
    }

    [JSInvokable]
    public async Task OnRichTextEditorInput(string html)
    {
        if (Editor is null)
        {
            return;
        }

        Editor.ContentMarkdown = html ?? string.Empty;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ReloadAsync(Guid? selectPostId = null)
    {
        IsLoading = true;
        ErrorMessage = null;

        try
        {
            var dashboard = await BlogAdminService.GetDashboardAsync(SignedInEmail);
            Posts = dashboard.Posts;
            Categories = dashboard.Categories;

            var selected = selectPostId is Guid targetId && targetId != Guid.Empty
                ? Posts.FirstOrDefault(post => post.PostId == targetId)
                : Editor?.PostId is Guid currentId && currentId != Guid.Empty
                    ? Posts.FirstOrDefault(post => post.PostId == currentId)
                    : Posts.FirstOrDefault();

            Editor = selected is null ? null : EditableBlogPost.From(selected);
            MarkRichTextEditorDirty();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to load blog admin dashboard.");
            Posts = Array.Empty<AdminBlogPostRecord>();
            Categories = Array.Empty<BlogCategoryItem>();
            Editor = null;
            ErrorMessage = T("Kon nie blog plasings nou laai nie.", "Could not load blog posts right now.");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void BeginCreatePost()
    {
        ErrorMessage = null;
        StatusMessage = null;
        Editor = EditableBlogPost.CreateEmpty();
        MarkRichTextEditorDirty();
    }

    private void SelectPost(AdminBlogPostRecord post)
    {
        ErrorMessage = null;
        StatusMessage = null;
        Editor = EditableBlogPost.From(post);
        MarkRichTextEditorDirty();
    }

    private void OnTitleChanged(ChangeEventArgs args)
    {
        if (Editor is null)
        {
            return;
        }

        Editor.Title = args.Value?.ToString() ?? string.Empty;
        if (!Editor.HasManualSlug || string.IsNullOrWhiteSpace(Editor.Slug))
        {
            Editor.Slug = BuildEffectiveSlug(null, Editor.Title);
            Editor.HasManualSlug = false;
        }
    }

    private void OnSlugChanged(ChangeEventArgs args)
    {
        if (Editor is null)
        {
            return;
        }

        var value = args.Value?.ToString() ?? string.Empty;
        Editor.Slug = BuildEffectiveSlug(value, value);
        Editor.HasManualSlug = !string.IsNullOrWhiteSpace(Editor.Slug);
    }

    private void OnPublishedAtChanged(ChangeEventArgs args)
    {
        if (Editor is null)
        {
            return;
        }

        Editor.PublishedAtLocal = args.Value?.ToString();
    }

    private async Task OnFeaturedImageSelectedAsync(InputFileChangeEventArgs args)
    {
        if (Editor is null)
        {
            return;
        }

        ErrorMessage = null;
        var file = args.File;
        if (file is null || file.Size <= 0 || file.Size > MaxImageUploadBytes)
        {
            ErrorMessage = T("Kies asseblief 'n geldige prent tot 10 MB.", "Please choose a valid image up to 10 MB.");
            return;
        }

        var normalizedContentType = NormalizeImageContentType(file);
        if (!IsSupportedImageContentType(normalizedContentType))
        {
            ErrorMessage = T("Gebruik asseblief JPG, PNG of WEBP vir die blog prent.", "Please use JPG, PNG, or WEBP for the blog image.");
            return;
        }

        Editor.FeaturedImageFile = file;
        Editor.FeaturedImageFileName = file.Name;
        Editor.FeaturedImagePreviewUrl = await ReadImageFileAsDataUrlAsync(file)
            ?? ResolvePreviewImageUrl(Editor.FeaturedImageUrl);
    }

    private bool CanRemoveFeaturedImage() =>
        Editor is not null &&
        (Editor.FeaturedImageFile is not null || !string.IsNullOrWhiteSpace(Editor.FeaturedImageUrl));

    private async Task RemoveFeaturedImageAsync()
    {
        if (Editor is null ||
            !await ConfirmImageRemovalAsync(
                "Is jy seker jy wil hierdie hoofprent verwyder?",
                "Are you sure you want to remove this featured image?"))
        {
            return;
        }

        Editor.FeaturedImageFile = null;
        Editor.FeaturedImageFileName = null;
        Editor.FeaturedImagePreviewUrl = null;
        Editor.FeaturedImageUrl = null;
    }

    private async Task SavePostAsync()
    {
        if (Editor is null || IsSaving)
        {
            return;
        }

        IsSaving = true;
        ErrorMessage = null;
        StatusMessage = null;

        try
        {
            var originalFeaturedImageUrl = Editor.FeaturedImageUrl;
            var effectiveSlug = BuildEffectiveSlug(Editor.Slug, Editor.Title);
            if (string.IsNullOrWhiteSpace(effectiveSlug))
            {
                ErrorMessage = T("Voeg asseblief eers 'n titel by.", "Please add a title first.");
                return;
            }

            if (string.IsNullOrWhiteSpace(Editor.ContentMarkdown))
            {
                ErrorMessage = T("Voeg asseblief blog inhoud by.", "Please add blog content.");
                return;
            }

            if (Editor.FeaturedImageFile is not null)
            {
                Editor.FeaturedImageUrl = await UploadFeaturedImageAsync(effectiveSlug, Editor.FeaturedImageFile);
                Editor.FeaturedImageFile = null;
                Editor.FeaturedImageFileName = null;
                Editor.FeaturedImagePreviewUrl = ResolvePreviewImageUrl(Editor.FeaturedImageUrl);
            }

            var request = new AdminBlogPostSaveRequest(
                PostId: Editor.PostId,
                Title: Editor.Title,
                Slug: effectiveSlug,
                Summary: Editor.Summary,
                ContentMarkdown: Editor.ContentMarkdown,
                FeaturedImageUrl: Editor.FeaturedImageUrl,
                AuthorName: Editor.AuthorName,
                CategoryName: Editor.CategoryName,
                TagNames: ParseTags(Editor.TagsText),
                IsPublished: Editor.IsPublished,
                PublishedAt: ParseOptionalLocalDateTime(Editor.PublishedAtLocal),
                SeoTitle: Editor.SeoTitle,
                SeoDescription: Editor.SeoDescription);

            var result = await BlogAdminService.SavePostAsync(SignedInEmail, request);
            if (!result.IsSuccess)
            {
                ErrorMessage = TranslateServiceMessage(result.ErrorMessage)
                               ?? T("Kon nie blog nou stoor nie.", "Could not save the blog post right now.");
                return;
            }

            await CleanupReplacedImageAssetAsync(originalFeaturedImageUrl, Editor.FeaturedImageUrl);
            await ReloadAsync(result.EntityId);
            StatusMessage = T("Blog plasing suksesvol gestoor.", "Blog post saved successfully.");
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to save blog post.");
            ErrorMessage = T("Kon nie blog nou stoor nie.", "Could not save the blog post right now.");
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task TogglePublishedStateAsync()
    {
        if (Editor is null)
        {
            return;
        }

        Editor.IsPublished = !Editor.IsPublished;
        if (Editor.IsPublished && string.IsNullOrWhiteSpace(Editor.PublishedAtLocal))
        {
            Editor.PublishedAtLocal = DateTime.Now.ToString("yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture);
        }

        await SavePostAsync();
    }

    private async Task DeletePostAsync()
    {
        if (Editor?.PostId is not Guid postId || postId == Guid.Empty || IsDeleting)
        {
            return;
        }

        var confirmed = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            T("Is jy seker jy wil hierdie blog plasing verwyder?", "Are you sure you want to delete this blog post?"));
        if (!confirmed)
        {
            return;
        }

        IsDeleting = true;
        ErrorMessage = null;
        StatusMessage = null;

        try
        {
            var result = await BlogAdminService.DeletePostAsync(SignedInEmail, postId);
            if (!result.IsSuccess)
            {
                ErrorMessage = TranslateServiceMessage(result.ErrorMessage)
                               ?? T("Kon nie blog nou verwyder nie.", "Could not delete the blog post right now.");
                return;
            }

            Editor = null;
            await ReloadAsync();
            StatusMessage = T("Blog plasing verwyder.", "Blog post deleted.");
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to delete blog post.");
            ErrorMessage = T("Kon nie blog nou verwyder nie.", "Could not delete the blog post right now.");
        }
        finally
        {
            IsDeleting = false;
        }
    }

    private bool MatchesStatusFilter(AdminBlogPostRecord post) =>
        StatusFilter switch
        {
            "draft" => !post.IsPublished,
            "published" => post.IsPublished && post.PublishedAt <= DateTimeOffset.UtcNow,
            "scheduled" => post.IsPublished && post.PublishedAt > DateTimeOffset.UtcNow,
            _ => true
        };

    private bool MatchesSearch(AdminBlogPostRecord post)
    {
        if (string.IsNullOrWhiteSpace(PostSearch))
        {
            return true;
        }

        var search = PostSearch.Trim();
        return post.Title.Contains(search, StringComparison.OrdinalIgnoreCase) ||
               post.Slug.Contains(search, StringComparison.OrdinalIgnoreCase) ||
               (post.Summary?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private async Task<string> UploadFeaturedImageAsync(string slug, IBrowserFile file)
    {
        var normalizedContentType = NormalizeImageContentType(file);

        if (IsR2UploadConfigured)
        {
            await using var stream = file.OpenReadStream(MaxImageUploadBytes);
            var uploaded = await StoryMediaStorageService.UploadImageAsync(
                $"blog-{slug}",
                StoryImageKind.Cover,
                file.Name,
                normalizedContentType,
                stream);

            return uploaded.PublicUrl;
        }

        var localUpload = await SaveFeaturedImageToLocalAsync(slug, file);
        return localUpload.PublicPath;
    }

    private async Task<(string PublicPath, string PhysicalPath)> SaveFeaturedImageToLocalAsync(string slug, IBrowserFile file)
    {
        var extension = ResolveSafeImageExtension(file.Name);
        var safeSlug = BuildEffectiveSlug(slug, slug);
        var year = DateTime.UtcNow.ToString("yyyy", CultureInfo.InvariantCulture);
        var month = DateTime.UtcNow.ToString("MM", CultureInfo.InvariantCulture);
        var fileSuffix = Guid.NewGuid().ToString("N")[..10];
        var fileName = $"{safeSlug}-blog-{DateTime.UtcNow:yyyyMMddHHmmss}-{fileSuffix}{extension}";
        var relativeDirectory = Path.Combine("branding", "uploaded", "blog", year, month);
        var physicalDirectory = Path.Combine(WebHostEnvironment.WebRootPath, relativeDirectory);
        Directory.CreateDirectory(physicalDirectory);

        var physicalPath = Path.Combine(physicalDirectory, fileName);
        await using var sourceStream = file.OpenReadStream(MaxImageUploadBytes);
        await using var destinationStream = File.Create(physicalPath);
        await sourceStream.CopyToAsync(destinationStream);

        var publicPath = $"/branding/uploaded/blog/{year}/{month}/{fileName}";
        return (publicPath, physicalPath);
    }

    private async Task<string?> ReadImageFileAsDataUrlAsync(IBrowserFile file)
    {
        try
        {
            var normalizedContentType = NormalizeImageContentType(file);
            await using var stream = file.OpenReadStream(MaxImageUploadBytes);
            using var buffer = new MemoryStream();
            await stream.CopyToAsync(buffer);
            var base64 = Convert.ToBase64String(buffer.ToArray());
            return $"data:{normalizedContentType};base64,{base64}";
        }
        catch (Exception exception) when (exception is IOException or InvalidOperationException)
        {
            Logger.LogDebug(exception, "Inline blog image preview generation skipped.");
            return null;
        }
    }

