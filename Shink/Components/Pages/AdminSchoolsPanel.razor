@using System.Globalization
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@inject IAdminManagementService AdminManagementService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ILogger<AdminSchoolsPanel> Logger
@inject ISnackbar Snackbar

@if (IsLoading)
{
    <section class="admin-section">
        <div class="admin-section-head">
            <div>
                <h2>@T("Skole", "Schools")</h2>
                <p>@T("Laai skoolrekeninge...", "Loading school accounts...")</p>
            </div>
        </div>
    </section>
}
else
{
    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <p class="admin-feedback is-success">@StatusMessage</p>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <p class="admin-feedback is-error">@ErrorMessage</p>
    }

    <section class="admin-section admin-schools-panel">
        <div class="admin-section-head">
            <div>
                <h2>@T("Skole", "Schools")</h2>
                <p>@T("Stel skoolrekeninge, pakkette en admin toegang op.", "Set up school accounts, packages, and admin access.")</p>
            </div>
            <div class="admin-schools-actions">
                <MudButton Class="admin-icon-btn admin-action-btn admin-icon-only"
                           Variant="Variant.Outlined"
                           Color="Color.Primary"
                           OnClick="StartNewSchool"
                           Disabled="@(IsSaving || IsSeatActionBusy)"
                           aria-label='@T("Nuwe skool", "New school")'
                           title='@T("Nuwe skool", "New school")'>
                    <i class="fa-solid fa-plus" aria-hidden="true"></i>
                    <span class="admin-btn-text">@T("Nuwe skool", "New school")</span>
                </MudButton>
                <MudButton Class="admin-icon-btn admin-action-btn admin-icon-only"
                           Variant="Variant.Outlined"
                           Color="Color.Primary"
                           OnClick="ReloadAsync"
                           Disabled="@(IsSaving || IsSeatActionBusy)"
                           aria-label='@T("Verfris skole", "Refresh schools")'
                           title='@T("Verfris skole", "Refresh schools")'>
                    <i class="fa-solid fa-rotate-right" aria-hidden="true"></i>
                    <span class="admin-btn-text">@T("Verfris", "Refresh")</span>
                </MudButton>
            </div>
        </div>

        <div class="admin-schools-layout">
            <div class="admin-schools-card admin-schools-list-card">
                <div class="admin-schools-card-head">
                    <h3>@T("Skoolrekeninge", "School accounts")</h3>
                    <span>@Snapshot.Schools.Count</span>
                </div>

                @if (Snapshot.Schools.Count == 0)
                {
                    <p class="admin-schools-empty">@T("Geen skole is nog opgestel nie.", "No schools have been set up yet.")</p>
                }
                else
                {
                    <div class="admin-schools-list" role="list">
                        @foreach (var school in Snapshot.Schools)
                        {
                            <button type="button"
                                    class="admin-schools-row @(IsSelected(school) ? "is-selected" : null)"
                                    @onclick="() => SelectSchoolAsync(school)">
                                <span class="admin-schools-row-main">
                                    <strong>@school.SchoolName</strong>
                                    <small>@school.AdminEmail</small>
                                </span>
                                <span class="admin-schools-row-meta">
                                    <span>@school.PlanName</span>
                                    <span>@BuildSeatSummary(school)</span>
                                </span>
                                <span class="admin-schools-status @BuildStatusClass(school.Status)">
                                    @BuildStatusLabel(school.Status)
                                </span>
                            </button>
                        }
                    </div>
                }
            </div>

            <EditForm Model="Editor" OnValidSubmit="SaveAsync" class="admin-schools-card admin-schools-editor">
                <div class="admin-schools-card-head">
                    <h3>@(Editor.SchoolAccountId.HasValue ? T("Wysig skool", "Edit school") : T("Nuwe skool", "New school"))</h3>
                    @if (Editor.SchoolAccountId.HasValue)
                    {
                        <span>@T("Bestaande", "Existing")</span>
                    }
                </div>

                <div class="admin-schools-form-grid">
                    <label class="admin-schools-field">
                        <span>@T("Skoolnaam", "School name")</span>
                        <input @bind="Editor.SchoolName" maxlength="180" autocomplete="organization" />
                    </label>

                    <label class="admin-schools-field">
                        <span>@T("Admin e-pos", "Admin email")</span>
                        <input @bind="Editor.AdminEmail" type="email" maxlength="320" autocomplete="email" />
                    </label>

                    <label class="admin-schools-field">
                        <span>@T("Plan", "Plan")</span>
                        <select @bind="Editor.PlanTierCode">
                            @foreach (var plan in Snapshot.Plans)
                            {
                                <option value="@plan.TierCode">@BuildPlanLabel(plan)</option>
                            }
                        </select>
                    </label>

                    <label class="admin-schools-field">
                        <span>@T("Status", "Status")</span>
                        <select @bind="Editor.Status">
                            <option value="active">@T("Aktief", "Active")</option>
                            <option value="paused">@T("Gepouseer", "Paused")</option>
                            <option value="cancelled">@T("Gekanselleer", "Cancelled")</option>
                        </select>
                    </label>

                    <label class="admin-schools-field">
                        <span>@T("Toegang verval", "Access expires")</span>
                        <input value="@Editor.AccessExpiresOn" @onchange="OnAccessExpiresOnChanged" type="date" />
                    </label>

                    <label class="admin-schools-toggle">
                        <input @bind="Editor.AdminUsesSlot" type="checkbox" />
                        <span>
                            <strong>@T("Admin gebruik 'n plek", "Admin uses a seat")</strong>
                            <small>@T("Tel die skool admin teen die beskikbare klaskamerplekke.", "Count the school admin against the available classroom seats.")</small>
                        </span>
                    </label>
                </div>

                <div class="admin-schools-save-row">
                    <MudButton ButtonType="ButtonType.Submit"
                               Class="admin-icon-btn admin-action-btn"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="@IsSaving"
                               aria-label='@T("Stoor skool", "Save school")'
                               title='@T("Stoor skool", "Save school")'>
                        <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                        <span>@(IsSaving ? T("Stoor...", "Saving...") : T("Stoor skool", "Save school"))</span>
                    </MudButton>
                </div>
            </EditForm>
        </div>

        @if (Editor.SchoolAccountId.HasValue)
        {
            <div class="admin-schools-manage">
                <section class="admin-schools-card admin-schools-dashboard">
                    <div class="admin-schools-card-head">
                        <h3>@T("Skoolplekke", "School seats")</h3>
                        @if (SelectedSchoolDashboard is not null)
                        {
                            <span>@SelectedSchoolDashboard.UsedSlots / @SelectedSchoolDashboard.SlotLimit @T("gebruik", "used")</span>
                        }
                    </div>

                    @if (IsDashboardLoading)
                    {
                        <p class="admin-schools-empty">@T("Laai skoolplekke...", "Loading school seats...")</p>
                    }
                    else if (SelectedSchoolDashboard is null || !SelectedSchoolDashboard.HasSchoolAccess)
                    {
                        <p class="admin-schools-empty">@T("Kon nie hierdie skool se plekke laai nie.", "Could not load this school's seats.")</p>
                    }
                    else
                    {
                        <div class="admin-schools-stats-row" aria-label='@T("Skoolplek opsomming", "School seat summary")'>
                            <article>
                                <span>@T("Beskikbaar", "Available")</span>
                                <strong>@SelectedSchoolDashboard.AvailableSlots</strong>
                            </article>
                            <article>
                                <span>@T("Uitgenooi", "Invited")</span>
                                <strong>@SelectedSchoolDashboard.InvitedSeats</strong>
                            </article>
                            <article>
                                <span>@T("Aktief", "Active")</span>
                                <strong>@SelectedSchoolDashboard.AcceptedSeats</strong>
                            </article>
                        </div>

                        <div class="admin-schools-invite">
                            <label class="admin-schools-field">
                                <span>@T("Gebruiker e-pos", "User email")</span>
                                <input @bind="InviteEmail" type="email" maxlength="320" autocomplete="email" placeholder="gebruiker@skool.co.za" />
                            </label>
                            <label class="admin-schools-field">
                                <span>@T("Naam opsioneel", "Name optional")</span>
                                <input @bind="InviteDisplayName" maxlength="120" autocomplete="name" />
                            </label>
                            <label class="admin-schools-field">
                                <span>@T("Tydelike wagwoord", "Temporary password")</span>
                                <input @bind="InvitePassword" type="password" maxlength="200" autocomplete="new-password" />
                            </label>
                            <label class="admin-schools-field">
                                <span>@T("Bevestig wagwoord", "Confirm password")</span>
                                <input @bind="InvitePasswordConfirmation" type="password" maxlength="200" autocomplete="new-password" />
                            </label>
                            <MudButton Class="admin-icon-btn admin-action-btn"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Disabled="@(!CanInviteSeat || IsSeatActionBusy)"
                                       OnClick="InviteSeatAsync"
                                       aria-label='@T("Nooi gebruiker", "Invite user")'
                                       title='@T("Nooi gebruiker", "Invite user")'>
                                <i class="fa-solid fa-user-plus" aria-hidden="true"></i>
                                <span>@T("Nooi gebruiker", "Invite user")</span>
                            </MudButton>
                        </div>

                        @if (SelectedSchoolDashboard.Seats.Count == 0)
                        {
                            <p class="admin-schools-empty">@T("Nog geen plekke is toegeken nie.", "No seats have been assigned yet.")</p>
                        }
                        else
                        {
                            <div class="admin-schools-seat-list">
                                @foreach (var seat in SelectedSchoolDashboard.Seats)
                                {
                                    <div class="admin-schools-seat"
                                         role="button"
                                         tabindex="0"
                                         title='@T("Wys plek-statistiek", "Show seat stats")'
                                         @onclick="() => OpenSeatStatsAsync(seat)"
                                         @onkeydown="args => HandleSeatKeyDownAsync(args, seat)">
                                        <div class="admin-schools-seat-main">
                                            <strong>@BuildSeatName(seat)</strong>
                                            <span>@seat.Email</span>
                                        </div>
                                        <div class="admin-schools-seat-meta">
                                            <span>@BuildSeatStatus(seat)</span>
                                            @if (!string.Equals(seat.Role, "school_admin", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <button type="button"
                                                        class="admin-schools-icon-button"
                                                        title='@T("Verwyder plek", "Remove seat")'
                                                        aria-label='@T("Verwyder plek", "Remove seat")'
                                                        disabled="@IsSeatActionBusy"
                                                        @onclick="() => RemoveSeatAsync(seat.SchoolSeatId)"
                                                        @onclick:stopPropagation="true">
                                                    <i class="fa-solid fa-trash" aria-hidden="true"></i>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                </section>
            </div>
        }
    </section>
}

@if (StatsModalSeat is not null)
{
    <div class="admin-schools-modal-backdrop" role="presentation" @onclick="CloseSeatStats">
        <section class="admin-schools-modal" role="dialog" aria-modal="true" aria-labelledby="admin-school-seat-stats-title" @onclick:stopPropagation="true">
            <header class="admin-schools-modal-head">
                <div class="admin-schools-modal-title">
                    <p>@T("Plek-statistiek", "Seat stats")</p>
                    <h2 id="admin-school-seat-stats-title">@BuildSeatName(StatsModalSeat)</h2>
                    <span>@StatsModalSeat.Email</span>
                    @if (!IsStatsLoading && SeatStats is not null)
                    {
                        <dl class="admin-schools-modal-meta" aria-label='@T("Plek besonderhede", "Seat details")'>
                            <div>
                                <dt>@T("Status", "Status")</dt>
                                <dd>@BuildSeatStatus(SeatStats.Seat)</dd>
                            </div>
                            <div>
                                <dt>@T("Rekening", "Account")</dt>
                                <dd>@(SeatStats.HasSubscriberAccount ? T("Gekoppel", "Linked") : T("Nog nie geregistreer", "Not registered yet"))</dd>
                            </div>
                            <div>
                                <dt>@T("Toegang eindig", "Access ends")</dt>
                                <dd>@FormatDate(SeatStats.AccessExpiresAt)</dd>
                            </div>
                        </dl>
                    }
                </div>
                <button type="button" class="admin-schools-icon-button" title='@T("Maak toe", "Close")' aria-label='@T("Maak statistiek toe", "Close stats")' @onclick="CloseSeatStats">
                    <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                </button>
            </header>

            @if (IsStatsLoading)
            {
                <p class="admin-schools-empty" role="status" aria-live="polite">@T("Laai statistiek...", "Loading stats...")</p>
            }
            else if (!string.IsNullOrWhiteSpace(StatsErrorMessage))
            {
                <p class="admin-feedback is-error">@StatsErrorMessage</p>
            }
            else if (SeatStats is null)
            {
                <p class="admin-schools-empty">@T("Geen statistiek beskikbaar nie.", "No stats available.")</p>
            }
            else
            {
                <div class="admin-schools-seat-stats-grid">
                    <article>
                        <span>@T("Stories oopgemaak", "Stories opened")</span>
                        <strong>@SeatStats.TotalViews</strong>
                    </article>
                    <article>
                        <span>@T("Unieke stories", "Unique stories")</span>
                        <strong>@Math.Max(SeatStats.UniqueViewedStories, SeatStats.UniqueListenedStories)</strong>
                    </article>
                    <article>
                        <span>@T("Luistersessies", "Listen sessions")</span>
                        <strong>@SeatStats.TotalListenSessions</strong>
                    </article>
                    <article>
                        <span>@T("Luistertyd", "Listen time")</span>
                        <strong>@FormatDuration(SeatStats.TotalListenedSeconds)</strong>
                    </article>
                </div>

                <div class="admin-schools-modal-section">
                    <p>@T("Laaste aktiwiteit", "Last activity")</p>
                    <strong>@FormatDateTime(SeatStats.LastActivityAt)</strong>
                </div>

                <div class="admin-schools-modal-section">
                    <p>@T("Onlangse stories", "Recent stories")</p>
                    @if (SeatStats.RecentStories.Count == 0)
                    {
                        <p class="admin-schools-empty">@T("Nog geen storie-aktiwiteit vir hierdie plek nie.", "No story activity for this seat yet.")</p>
                    }
                    else
                    {
                        <div class="admin-schools-recent-list">
                            @foreach (var story in SeatStats.RecentStories)
                            {
                                <div class="admin-schools-recent-item">
                                    <div>
                                        <strong>@story.StoryTitle</strong>
                                        <span>@FormatDateTime(story.LastActivityAt)</span>
                                    </div>
                                    <span>@FormatViewCount(story.Views) · @FormatDuration(story.ListenedSeconds)</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </section>
    </div>
}

@code {
    [Parameter]
    public string? AdminEmail { get; set; }

    [Parameter]
    public string? LanguageCode { get; set; }

    private AdminSchoolSetupSnapshot Snapshot { get; set; } = new([], []);
    private EditableSchoolSetup Editor { get; set; } = EditableSchoolSetup.New(null);
    private string? LoadedAdminEmail { get; set; }
    private bool IsLoading { get; set; } = true;
    private bool IsSaving { get; set; }
    private bool IsDashboardLoading { get; set; }
    private bool IsSeatActionBusy { get; set; }
    private SchoolDashboardSnapshot? SelectedSchoolDashboard { get; set; }
    private string? InviteEmail { get; set; }
    private string? InviteDisplayName { get; set; }
    private string? InvitePassword { get; set; }
    private string? InvitePasswordConfirmation { get; set; }
    private SchoolSeatRecord? StatsModalSeat { get; set; }
    private SchoolSeatStatsSnapshot? SeatStats { get; set; }
    private bool IsStatsLoading { get; set; }
    private string? StatsErrorMessage { get; set; }
    private string? StatusMessage { get; set; }
    private string? ErrorMessage { get; set; }
    private bool CanInviteSeat => SelectedSchoolDashboard?.AvailableSlots > 0 && !string.IsNullOrWhiteSpace(InviteEmail);

    protected override async Task OnParametersSetAsync()
    {
        var effectiveAdminEmail = await ResolveAdminEmailAsync();
        if (!string.Equals(LoadedAdminEmail, effectiveAdminEmail, StringComparison.OrdinalIgnoreCase))
        {
            await LoadAsync(effectiveAdminEmail);
        }
    }

    private async Task ReloadAsync()
    {
        ClearMessages();
        await LoadAsync(await ResolveAdminEmailAsync());
    }

    private async Task LoadAsync(string? effectiveAdminEmail)
    {
        IsLoading = true;
        LoadedAdminEmail = effectiveAdminEmail;
        try
        {
            Snapshot = await AdminManagementService.GetSchoolSetupsAsync(effectiveAdminEmail);
            if (Snapshot.Schools.Count > 0)
            {
                await SelectSchoolAsync(Snapshot.Schools[0]);
            }
            else
            {
                StartNewSchool();
            }
        }
        catch (Exception exception)
        {
            Logger.LogWarning(exception, "Failed to load admin schools.");
            SetError(T("Kon nie skole nou laai nie.", "Could not load schools right now."));
            Snapshot = new AdminSchoolSetupSnapshot([], []);
            StartNewSchool();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        ClearMessages();
        IsSaving = true;
        try
        {
            var expiresAt = ParseDateInput(Editor.AccessExpiresOn);
            var result = await AdminManagementService.SaveSchoolSetupAsync(
                await ResolveAdminEmailAsync(),
                new AdminSchoolSetupSaveRequest(
                    Editor.SchoolAccountId,
                    Editor.SchoolName,
                    Editor.AdminEmail,
                    Editor.PlanTierCode,
                    Editor.AdminUsesSlot,
                    Editor.Status,
                    expiresAt));

            if (!result.IsSuccess)
            {
                SetError(result.ErrorMessage ?? T("Kon nie die skool nou stoor nie.", "Could not save the school right now."));
                return;
            }

            SetStatus(T("Skool is gestoor.", "School saved."));
            Snackbar.Add(StatusMessage!, Severity.Success);
            await LoadAsync(await ResolveAdminEmailAsync());
            if (result.EntityId.HasValue)
            {
                var saved = Snapshot.Schools.FirstOrDefault(school => school.SchoolAccountId == result.EntityId.Value);
                if (saved is not null)
                {
                    await SelectSchoolAsync(saved);
                }
            }
        }
        catch (Exception exception)
        {
            Logger.LogWarning(exception, "Failed to save admin school.");
            SetError(T("Kon nie die skool nou stoor nie.", "Could not save the school right now."));
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task SelectSchoolAsync(AdminSchoolAccountRecord school)
    {
        Editor = EditableSchoolSetup.From(school, Snapshot.Plans.FirstOrDefault()?.TierCode);
        await LoadSelectedSchoolDashboardAsync(school.SchoolAccountId);
    }

    private void StartNewSchool()
    {
        Editor = EditableSchoolSetup.New(Snapshot.Plans.FirstOrDefault()?.TierCode);
        SelectedSchoolDashboard = null;
        InviteEmail = null;
        InviteDisplayName = null;
        InvitePassword = null;
        InvitePasswordConfirmation = null;
        CloseSeatStats();
    }

    private async Task LoadSelectedSchoolDashboardAsync(Guid schoolAccountId)
    {
        IsDashboardLoading = true;
        try
        {
            SelectedSchoolDashboard = await AdminManagementService.GetAdminSchoolDashboardAsync(
                await ResolveAdminEmailAsync(),
                schoolAccountId);
        }
        catch (Exception exception)
        {
            Logger.LogWarning(exception, "Failed to load admin school dashboard. schoolAccountId={SchoolAccountId}", schoolAccountId);
            SelectedSchoolDashboard = null;
            SetError(T("Kon nie hierdie skool se plekke nou laai nie.", "Could not load this school's seats right now."));
        }
        finally
        {
            IsDashboardLoading = false;
        }
    }

    private async Task InviteSeatAsync()
    {
        if (Editor.SchoolAccountId is null)
        {
            return;
        }

        ClearMessages();
        if (!ValidateInvitePassword())
        {
            return;
        }

        IsSeatActionBusy = true;
        try
        {
            var result = await AdminManagementService.InviteAdminSchoolSeatAsync(
                await ResolveAdminEmailAsync(),
                Editor.SchoolAccountId.Value,
                new SchoolInviteTeacherRequest(InviteEmail, InviteDisplayName, InvitePassword));
            if (result.IsSuccess)
            {
                InviteEmail = null;
                InviteDisplayName = null;
                InvitePassword = null;
                InvitePasswordConfirmation = null;
            }

            await HandleSeatOperationResultAsync(result, T("Gebruiker is by die skoolplekke gevoeg.", "User was added to the school seats."));
        }
        catch (Exception exception)
        {
            Logger.LogWarning(exception, "Failed to invite admin school seat. schoolAccountId={SchoolAccountId}", Editor.SchoolAccountId);
            SetError(T("Kon nie die gebruiker nou nooi nie.", "Could not invite the user right now."));
        }
        finally
        {
            IsSeatActionBusy = false;
        }
    }

    private async Task RemoveSeatAsync(Guid seatId)
    {
        if (Editor.SchoolAccountId is null)
        {
            return;
        }

        ClearMessages();
        IsSeatActionBusy = true;
        try
        {
            var result = await AdminManagementService.RemoveAdminSchoolSeatAsync(
                await ResolveAdminEmailAsync(),
                Editor.SchoolAccountId.Value,
                seatId);
            await HandleSeatOperationResultAsync(result, T("Plek is verwyder.", "Seat removed."));
        }
        catch (Exception exception)
        {
            Logger.LogWarning(exception, "Failed to remove admin school seat. schoolAccountId={SchoolAccountId} seatId={SeatId}", Editor.SchoolAccountId, seatId);
            SetError(T("Kon nie die plek nou verwyder nie.", "Could not remove the seat right now."));
        }
        finally
        {
            IsSeatActionBusy = false;
        }
    }

    private async Task OpenSeatStatsAsync(SchoolSeatRecord seat)
    {
        if (Editor.SchoolAccountId is null)
        {
            return;
        }

        StatsModalSeat = seat;
        SeatStats = null;
        StatsErrorMessage = null;
        IsStatsLoading = true;

        try
        {
            var stats = await AdminManagementService.GetAdminSchoolSeatStatsAsync(
                await ResolveAdminEmailAsync(),
                Editor.SchoolAccountId.Value,
                seat.SchoolSeatId);
            if (stats is null)
            {
                StatsErrorMessage = T("Kon nie hierdie plek se statistiek laai nie.", "Could not load this seat's stats.");
            }
            else
            {
                SeatStats = stats;
            }
        }
        catch (Exception exception)
        {
            Logger.LogWarning(exception, "Failed to load admin school seat stats. schoolAccountId={SchoolAccountId} seatId={SeatId}", Editor.SchoolAccountId, seat.SchoolSeatId);
            StatsErrorMessage = T("Kon nie hierdie plek se statistiek laai nie.", "Could not load this seat's stats.");
        }
        finally
        {
            IsStatsLoading = false;
        }
    }

    private async Task HandleSeatKeyDownAsync(KeyboardEventArgs args, SchoolSeatRecord seat)
    {
        if (string.Equals(args.Key, "Enter", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(args.Key, " ", StringComparison.Ordinal))
        {
            await OpenSeatStatsAsync(seat);
        }
    }

    private void CloseSeatStats()
    {
        StatsModalSeat = null;
        SeatStats = null;
        StatsErrorMessage = null;
        IsStatsLoading = false;
    }

    private async Task HandleSeatOperationResultAsync(SchoolOperationResult result, string successMessage)
    {
        if (!result.IsSuccess)
        {
            SetError(result.ErrorMessage ?? T("Die aksie kon nie nou voltooi word nie.", "The action could not be completed right now."));
            return;
        }

        SetStatus(successMessage);
        Snackbar.Add(StatusMessage!, Severity.Success);
        if (Editor.SchoolAccountId.HasValue)
        {
            await LoadSelectedSchoolDashboardAsync(Editor.SchoolAccountId.Value);
            Snapshot = await AdminManagementService.GetSchoolSetupsAsync(await ResolveAdminEmailAsync());
        }
    }

    private void OnAccessExpiresOnChanged(ChangeEventArgs args)
    {
        Editor.AccessExpiresOn = args.Value?.ToString() ?? string.Empty;
    }

    private bool ValidateInvitePassword()
    {
        if (string.IsNullOrWhiteSpace(InvitePassword) ||
            InvitePassword.Length is < 6 or > 200)
        {
            SetError(T("Wagwoord moet tussen 6 en 200 karakters wees.", "Password must be between 6 and 200 characters."));
            return false;
        }

        if (!string.Equals(InvitePassword, InvitePasswordConfirmation, StringComparison.Ordinal))
        {
            SetError(T("Wagwoorde stem nie ooreen nie.", "Passwords do not match."));
            return false;
        }

        return true;
    }

    private bool IsSelected(AdminSchoolAccountRecord school) =>
        Editor.SchoolAccountId == school.SchoolAccountId;

    private string BuildPlanLabel(AdminSchoolPlanOption plan) =>
        $"{plan.Name} - {plan.SlotLimit} {T("plekke", "seats")} - R{plan.Amount:0}";

    private string BuildSeatSummary(AdminSchoolAccountRecord school) =>
        $"{school.ActiveSeatCount}/{school.SlotLimit} {T("plekke", "seats")}";

    private static string BuildSeatName(SchoolSeatRecord seat) =>
        !string.IsNullOrWhiteSpace(seat.DisplayName) ? seat.DisplayName : seat.Email;

    private string BuildSeatStatus(SchoolSeatRecord seat)
    {
        if (string.Equals(seat.Role, "school_admin", StringComparison.OrdinalIgnoreCase))
        {
            return T("Skool admin", "School admin");
        }

        return string.Equals(seat.Status, "accepted", StringComparison.OrdinalIgnoreCase)
            ? T("Aktief", "Active")
            : T("Uitgenooi", "Invited");
    }

    private string BuildStatusLabel(string? status) =>
        status?.ToLowerInvariant() switch
        {
            "active" => T("Aktief", "Active"),
            "paused" => T("Gepouseer", "Paused"),
            "cancelled" => T("Gekanselleer", "Cancelled"),
            _ => T("Onbekend", "Unknown")
        };

    private static string BuildStatusClass(string? status) =>
        status?.ToLowerInvariant() switch
        {
            "active" => "is-active",
            "paused" => "is-paused",
            "cancelled" => "is-cancelled",
            _ => "is-paused"
        };

    private DateTimeOffset? ParseDateInput(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return DateTime.TryParseExact(
            value,
            "yyyy-MM-dd",
            CultureInfo.InvariantCulture,
            DateTimeStyles.None,
            out var parsed)
            ? new DateTimeOffset(parsed.Date, TimeZoneInfo.Local.GetUtcOffset(parsed.Date)).ToUniversalTime()
            : null;
    }

    private static string FormatDateInput(DateTimeOffset? value) =>
        value.HasValue
            ? value.Value.ToLocalTime().ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)
            : DateTimeOffset.UtcNow.AddYears(1).ToLocalTime().ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);

    private string FormatDate(DateTimeOffset? value) =>
        value is null ? T("Onbekend", "Unknown") : value.Value.ToLocalTime().ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);

    private string FormatDateTime(DateTimeOffset? value) =>
        value is null ? T("Nog geen aktiwiteit", "No activity yet") : value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm", CultureInfo.InvariantCulture);

    private string FormatViewCount(int views) =>
        views == 1 ? T("1 kyk", "1 view") : string.Format(CultureInfo.InvariantCulture, T("{0} kyke", "{0} views"), views);

    private string FormatDuration(decimal seconds)
    {
        if (seconds <= 0)
        {
            return T("0 min", "0 min");
        }

        var totalMinutes = (int)Math.Round(seconds / 60m, MidpointRounding.AwayFromZero);
        if (totalMinutes < 60)
        {
            return string.Format(CultureInfo.InvariantCulture, T("{0} min", "{0} min"), Math.Max(1, totalMinutes));
        }

        var hours = totalMinutes / 60;
        var minutes = totalMinutes % 60;
        return minutes == 0
            ? string.Format(CultureInfo.InvariantCulture, T("{0} u", "{0} h"), hours)
            : string.Format(CultureInfo.InvariantCulture, T("{0} u {1} min", "{0} h {1} min"), hours, minutes);
    }

    private async Task<string?> ResolveAdminEmailAsync()
    {
        if (!string.IsNullOrWhiteSpace(AdminEmail))
        {
            return AdminEmail;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        return authState.User.FindFirst(ClaimTypes.Email)?.Value ??
               authState.User.FindFirst("email")?.Value ??
               authState.User.Identity?.Name;
    }

    private bool IsEnglish => string.Equals(LanguageCode, "en", StringComparison.OrdinalIgnoreCase);

    private string T(string afrikaans, string english) => IsEnglish ? english : afrikaans;

    private void ClearMessages()
    {
        ErrorMessage = null;
        StatusMessage = null;
    }

    private void SetError(string message)
    {
        StatusMessage = null;
        ErrorMessage = message;
    }

    private void SetStatus(string message)
    {
        ErrorMessage = null;
        StatusMessage = message;
    }

    private sealed class EditableSchoolSetup
    {
        public Guid? SchoolAccountId { get; set; }
        public string SchoolName { get; set; } = string.Empty;
        public string AdminEmail { get; set; } = string.Empty;
        public string PlanTierCode { get; set; } = string.Empty;
        public bool AdminUsesSlot { get; set; }
        public string Status { get; set; } = "active";
        public string AccessExpiresOn { get; set; } = string.Empty;

        public static EditableSchoolSetup New(string? defaultPlanTierCode) => new()
        {
            PlanTierCode = defaultPlanTierCode ?? string.Empty,
            Status = "active",
            AccessExpiresOn = FormatDateInput(null)
        };

        public static EditableSchoolSetup From(AdminSchoolAccountRecord school, string? defaultPlanTierCode) => new()
        {
            SchoolAccountId = school.SchoolAccountId,
            SchoolName = school.SchoolName,
            AdminEmail = school.AdminEmail,
            PlanTierCode = string.IsNullOrWhiteSpace(school.PlanTierCode) ? defaultPlanTierCode ?? string.Empty : school.PlanTierCode,
            AdminUsesSlot = school.AdminUsesSlot,
            Status = string.IsNullOrWhiteSpace(school.Status) ? "active" : school.Status,
            AccessExpiresOn = FormatDateInput(school.AccessExpiresAt)
        };
    }
}
