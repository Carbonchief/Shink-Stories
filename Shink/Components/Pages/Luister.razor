@page "/luister"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Globalization
@using System.Security.Claims
@using System.Text.Json
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@inject NavigationManager NavigationManager
@inject IStoryCatalogService StoryCatalogService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISubscriptionLedgerService SubscriptionLedgerService
@inject IStoryFavoriteService StoryFavoriteService
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Schink Stories | Luister</PageTitle>
<HeadContent>
    <link rel="canonical" href="@LuisterCanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Schink Stories | Luister" />
    <meta property="og:description" content="Luister na ons nuutste stories op Schink Stories." />
    <meta property="og:url" content="@LuisterCanonicalUrl" />
    <meta property="og:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:secure_url" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content="Schink Stories logo" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Schink Stories | Luister" />
    <meta name="twitter:description" content="Luister na ons nuutste stories op Schink Stories." />
    <meta name="twitter:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta name="twitter:image:alt" content="Schink Stories logo" />
    <JsonLdScript Json="@LuisterJsonLd" />
</HeadContent>

<div class="luister-page-shell">
    <section class="gratis-hero">
        <img class="gratis-banner" src="/branding/DIS_STORIETYD.png"
             alt="Luister stories banner" loading="eager" fetchpriority="high" decoding="async" />
    </section>

    <section class="luister-search-section" aria-labelledby="luister-soek-heading">
        <h2 id="luister-soek-heading" class="sr-only">Soek stories</h2>
        <form class="luister-search-form" role="search" @onsubmit:preventDefault="true">
            <label class="sr-only" for="luister-search">Soek stories</label>
            <span class="luister-search-icon" aria-hidden="true">
                <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
            </span>
            <input id="luister-search"
                   class="luister-search-input"
                   type="search"
                   placeholder="Soek stories"
                   autocomplete="off"
                   value="@SearchQuery"
                   @oninput="HandleSearchInputAsync" />
            @if (IsSearching)
            {
                <span class="luister-search-loader" aria-live="polite">
                    <span class="luister-search-spinner" aria-hidden="true"></span>
                    <span class="luister-search-loader-text">Soek...</span>
                </span>
            }
        </form>
    </section>

@if (!string.IsNullOrWhiteSpace(PageLoadErrorMessage))
{
    <section class="luister-empty-state" role="status" aria-live="polite">
        <p>@PageLoadErrorMessage</p>
        <p><a href="/luister">Probeer weer</a> of bly op Luister vir die gratis stories.</p>
    </section>
}
else if (IsLoadingPage)
{
    <section class="luister-loading-state" aria-live="polite" aria-busy="true">
        <div class="luister-loading-indicator" role="status" aria-label="Stories laai">
            <span class="luister-loading-spinner" aria-hidden="true"></span>
            <span class="luister-loading-text">Stories laai</span>
        </div>
    </section>
}
else if (!AllowEmptyState && (LuisterPlaylists.Count == 0 || FilteredLuisterPlaylists.Count == 0))
{
    <section class="luister-loading-state" aria-live="polite" aria-busy="true">
        <div class="luister-loading-indicator" role="status" aria-label="Stories laai">
            <span class="luister-loading-spinner" aria-hidden="true"></span>
            <span class="luister-loading-text">Stories laai</span>
        </div>
    </section>
}
else if (LuisterPlaylists.Count == 0)
{
    <section class="luister-empty-state">
        <p>Ons kon nie nou die playlists laai nie. Probeer asseblief oor 'n oomblik weer.</p>
    </section>
}
else if (FilteredLuisterPlaylists.Count == 0)
{
    <section class="luister-empty-state">
        <p>Geen stories pas by jou soektog vir "@SearchQuery".</p>
    </section>
}
else
{
    var speellysteCarouselPlaylists = GetSpeellysteCarouselPlaylists();

    @if (speellysteCarouselPlaylists.Count > 0)
    {
        <section class="section-block stories-carousel-section luister-speellyste-section" aria-labelledby="luister-speellyste-heading">
            <h2 id="luister-speellyste-heading">Speellyste</h2>
            <div class="stories-carousel-shell">
                <div class="stories-carousel luister-speellyste-carousel" role="list" aria-label="Speellyste">
                    @for (var playlistIndex = 0; playlistIndex < speellysteCarouselPlaylists.Count; playlistIndex++)
                    {
                        var playlist = speellysteCarouselPlaylists[playlistIndex];
                        var playlistTitle = GetPlaylistTitle(playlist);
                        var playlistSlug = GetPlaylistSlug(playlist);
                        var playlistShowcasePath = GetPlaylistShowcaseHref(playlistSlug);
                        var playlistImagePath = GetPlaylistCarouselImagePath(playlist);

                        <article class="story-carousel-item luister-speellyste-item" role="listitem">
                            <a class="story-carousel-link luister-speellyste-link"
                               href="@playlistShowcasePath"
                               data-enhance-nav="false"
                               draggable="false"
                               aria-label="Maak @playlistTitle se speellys showcase oop">
                                <span class="story-carousel-cover luister-speellyste-cover">
                                    <img class="story-carousel-image luister-speellyste-image"
                                         src="@playlistImagePath"
                                         sizes="(max-width: 620px) 76vw, (max-width: 980px) 46vw, 360px"
                                         draggable="false"
                                         alt="Voorblad vir @playlistTitle speellys"
                                         width="1024"
                                         height="576"
                                         loading="lazy"
                                         decoding="async" />
                                    <span class="story-cover-play" aria-hidden="true">
                                        <i class="story-cover-play-icon fa-solid fa-images" aria-hidden="true"></i>
                                    </span>
                                </span>
                                <h3>@playlistTitle</h3>
                            </a>
                        </article>
                    }
                </div>
            </div>
        </section>
    }

    @for (var index = 0; index < FilteredLuisterPlaylists.Count; index++)
    {
        var playlist = FilteredLuisterPlaylists[index];
        var playlistSlug = GetPlaylistSlug(playlist);
        var playlistTitle = GetPlaylistTitle(playlist);
        var playlistStories = GetPlaylistStories(playlist);
        var headingId = $"luister-playlist-{playlistSlug}-heading";
        var hasDescription = !string.IsNullOrWhiteSpace(playlist.Description);
        var canOpenPlaylist = CanOpenPlaylist(playlist);
        var showcaseStory = GetPlaylistShowcaseStory(playlist);
        var hasShowcaseImage = playlist.ShowShowcaseImageOnLuisterPage && showcaseStory is not null;
        var isWeeklyPopularPlaylist = IsWeeklyPopularPlaylist(playlist);

        <section class="section-block stories-carousel-section luister-stories-section" aria-labelledby="@headingId">
            <h2 id="@headingId">
                @if (canOpenPlaylist)
                {
                    <a class="luister-playlist-link"
                       href="@GetPlaylistHref(playlistSlug)"
                       data-enhance-nav="false">@playlistTitle</a>
                }
                else
                {
                    <button type="button"
                            class="luister-playlist-link luister-playlist-link-button"
                            @onclick="() => HandlePlaylistClickAsync(playlist)">@playlistTitle</button>
                }
            </h2>
            @if (hasDescription)
            {
                <p class="section-intro">@playlist.Description</p>
            }
            @if (hasShowcaseImage)
            {
                var showcaseStoryTitle = string.IsNullOrWhiteSpace(showcaseStory!.Title) ? "hierdie storie" : showcaseStory.Title.Trim();
                var canAccessShowcaseStory = HasAccessToStory(showcaseStory);

                <div class="luister-playlist-showcase">
                    @if (canAccessShowcaseStory)
                    {
                        <a class="luister-playlist-showcase-link"
                           href="@GetStoryHref(showcaseStory.Slug)"
                           data-enhance-nav="false"
                           aria-label="Luister na @showcaseStoryTitle">
                            <span class="luister-playlist-showcase-cover">
                                <img class="luister-playlist-showcase-image"
                                     src="@showcaseStory.ThumbnailPath"
                                     srcset="@($"{showcaseStory.ThumbnailPath} 640w, {showcaseStory.ImagePath} 1024w")"
                                     sizes="(max-width: 900px) calc(100vw - 2rem), 720px"
                                     alt="Voorblad van @showcaseStoryTitle"
                                     width="1024"
                                     height="576"
                                     loading="lazy"
                                     decoding="async" />
                                <span class="story-cover-play" aria-hidden="true">
                                    <i class="story-cover-play-icon fa-solid fa-play" aria-hidden="true"></i>
                                </span>
                            </span>
                            <span class="luister-playlist-showcase-title">@showcaseStoryTitle</span>
                        </a>
                    }
                    else
                    {
                        <button type="button"
                                class="luister-playlist-showcase-link luister-playlist-showcase-link-button"
                                @onclick="() => HandleStoryCardClickAsync(showcaseStory)"
                                aria-label="Luister na @showcaseStoryTitle">
                            <span class="luister-playlist-showcase-cover">
                                <img class="luister-playlist-showcase-image"
                                     src="@showcaseStory.ThumbnailPath"
                                     srcset="@($"{showcaseStory.ThumbnailPath} 640w, {showcaseStory.ImagePath} 1024w")"
                                     sizes="(max-width: 900px) calc(100vw - 2rem), 720px"
                                     alt="Voorblad van @showcaseStoryTitle"
                                     width="1024"
                                     height="576"
                                     loading="lazy"
                                     decoding="async" />
                                <span class="story-cover-play" aria-hidden="true">
                                    <i class="story-cover-play-icon fa-solid fa-play" aria-hidden="true"></i>
                                </span>
                            </span>
                            <span class="luister-playlist-showcase-title">@showcaseStoryTitle</span>
                        </button>
                    }
                </div>
            }

            <div class="stories-carousel-shell">
                <div class="stories-carousel" role="list" aria-label="@playlistTitle">
                    @for (var storyIndex = 0; storyIndex < playlistStories.Count; storyIndex++)
                    {
                        var story = playlistStories[storyIndex];
                        var canAccessStory = HasAccessToStory(story);
                        var storyTitle = string.IsNullOrWhiteSpace(story.Title) ? "hierdie storie" : story.Title.Trim();
                        var articleClassName = isWeeklyPopularPlaylist
                            ? "story-carousel-item story-carousel-item-ranked"
                            : "story-carousel-item";

                        <article class="@articleClassName" role="listitem">
                            <div class="story-carousel-card-shell">
                                @if (isWeeklyPopularPlaylist)
                                {
                                    <span class="story-carousel-rank" aria-hidden="true">@((storyIndex + 1).ToString(CultureInfo.InvariantCulture))</span>
                                }
                                @if (canAccessStory)
                                {
                                    <a class="story-carousel-link"
                                       href="@GetStoryHref(story.Slug)"
                                       data-enhance-nav="false"
                                       draggable="false"
                                       aria-label="Luister na @storyTitle">
                                        <span class="story-carousel-cover">
                                            <img class="story-carousel-image"
                                                 src="@story.ThumbnailPath"
                                                 srcset="@($"{story.ThumbnailPath} 640w, {story.ImagePath} 1024w")"
                                                 sizes="(max-width: 620px) 68vw, (max-width: 980px) 42vw, 320px"
                                                 draggable="false"
                                                 alt="Voorblad van @storyTitle" width="640" height="485" loading="lazy" decoding="async" />
                                            <span class="story-cover-play" aria-hidden="true">
                                                <i class="story-cover-play-icon fa-solid fa-play" aria-hidden="true"></i>
                                            </span>
                                        </span>
                                        <h3>@storyTitle</h3>
                                    </a>
                                }
                                else
                                {
                                    <button type="button"
                                            class="story-carousel-link story-carousel-link-button"
                                            @onclick="() => HandleStoryCardClickAsync(story)"
                                            aria-label="Luister na @storyTitle">
                                        <span class="story-carousel-cover">
                                            <img class="story-carousel-image"
                                                 src="@story.ThumbnailPath"
                                                 srcset="@($"{story.ThumbnailPath} 640w, {story.ImagePath} 1024w")"
                                                 sizes="(max-width: 620px) 68vw, (max-width: 980px) 42vw, 320px"
                                                 draggable="false"
                                                 alt="Voorblad van @storyTitle" width="640" height="485" loading="lazy" decoding="async" />
                                            <span class="story-cover-play" aria-hidden="true">
                                                <i class="story-cover-play-icon fa-solid fa-play" aria-hidden="true"></i>
                                            </span>
                                        </span>
                                        <h3>@storyTitle</h3>
                                    </button>
                                }
                                <button type="button"
                                        class="story-favorite-toggle @(IsStoryFavorite(story.Slug) ? "is-favorite" : null)"
                                        @onclick="() => ToggleStoryFavoriteAsync(story)"
                                        aria-label="@(IsStoryFavorite(story.Slug) ? $"Verwyder {storyTitle} uit jou gunstelinge" : $"Voeg {storyTitle} by jou gunstelinge")"
                                        title="@(IsStoryFavorite(story.Slug) ? "Verwyder uit gunstelinge" : "Voeg by gunstelinge")"
                                        aria-pressed="@IsStoryFavorite(story.Slug)"
                                        disabled="@IsFavoriteBusy(story.Slug)">
                                    <i class="fa-@(IsStoryFavorite(story.Slug) ? "solid" : "regular") fa-heart" aria-hidden="true"></i>
                                </button>
                            </div>
                        </article>
                    }
                </div>
            </div>
        </section>
    }
}

<section class="luister-whatsapp-join" aria-label="WhatsApp groep">
    <a class="luister-whatsapp-join-btn"
       href="https://chat.whatsapp.com/FLbBQBo0mVcBZDTublIWi5"
       target="_blank"
       rel="noopener noreferrer"
       aria-label="Sluit by die Schink WhatsApp-groep aan">
        <i class="fa-brands fa-whatsapp" aria-hidden="true"></i>
        <span>Sluit aan op WhatsApp</span>
    </a>
</section>

<StoryAccessPopup IsOpen="@ShowStoryAccessPopup"
                  PrimaryActionHref="@StoryAccessPopupPrimaryHref"
                  PlanActionHref="@StoryAccessPopupPlanHref"
                  OnClose="CloseStoryAccessPopupAsync" />

<StoryAccessPopup IsOpen="@ShowCharacterUnlockPopup"
                  ImageSrc="@CharacterUnlockPopupImagePath"
                  ImageAlt="@CharacterUnlockPopupImageAlt"
                  Title="@CharacterUnlockPopupTitle"
                  Subtitle="@CharacterUnlockPopupSubtitle"
                  ShowSubtitleLockIcon="false"
                  Message="@CharacterUnlockPopupMessage"
                  PrimaryActionHref="@CharacterUnlockPopupHref"
                  PrimaryActionText="Maak Karakter Blad Oop"
                  PlanActionHref=""
                  OnClose="CloseCharacterUnlockPopupAsync" />

@code {
    private const string PendingCharacterUnlockPopupStorageKey = "schink:pending-character-unlock-popup";
    private static readonly JsonSerializerOptions BrowserJsonOptions = new(JsonSerializerDefaults.Web);

    private IReadOnlyList<StoryPlaylist> LuisterPlaylists { get; set; } = Array.Empty<StoryPlaylist>();
    private IReadOnlyList<StoryPlaylist> FilteredLuisterPlaylists { get; set; } = Array.Empty<StoryPlaylist>();
    private HashSet<string> FavoriteStorySlugs { get; } = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> FavoriteStoryBusySlugs { get; } = new(StringComparer.OrdinalIgnoreCase);
    private IJSObjectReference? _luisterModule;
    private bool _luisterModuleLoadFailed;
    private bool _checkedPendingCharacterUnlockPopup;
    private CancellationTokenSource? _searchDebounceCts;
    private string? SignedInEmail { get; set; }
    private string SearchQuery { get; set; } = string.Empty;
    private bool IsSearching { get; set; }
    private LuisterAccessProfile AccessProfile { get; set; } = new(false, false, false);
    private string? PageLoadErrorMessage { get; set; }
    private bool ShowStoryAccessPopup { get; set; }
    private bool ShowCharacterUnlockPopup { get; set; }
    private bool IsLoadingPage { get; set; } = true;
    private bool AllowEmptyState { get; set; }
    private string PendingLockedStoryPath { get; set; } = "/luister";
    private string CharacterUnlockPopupImagePath { get; set; } = "/branding/schink-logo-text.png";
    private string CharacterUnlockPopupImageAlt { get; set; } = "Karakter illustrasie";
    private string CharacterUnlockPopupTitle { get; set; } = "Nuwe karakter oopgesluit";
    private string CharacterUnlockPopupSubtitle { get; set; } = "Kyk nou jou nuwe karakter";
    private string CharacterUnlockPopupMessage { get; set; } = "Jou nuwe karakter wag vir jou op die Karakter blad.";
    private string CharacterUnlockPopupHref { get; set; } = "/karakters";
    private CancellationTokenSource? _emptyStateDelayCts;

    private string LuisterCanonicalUrl => NavigationManager.ToAbsoluteUri("/luister").ToString();
    private bool IsSignedIn => !string.IsNullOrWhiteSpace(SignedInEmail);
    private string StoryAccessPopupPrimaryHref =>
        IsSignedIn
            ? BuildOpsiesHref(PendingLockedStoryPath)
            : $"/teken-in?returnUrl={Uri.EscapeDataString(PendingLockedStoryPath)}";
    private string StoryAccessPopupPlanHref => BuildOpsiesHref(PendingLockedStoryPath);

    private MarkupString LuisterJsonLd => new(JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "CollectionPage",
        ["name"] = "Schink Stories | Luister",
        ["description"] = "Luister na ons nuutste stories op Schink Stories.",
        ["url"] = LuisterCanonicalUrl,
        ["inLanguage"] = "af-ZA",
        ["isPartOf"] = new Dictionary<string, object?>
        {
            ["@type"] = "WebSite",
            ["name"] = "Schink Stories",
            ["url"] = NavigationManager.ToAbsoluteUri("/").ToString()
        },
        ["primaryImageOfPage"] = NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()
    }));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            SignedInEmail = authState.User.Identity?.IsAuthenticated == true
                ? authState.User.FindFirst(ClaimTypes.Email)?.Value ?? authState.User.Identity?.Name
                : null;

            try
            {
                AccessProfile = await ResolveLuisterAccessProfileAsync(authState.User);
            }
            catch
            {
                AccessProfile = new LuisterAccessProfile(false, false, false);
            }

            try
            {
                LuisterPlaylists = await StoryCatalogService.GetLuisterPlaylistsAsync(SignedInEmail);
            }
            catch
            {
                LuisterPlaylists = Array.Empty<StoryPlaylist>();
            }

            UpdateFilteredPlaylists();
            _ = LoadFavoriteStorySlugsInBackgroundAsync();
        }
        catch
        {
            PageLoadErrorMessage = "Ons kon nie nou jou luisterblad oopmaak nie. Herlaai asseblief die bladsy of probeer weer vanaf Gratis stories.";
            LuisterPlaylists = Array.Empty<StoryPlaylist>();
            FilteredLuisterPlaylists = Array.Empty<StoryPlaylist>();
            AccessProfile = new LuisterAccessProfile(false, false, false);
        }
        finally
        {
            IsLoadingPage = false;
            await UpdateEmptyStateVisibilityAsync();
        }
    }

    private async Task UpdateEmptyStateVisibilityAsync()
    {
        CancelEmptyStateDelay();
        AllowEmptyState = false;

        if (!string.IsNullOrWhiteSpace(PageLoadErrorMessage) ||
            (LuisterPlaylists.Count > 0 && FilteredLuisterPlaylists.Count > 0))
        {
            return;
        }

        var delayCts = new CancellationTokenSource();
        _emptyStateDelayCts = delayCts;

        try
        {
            await Task.Delay(450, delayCts.Token);
            AllowEmptyState = true;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void CancelEmptyStateDelay()
    {
        _emptyStateDelayCts?.Cancel();
        _emptyStateDelayCts?.Dispose();
        _emptyStateDelayCts = null;
    }

    private static string GetStoryHref(string? slug) =>
        string.IsNullOrWhiteSpace(slug)
            ? "/luister"
            : $"/luister/{Uri.EscapeDataString(slug.Trim())}";

    private static string GetPlaylistHref(string? slug) =>
        string.IsNullOrWhiteSpace(slug)
            ? "/luister"
            : $"/luister/speellys/{Uri.EscapeDataString(slug.Trim())}/stories";

    private static string GetPlaylistShowcaseHref(string? slug) =>
        string.IsNullOrWhiteSpace(slug)
            ? "/luister"
            : $"/luister/speellys/{Uri.EscapeDataString(slug.Trim())}/stories";

    private static string GetPlaylistSlug(StoryPlaylist playlist) =>
        string.IsNullOrWhiteSpace(playlist.Slug) ? "stories" : playlist.Slug.Trim();

    private static string GetPlaylistTitle(StoryPlaylist playlist) =>
        string.IsNullOrWhiteSpace(playlist.Title) ? "Stories" : playlist.Title.Trim();

    private static IReadOnlyList<StoryItem> GetPlaylistStories(StoryPlaylist playlist) =>
        playlist.Stories ?? Array.Empty<StoryItem>();

    private static StoryItem? GetPlaylistShowcaseStory(StoryPlaylist playlist) =>
        playlist.PreferredStory;

    private IReadOnlyList<StoryPlaylist> GetSpeellysteCarouselPlaylists() =>
        FilteredLuisterPlaylists
            .Where(playlist => playlist.IncludeInSpeellysteCarousel)
            .ToArray();

    private static string GetPlaylistCarouselImagePath(StoryPlaylist playlist)
    {
        var explicitShowcaseImagePath = NormalizeOptionalImagePath(playlist.ShowcaseImagePath);
        if (!string.IsNullOrWhiteSpace(explicitShowcaseImagePath))
        {
            return explicitShowcaseImagePath;
        }

        var preferredStory = playlist.PreferredStory;
        if (preferredStory is not null)
        {
            var preferredStoryImage = NormalizeOptionalImagePath(preferredStory.ImagePath);
            if (!string.IsNullOrWhiteSpace(preferredStoryImage))
            {
                return preferredStoryImage;
            }

            var preferredStoryThumbnail = NormalizeOptionalImagePath(preferredStory.ThumbnailPath);
            if (!string.IsNullOrWhiteSpace(preferredStoryThumbnail))
            {
                return preferredStoryThumbnail;
            }
        }

        var backdropPath = NormalizeOptionalImagePath(playlist.BackdropImagePath);
        if (!string.IsNullOrWhiteSpace(backdropPath))
        {
            return backdropPath;
        }

        var logoPath = NormalizeOptionalImagePath(playlist.LogoImagePath);
        if (!string.IsNullOrWhiteSpace(logoPath))
        {
            return logoPath;
        }

        return "/branding/Schink_Stories_01.png";
    }

    private static string? NormalizeOptionalImagePath(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static bool IsWeeklyPopularPlaylist(StoryPlaylist playlist) =>
        string.Equals(playlist.SystemKey, "popular-stories-this-week", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(playlist.Slug, "popular-stories-this-week", StringComparison.OrdinalIgnoreCase);

    private bool IsStoryFavorite(string slug) => FavoriteStorySlugs.Contains(slug);

    private bool IsFavoriteBusy(string slug) => FavoriteStoryBusySlugs.Contains(slug);

    private async Task ToggleStoryFavoriteAsync(StoryItem story)
    {
        if (string.IsNullOrWhiteSpace(story.Slug))
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(SignedInEmail))
        {
            ShowAccessPopupForPath(GetStoryHref(story.Slug));
            return;
        }

        var normalizedSlug = story.Slug.Trim();
        if (!FavoriteStoryBusySlugs.Add(normalizedSlug))
        {
            return;
        }

        var isCurrentlyFavorite = FavoriteStorySlugs.Contains(normalizedSlug);
        try
        {
            var updated = await StoryFavoriteService.SetStoryFavoriteAsync(
                SignedInEmail,
                new StoryFavoriteMutationRequest(
                    StorySlug: normalizedSlug,
                    StoryPath: GetStoryHref(normalizedSlug),
                    Source: "luister",
                    IsFavorite: !isCurrentlyFavorite,
                    PlaylistSlug: null));

            if (updated)
            {
                if (isCurrentlyFavorite)
                {
                    FavoriteStorySlugs.Remove(normalizedSlug);
                }
                else
                {
                    FavoriteStorySlugs.Add(normalizedSlug);
                }
            }
        }
        finally
        {
            FavoriteStoryBusySlugs.Remove(normalizedSlug);
        }
    }

    private async Task LoadFavoriteStorySlugsAsync()
    {
        FavoriteStorySlugs.Clear();
        FavoriteStoryBusySlugs.Clear();

        if (string.IsNullOrWhiteSpace(SignedInEmail))
        {
            return;
        }

        var favoriteSlugs = await StoryFavoriteService.GetFavoriteStorySlugsAsync(SignedInEmail, "luister");
        foreach (var favoriteSlug in favoriteSlugs)
        {
            FavoriteStorySlugs.Add(favoriteSlug);
        }
    }

    private async Task LoadFavoriteStorySlugsInBackgroundAsync()
    {
        try
        {
            await LoadFavoriteStorySlugsAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // Keep the page responsive if favorites fail to load.
        }
    }

    private Task HandleStoryCardClickAsync(StoryItem story)
    {
        var storyPath = GetStoryHref(story.Slug);
        if (HasAccessToStory(story))
        {
            NavigationManager.NavigateTo(storyPath);
            return Task.CompletedTask;
        }

        ShowAccessPopupForPath(storyPath);
        return Task.CompletedTask;
    }

    private Task HandlePlaylistClickAsync(StoryPlaylist playlist)
    {
        var playlistPath = GetPlaylistHref(GetPlaylistSlug(playlist));
        if (CanOpenPlaylist(playlist))
        {
            NavigationManager.NavigateTo(playlistPath);
            return Task.CompletedTask;
        }

        ShowAccessPopupForPath(playlistPath);
        return Task.CompletedTask;
    }

    private Task CloseStoryAccessPopupAsync()
    {
        ShowStoryAccessPopup = false;
        return Task.CompletedTask;
    }

    private Task CloseCharacterUnlockPopupAsync()
    {
        ShowCharacterUnlockPopup = false;
        return Task.CompletedTask;
    }

    private bool HasAccessToStory(StoryItem story)
    {
        var requirement = StoryAccessPolicy.ResolveRequirement("luister", story);
        return requirement switch
        {
            StoryAccessRequirement.Free => IsSignedIn && AccessProfile.HasGratisOrPaid,
            StoryAccessRequirement.StoryCornerOrAllStories => AccessProfile.HasStoryCornerOrAll,
            StoryAccessRequirement.AllStoriesOnly => AccessProfile.HasAllStories,
            _ => false
        };
    }

    private bool CanOpenPlaylist(StoryPlaylist playlist) =>
        GetPlaylistStories(playlist).Any(HasAccessToStory);

    private void ShowAccessPopupForPath(string path)
    {
        PendingLockedStoryPath = string.IsNullOrWhiteSpace(path) ? "/luister" : path;
        ShowStoryAccessPopup = true;
    }

    private async Task<LuisterAccessProfile> ResolveLuisterAccessProfileAsync(ClaimsPrincipal user)
    {
        var email = user.FindFirst(ClaimTypes.Email)?.Value
                    ?? user.Identity?.Name;
        if (string.IsNullOrWhiteSpace(email))
        {
            return new LuisterAccessProfile(false, false, false);
        }

        var gratisTask = SubscriptionLedgerService.HasActiveSubscriptionForTierAsync(email, "gratis");
        var storyCornerTask = SubscriptionLedgerService.HasActiveSubscriptionForTierAsync(email, StoryAccessPolicy.StoryCornerMonthlyTierCode);
        var allStoriesMonthlyTask = SubscriptionLedgerService.HasActiveSubscriptionForTierAsync(email, StoryAccessPolicy.AllStoriesMonthlyTierCode);
        var allStoriesYearlyTask = SubscriptionLedgerService.HasActiveSubscriptionForTierAsync(email, StoryAccessPolicy.AllStoriesYearlyTierCode);

        await Task.WhenAll(gratisTask, storyCornerTask, allStoriesMonthlyTask, allStoriesYearlyTask);

        var hasAllStories = allStoriesMonthlyTask.Result || allStoriesYearlyTask.Result;
        return new LuisterAccessProfile(
            HasGratisOrPaid: gratisTask.Result || storyCornerTask.Result || hasAllStories,
            HasStoryCornerOrAll: storyCornerTask.Result || hasAllStories,
            HasAllStories: hasAllStories);
    }

    private static string BuildOpsiesHref(string returnPath)
    {
        var safePath = string.IsNullOrWhiteSpace(returnPath) ? "/luister" : returnPath;
        return $"/opsies?returnUrl={Uri.EscapeDataString(safePath)}";
    }

    private async Task HandleSearchInputAsync(ChangeEventArgs args)
    {
        SearchQuery = args.Value?.ToString() ?? string.Empty;
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();

        var trimmedQuery = SearchQuery.Trim();
        if (string.IsNullOrWhiteSpace(trimmedQuery))
        {
            IsSearching = false;
            UpdateFilteredPlaylists();
            return;
        }

        var debounceCts = new CancellationTokenSource();
        _searchDebounceCts = debounceCts;
        IsSearching = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(180, debounceCts.Token);
            if (debounceCts.IsCancellationRequested)
            {
                return;
            }

            UpdateFilteredPlaylists();
        }
        catch (OperationCanceledException)
        {
            return;
        }
        finally
        {
            if (ReferenceEquals(_searchDebounceCts, debounceCts))
            {
                IsSearching = false;
                _searchDebounceCts = null;
                debounceCts.Dispose();
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private void UpdateFilteredPlaylists()
    {
        var trimmedQuery = SearchQuery.Trim();
        if (string.IsNullOrWhiteSpace(trimmedQuery))
        {
            FilteredLuisterPlaylists = LuisterPlaylists;
            return;
        }

        FilteredLuisterPlaylists = LuisterPlaylists
            .Select(playlist =>
            {
                var matchingStories = playlist.Stories
                    .Where(story => story.Title.Contains(trimmedQuery, StringComparison.OrdinalIgnoreCase))
                    .ToArray();

                var playlistMatches =
                    playlist.Title.Contains(trimmedQuery, StringComparison.OrdinalIgnoreCase) ||
                    (!string.IsNullOrWhiteSpace(playlist.Description) &&
                     playlist.Description.Contains(trimmedQuery, StringComparison.OrdinalIgnoreCase));

                return playlistMatches || matchingStories.Length > 0
                    ? playlist with
                    {
                        Stories = playlistMatches ? playlist.Stories : matchingStories
                    }
                    : null;
            })
            .Where(playlist => playlist is not null)
            .Cast<StoryPlaylist>()
            .ToArray();
    }

    protected override async Task OnAfterRenderAsync(bool _)
    {
        if (!_checkedPendingCharacterUnlockPopup)
        {
            _checkedPendingCharacterUnlockPopup = true;
            await TryShowPendingCharacterUnlockPopupAsync();
        }

        var module = await TryGetLuisterModuleAsync();
        if (module is null)
        {
            return;
        }

        try
        {
            await module.InvokeVoidAsync("initializeHomeStoryLoading");
        }
        catch (OperationCanceledException)
        {
            // Ignore cancellations when navigation interrupts JS interop.
        }
        catch (JSException)
        {
            _luisterModuleLoadFailed = true;
        }
        catch (JSDisconnectedException)
        {
            // Ignore circuit disconnects during teardown/navigation.
        }
    }

    private async Task TryShowPendingCharacterUnlockPopupAsync()
    {
        string? pendingPopupPayload = null;
        try
        {
            pendingPopupPayload = await JS.InvokeAsync<string?>("sessionStorage.getItem", PendingCharacterUnlockPopupStorageKey);
        }
        catch (OperationCanceledException)
        {
            return;
        }
        catch (JSException)
        {
            return;
        }
        catch (JSDisconnectedException)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(pendingPopupPayload))
        {
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("sessionStorage.removeItem", PendingCharacterUnlockPopupStorageKey);
        }
        catch (OperationCanceledException)
        {
        }
        catch (JSException)
        {
        }
        catch (JSDisconnectedException)
        {
        }

        PendingCharacterUnlockPopupPayload? payload = null;
        try
        {
            payload = JsonSerializer.Deserialize<PendingCharacterUnlockPopupPayload>(pendingPopupPayload, BrowserJsonOptions);
        }
        catch (JsonException)
        {
            payload = null;
        }

        CharacterUnlockPopupImagePath = NormalizePopupPath(payload?.ImagePath) ?? "/branding/schink-logo-text.png";
        CharacterUnlockPopupImageAlt = string.IsNullOrWhiteSpace(payload?.ImageAlt)
            ? "Karakter illustrasie"
            : payload.ImageAlt.Trim();
        CharacterUnlockPopupHref = NormalizePopupHref(payload?.Href);
        CharacterUnlockPopupTitle = string.IsNullOrWhiteSpace(payload?.Title)
            ? "Nuwe karakter oopgesluit"
            : payload.Title.Trim();
        CharacterUnlockPopupSubtitle = "Kyk nou jou nuwe karakter";
        CharacterUnlockPopupMessage = string.IsNullOrWhiteSpace(payload?.Body)
            ? "Jou nuwe karakter wag vir jou op die Karakter blad."
            : payload.Body.Trim();

        ShowCharacterUnlockPopup = true;
        await InvokeAsync(StateHasChanged);
    }

    private static string NormalizePopupHref(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "/karakters";
        }

        var trimmed = value.Trim();
        if (Uri.TryCreate(trimmed, UriKind.Absolute, out var absoluteUri))
        {
            trimmed = absoluteUri.PathAndQuery;
        }

        if (!trimmed.StartsWith("/", StringComparison.Ordinal))
        {
            trimmed = $"/{trimmed.TrimStart('/')}";
        }

        if (trimmed.Equals("/karakters", StringComparison.OrdinalIgnoreCase) ||
            trimmed.StartsWith("/karakters?", StringComparison.OrdinalIgnoreCase) ||
            trimmed.StartsWith("/karakters#", StringComparison.OrdinalIgnoreCase))
        {
            return trimmed;
        }

        var pathOnly = trimmed.Split('?', '#')[0].Trim('/');
        var segments = pathOnly.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (segments.Length >= 2 &&
            IsCharacterPopupRouteSegment(segments[0]) &&
            !string.IsNullOrWhiteSpace(segments[1]))
        {
            return $"/karakters?karakter={Uri.EscapeDataString(segments[1])}";
        }

        return "/karakters";
    }

    private static bool IsCharacterPopupRouteSegment(string value) =>
        value.Equals("karakter", StringComparison.OrdinalIgnoreCase) ||
        value.Equals("karakters", StringComparison.OrdinalIgnoreCase) ||
        value.Equals("character", StringComparison.OrdinalIgnoreCase) ||
        value.Equals("characters", StringComparison.OrdinalIgnoreCase);

    private static string? NormalizePopupPath(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var trimmed = value.Trim();
        if (Uri.TryCreate(trimmed, UriKind.Absolute, out _))
        {
            return trimmed;
        }

        return trimmed.StartsWith("/", StringComparison.Ordinal) ? trimmed : $"/{trimmed.TrimStart('/')}";
    }

    private async Task<IJSObjectReference?> TryGetLuisterModuleAsync()
    {
        if (_luisterModuleLoadFailed)
        {
            return null;
        }

        if (_luisterModule is not null)
        {
            return _luisterModule;
        }

        try
        {
            _luisterModule = await JS.InvokeAsync<IJSObjectReference>("import", "/Components/Pages/Home.razor.js");
            return _luisterModule;
        }
        catch (OperationCanceledException)
        {
            return null;
        }
        catch (JSException)
        {
            _luisterModuleLoadFailed = true;
            return null;
        }
        catch (JSDisconnectedException)
        {
            return null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        CancelEmptyStateDelay();
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();

        if (_luisterModule is null)
        {
            return;
        }

        try
        {
            await _luisterModule.DisposeAsync();
        }
        catch (OperationCanceledException)
        {
            // Ignore cancellations during component disposal.
        }
        catch (JSDisconnectedException)
        {
            // Ignore JS disconnects during teardown.
        }
    }

    private sealed record LuisterAccessProfile(bool HasGratisOrPaid, bool HasStoryCornerOrAll, bool HasAllStories);

    private sealed record PendingCharacterUnlockPopupPayload(
        string? Type,
        string? ImagePath,
        string? ImageAlt,
        string? Href,
        string? Title,
        string? Body,
        string? CreatedAt);
}

