@page "/luister"
@rendermode InteractiveServer
@using System.Security.Claims
@using System.Text.Json
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@inject NavigationManager NavigationManager
@inject IStoryCatalogService StoryCatalogService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IStoryFavoriteService StoryFavoriteService
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Schink Stories | Luister</PageTitle>
<HeadContent>
    <link rel="canonical" href="@LuisterCanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Schink Stories | Luister" />
    <meta property="og:description" content="Luister na ons nuutste stories op Schink Stories." />
    <meta property="og:url" content="@LuisterCanonicalUrl" />
    <meta property="og:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:secure_url" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content="Schink Stories logo" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Schink Stories | Luister" />
    <meta name="twitter:description" content="Luister na ons nuutste stories op Schink Stories." />
    <meta name="twitter:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta name="twitter:image:alt" content="Schink Stories logo" />
    <script type="application/ld+json">@LuisterJsonLd</script>
</HeadContent>

<div class="luister-page-shell">
    <section class="gratis-hero">
        <img class="gratis-banner" src="/branding/DIS_STORIETYD.png"
             alt="Luister stories banner" loading="eager" fetchpriority="high" decoding="async" />
    </section>

    <section class="luister-search-section" aria-labelledby="luister-soek-heading">
        <h2 id="luister-soek-heading" class="sr-only">Soek stories</h2>
        <form class="luister-search-form" role="search" @onsubmit:preventDefault="true">
            <label class="sr-only" for="luister-search">Soek stories</label>
            <span class="luister-search-icon" aria-hidden="true">
                <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
            </span>
            <input id="luister-search"
                   class="luister-search-input"
                   type="search"
                   placeholder="Soek stories"
                   autocomplete="off"
                   value="@SearchQuery"
                   @oninput="HandleSearchInputAsync" />
            @if (IsSearching)
            {
                <span class="luister-search-loader" aria-live="polite">
                    <span class="luister-search-spinner" aria-hidden="true"></span>
                    <span class="luister-search-loader-text">Soek...</span>
                </span>
            }
        </form>
    </section>

@code {
    private IReadOnlyList<StoryPlaylist> LuisterPlaylists { get; set; } = Array.Empty<StoryPlaylist>();
    private IReadOnlyList<StoryPlaylist> FilteredLuisterPlaylists { get; set; } = Array.Empty<StoryPlaylist>();
    private HashSet<string> FavoriteStorySlugs { get; } = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> FavoriteStoryBusySlugs { get; } = new(StringComparer.OrdinalIgnoreCase);
    private IJSObjectReference? _luisterModule;
    private bool _luisterModuleLoadFailed;
    private CancellationTokenSource? _searchDebounceCts;
    private string? SignedInEmail { get; set; }
    private string SearchQuery { get; set; } = string.Empty;
    private bool IsSearching { get; set; }

    private string LuisterCanonicalUrl => NavigationManager.ToAbsoluteUri("/luister").ToString();

    private MarkupString LuisterJsonLd => new(JsonSerializer.Serialize(new
    {
        @context = "https://schema.org",
        @type = "CollectionPage",
        name = "Schink Stories | Luister",
        description = "Luister na ons nuutste stories op Schink Stories.",
        url = LuisterCanonicalUrl,
        inLanguage = "af-ZA",
        isPartOf = new
        {
            @type = "WebSite",
            name = "Schink Stories",
            url = NavigationManager.ToAbsoluteUri("/").ToString()
        },
        primaryImageOfPage = NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()
    }));

    protected override async Task OnInitializedAsync()
    {
        await ResolveSignedInEmailAsync();

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var signedInEmail = authState.User.Identity?.IsAuthenticated == true
                ? authState.User.FindFirst(ClaimTypes.Email)?.Value ?? authState.User.Identity?.Name
                : null;

            LuisterPlaylists = await StoryCatalogService.GetLuisterPlaylistsAsync(signedInEmail);
        }
        catch
        {
            LuisterPlaylists = Array.Empty<StoryPlaylist>();
        }

        UpdateFilteredPlaylists();
        _ = LoadFavoriteStorySlugsInBackgroundAsync();
    }

    private static string GetStoryHref(string slug) => $"/luister/{Uri.EscapeDataString(slug)}";

    private static string GetPlaylistHref(string slug) => $"/luister/speellys/{Uri.EscapeDataString(slug)}/stories";

    private bool IsStoryFavorite(string slug) => FavoriteStorySlugs.Contains(slug);

    private bool IsFavoriteBusy(string slug) => FavoriteStoryBusySlugs.Contains(slug);

    private async Task ToggleStoryFavoriteAsync(StoryItem story)
    {
        if (string.IsNullOrWhiteSpace(story.Slug))
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(SignedInEmail))
        {
            RedirectToOpsies();
            return;
        }

        var normalizedSlug = story.Slug.Trim();
        if (!FavoriteStoryBusySlugs.Add(normalizedSlug))
        {
            return;
        }

        var isCurrentlyFavorite = FavoriteStorySlugs.Contains(normalizedSlug);
        try
        {
            var updated = await StoryFavoriteService.SetStoryFavoriteAsync(
                SignedInEmail,
                new StoryFavoriteMutationRequest(
                    StorySlug: normalizedSlug,
                    StoryPath: GetStoryHref(normalizedSlug),
                    Source: "luister",
                    IsFavorite: !isCurrentlyFavorite,
                    PlaylistSlug: null));

            if (updated)
            {
                if (isCurrentlyFavorite)
                {
                    FavoriteStorySlugs.Remove(normalizedSlug);
                }
                else
                {
                    FavoriteStorySlugs.Add(normalizedSlug);
                }
            }
        }
        finally
        {
            FavoriteStoryBusySlugs.Remove(normalizedSlug);
        }
    }

    private async Task ResolveSignedInEmailAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            SignedInEmail = null;
            return;
        }

        SignedInEmail = authState.User.FindFirst(ClaimTypes.Email)?.Value
            ?? authState.User.Identity?.Name;
    }

    private async Task LoadFavoriteStorySlugsAsync()
    {
        FavoriteStorySlugs.Clear();
        FavoriteStoryBusySlugs.Clear();

        if (string.IsNullOrWhiteSpace(SignedInEmail))
        {
            return;
        }

        var favoriteSlugs = await StoryFavoriteService.GetFavoriteStorySlugsAsync(SignedInEmail, "luister");
        foreach (var favoriteSlug in favoriteSlugs)
        {
            FavoriteStorySlugs.Add(favoriteSlug);
        }
    }

    private async Task LoadFavoriteStorySlugsInBackgroundAsync()
    {
        try
        {
            await LoadFavoriteStorySlugsAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // Keep the page responsive if favorites fail to load.
        }
    }

    private void RedirectToOpsies()
    {
        var currentUri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var currentPathAndQuery = $"{currentUri.AbsolutePath}{currentUri.Query}";
        var returnPath = string.IsNullOrWhiteSpace(currentPathAndQuery)
            ? "/luister"
            : currentPathAndQuery;
        var returnUrl = Uri.EscapeDataString(returnPath);
        NavigationManager.NavigateTo($"/opsies?returnUrl={returnUrl}");
    }

    private async Task HandleSearchInputAsync(ChangeEventArgs args)
    {
        SearchQuery = args.Value?.ToString() ?? string.Empty;
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();

        var trimmedQuery = SearchQuery.Trim();
        if (string.IsNullOrWhiteSpace(trimmedQuery))
        {
            IsSearching = false;
            UpdateFilteredPlaylists();
            return;
        }

        var debounceCts = new CancellationTokenSource();
        _searchDebounceCts = debounceCts;
        IsSearching = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(180, debounceCts.Token);
            if (debounceCts.IsCancellationRequested)
            {
                return;
            }

            UpdateFilteredPlaylists();
        }
        catch (OperationCanceledException)
        {
            return;
        }
        finally
        {
            if (ReferenceEquals(_searchDebounceCts, debounceCts))
            {
                IsSearching = false;
                _searchDebounceCts = null;
                debounceCts.Dispose();
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private void UpdateFilteredPlaylists()
    {
        var trimmedQuery = SearchQuery.Trim();
        if (string.IsNullOrWhiteSpace(trimmedQuery))
        {
            FilteredLuisterPlaylists = LuisterPlaylists;
            return;
        }

        FilteredLuisterPlaylists = LuisterPlaylists
            .Select(playlist =>
            {
                var matchingStories = playlist.Stories
                    .Where(story => story.Title.Contains(trimmedQuery, StringComparison.OrdinalIgnoreCase))
                    .ToArray();

                var playlistMatches =
                    playlist.Title.Contains(trimmedQuery, StringComparison.OrdinalIgnoreCase) ||
                    (!string.IsNullOrWhiteSpace(playlist.Description) &&
                     playlist.Description.Contains(trimmedQuery, StringComparison.OrdinalIgnoreCase));

                return playlistMatches || matchingStories.Length > 0
                    ? playlist with
                    {
                        Stories = playlistMatches ? playlist.Stories : matchingStories
                    }
                    : null;
            })
            .Where(playlist => playlist is not null)
            .Cast<StoryPlaylist>()
            .ToArray();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var module = await TryGetLuisterModuleAsync();
        if (module is null)
        {
            return;
        }

        await module.InvokeVoidAsync("initializeHomeStoryLoading");
    }

    private async Task<IJSObjectReference?> TryGetLuisterModuleAsync()
    {
        if (_luisterModuleLoadFailed)
        {
            return null;
        }

        if (_luisterModule is not null)
        {
            return _luisterModule;
        }

        try
        {
            _luisterModule = await JS.InvokeAsync<IJSObjectReference>("import", "/Components/Pages/Home.razor.js");
            return _luisterModule;
        }
        catch (JSException)
        {
            _luisterModuleLoadFailed = true;
            return null;
        }
        catch (JSDisconnectedException)
        {
            return null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();

        if (_luisterModule is null)
        {
            return;
        }

        try
        {
            await _luisterModule.DisposeAsync();
        }
        catch (JSDisconnectedException)
        {
            // Ignore JS disconnects during teardown.
        }
    }
}

@if (LuisterPlaylists.Count == 0)
{
    <section class="luister-empty-state">
        <p>Ons kon nie nou die playlists laai nie. Probeer asseblief oor 'n oomblik weer.</p>
    </section>
}
else if (FilteredLuisterPlaylists.Count == 0)
{
    <section class="luister-empty-state">
        <p>Geen stories pas by jou soektog vir "@SearchQuery".</p>
    </section>
}
else
{
    @for (var index = 0; index < FilteredLuisterPlaylists.Count; index++)
    {
        var playlist = FilteredLuisterPlaylists[index];
        var headingId = $"luister-playlist-{playlist.Slug}-heading";
        var hasDescription = !string.IsNullOrWhiteSpace(playlist.Description);

        <section class="section-block stories-carousel-section luister-stories-section" aria-labelledby="@headingId">
            <h2 id="@headingId">
                <a class="luister-playlist-link" href="@GetPlaylistHref(playlist.Slug)">@playlist.Title</a>
            </h2>
            @if (hasDescription)
            {
                <p class="section-intro">@playlist.Description</p>
            }

            <div class="stories-carousel-shell">
                <div class="stories-carousel" role="list" aria-label="@playlist.Title">
                    @foreach (var story in playlist.Stories)
                    {
                        <article class="story-carousel-item" role="listitem">
                            <div class="story-carousel-card-shell">
                                <a class="story-carousel-link"
                                       href="@GetStoryHref(story.Slug)"
                                       aria-label="Luister na @story.Title">
                                    <span class="story-carousel-cover">
                                        <img class="story-carousel-image"
                                             src="@story.ThumbnailPath"
                                             srcset="@($"{story.ThumbnailPath} 640w, {story.ImagePath} 1024w")"
                                             sizes="(max-width: 620px) 68vw, (max-width: 980px) 42vw, 320px"
                                             alt="Voorblad van @story.Title" width="640" height="485" loading="lazy" decoding="async" />
                                        <span class="story-cover-play" aria-hidden="true">
                                            <i class="story-cover-play-icon fa-solid fa-play" aria-hidden="true"></i>
                                        </span>
                                    </span>
                                    <h3>@story.Title</h3>
                                </a>
                                <button type="button"
                                        class="story-favorite-toggle @(IsStoryFavorite(story.Slug) ? "is-favorite" : null)"
                                        @onclick="() => ToggleStoryFavoriteAsync(story)"
                                        aria-label="@(IsStoryFavorite(story.Slug) ? $"Verwyder {story.Title} uit jou gunstelinge" : $"Voeg {story.Title} by jou gunstelinge")"
                                        title="@(IsStoryFavorite(story.Slug) ? "Verwyder uit gunstelinge" : "Voeg by gunstelinge")"
                                        aria-pressed="@IsStoryFavorite(story.Slug)"
                                        disabled="@IsFavoriteBusy(story.Slug)">
                                    <i class="fa-@(IsStoryFavorite(story.Slug) ? "solid" : "regular") fa-heart" aria-hidden="true"></i>
                                </button>
                            </div>
                        </article>
                    }
                </div>
            </div>
        </section>
    }
}
</div>
