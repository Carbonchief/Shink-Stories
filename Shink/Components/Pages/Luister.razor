@page "/luister"
@using System.Text.Json
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@inject NavigationManager NavigationManager
@inject IStoryCatalogService StoryCatalogService
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Schink Stories | Luister</PageTitle>
<HeadContent>
    <link rel="canonical" href="@LuisterCanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Schink Stories | Luister" />
    <meta property="og:description" content="Luister na ons nuutste stories op Schink Stories." />
    <meta property="og:url" content="@LuisterCanonicalUrl" />
    <meta property="og:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:secure_url" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content="Schink Stories logo" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Schink Stories | Luister" />
    <meta name="twitter:description" content="Luister na ons nuutste stories op Schink Stories." />
    <meta name="twitter:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta name="twitter:image:alt" content="Schink Stories logo" />
    <script type="application/ld+json">@LuisterJsonLd</script>
</HeadContent>

<section class="gratis-hero">
    <div class="gratis-hero-copy">
        <h1>Alle beskikbare stories vir jou gesin</h1>
        <p>
            Kies enige storie hieronder. Tik om dit oop te maak en
            direk te luister.
        </p>
    </div>
    <img class="gratis-banner" src="/branding/DIS_STORIETYD.png"
         alt="Luister stories banner" loading="eager" fetchpriority="high" decoding="async" />
</section>

@code {
    private IReadOnlyList<StoryPlaylist> LuisterPlaylists { get; set; } = Array.Empty<StoryPlaylist>();
    private ElementReference[] PlaylistCarouselRefs { get; set; } = Array.Empty<ElementReference>();
    private IJSObjectReference? _luisterModule;

    private string LuisterCanonicalUrl => NavigationManager.ToAbsoluteUri("/luister").ToString();

    private MarkupString LuisterJsonLd => new(JsonSerializer.Serialize(new
    {
        @context = "https://schema.org",
        @type = "CollectionPage",
        name = "Schink Stories | Luister",
        description = "Luister na ons nuutste stories op Schink Stories.",
        url = LuisterCanonicalUrl,
        inLanguage = "af-ZA",
        isPartOf = new
        {
            @type = "WebSite",
            name = "Schink Stories",
            url = NavigationManager.ToAbsoluteUri("/").ToString()
        },
        primaryImageOfPage = NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()
    }));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            LuisterPlaylists = await StoryCatalogService.GetLuisterPlaylistsAsync();
        }
        catch
        {
            LuisterPlaylists = Array.Empty<StoryPlaylist>();
        }

        PlaylistCarouselRefs = new ElementReference[LuisterPlaylists.Count];
    }

    private static string GetStoryHref(string slug) => $"/luister/{Uri.EscapeDataString(slug)}";

    private async Task ScrollCarouselAsync(ElementReference carouselRef, int direction)
    {
        if (direction is 0)
        {
            return;
        }

        _luisterModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/Home.razor.js");
        await _luisterModule.InvokeVoidAsync("scrollCarouselByPage", carouselRef, direction);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _luisterModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/Home.razor.js");
        await _luisterModule.InvokeVoidAsync("initializeHomeStoryLoading");
    }

    public async ValueTask DisposeAsync()
    {
        if (_luisterModule is null)
        {
            return;
        }

        try
        {
            await _luisterModule.DisposeAsync();
        }
        catch (JSDisconnectedException)
        {
            // Ignore JS disconnects during teardown.
        }
    }
}

@if (LuisterPlaylists.Count == 0)
{
    <section class="luister-empty-state">
        <p>Ons kon nie nou die playlists laai nie. Probeer asseblief oor 'n oomblik weer.</p>
    </section>
}
else
{
    @for (var index = 0; index < LuisterPlaylists.Count; index++)
    {
        var playlist = LuisterPlaylists[index];
        var headingId = $"luister-playlist-{playlist.Slug}-heading";
        var carouselIndex = index;
        var hasDescription = !string.IsNullOrWhiteSpace(playlist.Description);

        <section class="section-block stories-carousel-section luister-stories-section" aria-labelledby="@headingId">
            <h2 id="@headingId">@playlist.Title</h2>
            @if (hasDescription)
            {
                <p class="section-intro">@playlist.Description</p>
            }

            <div class="stories-carousel-shell">
                <div class="carousel-controls" aria-label="@($"{playlist.Title} navigasie")">
                    <button type="button" class="carousel-nav-btn carousel-nav-btn-prev" aria-label="@($"Vorige stories in {playlist.Title}")"
                            @onclick="() => ScrollCarouselAsync(PlaylistCarouselRefs[carouselIndex], -1)">
                        <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
                    </button>
                    <button type="button" class="carousel-nav-btn carousel-nav-btn-next" aria-label="@($"Volgende stories in {playlist.Title}")"
                            @onclick="() => ScrollCarouselAsync(PlaylistCarouselRefs[carouselIndex], 1)">
                        <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
                    </button>
                </div>

                <div class="stories-carousel" role="list" aria-label="@playlist.Title" @ref="PlaylistCarouselRefs[carouselIndex]">
                    @foreach (var story in playlist.Stories)
                    {
                        <article class="story-carousel-item" role="listitem">
                            <a class="story-carousel-link"
                               href="@GetStoryHref(story.Slug)"
                               data-enhance-nav="false"
                               aria-label="Luister na @story.Title">
                                <span class="story-carousel-cover">
                                    <img class="story-carousel-image"
                                         src="@story.ThumbnailPath"
                                         srcset="@($"{story.ThumbnailPath} 640w, {story.ImagePath} 1024w")"
                                         sizes="(max-width: 620px) 68vw, (max-width: 980px) 42vw, 320px"
                                         alt="Voorblad van @story.Title" width="640" height="485" loading="lazy" decoding="async" />
                                    <span class="story-cover-play" aria-hidden="true">
                                        <i class="story-cover-play-icon fa-solid fa-play" aria-hidden="true"></i>
                                    </span>
                                </span>
                                <h3>@story.Title</h3>
                            </a>
                        </article>
                    }
                </div>
            </div>
        </section>
    }
}
