@page "/luister"
@using System.Text.Json
@using Microsoft.AspNetCore.Components
@inject NavigationManager NavigationManager

<PageTitle>Schink Stories | Luister</PageTitle>
<HeadContent>
    <link rel="canonical" href="@LuisterCanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Schink Stories | Luister" />
    <meta property="og:description" content="Luister na ons nuutste stories op Schink Stories." />
    <meta property="og:url" content="@LuisterCanonicalUrl" />
    <meta property="og:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:secure_url" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content="Schink Stories logo" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Schink Stories | Luister" />
    <meta name="twitter:description" content="Luister na ons nuutste stories op Schink Stories." />
    <meta name="twitter:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta name="twitter:image:alt" content="Schink Stories logo" />
    <script type="application/ld+json">@LuisterJsonLd</script>
</HeadContent>

<section class="gratis-hero">
    <div class="gratis-hero-copy">
        <h1>Alle beskikbare stories vir jou gesin</h1>
        <p>
            Kies enige storie hieronder. Tik om dit oop te maak en
            direk te luister.
        </p>
    </div>
    <img class="gratis-banner" src="/branding/Schink_Stories_Kom_Luister_Saam.webp"
         alt="Luister stories banner" loading="eager" fetchpriority="high" decoding="async" />
</section>

@code {
    private string LuisterCanonicalUrl => NavigationManager.ToAbsoluteUri("/luister").ToString();

    private MarkupString LuisterJsonLd => new(JsonSerializer.Serialize(new
    {
        @context = "https://schema.org",
        @type = "CollectionPage",
        name = "Schink Stories | Luister",
        description = "Luister na ons nuutste stories op Schink Stories.",
        url = LuisterCanonicalUrl,
        inLanguage = "af-ZA",
        isPartOf = new
        {
            @type = "WebSite",
            name = "Schink Stories",
            url = NavigationManager.ToAbsoluteUri("/").ToString()
        },
        primaryImageOfPage = NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()
    }));
}

<section>
    <div class="gratis-grid">
        @foreach (var story in StoryCatalog.LuisterStories)
        {
            <article class="gratis-card">
                <a class="gratis-cover-link" href="@($"/luister/{story.Slug}")" aria-label="Luister na @story.Title">
                    <img src="@story.ThumbnailPath"
                         srcset="@($"{story.ThumbnailPath} 640w, {story.ImagePath} 1024w")"
                         sizes="(max-width: 980px) 100vw, 50vw"
                         alt="Voorblad van @story.Title" width="640" height="485" loading="lazy" decoding="async" />
                    <span class="gratis-cover-play" aria-hidden="true">
                        <span class="gratis-cover-play-icon">&#9654;</span>
                    </span>
                </a>
                <div class="gratis-card-body">
                    <h2>@story.Title</h2>
                    <p>@story.Description</p>
                    <a class="play-btn" href="@($"/luister/{story.Slug}")">Luister na hierdie storie</a>
                </div>
            </article>
        }
    </div>
</section>
