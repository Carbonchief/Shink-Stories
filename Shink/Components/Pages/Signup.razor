@page "/teken-op"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.JSInterop
@using Shink.Components.Content
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISubscriptionLedgerService SubscriptionLedgerService

<PageTitle>Schink Stories | Teken op</PageTitle>
<HeadContent>
    <link href="/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <meta name="description" content="Skep jou Schink Stories rekening en begin met veilige Afrikaanse storietyd." />
    <meta name="robots" content="noindex, follow, noarchive, nosnippet" />
    <link rel="canonical" href="@NavigationManager.ToAbsoluteUri("/teken-op").ToString()" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Schink Stories | Teken op" />
    <meta property="og:description" content="Skep jou Schink Stories rekening en begin met veilige Afrikaanse storietyd." />
    <meta property="og:url" content="@NavigationManager.ToAbsoluteUri("/teken-op").ToString()" />
    <meta property="og:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:secure_url" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content="Schink Stories logo" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Schink Stories | Teken op" />
    <meta name="twitter:description" content="Skep jou Schink Stories rekening en begin met veilige Afrikaanse storietyd." />
    <meta name="twitter:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta name="twitter:image:alt" content="Schink Stories logo" />
</HeadContent>

<section class="signup-shell">
    <header class="signup-page-header text-center">
        <img class="signup-logo" src="/branding/schink_stories_logo_turqoise.png" alt="Schink Stories" />
        <h1>Skep jou rekening</h1>
        <p class="d-inline" >Voltooi jou besonderhede en begin met veilige Afrikaanse storietyd.</p>
    </header>

    <EditForm FormName="signup-form" class="signup-checkout-form" EditContext="FormEditContext" OnSubmit="HandleSignUpSubmitAsync" aria-busy="@IsSubmitting">
        <DataAnnotationsValidator />

    <div class="signup-checkout-grid">
        <article class="signup-card signup-card-form">
            <header class="signup-card-header">
                <img class="signup-mobile-card-logo" src="/branding/schink_stories_logo_turqoise.png" alt="Schink Stories" />
                <h2>Rekeninginligting</h2>
                <p class="signup-required-note"><span class="required-indicator" aria-hidden="true">*</span> dui verpligte velde aan.</p>
            </header>

            <div class="signup-form">
                <div class="signup-grid">
                    <div class="signup-field">
                        <label class="form-label" for="signup-first-name">Voornaam <span class="required-indicator" aria-hidden="true">*</span></label>
                        <InputText id="signup-first-name" class="form-control" autocomplete="given-name" placeholder="Voornaam *" aria-label="Voornaam" @bind-Value="SignUpForm.FirstName" />
                        <ValidationMessage class="invalid-feedback d-block" For="@(() => SignUpForm.FirstName)" />
                    </div>

                    <div class="signup-field">
                        <label class="form-label" for="signup-last-name">Van</label>
                        <InputText id="signup-last-name" class="form-control" autocomplete="family-name" placeholder="Van" aria-label="Van" @bind-Value="SignUpForm.LastName" />
                        <ValidationMessage class="invalid-feedback d-block" For="@(() => SignUpForm.LastName)" />
                    </div>

                    <div class="signup-field">
                        <label class="form-label" for="signup-display-name">Wys my naam as</label>
                        <InputText id="signup-display-name" class="form-control" autocomplete="nickname" placeholder="Wys my naam as" aria-label="Wys my naam as" @bind-Value="SignUpForm.DisplayName" />
                        <ValidationMessage class="invalid-feedback d-block" For="@(() => SignUpForm.DisplayName)" />
                    </div>

                    <div class="signup-field">
                        <label class="form-label" for="signup-email">E-pos <span class="required-indicator" aria-hidden="true">*</span></label>
                        <InputText id="signup-email" class="form-control" type="email" autocomplete="email" placeholder="E-pos *" aria-label="E-pos" @bind-Value="SignUpForm.Email" />
                        <ValidationMessage class="invalid-feedback d-block" For="@(() => SignUpForm.Email)" />
                    </div>

                    <div class="signup-field signup-field-full">
                        <label class="form-label" for="signup-mobile-number">Selfoonnommer</label>
                        <InputText id="signup-mobile-number" class="form-control" autocomplete="tel" placeholder="Selfoonnommer" aria-label="Selfoonnommer" @bind-Value="SignUpForm.MobileNumber" />
                        <ValidationMessage class="invalid-feedback d-block" For="@(() => SignUpForm.MobileNumber)" />
                    </div>
                </div>

                <div class="signup-grid signup-grid-security">
                    <div class="signup-field">
                        <label class="form-label" for="signup-password">Wagwoord <span class="required-indicator" aria-hidden="true">*</span></label>
                        <InputText id="signup-password" class="form-control" type="password" autocomplete="new-password" placeholder="Wagwoord *" aria-label="Wagwoord" @bind-Value="SignUpForm.Password" />
                        <ValidationMessage class="invalid-feedback d-block" For="@(() => SignUpForm.Password)" />
                    </div>

                    <div class="signup-field">
                        <label class="form-label" for="signup-password-confirm">Bevestig wagwoord <span class="required-indicator" aria-hidden="true">*</span></label>
                        <InputText id="signup-password-confirm" class="form-control" type="password" autocomplete="new-password" placeholder="Bevestig wagwoord *" aria-label="Bevestig wagwoord" @bind-Value="SignUpForm.ConfirmPassword" />
                        <ValidationMessage class="invalid-feedback d-block" For="@(() => SignUpForm.ConfirmPassword)" />
                    </div>
                </div>

                <div class="signup-actions">
                    <p class="signup-selected-option" aria-live="polite">
                        Gekose opsie:
                        <strong>@GetSelectedOptionLabel()</strong>
                    </p>
                    <button type="submit" class="signup-submit" disabled="@IsSubmitting">
                        @(IsSubmitting ? "Besig..." : "Skep rekening")
                    </button>
                    <a class="signup-link" href="@SignInHref">Ek het reeds 'n rekening</a>
                </div>

                @if (!string.IsNullOrWhiteSpace(StatusMessage))
                {
                    <p class="@($"signup-status {(SignUpSucceeded ? "signup-status-success" : "signup-status-error")}")"
                       role="@(SignUpSucceeded ? "status" : "alert")"
                       aria-live="polite">
                        @StatusMessage
                    </p>
                }
            </div>
        </article>

        <aside class="signup-card signup-card-membership" aria-label="Jou lidmaatskap">
            <h2>Jou lidmaatskap</h2>

            <div class="membership-plan-selector" role="list" aria-label="Kies jou plan">
                @foreach (var plan in AvailablePlans)
                {
                    <button type="button"
                            class="@GetMembershipPlanOptionClass(plan)"
                            @onclick="() => SelectPlan(plan)"
                            aria-pressed="@IsSelectedPlan(plan)">
                        <span class="membership-plan-option-checkbox" aria-hidden="true"></span>
                        <span class="membership-plan-option-content">
                            <span class="membership-plan-option-badge">@GetPlanBadge(plan)</span>
                            <span class="membership-plan-option-name">@plan.Name</span>
                            <span class="membership-plan-option-price">
                                <strong>@FormatPlanAmount(plan)</strong>
                                <span>@GetPlanBillingLabel(plan)</span>
                            </span>
                            @if (IsYearlyAllStoriesPlan(plan))
                            {
                                <span class="membership-save-badge membership-save-badge-inline">Save 2 months</span>
                            }
                        </span>
                    </button>
                }
            </div>

            <article class="@GetGratisMembershipClass()">
                <p class="membership-plan-label">GRATIS</p>
                <h3>Gratis stories is onmiddellik aktief</h3>
                <p>As betaling misluk of gekanselleer word, behou jy steeds toegang tot die gratis stories.</p>
            </article>

            @if (SelectedPlan is not null)
            {
                <p class="membership-total">Totaal om vandag te betaal: <strong>@FormatPlanAmount(SelectedPlan)</strong></p>
            }

            <div class="signup-field signup-field-full signup-discount-code-field">
                <label class="form-label" for="signup-discount-code">Kode of voucher</label>
                <InputText id="signup-discount-code"
                           class="form-control"
                           autocomplete="off"
                           placeholder="Voer jou kode in"
                           aria-label="Kode of voucher"
                           @bind-Value="SignUpForm.DiscountCode" />
                <ValidationMessage class="invalid-feedback d-block" For="@(() => SignUpForm.DiscountCode)" />
                <p class="signup-discount-code-help">
                    As jou kode geldig is, slaan ons PayStack vir nou oor en aktiveer jou toegang direk.
                </p>
            </div>

        </aside>
    </div>
    </EditForm>
</section>

@if (ShowAccountCreatedPopup)
{
    <div class="signup-created-popup-backdrop" role="presentation" @onclick="CloseAccountCreatedPopup">
        <section class="signup-created-popup-card"
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="signup-created-popup-title"
                 @onclick:stopPropagation="true">
            <button type="button"
                    class="signup-created-popup-close"
                    @onclick="CloseAccountCreatedPopup"
                    aria-label="Maak toe">
                <i class="fa-solid fa-xmark" aria-hidden="true"></i>
            </button>

            <img class="signup-created-popup-image"
                 src="/branding/Whatsapp_Eendjie.png"
                 alt="Eendjie"
                 width="220"
                 height="220"
                 loading="lazy"
                 decoding="async" />

            <h2 id="signup-created-popup-title">
                Jou rekening is geskep.
            </h2>

            <p>
                Bevestig asseblief jou e-posadres en teken daarna in.
            </p>

            <div class="signup-created-popup-actions">
                <a class="signup-created-popup-button signup-created-popup-button-primary"
                   href="@SignInHref">
                    Teken in
                </a>
            </div>
        </section>
    </div>
}

@code {
    private const string AccountCreatedConfirmationMessage = "Jou rekening is geskep. Bevestig asseblief jou e-posadres en teken daarna in.";
    private SignUpFormModel SignUpForm { get; set; } = new();
    private EditContext FormEditContext { get; set; } = default!;
    private IJSObjectReference? _authModule;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "plan")]
    public string? Plan { get; set; }

    private bool IsSubmitting { get; set; }
    private bool SignUpSucceeded { get; set; }
    private bool ShowAccountCreatedPopup { get; set; }
    private string? StatusMessage { get; set; }
    private PaymentPlan? SelectedPlan { get; set; }
    private string SignInHref => BuildSignInHref(GetSafeReturnUrl(ReturnUrl), GetSelectedPlanCheckoutPath());
    private IReadOnlyList<PaymentPlan> AvailablePlans => PaymentPlanCatalog.All;

    protected override void OnInitialized()
    {
        ResetForm();
    }

    protected override async Task OnParametersSetAsync()
    {
        SelectedPlan = ResolveSelectedPlan();

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            await RedirectToTargetAsync(await GetRedirectTargetForAuthenticatedUserAsync(authState));
        }
    }

    private async Task HandleSignUpSubmitAsync(EditContext editContext)
    {
        if (IsSubmitting)
        {
            return;
        }

        await SyncSignUpInputsFromDomAsync();

        if (!editContext.Validate())
        {
            return;
        }

        IsSubmitting = true;
        SignUpSucceeded = false;
        ShowAccountCreatedPopup = false;
        StatusMessage = null;
        await ShowSubmittingStateAsync();

        try
        {
            var authModule = await EnsureAuthModuleAsync();
            var payload = new SignUpApiPayload(
                FirstName: SignUpForm.FirstName.Trim(),
                LastName: SignUpForm.LastName.Trim(),
                DisplayName: SignUpForm.DisplayName.Trim(),
                Email: SignUpForm.Email.Trim(),
                MobileNumber: SignUpForm.MobileNumber.Trim(),
                Password: SignUpForm.Password,
                SelectedTierCode: SelectedPlan?.TierCode,
                DiscountCode: SignUpForm.DiscountCode.Trim());

            var response = await authModule.InvokeAsync<AuthBrowserResponse>("postAuthJson", "/api/auth/signup", payload);
            if (response.Ok)
            {
                SignUpSucceeded = true;
                StatusMessage = response.Message ?? "Welkom! Jou rekening is geskep en jy is nou ingeteken.";
                ResetForm();
                await RedirectToTargetAsync(GetRedirectTarget(response.RedirectPath, response.CodeApplied));
                return;
            }

            SignUpSucceeded = false;
            ShowAccountCreatedPopup = string.Equals(response.Message, AccountCreatedConfirmationMessage, StringComparison.Ordinal);
            StatusMessage = response.Message ?? "Kon nie nou registreer nie. Probeer asseblief weer.";
        }
        catch
        {
            SignUpSucceeded = false;
            StatusMessage = "Kon nie nou registreer nie. Probeer asseblief weer.";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task ShowSubmittingStateAsync()
    {
        StateHasChanged();
        await Task.Yield();
    }

    private async Task SyncSignUpInputsFromDomAsync()
    {
        try
        {
            var authModule = await EnsureAuthModuleAsync();
            var values = await authModule.InvokeAsync<Dictionary<string, string>>(
                "readInputValues",
                new[]
                {
                    "signup-first-name",
                    "signup-last-name",
                    "signup-display-name",
                    "signup-email",
                    "signup-mobile-number",
                    "signup-password",
                    "signup-password-confirm",
                    "signup-discount-code"
                });

            if (values.TryGetValue("signup-first-name", out var firstNameValue))
            {
                SignUpForm.FirstName = firstNameValue?.Trim() ?? string.Empty;
            }

            if (values.TryGetValue("signup-last-name", out var lastNameValue))
            {
                SignUpForm.LastName = lastNameValue?.Trim() ?? string.Empty;
            }

            if (values.TryGetValue("signup-display-name", out var displayNameValue))
            {
                SignUpForm.DisplayName = displayNameValue?.Trim() ?? string.Empty;
            }

            if (values.TryGetValue("signup-email", out var emailValue))
            {
                SignUpForm.Email = emailValue?.Trim() ?? string.Empty;
            }

            if (values.TryGetValue("signup-mobile-number", out var mobileValue))
            {
                SignUpForm.MobileNumber = mobileValue?.Trim() ?? string.Empty;
            }

            if (values.TryGetValue("signup-password", out var passwordValue))
            {
                SignUpForm.Password = passwordValue ?? string.Empty;
            }

            if (values.TryGetValue("signup-password-confirm", out var confirmPasswordValue))
            {
                SignUpForm.ConfirmPassword = confirmPasswordValue ?? string.Empty;
            }

            if (values.TryGetValue("signup-discount-code", out var discountCodeValue))
            {
                SignUpForm.DiscountCode = discountCodeValue?.Trim() ?? string.Empty;
            }
        }
        catch
        {
            // Keep existing bound values if DOM reads fail.
        }
    }

    private void ResetForm()
    {
        SignUpForm = new SignUpFormModel();
        FormEditContext = new EditContext(SignUpForm);
    }

    private void CloseAccountCreatedPopup()
    {
        ShowAccountCreatedPopup = false;
    }

    private void SelectPlan(PaymentPlan plan)
    {
        if (IsSelectedPlan(plan))
        {
            SelectedPlan = null;
            return;
        }

        SelectedPlan = plan;
    }

    private Task<string> GetRedirectTargetForAuthenticatedUserAsync(AuthenticationState authState)
    {
        var safeReturnUrl = GetSafeNonCheckoutReturnUrl();
        if (safeReturnUrl is not null)
        {
            return Task.FromResult(safeReturnUrl);
        }

        var selectedPlanCheckoutPath = GetSelectedPlanCheckoutPath();
        if (selectedPlanCheckoutPath is not null)
        {
            return Task.FromResult(selectedPlanCheckoutPath);
        }

        return Task.FromResult("/luister");
    }

    private string GetRedirectTarget(string? apiRedirectPath = null, bool codeApplied = false) =>
        (codeApplied ? GetSafePostAuthPath(apiRedirectPath) : null)
        ?? GetSelectedPlanCheckoutPath()
        ?? GetSafeNonCheckoutReturnUrl()
        ?? GetSafePostAuthPath(apiRedirectPath)
        ?? "/luister";

    private async Task RedirectToTargetAsync(string target)
    {
        var safeTarget = string.IsNullOrWhiteSpace(target) ? "/luister" : target;

        try
        {
            var authModule = await EnsureAuthModuleAsync();
            await authModule.InvokeVoidAsync("redirectTo", safeTarget);
        }
        catch
        {
            NavigationManager.NavigateTo(safeTarget, forceLoad: true);
        }
    }

    private PaymentPlan? ResolveSelectedPlan()
    {
        var planFromQuery = PaymentPlanCatalog.FindBySlug(NormalizePlanSlug(Plan));
        if (planFromQuery is not null)
        {
            return planFromQuery;
        }

        var safeReturnUrl = GetSafeReturnUrl(ReturnUrl);
        var extractedPlanSlug = TryExtractPlanSlugFromReturnUrl(safeReturnUrl);
        return PaymentPlanCatalog.FindBySlug(extractedPlanSlug);
    }

    private string? GetSelectedPlanCheckoutPath()
    {
        if (SelectedPlan is null)
        {
            return null;
        }

        var checkoutPath = $"/betaal/{Uri.EscapeDataString(SelectedPlan.Slug)}";
        var requestedReturnPath = ResolveRequestedReturnPath();
        return string.IsNullOrWhiteSpace(requestedReturnPath)
            ? checkoutPath
            : QueryHelpers.AddQueryString(checkoutPath, "returnUrl", requestedReturnPath);
    }

    private async Task<IJSObjectReference> EnsureAuthModuleAsync()
    {
        if (_authModule is not null)
        {
            return _authModule;
        }

        _authModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/auth-browser.js");
        return _authModule;
    }

    private static string? GetSafeReturnUrl(string? returnUrl)
    {
        var normalizedReturnUrl = NormalizeReturnUrl(returnUrl);
        if (string.IsNullOrWhiteSpace(normalizedReturnUrl))
        {
            return null;
        }

        if (!normalizedReturnUrl.StartsWith("/", StringComparison.Ordinal) ||
            normalizedReturnUrl.StartsWith("//", StringComparison.Ordinal) ||
            normalizedReturnUrl.StartsWith("/teken-in", StringComparison.OrdinalIgnoreCase) ||
            normalizedReturnUrl.StartsWith("/teken-op", StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        return normalizedReturnUrl;
    }

    private static string? GetSafePostAuthPath(string? path)
    {
        var normalizedPath = NormalizeReturnUrl(path);
        if (string.IsNullOrWhiteSpace(normalizedPath))
        {
            return null;
        }

        if (!normalizedPath.StartsWith("/", StringComparison.Ordinal) ||
            normalizedPath.StartsWith("//", StringComparison.Ordinal) ||
            normalizedPath.StartsWith("/teken-in", StringComparison.OrdinalIgnoreCase) ||
            normalizedPath.StartsWith("/teken-op", StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        return normalizedPath;
    }

    private string? GetSafeNonCheckoutReturnUrl()
    {
        var safeReturnUrl = GetSafeReturnUrl(ReturnUrl);
        if (string.IsNullOrWhiteSpace(safeReturnUrl))
        {
            return null;
        }

        return safeReturnUrl.StartsWith("/betaal/", StringComparison.OrdinalIgnoreCase)
            ? null
            : safeReturnUrl;
    }

    private static string? NormalizeReturnUrl(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var candidate = value.Trim();
        for (var index = 0; index < 2; index++)
        {
            if (candidate.StartsWith("/", StringComparison.Ordinal))
            {
                break;
            }

            if (!candidate.Contains('%', StringComparison.Ordinal))
            {
                break;
            }

            try
            {
                candidate = Uri.UnescapeDataString(candidate);
            }
            catch
            {
                break;
            }
        }

        return candidate;
    }

    private string? ResolveRequestedReturnPath()
    {
        var safeReturnUrl = GetSafeReturnUrl(ReturnUrl);
        if (string.IsNullOrWhiteSpace(safeReturnUrl))
        {
            return null;
        }

        if (TryExtractNestedReturnUrl(safeReturnUrl, out var nestedReturnUrl))
        {
            return nestedReturnUrl;
        }

        return safeReturnUrl.StartsWith("/betaal/", StringComparison.OrdinalIgnoreCase)
            ? null
            : safeReturnUrl;
    }

    private static bool TryExtractNestedReturnUrl(string safeReturnUrl, out string? nestedReturnUrl)
    {
        nestedReturnUrl = null;
        if (string.IsNullOrWhiteSpace(safeReturnUrl) ||
            !safeReturnUrl.StartsWith("/betaal/", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        var queryIndex = safeReturnUrl.IndexOf('?');
        if (queryIndex < 0 || queryIndex == safeReturnUrl.Length - 1)
        {
            return false;
        }

        var queryValues = QueryHelpers.ParseQuery(safeReturnUrl[(queryIndex + 1)..]);
        if (!queryValues.TryGetValue("returnUrl", out var returnUrlValues))
        {
            return false;
        }

        nestedReturnUrl = GetSafeReturnUrl(returnUrlValues.LastOrDefault());
        return !string.IsNullOrWhiteSpace(nestedReturnUrl);
    }

    private static string BuildSignInHref(string? safeReturnUrl, string? selectedPlanCheckoutPath)
    {
        var queryValues = new List<string>();
        var signInReturnUrl = ResolveSignInReturnUrl(safeReturnUrl, selectedPlanCheckoutPath);
        if (!string.IsNullOrWhiteSpace(signInReturnUrl))
        {
            queryValues.Add($"returnUrl={Uri.EscapeDataString(signInReturnUrl)}");
        }

        return queryValues.Count == 0
            ? "/teken-in"
            : $"/teken-in?{string.Join("&", queryValues)}";
    }

    private static string? ResolveSignInReturnUrl(string? safeReturnUrl, string? selectedPlanCheckoutPath)
    {
        if (!string.IsNullOrWhiteSpace(selectedPlanCheckoutPath))
        {
            return selectedPlanCheckoutPath;
        }

        if (string.IsNullOrWhiteSpace(safeReturnUrl))
        {
            return null;
        }

        if (safeReturnUrl.StartsWith("/opsies", StringComparison.OrdinalIgnoreCase) ||
            safeReturnUrl.StartsWith("/teken-op", StringComparison.OrdinalIgnoreCase) ||
            safeReturnUrl.StartsWith("/teken-in", StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        return safeReturnUrl;
    }

    private static string? TryExtractPlanSlugFromReturnUrl(string? safeReturnUrl)
    {
        if (string.IsNullOrWhiteSpace(safeReturnUrl))
        {
            return null;
        }

        var pathOnly = safeReturnUrl;
        var queryIndex = pathOnly.IndexOf('?');
        if (queryIndex >= 0)
        {
            pathOnly = pathOnly[..queryIndex];
        }

        const string checkoutPrefix = "/betaal/";
        if (!pathOnly.StartsWith(checkoutPrefix, StringComparison.OrdinalIgnoreCase) ||
            pathOnly.Length <= checkoutPrefix.Length)
        {
            return null;
        }

        var slug = pathOnly[checkoutPrefix.Length..];
        var pathSeparatorIndex = slug.IndexOf('/');
        if (pathSeparatorIndex >= 0)
        {
            slug = slug[..pathSeparatorIndex];
        }

        try
        {
            slug = Uri.UnescapeDataString(slug);
        }
        catch
        {
            // Ignore decode failures and continue with the raw segment.
        }

        return NormalizePlanSlug(slug);
    }

    private static string? NormalizePlanSlug(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var trimmed = value.Trim();
        return trimmed.Length == 0 ? null : trimmed;
    }

    private static string GetPlanBadge(PaymentPlan plan) =>
        plan.BillingPeriodMonths switch
        {
            <= 1 => "MAANDELIKS",
            12 => "JAARLIKS",
            _ => "INTEKENING"
        };

    private static string GetPlanBillingLabel(PaymentPlan plan) =>
        plan.BillingPeriodMonths switch
        {
            <= 1 => "per maand",
            12 => "per jaar",
            _ => $"elke {plan.BillingPeriodMonths} maande"
        };

    private static bool IsYearlyAllStoriesPlan(PaymentPlan plan) =>
        string.Equals(plan.TierCode, "all_stories_yearly", StringComparison.OrdinalIgnoreCase);

    private static string FormatPlanAmount(PaymentPlan plan) =>
        $"R {plan.Amount:0.00}";

    private static string GetPlanDescription(PaymentPlan plan) =>
        plan.TierCode switch
        {
            "story_corner_monthly" => "Toegang tot stories uit die Storie Hoekie-reeks.",
            "all_stories_monthly" => "Volledige toegang tot alle Schink Stories en reekse.",
            "all_stories_yearly" => "Volledige jaarlikse toegang tot alle Schink Stories teen afslag.",
            _ => "Volledige toegang volgens jou gekose plan."
        };

    private string GetSelectedOptionLabel() =>
        SelectedPlan is null
            ? "Gratis stories"
            : $"{SelectedPlan.Name} ({FormatPlanAmount(SelectedPlan)} {GetPlanBillingLabel(SelectedPlan)})";

    private bool IsSelectedPlan(PaymentPlan plan) =>
        SelectedPlan is not null &&
        string.Equals(SelectedPlan.Slug, plan.Slug, StringComparison.OrdinalIgnoreCase);

    private string GetMembershipPlanOptionClass(PaymentPlan plan)
    {
        var classNames = new List<string> { "membership-plan-option" };
        if (IsSelectedPlan(plan))
        {
            classNames.Add("membership-plan-option-selected");
        }

        return string.Join(" ", classNames);
    }

    private string GetGratisMembershipClass()
    {
        var classNames = new List<string> { "membership-plan", "membership-plan-gratis" };
        if (SelectedPlan is null)
        {
            classNames.Add("membership-plan-gratis-selected");
        }

        return string.Join(" ", classNames);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_authModule is not null)
            {
                await _authModule.DisposeAsync();
            }
        }
        catch
        {
            // Ignore module disposal failures.
        }
    }

    private sealed record SignUpApiPayload(
        string FirstName,
        string LastName,
        string DisplayName,
        string Email,
        string MobileNumber,
        string Password,
        string? SelectedTierCode,
        string? DiscountCode);

    private sealed record AuthBrowserResponse(bool Ok, int Status, string? Message, string? RedirectPath, bool CodeApplied);

    private sealed class SignUpFormModel
    {
        [Required(ErrorMessage = "Vul asseblief jou voornaam in.")]
        [StringLength(80)]
        public string FirstName { get; set; } = string.Empty;

        [StringLength(80)]
        public string LastName { get; set; } = string.Empty;

        [StringLength(120)]
        public string DisplayName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Vul asseblief jou e-pos in.")]
        [EmailAddress(ErrorMessage = "Gebruik asseblief 'n geldige e-posadres.")]
        [StringLength(254)]
        public string Email { get; set; } = string.Empty;

        [RegularExpression(@"^\+?[0-9 ()-]{7,20}$", ErrorMessage = "Gebruik asseblief 'n geldige selfoonnommer.")]
        [StringLength(30)]
        public string MobileNumber { get; set; } = string.Empty;

        [Required(ErrorMessage = "Vul asseblief jou wagwoord in.")]
        [StringLength(200, MinimumLength = 6, ErrorMessage = "Jou wagwoord moet ten minste 6 karakters wees.")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Bevestig asseblief jou wagwoord.")]
        [Compare(nameof(Password), ErrorMessage = "Wagwoorde stem nie ooreen nie.")]
        public string ConfirmPassword { get; set; } = string.Empty;

        [StringLength(80, ErrorMessage = "Jou kode mag nie langer as 80 karakters wees nie.")]
        public string DiscountCode { get; set; } = string.Empty;
    }
}
