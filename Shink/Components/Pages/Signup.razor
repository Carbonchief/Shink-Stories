@page "/teken-op"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@using Shink.Components.Content
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISubscriptionLedgerService SubscriptionLedgerService

<PageTitle>Schink Stories | Teken op</PageTitle>
<HeadContent>
    <link href="/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
</HeadContent>

<section class="signup-shell">
    <header class="signup-page-header text-center">
        <img class="signup-logo" src="/branding/schink_stories_logo_turqoise.png" alt="Schink Stories" />
        <h1>Skep jou rekening</h1>
        <p class="d-inline" >Voltooi jou besonderhede en begin met veilige Afrikaanse storietyd.</p>
    </header>

    <div class="signup-checkout-grid">
        <article class="signup-card signup-card-form">
            <header class="signup-card-header">
                <h2>Rekeninginligting</h2>
                <p class="signup-required-note"><span class="required-indicator" aria-hidden="true">*</span> dui verpligte velde aan.</p>
            </header>

            <EditForm class="signup-form" EditContext="FormEditContext" OnValidSubmit="HandleSignUpAsync" aria-busy="@IsSubmitting">
                <DataAnnotationsValidator />

                <div class="signup-grid">
                    <div class="signup-field">
                        <label class="form-label" for="signup-first-name">Voornaam <span class="required-indicator" aria-hidden="true">*</span></label>
                        <InputText id="signup-first-name" class="form-control" autocomplete="given-name" @bind-Value="SignUpForm.FirstName" />
                        <ValidationMessage class="invalid-feedback d-block" For="@(() => SignUpForm.FirstName)" />
                    </div>

                    <div class="signup-field">
                        <label class="form-label" for="signup-last-name">Van</label>
                        <InputText id="signup-last-name" class="form-control" autocomplete="family-name" @bind-Value="SignUpForm.LastName" />
                        <ValidationMessage class="invalid-feedback d-block" For="@(() => SignUpForm.LastName)" />
                    </div>

                    <div class="signup-field">
                        <label class="form-label" for="signup-display-name">Wys my naam as</label>
                        <InputText id="signup-display-name" class="form-control" autocomplete="nickname" @bind-Value="SignUpForm.DisplayName" />
                        <ValidationMessage class="invalid-feedback d-block" For="@(() => SignUpForm.DisplayName)" />
                    </div>

                    <div class="signup-field">
                        <label class="form-label" for="signup-email">E-pos <span class="required-indicator" aria-hidden="true">*</span></label>
                        <InputText id="signup-email" class="form-control" type="email" autocomplete="email" @bind-Value="SignUpForm.Email" />
                        <ValidationMessage class="invalid-feedback d-block" For="@(() => SignUpForm.Email)" />
                    </div>

                    <div class="signup-field signup-field-full">
                        <label class="form-label" for="signup-mobile-number">Selfoonnommer</label>
                        <InputText id="signup-mobile-number" class="form-control" autocomplete="tel" @bind-Value="SignUpForm.MobileNumber" />
                        <ValidationMessage class="invalid-feedback d-block" For="@(() => SignUpForm.MobileNumber)" />
                    </div>
                </div>

                <div class="signup-grid signup-grid-security">
                    <div class="signup-field">
                        <label class="form-label" for="signup-password">Wagwoord <span class="required-indicator" aria-hidden="true">*</span></label>
                        <InputText id="signup-password" class="form-control" type="password" autocomplete="new-password" @bind-Value="SignUpForm.Password" />
                        <ValidationMessage class="invalid-feedback d-block" For="@(() => SignUpForm.Password)" />
                    </div>

                    <div class="signup-field">
                        <label class="form-label" for="signup-password-confirm">Bevestig wagwoord <span class="required-indicator" aria-hidden="true">*</span></label>
                        <InputText id="signup-password-confirm" class="form-control" type="password" autocomplete="new-password" @bind-Value="SignUpForm.ConfirmPassword" />
                        <ValidationMessage class="invalid-feedback d-block" For="@(() => SignUpForm.ConfirmPassword)" />
                    </div>
                </div>

                <div class="signup-actions">
                    <button type="submit" class="signup-submit" disabled="@IsSubmitting">
                        @(IsSubmitting ? "Besig..." : "Skep rekening")
                    </button>
                    <a class="signup-link" href="@SignInHref">Ek het reeds 'n rekening</a>
                </div>

                @if (!string.IsNullOrWhiteSpace(StatusMessage))
                {
                    <p class="@($"signup-status {(SignUpSucceeded ? "signup-status-success" : "signup-status-error")}")"
                       role="@(SignUpSucceeded ? "status" : "alert")"
                       aria-live="polite">
                        @StatusMessage
                    </p>
                }
            </EditForm>
        </article>

        <aside class="signup-card signup-card-membership" aria-label="Jou lidmaatskap">
            <h2>Jou lidmaatskap</h2>

            @if (SelectedPlan is not null)
            {
                <article class="membership-plan">
                    <p class="membership-plan-label">@GetPlanBadge(SelectedPlan)</p>
                    <h3>@SelectedPlan.Name</h3>
                    <p class="membership-plan-price">
                        <strong>@FormatPlanAmount(SelectedPlan)</strong>
                        <span>@GetPlanBillingLabel(SelectedPlan)</span>
                    </p>
                    @if (IsYearlyAllStoriesPlan(SelectedPlan))
                    {
                        <p class="membership-save-badge">Save 2 months</p>
                    }
                    <p class="membership-plan-copy">@GetPlanDescription(SelectedPlan)</p>
                </article>
            }
            else
            {
                <article class="membership-plan membership-plan-placeholder">
                    <h3>Nog geen plan gekies nie</h3>
                    <p>Kies 'n plan op die tuisblad of opsies-blad om na registrasie direk na betaling te gaan.</p>
                </article>
            }

            <article class="membership-plan membership-plan-gratis">
                <p class="membership-plan-label">GRATIS</p>
                <h3>Gratis stories is onmiddellik aktief</h3>
                <p>As betaling misluk of gekanselleer word, behou jy steeds toegang tot die gratis stories.</p>
            </article>

            @if (SelectedPlan is not null)
            {
                <p class="membership-total">Totaal om vandag te betaal: <strong>@FormatPlanAmount(SelectedPlan)</strong></p>
            }

        </aside>
    </div>
</section>

@code {
    private SignUpFormModel SignUpForm { get; set; } = new();
    private EditContext FormEditContext { get; set; } = default!;
    private IJSObjectReference? _authModule;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "plan")]
    public string? Plan { get; set; }

    private bool IsSubmitting { get; set; }
    private bool SignUpSucceeded { get; set; }
    private string? StatusMessage { get; set; }
    private PaymentPlan? SelectedPlan { get; set; }
    private string SignInHref => BuildSignInHref(GetSafeReturnUrl(ReturnUrl), SelectedPlan?.Slug);

    protected override void OnInitialized()
    {
        ResetForm();
    }

    protected override async Task OnParametersSetAsync()
    {
        SelectedPlan = ResolveSelectedPlan();

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            NavigationManager.NavigateTo(await GetRedirectTargetForAuthenticatedUserAsync(authState), forceLoad: true);
        }
    }

    private async Task HandleSignUpAsync()
    {
        if (IsSubmitting)
        {
            return;
        }

        if (!FormEditContext.Validate())
        {
            return;
        }

        IsSubmitting = true;
        SignUpSucceeded = false;
        StatusMessage = null;

        try
        {
            var authModule = await EnsureAuthModuleAsync();
            var payload = new SignUpApiPayload(
                FirstName: SignUpForm.FirstName.Trim(),
                LastName: SignUpForm.LastName.Trim(),
                DisplayName: SignUpForm.DisplayName.Trim(),
                Email: SignUpForm.Email.Trim(),
                MobileNumber: SignUpForm.MobileNumber.Trim(),
                Password: SignUpForm.Password);

            var response = await authModule.InvokeAsync<AuthBrowserResponse>("postAuthJson", "/api/auth/signup", payload);
            if (response.Ok)
            {
                SignUpSucceeded = true;
                StatusMessage = response.Message ?? "Welkom! Jou rekening is geskep en jy is nou ingeteken.";
                ResetForm();
                NavigationManager.NavigateTo(GetRedirectTarget(response.RedirectPath), forceLoad: true);
                return;
            }

            SignUpSucceeded = false;
            StatusMessage = response.Message ?? "Kon nie nou registreer nie. Probeer asseblief weer.";
        }
        catch
        {
            SignUpSucceeded = false;
            StatusMessage = "Kon nie nou registreer nie. Probeer asseblief weer.";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private void ResetForm()
    {
        SignUpForm = new SignUpFormModel();
        FormEditContext = new EditContext(SignUpForm);
    }

    private async Task<string> GetRedirectTargetForAuthenticatedUserAsync(AuthenticationState authState)
    {
        var safeReturnUrl = GetSafeReturnUrl(ReturnUrl);
        if (safeReturnUrl is not null)
        {
            return safeReturnUrl;
        }

        var selectedPlanCheckoutPath = GetSelectedPlanCheckoutPath();
        if (selectedPlanCheckoutPath is not null)
        {
            return selectedPlanCheckoutPath;
        }

        var user = authState.User;
        var email = user.FindFirst(ClaimTypes.Email)?.Value
                    ?? user.Identity?.Name;
        var hasPaidSubscription = await SubscriptionLedgerService.HasActivePaidSubscriptionAsync(email);
        return hasPaidSubscription ? "/luister" : "/gratis";
    }

    private string GetRedirectTarget(string? apiRedirectPath = null) =>
        GetSafeReturnUrl(ReturnUrl)
        ?? GetSelectedPlanCheckoutPath()
        ?? GetSafePostAuthPath(apiRedirectPath)
        ?? "/gratis";

    private PaymentPlan? ResolveSelectedPlan()
    {
        var planFromQuery = PaymentPlanCatalog.FindBySlug(NormalizePlanSlug(Plan));
        if (planFromQuery is not null)
        {
            return planFromQuery;
        }

        var safeReturnUrl = GetSafeReturnUrl(ReturnUrl);
        var extractedPlanSlug = TryExtractPlanSlugFromReturnUrl(safeReturnUrl);
        return PaymentPlanCatalog.FindBySlug(extractedPlanSlug);
    }

    private string? GetSelectedPlanCheckoutPath() =>
        SelectedPlan is null
            ? null
            : $"/betaal/{Uri.EscapeDataString(SelectedPlan.Slug)}";

    private async Task<IJSObjectReference> EnsureAuthModuleAsync()
    {
        if (_authModule is not null)
        {
            return _authModule;
        }

        _authModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/auth-browser.js");
        return _authModule;
    }

    private static string? GetSafeReturnUrl(string? returnUrl)
    {
        var normalizedReturnUrl = NormalizeReturnUrl(returnUrl);
        if (string.IsNullOrWhiteSpace(normalizedReturnUrl))
        {
            return null;
        }

        if (!normalizedReturnUrl.StartsWith("/", StringComparison.Ordinal) ||
            normalizedReturnUrl.StartsWith("//", StringComparison.Ordinal) ||
            normalizedReturnUrl.StartsWith("/teken-in", StringComparison.OrdinalIgnoreCase) ||
            normalizedReturnUrl.StartsWith("/teken-op", StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        return normalizedReturnUrl;
    }

    private static string? GetSafePostAuthPath(string? path)
    {
        var normalizedPath = NormalizeReturnUrl(path);
        if (string.IsNullOrWhiteSpace(normalizedPath))
        {
            return null;
        }

        if (!normalizedPath.StartsWith("/", StringComparison.Ordinal) ||
            normalizedPath.StartsWith("//", StringComparison.Ordinal) ||
            normalizedPath.StartsWith("/teken-in", StringComparison.OrdinalIgnoreCase) ||
            normalizedPath.StartsWith("/teken-op", StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        return normalizedPath;
    }

    private static string? NormalizeReturnUrl(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var candidate = value.Trim();
        for (var index = 0; index < 2; index++)
        {
            if (candidate.StartsWith("/", StringComparison.Ordinal))
            {
                break;
            }

            if (!candidate.Contains('%', StringComparison.Ordinal))
            {
                break;
            }

            try
            {
                candidate = Uri.UnescapeDataString(candidate);
            }
            catch
            {
                break;
            }
        }

        return candidate;
    }

    private static string BuildSignInHref(string? safeReturnUrl, string? selectedPlanSlug)
    {
        var queryValues = new List<string>();
        var signInReturnUrl = ResolveSignInReturnUrl(safeReturnUrl, selectedPlanSlug);
        if (!string.IsNullOrWhiteSpace(signInReturnUrl))
        {
            queryValues.Add($"returnUrl={Uri.EscapeDataString(signInReturnUrl)}");
        }

        return queryValues.Count == 0
            ? "/teken-in"
            : $"/teken-in?{string.Join("&", queryValues)}";
    }

    private static string? ResolveSignInReturnUrl(string? safeReturnUrl, string? selectedPlanSlug)
    {
        if (!string.IsNullOrWhiteSpace(selectedPlanSlug))
        {
            return $"/betaal/{Uri.EscapeDataString(selectedPlanSlug.Trim())}";
        }

        if (string.IsNullOrWhiteSpace(safeReturnUrl))
        {
            return null;
        }

        if (safeReturnUrl.StartsWith("/opsies", StringComparison.OrdinalIgnoreCase) ||
            safeReturnUrl.StartsWith("/teken-op", StringComparison.OrdinalIgnoreCase) ||
            safeReturnUrl.StartsWith("/teken-in", StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        return safeReturnUrl;
    }

    private static string? TryExtractPlanSlugFromReturnUrl(string? safeReturnUrl)
    {
        if (string.IsNullOrWhiteSpace(safeReturnUrl))
        {
            return null;
        }

        var pathOnly = safeReturnUrl;
        var queryIndex = pathOnly.IndexOf('?');
        if (queryIndex >= 0)
        {
            pathOnly = pathOnly[..queryIndex];
        }

        const string checkoutPrefix = "/betaal/";
        if (!pathOnly.StartsWith(checkoutPrefix, StringComparison.OrdinalIgnoreCase) ||
            pathOnly.Length <= checkoutPrefix.Length)
        {
            return null;
        }

        var slug = pathOnly[checkoutPrefix.Length..];
        var pathSeparatorIndex = slug.IndexOf('/');
        if (pathSeparatorIndex >= 0)
        {
            slug = slug[..pathSeparatorIndex];
        }

        try
        {
            slug = Uri.UnescapeDataString(slug);
        }
        catch
        {
            // Ignore decode failures and continue with the raw segment.
        }

        return NormalizePlanSlug(slug);
    }

    private static string? NormalizePlanSlug(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var trimmed = value.Trim();
        return trimmed.Length == 0 ? null : trimmed;
    }

    private static string GetPlanBadge(PaymentPlan plan) =>
        plan.BillingPeriodMonths switch
        {
            <= 1 => "MAANDELIKS",
            12 => "JAARLIKS",
            _ => "INTEKENING"
        };

    private static string GetPlanBillingLabel(PaymentPlan plan) =>
        plan.BillingPeriodMonths switch
        {
            <= 1 => "per maand",
            12 => "per jaar",
            _ => $"elke {plan.BillingPeriodMonths} maande"
        };

    private static bool IsYearlyAllStoriesPlan(PaymentPlan plan) =>
        string.Equals(plan.TierCode, "all_stories_yearly", StringComparison.OrdinalIgnoreCase);

    private static string FormatPlanAmount(PaymentPlan plan) =>
        $"R {plan.Amount:0.00}";

    private static string GetPlanDescription(PaymentPlan plan) =>
        plan.TierCode switch
        {
            "story_corner_monthly" => "Toegang tot stories uit die Storie Hoekie-reeks.",
            "all_stories_monthly" => "Volledige toegang tot alle Schink Stories en reekse.",
            "all_stories_yearly" => "Volledige jaarlikse toegang tot alle Schink Stories teen afslag.",
            _ => "Volledige toegang volgens jou gekose plan."
        };

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_authModule is not null)
            {
                await _authModule.DisposeAsync();
            }
        }
        catch
        {
            // Ignore module disposal failures.
        }
    }

    private sealed record SignUpApiPayload(
        string FirstName,
        string LastName,
        string DisplayName,
        string Email,
        string MobileNumber,
        string Password);

    private sealed record AuthBrowserResponse(bool Ok, int Status, string? Message, string? RedirectPath);

    private sealed class SignUpFormModel
    {
        [Required(ErrorMessage = "Vul asseblief jou voornaam in.")]
        [StringLength(80)]
        public string FirstName { get; set; } = string.Empty;

        [StringLength(80)]
        public string LastName { get; set; } = string.Empty;

        [StringLength(120)]
        public string DisplayName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Vul asseblief jou e-pos in.")]
        [EmailAddress(ErrorMessage = "Gebruik asseblief 'n geldige e-posadres.")]
        [StringLength(254)]
        public string Email { get; set; } = string.Empty;

        [RegularExpression(@"^\+?[0-9 ()-]{7,20}$", ErrorMessage = "Gebruik asseblief 'n geldige selfoonnommer.")]
        [StringLength(30)]
        public string MobileNumber { get; set; } = string.Empty;

        [Required(ErrorMessage = "Vul asseblief jou wagwoord in.")]
        [StringLength(200, MinimumLength = 6, ErrorMessage = "Jou wagwoord moet ten minste 6 karakters wees.")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Bevestig asseblief jou wagwoord.")]
        [Compare(nameof(Password), ErrorMessage = "Wagwoorde stem nie ooreen nie.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
