@page "/teken-in"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISubscriptionLedgerService SubscriptionLedgerService

<PageTitle>Schink Stories | Teken in</PageTitle>
<HeadContent>
    <link href="/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
</HeadContent>

<section class="auth-shell">
    <div class="auth-frame">
        <aside class="auth-aside" aria-label="Welkom inligting">            
            <img class="auth-logo" src="/branding/schink_stories_logo_turqoise.png" alt="Schink" />
            <p class="auth-kicker">Ledeportaal</p>
            <h1>Welkom terug</h1>
            <p class="auth-intro">
                Teken in om jou gunsteling stories te luister, of sluit nou aan en begin saam lees en luister.
            </p>
            <ul class="auth-points" aria-label="Voordele">
                <li>Veilige toegang tot jou profiel</li>
                <li>Stories en luister-opsies op een plek</li>
                <li>Vinnig op selfoon en rekenaar</li>
            </ul>
        </aside>

        <article class="auth-card">
            <p class="login-kicker">Teken In</p>
            <p class="login-intro">
                Gebruik jou e-pos en wagwoord om voort te gaan.
            </p>

            <EditForm class="login-form" EditContext="FormEditContext" OnValidSubmit="HandleSignInAsync" aria-busy="@IsSubmitting">
                <DataAnnotationsValidator />

                <div class="login-field">
                    <label class="form-label" for="signin-email">E-pos</label>
                    <InputText id="signin-email" class="form-control" type="email" autocomplete="username" @bind-Value="SignInForm.Email" />
                    <ValidationMessage class="invalid-feedback d-block" For="@(() => SignInForm.Email)" />
                </div>

                <div class="login-field">
                    <label class="form-label" for="signin-password">Wagwoord</label>
                    <InputText id="signin-password" class="form-control" type="password" autocomplete="current-password" @bind-Value="SignInForm.Password" />
                    <ValidationMessage class="invalid-feedback d-block" For="@(() => SignInForm.Password)" />
                </div>

                <div class="login-actions">
                    <button type="submit" class="login-submit" disabled="@IsSubmitting">
                        @(IsSubmitting ? "Besig..." : "Teken in")
                    </button>
                    <a class="login-submit login-submit-secondary" href="@SignUpHref">
                        Skep rekening
                    </a>
                </div>

                @if (!string.IsNullOrWhiteSpace(StatusMessage))
                {
                    <p class="@($"login-status {(SignInSucceeded ? "login-status-success" : "login-status-error")}")"
                       role="@(SignInSucceeded ? "status" : "alert")"
                       aria-live="polite">
                        @StatusMessage
                    </p>
                }
            </EditForm>

            <a class="login-link" href="/opsies">Sien ons planne</a>
        </article>
    </div>
</section>

@code {
    private SignInFormModel SignInForm { get; set; } = new();
    private EditContext FormEditContext { get; set; } = default!;
    private IJSObjectReference? _authModule;
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }
    private bool IsSubmitting { get; set; }
    private bool SignInSucceeded { get; set; }
    private string? StatusMessage { get; set; }
    private string SignUpHref =>
        GetSafeReturnUrlForSignUp(ReturnUrl) is { } safeReturnUrl
            ? $"/teken-op?returnUrl={Uri.EscapeDataString(safeReturnUrl)}"
            : "/teken-op";

    protected override void OnInitialized()
    {
        ResetForm();
    }

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            NavigationManager.NavigateTo(await GetRedirectTargetForAuthenticatedUserAsync(authState), forceLoad: true);
        }
    }

    private async Task HandleSignInAsync()
    {
        await SubmitAuthAsync("/api/auth/login", "Kon nie teken in nie. Probeer asseblief weer.");
    }

    private void ResetForm()
    {
        SignInForm = new SignInFormModel();
        FormEditContext = new EditContext(SignInForm);
    }

    private async Task SubmitAuthAsync(string endpointPath, string fallbackErrorMessage)
    {
        if (IsSubmitting)
        {
            return;
        }

        IsSubmitting = true;
        SignInSucceeded = false;
        StatusMessage = null;

        try
        {
            var authModule = await EnsureAuthModuleAsync();
            var payload = new AuthApiPayload(
                Email: SignInForm.Email.Trim(),
                Password: SignInForm.Password);

            var response = await authModule.InvokeAsync<AuthBrowserResponse>("postAuthJson", endpointPath, payload);
            var apiMessage = response.Message;

            if (response.Ok)
            {
                SignInSucceeded = true;
                StatusMessage = apiMessage ?? "Suksesvol ingeteken.";
                ResetForm();
                NavigationManager.NavigateTo(GetRedirectTarget(response.RedirectPath), forceLoad: true);
                return;
            }

            SignInSucceeded = false;
            StatusMessage = apiMessage ?? fallbackErrorMessage;
        }
        catch
        {
            SignInSucceeded = false;
            StatusMessage = fallbackErrorMessage;
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task<string> GetRedirectTargetForAuthenticatedUserAsync(AuthenticationState authState)
    {
        var safeReturnUrl = GetSafeReturnUrl(ReturnUrl);
        if (safeReturnUrl is not null)
        {
            return safeReturnUrl;
        }

        var user = authState.User;
        var email = user.FindFirst(ClaimTypes.Email)?.Value
                    ?? user.Identity?.Name;
        var hasPaidSubscription = await SubscriptionLedgerService.HasActivePaidSubscriptionAsync(email);
        return hasPaidSubscription ? "/luister" : "/gratis";
    }

    private string GetRedirectTarget(string? apiRedirectPath = null) =>
        GetSafeReturnUrl(ReturnUrl)
        ?? GetSafePostAuthPath(apiRedirectPath)
        ?? "/gratis";

    private async Task<IJSObjectReference> EnsureAuthModuleAsync()
    {
        if (_authModule is not null)
        {
            return _authModule;
        }

        _authModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/auth-browser.js");
        return _authModule;
    }

    private static string? GetSafeReturnUrl(string? returnUrl)
    {
        var normalizedReturnUrl = NormalizeReturnUrl(returnUrl);
        if (string.IsNullOrWhiteSpace(normalizedReturnUrl))
        {
            return null;
        }

        if (!normalizedReturnUrl.StartsWith("/", StringComparison.Ordinal) ||
            normalizedReturnUrl.StartsWith("//", StringComparison.Ordinal) ||
            IsAuthEntryPath(normalizedReturnUrl))
        {
            return null;
        }

        return normalizedReturnUrl;
    }

    private static string? GetSafeReturnUrlForSignUp(string? returnUrl)
    {
        var normalizedReturnUrl = GetSafeReturnUrl(returnUrl);
        if (string.IsNullOrWhiteSpace(normalizedReturnUrl))
        {
            return null;
        }

        return normalizedReturnUrl.StartsWith("/teken-op", StringComparison.OrdinalIgnoreCase)
            ? null
            : normalizedReturnUrl;
    }

    private static string? GetSafePostAuthPath(string? path)
    {
        var normalizedPath = NormalizeReturnUrl(path);
        if (string.IsNullOrWhiteSpace(normalizedPath))
        {
            return null;
        }

        if (!normalizedPath.StartsWith("/", StringComparison.Ordinal) ||
            normalizedPath.StartsWith("//", StringComparison.Ordinal) ||
            IsAuthEntryPath(normalizedPath))
        {
            return null;
        }

        return normalizedPath;
    }

    private static bool IsAuthEntryPath(string path) =>
        path.StartsWith("/teken-in", StringComparison.OrdinalIgnoreCase) ||
        path.StartsWith("/teken-op", StringComparison.OrdinalIgnoreCase);

    private static string? NormalizeReturnUrl(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var candidate = value.Trim();
        for (var index = 0; index < 2; index++)
        {
            if (candidate.StartsWith("/", StringComparison.Ordinal))
            {
                break;
            }

            if (!candidate.Contains('%', StringComparison.Ordinal))
            {
                break;
            }

            try
            {
                candidate = Uri.UnescapeDataString(candidate);
            }
            catch
            {
                break;
            }
        }

        return candidate;
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_authModule is not null)
            {
                await _authModule.DisposeAsync();
            }
        }
        catch
        {
            // Ignore module disposal failures.
        }
    }

    private sealed record AuthApiPayload(string Email, string Password);

    private sealed record AuthBrowserResponse(bool Ok, int Status, string? Message, string? RedirectPath);

    private sealed class SignInFormModel
    {
        [Required(ErrorMessage = "Vul asseblief jou e-pos in.")]
        [EmailAddress(ErrorMessage = "Gebruik asseblief 'n geldige e-posadres.")]
        [StringLength(254)]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Vul asseblief jou wagwoord in.")]
        [StringLength(200, MinimumLength = 6, ErrorMessage = "Jou wagwoord moet ten minste 6 karakters wees.")]
        public string Password { get; set; } = string.Empty;
    }
}
