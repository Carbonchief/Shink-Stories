@page "/teken-in"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISubscriptionLedgerService SubscriptionLedgerService

<PageTitle>Schink Stories | Teken in</PageTitle>
<HeadContent>
    <link href="/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <meta name="description" content="Teken in op Schink Stories om jou stories, speellyste en intekening te bestuur." />
    <meta name="robots" content="noindex, follow, noarchive, nosnippet" />
    <link rel="canonical" href="@NavigationManager.ToAbsoluteUri("/teken-in").ToString()" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Schink Stories | Teken in" />
    <meta property="og:description" content="Teken in op Schink Stories om jou stories, speellyste en intekening te bestuur." />
    <meta property="og:url" content="@NavigationManager.ToAbsoluteUri("/teken-in").ToString()" />
    <meta property="og:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:secure_url" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content="Schink Stories logo" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Schink Stories | Teken in" />
    <meta name="twitter:description" content="Teken in op Schink Stories om jou stories, speellyste en intekening te bestuur." />
    <meta name="twitter:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta name="twitter:image:alt" content="Schink Stories logo" />
</HeadContent>

<section class="auth-shell">
    <div class="auth-frame">
        <aside class="auth-aside" aria-label="Welkom inligting">            
            <img class="auth-logo" src="/branding/schink_stories_logo_turqoise.png" alt="Schink" />
            <p class="auth-kicker">Ledeportaal</p>
            <h1>Welkom terug</h1>
            <p class="auth-intro">
                Teken in om jou gunsteling stories te luister, of sluit nou aan en begin saam lees en luister.
            </p>
            <ul class="auth-points" aria-label="Voordele">
                <li>Veilige toegang tot jou profiel</li>
                <li>Stories en luister-opsies op een plek</li>
                <li>Vinnig op selfoon en rekenaar</li>
            </ul>
        </aside>

        <article class="auth-card">
            <p class="login-kicker">Teken In</p>
            <p class="login-intro">
                Gebruik jou e-pos en wagwoord om voort te gaan.
            </p>

            <EditForm FormName="login-form" class="login-form" EditContext="FormEditContext" OnSubmit="HandleSignInSubmitAsync" aria-busy="@IsSubmitting">
                <DataAnnotationsValidator />

                <div class="login-field">
                    <label class="form-label" for="signin-email">E-pos</label>
                    <InputText id="signin-email" class="form-control" type="email" autocomplete="username" @bind-Value="SignInForm.Email" />
                    <ValidationMessage class="invalid-feedback d-block" For="@(() => SignInForm.Email)" />
                </div>

                <div class="login-field">
                    <label class="form-label" for="signin-password">Wagwoord</label>
                    <InputText id="signin-password" class="form-control" type="password" autocomplete="current-password" @bind-Value="SignInForm.Password" />
                    <ValidationMessage class="invalid-feedback d-block" For="@(() => SignInForm.Password)" />
                </div>

                <div class="login-actions">
                    <button type="submit" class="login-submit" disabled="@IsSubmitting">
                        @(IsSubmitting ? "Besig..." : "Teken in")
                    </button>
                    <a class="login-submit login-submit-secondary" href="@SignUpHref">
                        Skep rekening
                    </a>
                </div>

                <a class="login-submit login-submit-google" href="@GoogleSignInHref" @ref="_googleSignInLink" aria-label="Teken in met Google">
                    <span class="google-brand-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="18" height="18" role="img">
                            <path fill="#4285F4" d="M23.49 12.27c0-.79-.07-1.55-.2-2.27H12v4.3h6.45a5.53 5.53 0 0 1-2.4 3.63v3h3.88c2.27-2.09 3.56-5.16 3.56-8.66Z" />
                            <path fill="#34A853" d="M12 24c3.24 0 5.96-1.07 7.95-2.9l-3.88-3c-1.07.72-2.44 1.15-4.07 1.15-3.12 0-5.76-2.1-6.7-4.94H1.3v3.09A12 12 0 0 0 12 24Z" />
                            <path fill="#FBBC05" d="M5.3 14.31A7.2 7.2 0 0 1 4.93 12c0-.8.13-1.57.37-2.31V6.6H1.3A12 12 0 0 0 0 12c0 1.93.46 3.75 1.3 5.4l4-3.09Z" />
                            <path fill="#EA4335" d="M12 4.76c1.76 0 3.34.61 4.59 1.8l3.44-3.44C17.95 1.17 15.23 0 12 0A12 12 0 0 0 1.3 6.6l4 3.09c.94-2.84 3.58-4.93 6.7-4.93Z" />
                        </svg>
                    </span>
                    <span>Teken in met Google</span>
                </a>

                @if (!string.IsNullOrWhiteSpace(StatusMessage))
                {
                    <p class="@($"login-status {(SignInSucceeded ? "login-status-success" : "login-status-error")}")"
                       role="@(SignInSucceeded ? "status" : "alert")"
                       aria-live="polite">
                        @StatusMessage
                    </p>
                }
            </EditForm>

            <a class="login-link" href="/opsies">Sien ons planne</a>
        </article>
    </div>
</section>

@code {
    private SignInFormModel SignInForm { get; set; } = new();
    private EditContext FormEditContext { get; set; } = default!;
    private IJSObjectReference? _authModule;
    private ElementReference _googleSignInLink;
    private string? _configuredGoogleSignInHref;
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery(Name = "oauthError")]
    public string? OAuthError { get; set; }
    private bool IsSubmitting { get; set; }
    private bool SignInSucceeded { get; set; }
    private string? StatusMessage { get; set; }
    private string SignUpHref =>
        GetSafeReturnUrlForSignUp(ReturnUrl) is { } safeReturnUrl
            ? $"/teken-op?returnUrl={Uri.EscapeDataString(safeReturnUrl)}"
            : "/teken-op";
    private string GoogleSignInHref =>
        GetSafeReturnUrl(ReturnUrl) is { } safeReturnUrl
            ? $"/api/auth/google/start?returnUrl={Uri.EscapeDataString(safeReturnUrl)}"
            : "/api/auth/google/start";

    protected override void OnInitialized()
    {
        ResetForm();
    }

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            await RedirectToTargetAsync(await GetRedirectTargetForAuthenticatedUserAsync(authState));
            return;
        }

        if (!IsSubmitting &&
            !string.IsNullOrWhiteSpace(OAuthError))
        {
            SignInSucceeded = false;
            StatusMessage = OAuthError.Trim();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var desiredGoogleSignInHref = GoogleSignInHref;
        if (string.Equals(_configuredGoogleSignInHref, desiredGoogleSignInHref, StringComparison.Ordinal))
        {
            return;
        }

        try
        {
            var authModule = await EnsureAuthModuleAsync();
            await authModule.InvokeVoidAsync("configureGoogleSignInLink", _googleSignInLink, desiredGoogleSignInHref);
            _configuredGoogleSignInHref = desiredGoogleSignInHref;
        }
        catch
        {
            // Keep the server-rendered PKCE link if JS bootstrapping fails.
        }
    }

    private async Task HandleSignInSubmitAsync(EditContext editContext)
    {
        await SyncSignInInputsFromDomAsync();

        if (!editContext.Validate())
        {
            return;
        }

        await SubmitAuthAsync("/api/auth/login", "Kon nie teken in nie. Probeer asseblief weer.");
    }

    private async Task SyncSignInInputsFromDomAsync()
    {
        try
        {
            var authModule = await EnsureAuthModuleAsync();
            var values = await authModule.InvokeAsync<Dictionary<string, string>>(
                "readInputValues",
                new[] { "signin-email", "signin-password" });

            if (values.TryGetValue("signin-email", out var emailValue))
            {
                SignInForm.Email = emailValue?.Trim() ?? string.Empty;
            }

            if (values.TryGetValue("signin-password", out var passwordValue))
            {
                SignInForm.Password = passwordValue ?? string.Empty;
            }
        }
        catch
        {
            // Keep existing bound values if DOM reads fail.
        }
    }

    private void ResetForm()
    {
        SignInForm = new SignInFormModel();
        FormEditContext = new EditContext(SignInForm);
    }

    private async Task SubmitAuthAsync(string endpointPath, string fallbackErrorMessage)
    {
        if (IsSubmitting)
        {
            return;
        }

        IsSubmitting = true;
        SignInSucceeded = false;
        StatusMessage = null;

        try
        {
            var authModule = await EnsureAuthModuleAsync();
            var payload = new AuthApiPayload(
                Email: SignInForm.Email.Trim(),
                Password: SignInForm.Password);

            var response = await authModule.InvokeAsync<AuthBrowserResponse>("postAuthJson", endpointPath, payload);
            var apiMessage = response.Message;

            if (response.Ok)
            {
                SignInSucceeded = true;
                StatusMessage = apiMessage ?? "Suksesvol ingeteken.";
                ResetForm();
                await RedirectToTargetAsync(GetRedirectTarget(response.RedirectPath));
                return;
            }

            SignInSucceeded = false;
            StatusMessage = apiMessage ?? fallbackErrorMessage;
        }
        catch
        {
            SignInSucceeded = false;
            StatusMessage = fallbackErrorMessage;
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task<string> GetRedirectTargetForAuthenticatedUserAsync(AuthenticationState authState)
    {
        var safeReturnUrl = GetSafeReturnUrl(ReturnUrl);
        if (safeReturnUrl is not null)
        {
            return safeReturnUrl;
        }

        var user = authState.User;
        var email = user.FindFirst(ClaimTypes.Email)?.Value
                    ?? user.Identity?.Name;
        var hasPaidSubscription = await SubscriptionLedgerService.HasActivePaidSubscriptionAsync(email);
        return hasPaidSubscription ? "/luister" : "/gratis";
    }

    private string GetRedirectTarget(string? apiRedirectPath = null) =>
        GetSafeReturnUrl(ReturnUrl)
        ?? GetSafePostAuthPath(apiRedirectPath)
        ?? "/gratis";

    private async Task RedirectToTargetAsync(string target)
    {
        var safeTarget = string.IsNullOrWhiteSpace(target) ? "/gratis" : target;

        try
        {
            var authModule = await EnsureAuthModuleAsync();
            await authModule.InvokeVoidAsync("redirectTo", safeTarget);
        }
        catch
        {
            NavigationManager.NavigateTo(safeTarget, forceLoad: true);
        }
    }

    private async Task<IJSObjectReference> EnsureAuthModuleAsync()
    {
        if (_authModule is not null)
        {
            return _authModule;
        }

        _authModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/auth-browser.js");
        return _authModule;
    }

    private static string? GetSafeReturnUrl(string? returnUrl)
    {
        var normalizedReturnUrl = NormalizeReturnUrl(returnUrl);
        if (string.IsNullOrWhiteSpace(normalizedReturnUrl))
        {
            return null;
        }

        if (!normalizedReturnUrl.StartsWith("/", StringComparison.Ordinal) ||
            normalizedReturnUrl.StartsWith("//", StringComparison.Ordinal) ||
            IsAuthEntryPath(normalizedReturnUrl))
        {
            return null;
        }

        return normalizedReturnUrl;
    }

    private static string? GetSafeReturnUrlForSignUp(string? returnUrl)
    {
        var normalizedReturnUrl = GetSafeReturnUrl(returnUrl);
        if (string.IsNullOrWhiteSpace(normalizedReturnUrl))
        {
            return null;
        }

        return normalizedReturnUrl.StartsWith("/teken-op", StringComparison.OrdinalIgnoreCase)
            ? null
            : normalizedReturnUrl;
    }

    private static string? GetSafePostAuthPath(string? path)
    {
        var normalizedPath = NormalizeReturnUrl(path);
        if (string.IsNullOrWhiteSpace(normalizedPath))
        {
            return null;
        }

        if (!normalizedPath.StartsWith("/", StringComparison.Ordinal) ||
            normalizedPath.StartsWith("//", StringComparison.Ordinal) ||
            IsAuthEntryPath(normalizedPath))
        {
            return null;
        }

        return normalizedPath;
    }

    private static bool IsAuthEntryPath(string path) =>
        path.StartsWith("/teken-in", StringComparison.OrdinalIgnoreCase) ||
        path.StartsWith("/teken-op", StringComparison.OrdinalIgnoreCase);

    private static string? NormalizeReturnUrl(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var candidate = value.Trim();
        for (var index = 0; index < 2; index++)
        {
            if (candidate.StartsWith("/", StringComparison.Ordinal))
            {
                break;
            }

            if (!candidate.Contains('%', StringComparison.Ordinal))
            {
                break;
            }

            try
            {
                candidate = Uri.UnescapeDataString(candidate);
            }
            catch
            {
                break;
            }
        }

        return candidate;
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_authModule is not null)
            {
                await _authModule.DisposeAsync();
            }
        }
        catch
        {
            // Ignore module disposal failures.
        }
    }

    private sealed record AuthApiPayload(string Email, string Password);

    private sealed record AuthBrowserResponse(bool Ok, int Status, string? Message, string? RedirectPath);

    private sealed class SignInFormModel
    {
        [Required(ErrorMessage = "Vul asseblief jou e-pos in.")]
        [EmailAddress(ErrorMessage = "Gebruik asseblief 'n geldige e-posadres.")]
        [StringLength(254)]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Vul asseblief jou wagwoord in.")]
        [StringLength(200, MinimumLength = 6, ErrorMessage = "Jou wagwoord moet ten minste 6 karakters wees.")]
        public string Password { get; set; } = string.Empty;
    }
}
