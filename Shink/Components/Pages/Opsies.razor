@page "/opsies"
@using System.Text.Json
@using System.Security.Claims
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.AspNetCore.Components.Authorization
@using Shink.Components.Content
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISubscriptionLedgerService SubscriptionLedgerService
@inject IStoryCatalogService StoryCatalogService

<PageTitle>Schink Stories | Opsies</PageTitle>
<HeadContent>
    <link rel="canonical" href="@OpsiesCanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Schink Stories | Opsies" />
    <meta property="og:description" content="Kies jou Schink Stories opsie en begin luister na veilige Afrikaanse stories." />
    <meta property="og:url" content="@OpsiesCanonicalUrl" />
    <meta property="og:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:secure_url" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content="Schink Stories logo" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Schink Stories | Opsies" />
    <meta name="twitter:description" content="Kies jou Schink Stories opsie en begin luister na veilige Afrikaanse stories." />
    <meta name="twitter:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta name="twitter:image:alt" content="Schink Stories logo" />
    <script type="application/ld+json">@OpsiesJsonLd</script>
</HeadContent>

<section class="opsies-page">
    @if (string.Equals(PaymentStatus, "sukses", StringComparison.OrdinalIgnoreCase))
    {
        <p class="opsies-payment-status opsies-payment-success" role="status" aria-live="polite">
            Dankie! Jou betaling is ontvang. Ons bevestig dit nou op ons kant.
        </p>
    }
    else if (string.Equals(PaymentStatus, "gekanselleer", StringComparison.OrdinalIgnoreCase))
    {
        <p class="opsies-payment-status opsies-payment-cancelled" role="status" aria-live="polite">
            Betaling is gekanselleer. Jy kan enige tyd weer probeer.
        </p>
    }
    else if (string.Equals(PaymentStatus, "reeds-ingeteken", StringComparison.OrdinalIgnoreCase))
    {
        <p class="opsies-payment-status opsies-payment-blocked" role="status" aria-live="polite">
            Jy het reeds 'n aktiewe intekening op hierdie plan. Kies asseblief 'n ander opsie.
        </p>
    }

    <section class="opsies-hero">
        <img src="/branding/Schink_Stories_Home_Banner_White.png"
             alt="Schink Stories Opsies" class="opsies-hero-image" loading="eager" decoding="async" />
        <div class="opsies-hero-copy">
            <p class="opsies-eyebrow">Kies 'n opsie</p>
            <h1>Kies jou plan en begin vandag luister!</h1>
            <p>
                Sluit vandag aan en gee vir jou kind toegang tot veilige, opbouende Afrikaanse stories.
                Geen advertensies of donker temas nie.
            </p>
        </div>
    </section>

    <section class="opsies-grid" aria-label="Plan opsies">
        @if (ShouldShowFreePlanOption)
        {
            <article class="opsie-card opsie-free">
                <div class="opsie-head">
                    <p class="opsie-badge">GRATIS</p>
                    <h2>Schink Stories Gratis</h2>
                    <p class="opsie-price">Gratis.</p>
                </div>
                <p class="opsie-detail">Kom geniet <strong>drie</strong> van ons gunsteling Afrikaanse oudiostories - perfek vir slaaptyd en saamluister.</p>
                <ul>
                    <li>Toegang tot 3 stories</li>
                    <li>Hulpbronne deur e-pos</li>
                </ul>
                @if (HasActivePaidSubscription)
                {
                    <p class="opsie-note">Jy is reeds ingeteken op 'n betaalde plan. Die gratis opsie is nie meer beskikbaar nie.</p>
                    <span class="opsie-btn opsie-btn-disabled" aria-disabled="true">Nie beskikbaar</span>
                }
                else
                {
                    <p class="opsie-note">Geen kaart nodig. Net storietyd, gratis.</p>
                    <a href="@BuildFreeJoinHref()" class="opsie-btn">Sluit aan</a>
                }
            </article>
        }

        @if (ShouldShowStoryCornerPlanOption)
        {
            <article class="opsie-card featured opsie-monthly">
                <div class="opsie-head">
                    <p class="opsie-badge">MAANDELIKS</p>
                    <h2>Storie Hoekie</h2>
                    <p class="opsie-price">R 55.00 <span>per maand.</span></p>
                </div>
                <p class="opsie-detail">Geniet toegang tot stories uit die gewilde Storie Hoekie reeks!</p>
                <a href='@BuildPlanSignUpHref("storie-hoekie-maandeliks", SafeStoryReturnPath)' class="opsie-btn">Sluit aan</a>
            </article>
        }

        @if (ShouldShowAllStoriesPlanOptions)
        {
            <article class="opsie-card opsie-all">
                <div class="opsie-head">
                    <p class="opsie-badge">MAANDELIKS</p>
                    <h2>Schink Stories</h2>
                    <p class="opsie-price">R 79.00 <span>per maand.</span></p>
                </div>
                <p class="opsie-detail"><strong>Geniet toegang tot ALLES!</strong></p>
                <ul>
                    <li>Onbeperkte toegang tot alle stories en reekse</li>
                    <li>Opbouende stories - veilig vir kinders</li>
                    <li>Geen advertensies</li>
                    <li>Nuwe stories elke maand</li>
                    <li>Toegang tot hulpbronne</li>
                </ul>
                <a href='@BuildPlanSignUpHref("schink-stories-maandeliks", SafeStoryReturnPath)' class="opsie-btn">Sluit aan</a>
            </article>

            <article class="opsie-card opsie-yearly">
                <div class="opsie-head">
                    <p class="opsie-badge">JAARLIKS</p>
                    <h2>Schink Stories JAAR</h2>
                    <p class="opsie-price">R 790.00 <span>nou.</span></p>
                </div>
                <p class="opsie-detail">
                    Dieselfde onbeperkte toegang tot al ons oudiostories - teen 'n afslagprys vir ouers wat vooruit dink.
                    Spaar meer, luister langer!
                </p>
                <a href='@BuildPlanSignUpHref("schink-stories-jaarliks", SafeStoryReturnPath)' class="opsie-btn">Sluit aan</a>
            </article>
        }
    </section>

    <section class="opsies-testimonials">
        <h2>Wat ouers se</h2>
        <div class="opsies-review-grid">
            <article class="opsies-review-card">
                <p class="opsies-review-stars" aria-hidden="true">
                    <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                </p>
                <blockquote>
                    Ek love al Schink se stories. Dit is in goeie taal en daar is 'n goeie lessie in elke storie.
                </blockquote>
                <p class="opsies-review-author">- Renske</p>
            </article>

            <article class="opsies-review-card">
                <p class="opsies-review-stars" aria-hidden="true">
                    <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                </p>
                <blockquote>
                    Ons drie oudste kids se gunsteling. Schink Stories maak bedtyd iets waarna hulle uitsien.
                </blockquote>
                <p class="opsies-review-author">- Sivonne</p>
            </article>

            <article class="opsies-review-card">
                <p class="opsies-review-stars" aria-hidden="true">
                    <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                </p>
                <blockquote>
                    Schink Stories help regtig kinders. Dit is opbouend en veilig vir die hele gesin.
                </blockquote>
                <p class="opsies-review-author">- Elmarette</p>
            </article>
        </div>
    </section>
</section>

@code {
    [SupplyParameterFromQuery(Name = "betaling")]
    public string? PaymentStatus { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private bool HasActivePaidSubscription { get; set; }
    private bool IsUserAuthenticated { get; set; }
    private string? SafeStoryReturnPath { get; set; }
    private StoryItem? RequestedStory { get; set; }
    private StoryAccessRequirement RequiredAccess { get; set; } = StoryAccessRequirement.Unknown;

    private bool ShouldShowFreePlanOption =>
        RequiredAccess is StoryAccessRequirement.Unknown or StoryAccessRequirement.Free;

    private bool ShouldShowStoryCornerPlanOption =>
        RequiredAccess is not StoryAccessRequirement.AllStoriesOnly;

    private bool ShouldShowAllStoriesPlanOptions => true;

    private string OpsiesCanonicalUrl => NavigationManager.ToAbsoluteUri("/opsies").ToString();

    private MarkupString OpsiesJsonLd => new(JsonSerializer.Serialize(new
    {
        @context = "https://schema.org",
        @type = "WebPage",
        name = "Schink Stories | Opsies",
        description = "Kies jou Schink Stories opsie en begin luister na veilige Afrikaanse stories.",
        url = OpsiesCanonicalUrl,
        inLanguage = "af-ZA",
        isPartOf = new
        {
            @type = "WebSite",
            name = "Schink Stories",
            url = NavigationManager.ToAbsoluteUri("/").ToString()
        },
        primaryImageOfPage = NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()
    }));

    protected override async Task OnParametersSetAsync()
    {
        SafeStoryReturnPath = GetSafeReturnUrl(ReturnUrl);
        RequestedStory = await ResolveRequestedStoryAsync(SafeStoryReturnPath);
        RequiredAccess = ResolveRequiredAccess(SafeStoryReturnPath, RequestedStory);

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        IsUserAuthenticated = authState.User.Identity?.IsAuthenticated == true;
        if (!IsUserAuthenticated)
        {
            HasActivePaidSubscription = false;
            return;
        }

        var userEmail = authState.User.FindFirst(ClaimTypes.Email)?.Value
                        ?? authState.User.Identity?.Name;
        HasActivePaidSubscription = await SubscriptionLedgerService.HasActivePaidSubscriptionAsync(userEmail);

        if (string.IsNullOrWhiteSpace(SafeStoryReturnPath))
        {
            return;
        }

        var hasAccessToRequestedStory = await UserHasAccessToRequestedStoryAsync(authState.User);
        if (!hasAccessToRequestedStory &&
            string.Equals(PaymentStatus, "sukses", StringComparison.OrdinalIgnoreCase))
        {
            hasAccessToRequestedStory = await WaitForStoryAccessAfterPaymentAsync(authState.User);
        }

        if (hasAccessToRequestedStory)
        {
            NavigationManager.NavigateTo(SafeStoryReturnPath, forceLoad: true);
        }
    }

    private async Task<StoryItem?> ResolveRequestedStoryAsync(string? safeStoryReturnPath)
    {
        if (!StoryAccessPolicy.TryParseStoryPath(safeStoryReturnPath, out var source, out var slug))
        {
            return null;
        }

        return string.Equals(source, "gratis", StringComparison.OrdinalIgnoreCase)
            ? await StoryCatalogService.FindFreeBySlugAsync(slug)
            : await StoryCatalogService.FindLuisterBySlugAsync(slug);
    }

    private static StoryAccessRequirement ResolveRequiredAccess(string? safeStoryReturnPath, StoryItem? requestedStory)
    {
        if (!StoryAccessPolicy.TryParseStoryPath(safeStoryReturnPath, out var source, out _))
        {
            return StoryAccessRequirement.Unknown;
        }

        return StoryAccessPolicy.ResolveRequirement(source, requestedStory);
    }

    private async Task<bool> UserHasAccessToRequestedStoryAsync(ClaimsPrincipal user)
    {
        if (!StoryAccessPolicy.TryParseStoryPath(SafeStoryReturnPath, out _, out _))
        {
            return false;
        }

        if (!StoryAccessPolicy.RequiresPaidSubscription(RequiredAccess))
        {
            return user.Identity?.IsAuthenticated == true;
        }

        var userEmail = user.FindFirst(ClaimTypes.Email)?.Value
                        ?? user.Identity?.Name;
        if (string.IsNullOrWhiteSpace(userEmail))
        {
            return false;
        }

        var tierCodes = StoryAccessPolicy.GetAllowedTierCodes(RequiredAccess);
        if (tierCodes.Count == 0)
        {
            return false;
        }

        var checks = tierCodes
            .Select(tierCode => SubscriptionLedgerService.HasActiveSubscriptionForTierAsync(userEmail, tierCode))
            .ToArray();

        var results = await Task.WhenAll(checks);
        return results.Any(result => result);
    }

    private async Task<bool> WaitForStoryAccessAfterPaymentAsync(ClaimsPrincipal user)
    {
        const int attempts = 8;
        for (var attempt = 0; attempt < attempts; attempt++)
        {
            await Task.Delay(TimeSpan.FromMilliseconds(750));
            if (await UserHasAccessToRequestedStoryAsync(user))
            {
                return true;
            }
        }

        return false;
    }

    private string BuildFreeJoinHref()
    {
        if (string.IsNullOrWhiteSpace(SafeStoryReturnPath))
        {
            return "/gratis";
        }

        if (IsUserAuthenticated)
        {
            return SafeStoryReturnPath;
        }

        return QueryHelpers.AddQueryString("/teken-op", "returnUrl", SafeStoryReturnPath);
    }

    private static string BuildPlanSignUpHref(string planSlug, string? safeStoryReturnPath)
    {
        if (string.IsNullOrWhiteSpace(planSlug))
        {
            return "/teken-op";
        }

        var normalizedPlanSlug = planSlug.Trim();
        var checkoutPath = $"/betaal/{Uri.EscapeDataString(normalizedPlanSlug)}";
        if (!string.IsNullOrWhiteSpace(safeStoryReturnPath))
        {
            checkoutPath = QueryHelpers.AddQueryString(checkoutPath, "returnUrl", safeStoryReturnPath);
        }

        var signUpQuery = new Dictionary<string, string?>
        {
            ["plan"] = normalizedPlanSlug,
            ["returnUrl"] = checkoutPath
        };

        return QueryHelpers.AddQueryString("/teken-op", signUpQuery);
    }

    private static string? GetSafeReturnUrl(string? returnUrl)
    {
        var normalizedReturnUrl = NormalizeReturnUrl(returnUrl);
        if (string.IsNullOrWhiteSpace(normalizedReturnUrl))
        {
            return null;
        }

        if (!normalizedReturnUrl.StartsWith("/", StringComparison.Ordinal) ||
            normalizedReturnUrl.StartsWith("//", StringComparison.Ordinal) ||
            normalizedReturnUrl.StartsWith("/teken-in", StringComparison.OrdinalIgnoreCase) ||
            normalizedReturnUrl.StartsWith("/teken-op", StringComparison.OrdinalIgnoreCase) ||
            normalizedReturnUrl.StartsWith("/opsies", StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        return normalizedReturnUrl;
    }

    private static string? NormalizeReturnUrl(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var candidate = value.Trim();
        for (var index = 0; index < 2; index++)
        {
            if (candidate.StartsWith("/", StringComparison.Ordinal))
            {
                break;
            }

            if (!candidate.Contains('%', StringComparison.Ordinal))
            {
                break;
            }

            try
            {
                candidate = Uri.UnescapeDataString(candidate);
            }
            catch
            {
                break;
            }
        }

        return candidate;
    }
}
