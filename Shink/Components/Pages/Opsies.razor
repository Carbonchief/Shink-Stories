@page "/opsies"
@rendermode InteractiveServer
@using System.Text.Json
@using System.Security.Claims
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.AspNetCore.Components.Authorization
@using Shink.Components.Content
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISubscriptionLedgerService SubscriptionLedgerService
@inject IStoryCatalogService StoryCatalogService

<PageTitle>Schink Stories | Opsies</PageTitle>
<HeadContent>
    <link rel="canonical" href="@OpsiesCanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Schink Stories | Opsies" />
    <meta property="og:description" content="Kies jou Schink Stories opsie en begin luister na veilige Afrikaanse stories." />
    <meta property="og:url" content="@OpsiesCanonicalUrl" />
    <meta property="og:image" content="@NavigationManager.ToAbsoluteUri("/branding/Schink_Stories_Logo_turqoise.png").ToString()" />
    <meta property="og:image:secure_url" content="@NavigationManager.ToAbsoluteUri("/branding/Schink_Stories_Logo_turqoise.png").ToString()" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="1200" />
    <meta property="og:image:alt" content="Schink Stories logo" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Schink Stories | Opsies" />
    <meta name="twitter:description" content="Kies jou Schink Stories opsie en begin luister na veilige Afrikaanse stories." />
    <meta name="twitter:image" content="@NavigationManager.ToAbsoluteUri("/branding/Schink_Stories_Logo_turqoise.png").ToString()" />
    <meta name="twitter:image:alt" content="Schink Stories logo" />
    @if (PaymentSuccessAutoRedirectPath is not null)
    {
        <meta http-equiv="refresh" content="@($"5;url={PaymentSuccessAutoRedirectPath}")" />
    }
    <JsonLdScript Json="@OpsiesJsonLd" />
</HeadContent>

<section class="opsies-page">
    <div class="opsies-page-logo">
        <img src="/branding/Schink_Stories_Logo_turqoise.png"
             alt="Schink Stories"
             class="opsies-page-logo-image"
             loading="eager"
             decoding="async" />
    </div>

    @if (string.Equals(PaymentStatus, "sukses", StringComparison.OrdinalIgnoreCase))
    {
        <p class="opsies-payment-status opsies-payment-success" role="status" aria-live="polite">
            Dankie! Jou betaling is ontvang. Ons neem jou oor 5 sekondes na die luisterblad.
        </p>
    }
    else if (string.Equals(PaymentStatus, "gekanselleer", StringComparison.OrdinalIgnoreCase))
    {
        <p class="opsies-payment-status opsies-payment-cancelled" role="status" aria-live="polite">
            Betaling is gekanselleer. Jy kan enige tyd weer probeer.
        </p>
    }
    else if (string.Equals(PaymentStatus, "reeds-ingeteken", StringComparison.OrdinalIgnoreCase))
    {
        <p class="opsies-payment-status opsies-payment-blocked" role="status" aria-live="polite">
            Jy het reeds 'n aktiewe intekening op hierdie plan. Kies asseblief 'n ander opsie.
        </p>
    }

    <section class="opsies-hero">
        <div class="opsies-hero-copy">
            <p class="opsies-eyebrow">Kies 'n opsie</p>
            <h1>Kies die plan wat die beste by julle storietyd pas.</h1>
            <p class="opsies-hero-lead">
                Kies volle toegang tot ons veilige, opbouende Afrikaanse stories.
                Alles is eenvoudig, advertensievry en ontwerp vir gesinne.
            </p>
            <div class="opsies-hero-points" aria-label="Waarom ouers Schink kies">
                <div class="opsies-hero-point">
                    <strong>Veilige luisterervaring</strong>
                    <span>Geen advertensies of donker temas nie. Net storietyd wat rustig en geskik vir kinders voel.</span>
                </div>
                <div class="opsies-hero-point">
                    <strong>Buigsame planne</strong>
                    <span>Kies maandeliks of jaarliks en skuif maklik na die opsie wat by julle pas.</span>
                </div>
            </div>
        </div>
    </section>

    <section class="opsies-plan-shell" id="plan-opsies">
        <div class="opsies-section-heading">
            <p class="opsies-section-kicker">Plan vergelyking</p>
            <h2>Kies die opsie wat vir jou werk</h2>
            <p>
                Elke plan gee jou 'n skoon, veilige luisterervaring. Die verskil is net hoeveel toegang jy wil hê.
            </p>
        </div>

        <div class="opsies-grid" aria-label="Plan opsies">

            <article class="@GetPlanCardClass("opsie-card featured opsie-monthly", "storie-hoekie-maandeliks", IsStoryCornerPlanUnavailable)">
                <div class="opsie-head">
                    <p class="opsie-badge">MAANDELIKS</p>
                    <p class="opsie-summary">Vir gesinne wat met een geliefde reeks wil begin</p>
                    <h2>Storie Hoekie</h2>
                    <p class="opsie-price">R 55.00 <span>per maand.</span></p>
                </div>
                @if (IsSelectedPlan("storie-hoekie-maandeliks"))
                {
                    <p class="opsie-selected-indicator">Gekose plan</p>
                }
                <p class="opsie-detail">Geniet toegang tot stories uit die gewilde Storie Hoekie reeks.</p>
                <ul>
                    <li>Toegang tot die volledige Storie Hoekie reeks</li>
                    <li>Maklike maand-tot-maand intekening</li>
                    <li>Ideaal as jy met een reeks wil begin</li>
                </ul>
                @if (StoryCornerPlanMessage is not null)
                {
                    <p class="opsie-disabled-message">@StoryCornerPlanMessage</p>
                }
                <p class="opsie-note">'n Netjiese beginpunt vir ouers wat 'n kleiner maandopsie soek.</p>
                @if (IsStoryCornerPlanUnavailable)
                {
                    <span class="opsie-btn opsie-btn-disabled" aria-disabled="true">@StoryCornerDisabledButtonText</span>
                    @if (CanEnableStoryCornerPlan)
                    {
                        <button type="button" class="opsie-enable-btn" @onclick="EnableStoryCornerPlan">Wys Storie Hoekie opsie</button>
                    }
                }
                else
                {
                    <a href='@BuildPlanSignUpHref("storie-hoekie-maandeliks", StoryCornerCheckoutReturnPath)' class="opsie-btn">@(IsSelectedPlan("storie-hoekie-maandeliks") ? "Gaan voort" : "Kies hierdie plan")</a>
                }
            </article>

            @if (ShouldShowAllStoriesPlanOptions)
            {
                <article class="@GetPlanCardClass("opsie-card opsie-all", CurrentAllStoriesPlanSlug)">
                    <div class="opsie-head">
                        <p class="opsie-badge">Volle toegang</p>
                        <p class="opsie-pill opsie-pill-value">Meeste waarde</p>
                        <p class="opsie-summary">Vir volle toegang tot alles</p>
                        <h2>Schink Stories</h2>
                    </div>
                    <p class="opsie-detail"><strong>Geniet toegang tot ALLES!</strong></p>
                    <ul>
                        <li>Onbeperkte toegang tot alle stories en reekse</li>
                        <li>Opbouende stories wat veilig is vir kinders</li>
                        <li>Geen advertensies</li>
                        <li>Nuwe stories elke maand</li>
                        <li>Toegang tot hulpbronne</li>
                    </ul>

                    <div class="opsie-plan-options" role="radiogroup" aria-label="Schink Stories plan opsies">
                        <button type="button"
                                class="opsie-plan-option @(!IsYearlyAllStoriesPlan ? "is-selected" : null)"
                                role="radio"
                                aria-checked="@(!IsYearlyAllStoriesPlan)"
                                @onclick="(() => SetAllStoriesBillingCycle(false))">
                            <span class="opsie-plan-option-marker" aria-hidden="true">
                                <span class="opsie-plan-option-marker-dot"></span>
                            </span>
                            <span class="opsie-plan-option-copy">
                                <span class="opsie-plan-option-head">
                                    <span class="opsie-plan-option-price">R79</span>
                                    <span class="opsie-plan-option-period">Maandeliks</span>
                                </span>
                                <span class="opsie-plan-option-note">Volledige toegang vir 1 maand</span>
                            </span>
                        </button>

                        <button type="button"
                                class="opsie-plan-option @(IsYearlyAllStoriesPlan ? "is-selected" : null)"
                                role="radio"
                                aria-checked="@(IsYearlyAllStoriesPlan)"
                                @onclick="(() => SetAllStoriesBillingCycle(true))">
                            <span class="opsie-plan-option-marker" aria-hidden="true">
                                <span class="opsie-plan-option-marker-dot"></span>
                            </span>
                            <span class="opsie-plan-option-copy">
                                <span class="opsie-plan-option-head">
                                    <span class="opsie-plan-option-price">R790</span>
                                    <span class="opsie-plan-option-period">Jaarliks</span>
                                    <span class="opsie-save-badge">2 maande gratis</span>
                                </span>
                                <span class="opsie-plan-option-note">Volledige toegang vir 12 maande</span>
                            </span>
                        </button>
                    </div>

                    <a href='@BuildPlanSignUpHref(CurrentAllStoriesPlanSlug, SafeStoryReturnPath)' class="opsie-btn">@(IsSelectedPlan(CurrentAllStoriesPlanSlug) ? "Gaan voort" : "Kies hierdie plan")</a>
                </article>
            }
        </div>
    </section>

    <section class="opsies-compare" aria-labelledby="opsies-compare-title">
        <div class="opsies-section-heading">
            <p class="opsies-section-kicker">Vergelyk opsies</p>
            <h2 id="opsies-compare-title">Sien die verskille vinnig</h2>
            <p>Kyk hier langs mekaar watter plan die beste by julle gesin se storietyd pas.</p>
        </div>

        <div class="opsies-compare-scroll" role="region" aria-label="Vergelyk opsies tabel">
            <table class="opsies-compare-table">
                <thead>
                    <tr>
                        <th scope="col">Kenmerk</th>
                        <th scope="col" class="@GetCompareColumnClass("storie-hoekie-maandeliks")">Storie Hoekie</th>
                        <th scope="col" class="@GetCompareColumnClass("schink-stories-maandeliks")">Schink Stories Maandeliks</th>
                        <th scope="col" class="@GetCompareColumnClass("schink-stories-jaarliks")">Schink Stories Jaarliks</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <th scope="row">Prys</th>
                        <td class="@GetCompareColumnClass("storie-hoekie-maandeliks")">R55 per maand</td>
                        <td class="@GetCompareColumnClass("schink-stories-maandeliks")">R79 per maand</td>
                        <td class="@GetCompareColumnClass("schink-stories-jaarliks")">R790 per jaar</td>
                    </tr>
                    <tr>
                        <th scope="row">Toegang</th>
                        <td class="@GetCompareColumnClass("storie-hoekie-maandeliks")">Storie Hoekie-reeks</td>
                        <td class="@GetCompareColumnClass("schink-stories-maandeliks")">Alle stories en reekse</td>
                        <td class="@GetCompareColumnClass("schink-stories-jaarliks")">Alle stories en reekse</td>
                    </tr>
                    <tr>
                        <th scope="row">Nuwe stories</th>
                        <td class="@GetCompareColumnClass("storie-hoekie-maandeliks")">In Storie Hoekie-reeks</td>
                        <td class="@GetCompareColumnClass("schink-stories-maandeliks")">Ja, elke maand</td>
                        <td class="@GetCompareColumnClass("schink-stories-jaarliks")">Ja, elke maand</td>
                    </tr>
                    <tr>
                        <th scope="row">Hulpbronne</th>
                        <td class="@GetCompareColumnClass("storie-hoekie-maandeliks")">Basiese toegang</td>
                        <td class="@GetCompareColumnClass("schink-stories-maandeliks")">Vol toegang</td>
                        <td class="@GetCompareColumnClass("schink-stories-jaarliks")">Vol toegang</td>
                    </tr>
                    <tr>
                        <th scope="row">Advertensies</th>
                        <td class="@GetCompareColumnClass("storie-hoekie-maandeliks")">Geen advertensies</td>
                        <td class="@GetCompareColumnClass("schink-stories-maandeliks")">Geen advertensies</td>
                        <td class="@GetCompareColumnClass("schink-stories-jaarliks")">Geen advertensies</td>
                    </tr>
                    <tr>
                        <th scope="row">Besparing</th>
                        <td class="@GetCompareColumnClass("storie-hoekie-maandeliks")">NVT</td>
                        <td class="@GetCompareColumnClass("schink-stories-maandeliks")">NVT</td>
                        <td class="@GetCompareColumnClass("schink-stories-jaarliks")">2 maande gratis</td>
                    </tr>
                    <tr>
                        <th scope="row">Beste vir</th>
                        <td class="@GetCompareColumnClass("storie-hoekie-maandeliks")">Begin met een reeks</td>
                        <td class="@GetCompareColumnClass("schink-stories-maandeliks")">Volle toegang per maand</td>
                        <td class="@GetCompareColumnClass("schink-stories-jaarliks")">Volle toegang vir 'n jaar</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>

    <section class="opsies-faq" aria-labelledby="opsies-faq-title">
        <div class="opsies-section-heading">
            <p class="opsies-section-kicker">Algemene vrae</p>
            <h2 id="opsies-faq-title">Vrae wat ouers gereeld vra</h2>
            <p>Hier is vinnige antwoorde op die mees algemene vrae oor gratis stories, planne, toegang en betalings.</p>
        </div>

        <div class="opsies-faq-list">
            <details class="opsies-faq-item" open>
                <summary>Moet ek 'n kredietkaart invoer om die 3 gratis stories te luister?</summary>
                <p>Nee, glad nie. Jy kan dadelik begin luister — geen kaart, geen verbintenis. Slegs wanneer jy besluit om in te teken, vra ons vir betaalbesonderhede.</p>
            </details>

            <details class="opsies-faq-item">
                <summary>Wat gebeur nadat ek die 3 gratis stories geluister het?</summary>
                <p>Jy kies of jy wil voortgaan. As jy nie wil nie, gebeur daar niks — jy word nie outomaties gedebiteer nie.</p>
            </details>

            <details class="opsies-faq-item">
                <summary>Hoe lank het ek toegang tot die gratis stories?</summary>
                <p>Die 3 gratis stories bly beskikbaar solank jy 'n rekening het. Speel dit so dikwels as jy wil.</p>
            </details>

            <details class="opsies-faq-item">
                <summary>Vir watter ouderdom is Schink Stories geskik?</summary>
                <p>Ons stories is geskik vir kinders van 3 tot 10 jaar. Jonger kinders hou van die kleurryke karakters en eenvoudige verhale, terwyl ouer kinders hulself herken in die uitdagings en waardes.</p>
            </details>

            <details class="opsies-faq-item">
                <summary>Hoe lank is elke storie?</summary>
                <p>Elke storie is tussen 5 en 12 minute lank. Elke storie kom ook met aflaaibare hulpbronne en aktiwiteite sodat die ervaring verder as die luister gaan.</p>
            </details>

            <details class="opsies-faq-item">
                <summary>Wie lees die stories voor?</summary>
                <p>Die stories word deur die skrywer self ingespreek, en karakterklanke word deur professionele stemkunstenaars gedoen. Geen KI — net regte mense met hart vir stories.</p>
            </details>

            <details class="opsies-faq-item">
                <summary>Hoe gereeld word nuwe stories bygevoeg?</summary>
                <p>Nuwe stories word elke maand bygevoeg. As intekenaar kry jy ook volle toegang tot die groeiende biblioteek van bestaande stories.</p>
            </details>

            <details class="opsies-faq-item">
                <summary>Wat is die verskil tussen Storie Hoekie en Schink Stories?</summary>
                <p>Storie Hoekie (R55/maand) gee jou toegang tot 'n spesifieke reeks. Schink Stories (R79/maand) gee jou onbeperkte toegang tot die volle biblioteek — alle reekse, alle karakters, hulpbronne en aktiwiteite, nuwe stories elke maand ingesluit.</p>
            </details>

            <details class="opsies-faq-item">
                <summary>Kan ek op enige tyd kanselleer?</summary>
                <p>Absoluut. Geen boetes, geen lang prosesse. Een klik in jou rekening-instellings en jy is klaar. Jou toegang bly aktief tot die einde van jou betaalde tydperk.</p>
            </details>

            <details class="opsies-faq-item">
                <summary>Watter betaalmetodes aanvaar julle?</summary>
                <p>Ons verwerk betalings veilig deur Paystack.</p>
            </details>

            <details class="opsies-faq-item">
                <summary>Op watter toestelle kan ek Schink Stories luister?</summary>
                <p>Op enige slimfoon, tablet of rekenaar — iOS, Android of webblaaier. Jy log in en luister, so eenvoudig soos dit.</p>
            </details>

            <details class="opsies-faq-item">
                <summary>Is daar advertensies in die stories?</summary>
                <p>Nooit. Schink Stories is 'n veilige, advertensievrye ruimte. Geen donker temas, geen onderbrekings — net storietyd wat goed is vir jou kind.</p>
            </details>
        </div>
    </section>

    <section class="opsies-testimonials">
        <div class="opsies-section-heading opsies-section-heading-centered">
            <p class="opsies-section-kicker">Ouers vertel</p>
            <h2>Wat ouers se</h2>
            <p>Regte terugvoer van gesinne wat Schink Stories deel van hulle roetine gemaak het.</p>
        </div>
        <div class="opsies-review-grid">
            <article class="opsies-review-card">
                <p class="opsies-review-stars" aria-hidden="true">
                    <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                </p>
                <blockquote>
                    Ek love al Schink se stories. Dit is in goeie taal en daar is 'n goeie lessie in elke storie.
                </blockquote>
                <div class="opsies-review-person">
                    <p class="opsies-review-author">Renske</p>
                    <p class="opsies-review-role">Arbeidsterapeut</p>
                </div>
            </article>

            <article class="opsies-review-card">
                <p class="opsies-review-stars" aria-hidden="true">
                    <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                </p>
                <blockquote>
                    Ons drie oudste kids se gunsteling. Schink Stories maak bedtyd iets waarna hulle uitsien.
                </blockquote>
                <div class="opsies-review-person">
                    <p class="opsies-review-author">Sivonne</p>
                </div>
            </article>

            <article class="opsies-review-card">
                <p class="opsies-review-stars" aria-hidden="true">
                    <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                </p>
                <blockquote>
                    Schink Stories help regtig kinders. Dit is opbouend en veilig vir die hele gesin.
                </blockquote>
                <div class="opsies-review-person">
                    <p class="opsies-review-author">Elmarette</p>
                </div>
            </article>
        </div>
    </section>
</section>

@code {
    [SupplyParameterFromQuery(Name = "betaling")]
    public string? PaymentStatus { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "plan")]
    public string? Plan { get; set; }

    private bool IsUserAuthenticated { get; set; }
    private bool IsYearlyAllStoriesPlan { get; set; }
    private string? SafeStoryReturnPath { get; set; }
    private StoryItem? RequestedStory { get; set; }
    private StoryAccessRequirement RequiredAccess { get; set; } = StoryAccessRequirement.Unknown;
    private string? SelectedPlanSlug { get; set; }
    private bool HasActiveStoryCornerPlan { get; set; }
    private bool IsStoryCornerPlanForceEnabled { get; set; }

    private bool ShouldShowAllStoriesPlanOptions => true;

    private string CurrentAllStoriesPlanSlug => IsYearlyAllStoriesPlan
        ? "schink-stories-jaarliks"
        : "schink-stories-maandeliks";

    private bool IsStoryCornerPlanCompatibleWithRequestedStory =>
        RequiredAccess is not StoryAccessRequirement.AllStoriesOnly;

    private bool CanEnableStoryCornerPlan =>
        !HasActiveStoryCornerPlan &&
        !IsStoryCornerPlanCompatibleWithRequestedStory &&
        !IsStoryCornerPlanForceEnabled;

    private bool IsStoryCornerPlanUnavailable =>
        HasActiveStoryCornerPlan ||
        (!IsStoryCornerPlanCompatibleWithRequestedStory && !IsStoryCornerPlanForceEnabled);

    private string? StoryCornerCheckoutReturnPath =>
        IsStoryCornerPlanCompatibleWithRequestedStory ? SafeStoryReturnPath : null;

    private string? StoryCornerPlanMessage =>
        HasActiveStoryCornerPlan
            ? "Jy is reeds op hierdie plan."
            : IsStoryCornerPlanCompatibleWithRequestedStory
                ? null
                : "Hierdie storie is nie deel van Storie Hoekie nie. Kies Schink Stories vir toegang tot hierdie storie, of wys Storie Hoekie as jy net daardie beperkte plan wil kies.";

    private string StoryCornerDisabledButtonText =>
        HasActiveStoryCornerPlan ? "Huidige plan" : "Nie beskikbaar vir hierdie storie nie";

    private string OpsiesCanonicalUrl => NavigationManager.ToAbsoluteUri("/opsies").ToString();
    private bool IsPaymentSuccess => string.Equals(PaymentStatus, "sukses", StringComparison.OrdinalIgnoreCase);
    private string? PaymentSuccessAutoRedirectPath => IsPaymentSuccess
        ? GetSafeReturnUrl(ReturnUrl) ?? "/luister"
        : null;

    private MarkupString OpsiesJsonLd => new(JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "WebPage",
        ["name"] = "Schink Stories | Opsies",
        ["description"] = "Kies jou Schink Stories opsie en begin luister na veilige Afrikaanse stories.",
        ["url"] = OpsiesCanonicalUrl,
        ["inLanguage"] = "af-ZA",
        ["isPartOf"] = new Dictionary<string, object?>
        {
            ["@type"] = "WebSite",
            ["name"] = "Schink Stories",
            ["url"] = NavigationManager.ToAbsoluteUri("/").ToString()
        },
        ["primaryImageOfPage"] = NavigationManager.ToAbsoluteUri("/branding/Schink_Stories_Logo_turqoise.png").ToString()
    }));

    protected override async Task OnParametersSetAsync()
    {
        SafeStoryReturnPath = GetSafeReturnUrl(ReturnUrl);
        RequestedStory = await ResolveRequestedStoryAsync(SafeStoryReturnPath);
        RequiredAccess = ResolveRequiredAccess(SafeStoryReturnPath, RequestedStory);
        SelectedPlanSlug = ResolveSelectedPlanSlug();
        IsYearlyAllStoriesPlan = string.Equals(SelectedPlanSlug, "schink-stories-jaarliks", StringComparison.OrdinalIgnoreCase);
        HasActiveStoryCornerPlan = false;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        IsUserAuthenticated = authState.User.Identity?.IsAuthenticated == true;
        if (!IsUserAuthenticated)
        {
            return;
        }

        var userEmail = authState.User.FindFirst(ClaimTypes.Email)?.Value
                        ?? authState.User.Identity?.Name;

        HasActiveStoryCornerPlan = await SubscriptionLedgerService.HasActiveSubscriptionForTierAsync(
            userEmail,
            StoryAccessPolicy.StoryCornerMonthlyTierCode);

        if (string.IsNullOrWhiteSpace(SafeStoryReturnPath))
        {
            return;
        }

        var hasAccessToRequestedStory = await UserHasAccessToRequestedStoryAsync(authState.User);
        if (!hasAccessToRequestedStory &&
            string.Equals(PaymentStatus, "sukses", StringComparison.OrdinalIgnoreCase))
        {
            hasAccessToRequestedStory = await WaitForStoryAccessAfterPaymentAsync(authState.User);
        }

        if (hasAccessToRequestedStory)
        {
            NavigationManager.NavigateTo(SafeStoryReturnPath, forceLoad: true);
        }
    }

    private string? ResolveSelectedPlanSlug()
    {
        var selectedPlan = PaymentPlanCatalog.FindBySlug(NormalizePlanSlug(Plan));
        if (selectedPlan is not null)
        {
            return selectedPlan.Slug;
        }

        return RequiredAccess switch
        {
            StoryAccessRequirement.StoryCornerOrAllStories => "storie-hoekie-maandeliks",
            StoryAccessRequirement.AllStoriesOnly => "schink-stories-maandeliks",
            _ => "schink-stories-maandeliks"
        };
    }

    private async Task<StoryItem?> ResolveRequestedStoryAsync(string? safeStoryReturnPath)
    {
        if (!StoryAccessPolicy.TryParseStoryPath(safeStoryReturnPath, out var source, out var slug))
        {
            return null;
        }

        return string.Equals(source, "gratis", StringComparison.OrdinalIgnoreCase)
            ? await StoryCatalogService.FindFreeBySlugAsync(slug)
            : await StoryCatalogService.FindLuisterBySlugAsync(slug);
    }

    private static StoryAccessRequirement ResolveRequiredAccess(string? safeStoryReturnPath, StoryItem? requestedStory)
    {
        if (!StoryAccessPolicy.TryParseStoryPath(safeStoryReturnPath, out var source, out _))
        {
            return StoryAccessRequirement.Unknown;
        }

        return StoryAccessPolicy.ResolveRequirement(source, requestedStory);
    }

    private async Task<bool> UserHasAccessToRequestedStoryAsync(ClaimsPrincipal user)
    {
        if (!StoryAccessPolicy.TryParseStoryPath(SafeStoryReturnPath, out _, out _))
        {
            return false;
        }

        if (!StoryAccessPolicy.RequiresPaidSubscription(RequiredAccess))
        {
            return user.Identity?.IsAuthenticated == true;
        }

        var userEmail = user.FindFirst(ClaimTypes.Email)?.Value
                        ?? user.Identity?.Name;
        if (string.IsNullOrWhiteSpace(userEmail))
        {
            return false;
        }

        var tierCodes = StoryAccessPolicy.GetAllowedTierCodes(RequiredAccess);
        if (tierCodes.Count == 0)
        {
            return false;
        }

        var checks = tierCodes
            .Select(tierCode => SubscriptionLedgerService.HasActiveSubscriptionForTierAsync(userEmail, tierCode))
            .ToArray();

        var results = await Task.WhenAll(checks);
        return results.Any(result => result);
    }

    private async Task<bool> WaitForStoryAccessAfterPaymentAsync(ClaimsPrincipal user)
    {
        const int attempts = 8;
        for (var attempt = 0; attempt < attempts; attempt++)
        {
            await Task.Delay(TimeSpan.FromMilliseconds(750));
            if (await UserHasAccessToRequestedStoryAsync(user))
            {
                return true;
            }
        }

        return false;
    }

    private void SetAllStoriesBillingCycle(bool isYearlyPlan)
    {
        if (IsYearlyAllStoriesPlan == isYearlyPlan)
        {
            return;
        }

        IsYearlyAllStoriesPlan = isYearlyPlan;
        SelectedPlanSlug = CurrentAllStoriesPlanSlug;
    }

    private void EnableStoryCornerPlan()
    {
        if (HasActiveStoryCornerPlan)
        {
            return;
        }

        IsStoryCornerPlanForceEnabled = true;
    }

    private static string BuildPlanSignUpHref(string planSlug, string? safeStoryReturnPath)
    {
        if (string.IsNullOrWhiteSpace(planSlug))
        {
            return "/teken-op";
        }

        var normalizedPlanSlug = planSlug.Trim();
        var checkoutPath = $"/betaal/{Uri.EscapeDataString(normalizedPlanSlug)}";
        if (!string.IsNullOrWhiteSpace(safeStoryReturnPath))
        {
            checkoutPath = QueryHelpers.AddQueryString(checkoutPath, "returnUrl", safeStoryReturnPath);
        }

        var signUpQuery = new Dictionary<string, string?>
        {
            ["plan"] = normalizedPlanSlug,
            ["returnUrl"] = checkoutPath
        };

        return QueryHelpers.AddQueryString("/teken-op", signUpQuery);
    }

    private static string? NormalizePlanSlug(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var trimmed = value.Trim();
        return trimmed.Length == 0 ? null : trimmed;
    }

    private bool IsSelectedPlan(string planSlug) =>
        !string.IsNullOrWhiteSpace(SelectedPlanSlug) &&
        string.Equals(SelectedPlanSlug, planSlug, StringComparison.OrdinalIgnoreCase);

    private string GetCompareColumnClass(string planSlug) =>
        IsSelectedPlan(planSlug)
            ? "opsies-compare-plan is-selected"
            : "opsies-compare-plan";

    private string GetPlanCardClass(string baseClass, string planSlug, bool isUnavailable = false)
    {
        var cardClass = baseClass;
        if (IsSelectedPlan(planSlug))
        {
            cardClass = $"{cardClass} opsie-card-selected";
        }

        if (isUnavailable)
        {
            cardClass = $"{cardClass} opsie-card-disabled";
        }

        return cardClass;
    }

    private static string? GetSafeReturnUrl(string? returnUrl)
    {
        var normalizedReturnUrl = NormalizeReturnUrl(returnUrl);
        if (string.IsNullOrWhiteSpace(normalizedReturnUrl))
        {
            return null;
        }

        if (!normalizedReturnUrl.StartsWith("/", StringComparison.Ordinal) ||
            normalizedReturnUrl.StartsWith("//", StringComparison.Ordinal) ||
            normalizedReturnUrl.StartsWith("/teken-in", StringComparison.OrdinalIgnoreCase) ||
            normalizedReturnUrl.StartsWith("/teken-op", StringComparison.OrdinalIgnoreCase) ||
            normalizedReturnUrl.StartsWith("/opsies", StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        return normalizedReturnUrl;
    }

    private static string? NormalizeReturnUrl(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var candidate = value.Trim();
        for (var index = 0; index < 2; index++)
        {
            if (candidate.StartsWith("/", StringComparison.Ordinal))
            {
                break;
            }

            if (!candidate.Contains('%', StringComparison.Ordinal))
            {
                break;
            }

            try
            {
                candidate = Uri.UnescapeDataString(candidate);
            }
            catch
            {
                break;
            }
        }

        return candidate;
    }
