<section class="perfect-plan-section home-scroll-reveal" style="--home-reveal-delay: 0.08s;" aria-labelledby="perfekte-plan">
    <div class="perfect-plan-header">
        <h2 id="perfekte-plan">Vind jou perfekte plan</h2>
        <p>Vergelyk ons opsies en kies die intekening wat die beste by jou gesin pas.</p>
    </div>

    <div class="perfect-plan-grid">
        @foreach (var card in PerfectPlanCards)
        {
            <article class="@($"perfect-plan-card {(card.IsFeatured ? "is-featured" : null)}")">
                <p class="perfect-plan-badge">@card.Badge</p>
                <h3>@card.Title</h3>

                <ul class="perfect-plan-list">
                    @foreach (var benefit in card.Benefits)
                    {
                        <li>@benefit</li>
                    }
                </ul>

                <div class="perfect-plan-options" aria-label="@($"Prys opsies vir {card.Title}")">
                    @foreach (var option in card.Options)
                    {
                        var optionId = $"perfect-plan-{card.Key}-{option.Plan.Slug}";
                        var isSelected = IsSelectedPlanOption(option.Plan.Slug);
                        var hasSaveBadge = IsYearlyAllStoriesPlan(option.Plan);

                        <label class="@($"perfect-plan-option {(isSelected ? "is-selected" : null)} {(hasSaveBadge ? "has-save-badge" : null)}")" for="@optionId">
                            <input id="@optionId"
                                   type="radio"
                                   name="perfect-plan-group-global"
                                   checked="@isSelected"
                                   @onchange="@(() => SelectPlanOption(option.Plan.Slug))" />
                            <span class="perfect-plan-option-indicator" aria-hidden="true"></span>
                            <span class="perfect-plan-option-text">
                                <span class="perfect-plan-option-price-line">
                                    <strong>@FormatAmount(option.Plan.Amount)</strong>
                                    <span>@GetBillingLabel(option.Plan)</span>
                                </span>
                                @if (hasSaveBadge)
                                {
                                    <span class="perfect-plan-option-save-badge">2 maande gratis</span>
                                }
                                <span class="perfect-plan-option-caption">@option.Caption</span>
                            </span>
                        </label>
                    }
                </div>

                <a class="@($"perfect-plan-select {(CardHasSelectedOption(card) ? "is-linked-selected" : null)}")"
                   href="@GetSelectedPlanHref(card)">Kies plan</a>
            </article>
        }
    </div>
</section>

<section class="contact-section home-scroll-reveal" style="--home-reveal-delay: 0.08s;" aria-labelledby="kontak-ons">
    <div class="contact-inner">
        <h2 id="kontak-ons" class="contact-title">Kontak Ons</h2>

        <div class="contact-copy">
            <h3>Het jy vrae? Ons help graag.</h3>
            <p>
                Stuur vir ons 'n boodskap en ons kom so gou moontlik by jou terug.
            </p>
        </div>

        <div class="contact-form-shell">
            <EditForm FormName="contact-form" class="contact-form" Model="ContactForm" OnValidSubmit="HandleContactSubmitAsync" aria-busy="@IsSubmitting">
                <DataAnnotationsValidator />

                <div class="contact-honeypot" aria-hidden="true">
                    <label for="contact-website">Webwerf</label>
                    <InputText id="contact-website" class="form-control" autocomplete="off" tabindex="-1" @bind-Value="ContactForm.Website" />
                </div>

                <div class="contact-fields-grid row g-3 mb-3">
                    <div class="contact-field col-12 col-md-6">
                        <label class="form-label" for="contact-name">Naam</label>
                        <InputText id="contact-name" class="form-control form-control-lg" autocomplete="name" @bind-Value="ContactForm.Name" />
                        <ValidationMessage For="@(() => ContactForm.Name)" />
                    </div>

                    <div class="contact-field col-12 col-md-6">
                        <label class="form-label" for="contact-email">E-pos</label>
                        <InputText id="contact-email" class="form-control form-control-lg" type="email" autocomplete="email" @bind-Value="ContactForm.Email" />
                        <ValidationMessage For="@(() => ContactForm.Email)" />
                    </div>
                </div>

                <div class="contact-field mb-3">
                    <label class="form-label" for="contact-subject">Onderwerp</label>
                    <InputText id="contact-subject" class="form-control form-control-lg" autocomplete="off" @bind-Value="ContactForm.Subject" />
                    <ValidationMessage For="@(() => ContactForm.Subject)" />
                </div>

                <div class="contact-field mb-3">
                    <label class="form-label" for="contact-message">Boodskap</label>
                    <InputTextArea id="contact-message" class="form-control form-control-lg" rows="5" @bind-Value="ContactForm.Message" />
                    <ValidationMessage For="@(() => ContactForm.Message)" />
                </div>

                <button type="submit" class="join-promo-cta" disabled="@IsSubmitting">
                    @(IsSubmitting ? "Besig om te stuur..." : "Stuur boodskap")
                </button>

                @if (!string.IsNullOrWhiteSpace(FormStatusMessage))
                {
                    <p class="@($"contact-status {(SubmitSucceeded ? "contact-status-success" : "contact-status-error")}")"
                       role="@(SubmitSucceeded ? "status" : "alert")"
                       aria-live="polite">
                        @FormStatusMessage
                    </p>
                }
            </EditForm>
        </div>
    </div>
</section>

</div>

@code {
    private IJSObjectReference? _homeModule;
    private bool _homeModuleLoadFailed;
    private bool HasResolvedAuthState { get; set; }
    private bool IsLoadingPlaylists { get; set; } = true;
    private bool IsSignedIn { get; set; }
    private string? SignedInEmail { get; set; }
    private LuisterAccessProfile AccessProfile { get; set; } = new(false, false);
    private bool ShowStoryAccessPopup { get; set; }
    private string PendingLockedStoryPath { get; set; } = "/";

    private IReadOnlyList<StoryPlaylist> HomePlaylists { get; set; } = Array.Empty<StoryPlaylist>();
    private ContactFormModel ContactForm { get; set; } = new();
    private bool IsSubmitting { get; set; }
    private bool SubmitSucceeded { get; set; }
    private string? FormStatusMessage { get; set; }
    private string? SelectedPlanSlug { get; set; }
    private IReadOnlyList<PerfectPlanCard> PerfectPlanCards =>
        BuildPerfectPlanCards();

    private IReadOnlyList<PerfectPlanCard> BuildPerfectPlanCards()
    {
        var cards = new List<PerfectPlanCard>();

        var storyHoekiePlan = PaymentPlanCatalog.All.FirstOrDefault(plan =>
            string.Equals(plan.TierCode, "story_corner_monthly", StringComparison.OrdinalIgnoreCase));

        if (storyHoekiePlan is not null)
        {
            var cardMeta = PerfectPlanCardMetaByKey["story-hoekie"];
            cards.Add(new PerfectPlanCard(
                Key: "story-hoekie",
                Title: storyHoekiePlan.Name,
                Badge: cardMeta.Badge,
                Benefits: cardMeta.Benefits,
                Options:
                [
                    new PerfectPlanOption(storyHoekiePlan, "Storie Hoekie-reeks")
                ],
                IsFeatured: cardMeta.IsFeatured));
        }

        var schinkPlans = PaymentPlanCatalog.All
            .Where(plan => string.Equals(plan.TierCode, "all_stories_monthly", StringComparison.OrdinalIgnoreCase) ||
                           string.Equals(plan.TierCode, "all_stories_yearly", StringComparison.OrdinalIgnoreCase))
            .OrderBy(plan => plan.BillingPeriodMonths)
            .ThenBy(plan => plan.Amount)
            .ToArray();

        if (schinkPlans.Length > 0)
        {
            var cardMeta = PerfectPlanCardMetaByKey["schink-stories"];
            cards.Add(new PerfectPlanCard(
                Key: "schink-stories",
                Title: "Schink Stories",
                Badge: cardMeta.Badge,
                Benefits: cardMeta.Benefits,
                Options: schinkPlans
                    .Select(plan => new PerfectPlanOption(plan, GetPlanOptionCaption(plan)))
                    .ToArray(),
                IsFeatured: cardMeta.IsFeatured));
        }

        return cards;
    }

    private string GetSelectedPlanHref(PerfectPlanCard card)
    {
        var selectedPlanSlug = GetCallToActionPlanSlug(card);
        return string.IsNullOrWhiteSpace(selectedPlanSlug)
            ? "/opsies"
            : BuildPlanSignUpHref(selectedPlanSlug);
    }

    private static string BuildPlanSignUpHref(string planSlug)
    {
        if (string.IsNullOrWhiteSpace(planSlug))
        {
            return "/teken-op";
        }

        var normalizedPlanSlug = planSlug.Trim();
        var checkoutPath = $"/betaal/{Uri.EscapeDataString(normalizedPlanSlug)}";
        return $"/teken-op?plan={Uri.EscapeDataString(normalizedPlanSlug)}&returnUrl={Uri.EscapeDataString(checkoutPath)}";
    }

    private bool IsSelectedPlanOption(string planSlug) =>
        string.Equals(GetSelectedPlanSlug(), planSlug, StringComparison.OrdinalIgnoreCase);

    private string GetSelectedPlanSlug()
    {
        var allOptionSlugs = PerfectPlanCards
            .SelectMany(card => card.Options)
            .Select(option => option.Plan.Slug)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (SelectedPlanSlug is not null && allOptionSlugs.Contains(SelectedPlanSlug))
        {
            return SelectedPlanSlug;
        }

        const string defaultSchinkMonthlySlug = "schink-stories-maandeliks";
        if (allOptionSlugs.Contains(defaultSchinkMonthlySlug))
        {
            return defaultSchinkMonthlySlug;
        }

        return PerfectPlanCards
            .SelectMany(card => card.Options)
            .Select(option => option.Plan.Slug)
            .FirstOrDefault() ?? string.Empty;
    }

    private bool CardHasSelectedOption(PerfectPlanCard card)
    {
        var selectedSlug = GetSelectedPlanSlug();
        return card.Options.Any(option => string.Equals(option.Plan.Slug, selectedSlug, StringComparison.OrdinalIgnoreCase));
    }

    private string GetCallToActionPlanSlug(PerfectPlanCard card)
    {
        var selectedSlug = GetSelectedPlanSlug();
        return card.Options.Any(option => string.Equals(option.Plan.Slug, selectedSlug, StringComparison.OrdinalIgnoreCase))
            ? selectedSlug
            : card.Options.FirstOrDefault()?.Plan.Slug ?? string.Empty;
    }

    private void SelectPlanOption(string planSlug)
    {
        SelectedPlanSlug = planSlug;
    }

    private static string GetPlanOptionCaption(PaymentPlan plan) =>
        plan.BillingPeriodMonths switch
        {
            <= 1 => "Volledige toegang vir 1 maand",
            12 => "Volledige toegang vir 12 maande",
            _ => $"Volledige toegang vir {plan.BillingPeriodMonths} maande"
        };

    private static readonly IReadOnlyDictionary<string, PerfectPlanCardMeta> PerfectPlanCardMetaByKey =
        new Dictionary<string, PerfectPlanCardMeta>(StringComparer.OrdinalIgnoreCase)
        {
            ["story-hoekie"] = new(
                Badge: "STORIE HOEKIE",
                Benefits:
                [
                    "Toegang tot die Storie Hoekie-reeks.",
                    "Veilige stories sonder advertensies.",
                    "Nuwe episodes word gereeld bygevoeg."
                ],
                IsFeatured: false),
            ["schink-stories"] = new(
                Badge: "MEESTE WAARDE",
                Benefits:
                [
                    "Onbeperkte toegang tot alle Schink Stories.",
                    "Luister veilig op jou foon of tablet.",
                    "Nuwe stories elke maand + volle biblioteek."
                ],
                IsFeatured: true)
        };

    private string HomeCanonicalUrl => NavigationManager.ToAbsoluteUri("/").ToString();
    private string StoryAccessPopupPrimaryHref =>
        IsSignedIn
            ? BuildOpsiesHref(PendingLockedStoryPath)
            : $"/teken-in?returnUrl={Uri.EscapeDataString(PendingLockedStoryPath)}";
    private string StoryAccessPopupPlanHref => BuildOpsiesHref(PendingLockedStoryPath);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            IsSignedIn = authState.User.Identity?.IsAuthenticated == true;
            SignedInEmail = IsSignedIn
                ? authState.User.FindFirst(ClaimTypes.Email)?.Value ?? authState.User.Identity?.Name
                : null;
            HasResolvedAuthState = true;

            var accessProfileTask = ResolveLuisterAccessProfileAsync(authState.User);
            var luisterPlaylistsTask = StoryCatalogService.GetLuisterPlaylistsAsync(SignedInEmail);

            await Task.WhenAll(accessProfileTask, luisterPlaylistsTask);

            AccessProfile = accessProfileTask.Result;
            var luisterPlaylists = luisterPlaylistsTask.Result;
            HomePlaylists = luisterPlaylists
                .Where(playlist => playlist.ShowOnHome)
                .OrderBy(playlist => playlist.SortOrder)
                .ThenBy(playlist => playlist.Title, StringComparer.OrdinalIgnoreCase)
                .ToArray();
        }
        catch
        {
            HasResolvedAuthState = true;
            HomePlaylists = Array.Empty<StoryPlaylist>();
        }
        finally
        {
            IsLoadingPlaylists = false;
        }
    }

    private bool HasAccessToStory(StoryItem story)
    {
        var requirement = StoryAccessPolicy.ResolveRequirement(GetHomeStorySource(story), story);
        return requirement switch
        {
            StoryAccessRequirement.Free => true,
            StoryAccessRequirement.StoryCornerOrAllStories => IsSignedIn && AccessProfile.HasStoryCornerOrAll,
            StoryAccessRequirement.AllStoriesOnly => IsSignedIn && AccessProfile.HasAllStories,
            _ => false
        };
    }

