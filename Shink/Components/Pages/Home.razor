    protected override async Task OnInitializedAsync()
    {
        try
        {
            var freeStoriesTask = StoryCatalogService.GetFreeStoriesAsync();
            var luisterStoriesTask = StoryCatalogService.GetLuisterStoriesAsync();
            var newestStoriesTask = StoryCatalogService.GetNewestTop10Async();
            var bibleStoriesTask = StoryCatalogService.GetBibleStoriesAsync();
            await Task.WhenAll(freeStoriesTask, luisterStoriesTask, newestStoriesTask, bibleStoriesTask);

            FreeStories = freeStoriesTask.Result;
            KleuterStories = BuildKleuterStories(freeStoriesTask.Result, luisterStoriesTask.Result);
            NewestTop10Stories = newestStoriesTask.Result;
            BibleStories = bibleStoriesTask.Result;
        }
        catch
        {
            FreeStories = Array.Empty<StoryItem>();
            KleuterStories = Array.Empty<StoryPreviewItem>();
            NewestTop10Stories = Array.Empty<StoryPreviewItem>();
            BibleStories = Array.Empty<StoryPreviewItem>();
        }
    }

    private static IReadOnlyList<StoryPreviewItem> BuildKleuterStories(
        IReadOnlyList<StoryItem> freeStories,
        IReadOnlyList<StoryItem> luisterStories)
    {
        var bySlug = new Dictionary<string, StoryLinkCandidate>(StringComparer.OrdinalIgnoreCase);
        foreach (var story in luisterStories)
        {
            bySlug[story.Slug] = new StoryLinkCandidate(
                Slug: story.Slug,
                Title: story.Title,
                CoverPath: story.ImagePath,
                LinkPath: $"/luister/{Uri.EscapeDataString(story.Slug)}");
        }

        foreach (var story in freeStories)
        {
            bySlug[story.Slug] = new StoryLinkCandidate(
                Slug: story.Slug,
                Title: story.Title,
                CoverPath: story.ImagePath,
                LinkPath: $"/gratis/{Uri.EscapeDataString(story.Slug)}");
        }

        var candidates = bySlug.Values.ToArray();
        var selected = new List<StoryPreviewItem>();
        var selectedSlugs = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        foreach (var preferredTitle in KleuterStoryTitlesInOrder)
        {
            var match = FindKleuterStoryCandidate(preferredTitle, candidates);
            if (match is null || !selectedSlugs.Add(match.Slug))
            {
                continue;
            }

            selected.Add(new StoryPreviewItem(
                Title: match.Title,
                CoverPath: match.CoverPath,
                LinkPath: match.LinkPath));
        }

        return selected;
    }

    private static StoryLinkCandidate? FindKleuterStoryCandidate(
        string preferredTitle,
        IReadOnlyList<StoryLinkCandidate> candidates)
    {
        var normalizedPreferred = NormalizeTitleKey(preferredTitle);
        if (string.IsNullOrWhiteSpace(normalizedPreferred))
        {
            return null;
        }

        var exactMatch = candidates.FirstOrDefault(candidate =>
            string.Equals(NormalizeTitleKey(candidate.Title), normalizedPreferred, StringComparison.OrdinalIgnoreCase));
        if (exactMatch is not null)
        {
            return exactMatch;
        }

        var containsMatch = candidates.FirstOrDefault(candidate =>
        {
            var normalizedCandidate = NormalizeTitleKey(candidate.Title);
            return normalizedCandidate.Contains(normalizedPreferred, StringComparison.OrdinalIgnoreCase) ||
                   normalizedPreferred.Contains(normalizedCandidate, StringComparison.OrdinalIgnoreCase);
        });
        if (containsMatch is not null)
        {
            return containsMatch;
        }

        var preferredTokens = normalizedPreferred
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (preferredTokens.Length == 0)
        {
            return null;
        }

        var requiredSharedTokens = Math.Min(2, preferredTokens.Length);
        return candidates
            .Select(candidate =>
            {
                var normalizedCandidate = NormalizeTitleKey(candidate.Title);
                var candidateTokens = normalizedCandidate
                    .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                var sharedTokenCount = preferredTokens.Count(token =>
                    candidateTokens.Contains(token, StringComparer.OrdinalIgnoreCase));

                return new
                {
                    Candidate = candidate,
                    SharedTokenCount = sharedTokenCount,
                    LengthDelta = Math.Abs(normalizedCandidate.Length - normalizedPreferred.Length)
                };
            })
            .Where(match => match.SharedTokenCount >= requiredSharedTokens)
            .OrderByDescending(match => match.SharedTokenCount)
            .ThenBy(match => match.LengthDelta)
            .Select(match => match.Candidate)
            .FirstOrDefault();
    }

    private static string NormalizeTitleKey(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var builder = new System.Text.StringBuilder(value.Length);
        var previousWasSpace = false;
        foreach (var character in value.Trim())
        {
            if (char.IsLetterOrDigit(character))
            {
                builder.Append(char.ToLowerInvariant(character));
                previousWasSpace = false;
                continue;
            }

            if (previousWasSpace)
            {
                continue;
            }

            builder.Append(' ');
            previousWasSpace = true;
        }

        return builder.ToString().Trim();
    }

