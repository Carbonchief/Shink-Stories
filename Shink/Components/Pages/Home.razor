                <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
            </button>
            <button type="button" class="carousel-nav-btn carousel-nav-btn-next" aria-label="Volgende nuutste stories"
                    @onclick="() => ScrollCarouselAsync(NewestStoriesCarouselRef, 1)">
                <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
            </button>
        </div>

        <div class="stories-carousel" role="list" aria-label="Top 10 nuutste stories" @ref="NewestStoriesCarouselRef">
        @foreach (var story in NewestTop10Stories)
        {
            var storyPath = BuildStoryPath(story.LinkPath);
            <article class="story-carousel-item" role="listitem">
                <a class="story-carousel-link"
                   href="@storyPath"
                   data-enhance-nav="false"
