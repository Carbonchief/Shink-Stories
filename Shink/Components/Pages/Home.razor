    private static string FormatAmount(decimal amount)
    {
        var hasFraction = decimal.Truncate(amount) != amount;
        return hasFraction
            ? $"R{amount.ToString("0.00", CultureInfo.InvariantCulture)}"
            : $"R{amount.ToString("0", CultureInfo.InvariantCulture)}";
    }

