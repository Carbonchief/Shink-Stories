    private async Task<LuisterAccessProfile> ResolveLuisterAccessProfileAsync(ClaimsPrincipal user)
    {
        var email = user.FindFirst(ClaimTypes.Email)?.Value
                    ?? user.Identity?.Name;
        if (string.IsNullOrWhiteSpace(email))
        {
            return new LuisterAccessProfile(false, false);
        }

        var activeTierCodes = await SubscriptionLedgerService.GetActiveTierCodesAsync(email);
        var activeTierCodeSet = activeTierCodes.ToHashSet(StringComparer.OrdinalIgnoreCase);
        var hasStoryCorner = activeTierCodeSet.Contains(StoryAccessPolicy.StoryCornerMonthlyTierCode);
        var hasAllStories =
            activeTierCodeSet.Contains(StoryAccessPolicy.AllStoriesMonthlyTierCode) ||
            activeTierCodeSet.Contains(StoryAccessPolicy.AllStoriesYearlyTierCode);

        return new LuisterAccessProfile(
            HasStoryCornerOrAll: hasStoryCorner || hasAllStories,
            HasAllStories: hasAllStories);
    }

