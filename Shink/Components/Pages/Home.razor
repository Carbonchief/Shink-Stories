    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var module = await TryGetHomeModuleAsync();
        if (module is null)
        {
            return;
        }

        try
        {
            await module.InvokeVoidAsync("initializeHomeStoryLoading");
            await module.InvokeVoidAsync("initializeHomeAnimations");
        }
        catch (JSException)
        {
            _homeModuleLoadFailed = true;
        }
    }

    private async Task<IJSObjectReference?> TryGetHomeModuleAsync()
    {
        if (_homeModuleLoadFailed)
        {
            return null;
        }

        if (_homeModule is not null)
        {
            return _homeModule;
        }

        try
        {
            _homeModule = await JS.InvokeAsync<IJSObjectReference>("import", "/Components/Pages/Home.razor.js");
            return _homeModule;
        }
        catch (JSException)
        {
            _homeModuleLoadFailed = true;
            return null;
        }
        catch (JSDisconnectedException)
        {
            return null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_homeModule is null)
        {
            return;
        }

        try
        {
            await _homeModule.InvokeVoidAsync("disposeHomeAnimations");
            await _homeModule.DisposeAsync();
        }
        catch (JSException)
        {
            // Ignore browser-specific teardown failures on older engines.
        }
        catch (JSDisconnectedException)
        {
            // Ignore JS disconnects during teardown.
        }
    }

