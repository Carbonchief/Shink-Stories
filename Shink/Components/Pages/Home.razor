@page "/"
@rendermode InteractiveServer
@attribute [StreamRendering(true)]
@using System.ComponentModel.DataAnnotations
@using System.Globalization
@using System.Net.Http.Json
@using System.Security.Claims
@using System.Text.Json
@using Shink.Components.Content
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@inject IStoryCatalogService StoryCatalogService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISubscriptionLedgerService SubscriptionLedgerService
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Schink Stories | Tuis</PageTitle>
<HeadContent>
    <link rel="stylesheet" href="@Assets["lib/bootstrap/css/bootstrap.min.css"]" />
    <link rel="canonical" href="@HomeCanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Schink Stories | Tuis" />
    <meta property="og:description" content="Afrikaanse oudiostories vir gesinne. Luister veilig en bou karakter, een storie op 'n slag." />
    <meta property="og:url" content="@NavigationManager.ToAbsoluteUri("/").ToString()" />
    <meta property="og:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:secure_url" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content="Schink Stories logo" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Schink Stories | Tuis" />
    <meta name="twitter:description" content="Afrikaanse oudiostories vir gesinne. Luister veilig en bou karakter, een storie op 'n slag." />
    <meta name="twitter:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta name="twitter:image:alt" content="Schink Stories logo" />
    <script type="application/ld+json">@HomeOrganizationJsonLd</script>
    <script type="application/ld+json">@HomeWebSiteJsonLd</script>
</HeadContent>

<section class="hero">
    <div class="hero-visual">
        <div class="hero-logo-wrap">
            <img src="/branding/schink-stories-logo-white.png" alt="Schink Stories logo" class="hero-logo"
                 width="983" height="428" loading="eager" decoding="async" />
        </div>

        <div class="hero-media">
            <img src="/branding/Schink_Stories_01.png" alt="Schink Stories hoofbeeld"
                 width="800" height="600" loading="eager" fetchpriority="high" decoding="async" />
        </div>
    </div>

    <div class="hero-copy">
        <div class="hero-copy-text">
            <h1>
                Bou jou kind se karakter -
                <span>een storie op 'n slag.</span>
            </h1>
            <p class="hero-intro">
                Rustige, opbouende <strong>Afrikaanse storietyd</strong> - sonder skerms.
            </p>
            <p class="hero-support">Minder skerms. Rustiger aande. Stories wat waardes bou.</p>
        </div>
        <div class="hero-actions">
            @if (!HasResolvedAuthState)
            {
                <span class="cta cta-placeholder" aria-hidden="true"></span>
            }
            else if (IsSignedIn)
            {
                <a class="cta cta-primary" href="/luister">Luister Stories</a>
            }
            else
            {
                <button type="button" class="cta cta-primary" @onclick="@(() => NavigationManager.NavigateTo("/gratis"))">PROBEER GRATIS</button>
                <a class="cta cta-secondary" href="#perfekte-plan">KIES 'N PLAN</a>
            }
        </div>
        <p class="hero-pricing">R 79 per maand. Kanselleer enige tyd.</p>
    </div>
</section>

<div class="home-content-gradient">
@if (IsLoadingPlaylists && HomePlaylists.Count == 0)
{
    @for (var index = 0; index < 2; index++)
    {
        <section class="section-block stories-carousel-section home-loading-section" aria-hidden="true">
            <div class="home-loading-title shimmer-block"></div>
            <div class="home-loading-subtitle shimmer-block"></div>
            <div class="home-loading-carousel">
                @for (var storyIndex = 0; storyIndex < 4; storyIndex++)
                {
                    <article class="home-loading-card">
                        <div class="home-loading-cover shimmer-block"></div>
                        <div class="home-loading-line shimmer-block"></div>
                    </article>
                }
            </div>
        </section>
    }
}
else
{
    @for (var index = 0; index < HomePlaylists.Count; index++)
    {
        var playlist = HomePlaylists[index];
        var headingId = $"home-playlist-{playlist.Slug}-heading";
        var hasDescription = !string.IsNullOrWhiteSpace(playlist.Description);
        var isWeeklyPopularPlaylist = IsWeeklyPopularPlaylist(playlist);
        var displayTitle = GetHomePlaylistTitle(playlist);
        var sectionClassName = isWeeklyPopularPlaylist
            ? "section-block stories-carousel-section stories-carousel-section-ranked home-scroll-reveal"
            : "section-block stories-carousel-section home-scroll-reveal";
        var carouselClassName = $"stories-carousel {(playlist.Stories.Count <= 3 ? "stories-carousel-free" : string.Empty)}";
        var rankedStoryItemStyle = isWeeklyPopularPlaylist ? WeeklyPopularStoryItemInlineStyle : null;

        <section class="@sectionClassName" style="--home-reveal-delay: 0.08s;" aria-labelledby="@headingId">
            <h2 id="@headingId">@displayTitle</h2>
            @if (hasDescription)
            {
                <p class="section-intro">@playlist.Description</p>
            }

            <div class="stories-carousel-shell">
                <div class="@carouselClassName"
                     role="list"
                     aria-label="@displayTitle">
                @for (var storyIndex = 0; storyIndex < playlist.Stories.Count; storyIndex++)
                {
                    var story = playlist.Stories[storyIndex];
                    var storyPath = GetHomeStoryHref(story);
                    var canAccessStory = HasAccessToStory(story);
                    var articleClassName = isWeeklyPopularPlaylist
                        ? "story-carousel-item story-carousel-item-ranked"
                        : "story-carousel-item";

                    <article class="@articleClassName" style="@rankedStoryItemStyle" role="listitem">
                        @if (isWeeklyPopularPlaylist)
                        {
                            <span class="story-carousel-rank" style="@WeeklyPopularStoryRankInlineStyle" aria-hidden="true">@((storyIndex + 1).ToString(CultureInfo.InvariantCulture))</span>
                        }
                        @if (canAccessStory)
                        {
                            <a class="story-carousel-link"
                               href="@storyPath"
                               data-enhance-nav="false"
                               draggable="false"
                               aria-label="Luister @story.Title">
                                <span class="story-carousel-cover">
                                    <img class="story-carousel-image"
                                         src="@story.ThumbnailPath"
                                         srcset="@($"{story.ThumbnailPath} 640w, {story.ImagePath} 1024w")"
                                         sizes="(max-width: 620px) 56vw, (max-width: 900px) 35vw, 240px"
                                         draggable="false"
                                         alt="Voorblad van @story.Title" width="640" height="485" loading="lazy" decoding="async" />
                                    <span class="story-cover-play" aria-hidden="true">
                                        <i class="story-cover-play-icon fa-solid fa-play" aria-hidden="true"></i>
                                    </span>
                                </span>
                                <h3>@story.Title</h3>
                            </a>
                        }
                        else
                        {
                            <button type="button"
                                    class="story-carousel-link story-carousel-link-button"
                                    @onclick="@(() => ShowAccessPopupForPath(storyPath))"
                                    aria-label="Luister @story.Title">
                                <span class="story-carousel-cover">
                                    <img class="story-carousel-image"
                                         src="@story.ThumbnailPath"
                                         srcset="@($"{story.ThumbnailPath} 640w, {story.ImagePath} 1024w")"
                                         sizes="(max-width: 620px) 56vw, (max-width: 900px) 35vw, 240px"
                                         draggable="false"
                                         alt="Voorblad van @story.Title" width="640" height="485" loading="lazy" decoding="async" />
                                    <span class="story-cover-play" aria-hidden="true">
                                        <i class="story-cover-play-icon fa-solid fa-play" aria-hidden="true"></i>
                                    </span>
                                </span>
                                <h3>@story.Title</h3>
                            </button>
                        }
                    </article>
                }
                </div>
            </div>
        </section>
    }
}

<StoryAccessPopup IsOpen="@ShowStoryAccessPopup"
                  PrimaryActionHref="@StoryAccessPopupPrimaryHref"
                  PlanActionHref="@StoryAccessPopupPlanHref"
                  OnClose="CloseStoryAccessPopupAsync" />

