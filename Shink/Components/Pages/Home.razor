@page "/"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using System.Globalization
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.AspNetCore.WebUtilities
@using Shink.Components.Content
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Schink Stories | Tuis</PageTitle>
<HeadContent>
    <link rel="canonical" href="@HomeCanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Schink Stories | Tuis" />
    <meta property="og:description" content="Afrikaanse oudiostories vir gesinne. Luister veilig en bou karakter, een storie op 'n slag." />
    <meta property="og:url" content="@NavigationManager.ToAbsoluteUri("/").ToString()" />
    <meta property="og:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:secure_url" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content="Schink Stories logo" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Schink Stories | Tuis" />
    <meta name="twitter:description" content="Afrikaanse oudiostories vir gesinne. Luister veilig en bou karakter, een storie op 'n slag." />
    <meta name="twitter:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta name="twitter:image:alt" content="Schink Stories logo" />
    <script type="application/ld+json">@HomeOrganizationJsonLd</script>
    <script type="application/ld+json">@HomeWebSiteJsonLd</script>
</HeadContent>

<section class="hero">
    <div class="hero-visual">
        <div class="hero-logo-wrap">
            <img src="/branding/schink-stories-logo-white.png" alt="Schink Stories logo" class="hero-logo"
                 width="983" height="428" loading="eager" decoding="async" />
        </div>

        <div class="hero-media">
            <img src="/branding/Schink_Stories_01.png" alt="Schink Stories hoofbeeld"
                 width="800" height="600" loading="eager" fetchpriority="high" decoding="async" />
        </div>
    </div>

    <div class="hero-copy">
        <p class="eyebrow">Afrikaanse oudiostories</p>
        <h1>Bou jou kind se karakter, een storie op 'n slag.</h1>
        <p>
            Schink Stories gee vir ouers en kinders stories wat opbou, vermaak en geloofsgesprekke maklik maak.
            Begin vandag met drie gratis stories.
        </p>
        <div class="hero-actions">
            <button type="button" class="cta cta-primary" @onclick="@(() => NavigationManager.NavigateTo("/gratis"))">Luister gratis</button>
            <button type="button" class="cta cta-secondary" @onclick="@(() => NavigationManager.NavigateTo("/gratis"))">Sien alle stories</button>
        </div>
    </div>
</section>

<section class="join-promo">
    <div class="join-promo-media">
        <img src="/branding/Schink_Stories_Kom_Luister_Saam.webp"
             alt="Kom Luister Saam by Schink Stories" loading="lazy" decoding="async" />
    </div>

    <div class="join-promo-copy">
        <p class="join-promo-intro">Ontdek 'n wereld vol verbeelding, pret en betekenis.</p>

        <ul class="join-promo-list">
            <li>Geniet <strong>onbeperkte toegang</strong> tot al ons Afrikaanse oudiostories en reekse</li>
            <li>Dis veilig vir kinders - <strong>geen advertensies of donker temas nie</strong></li>
            <li>Bou gesonde karakter, leer goeie waardes en waardevolle lewenslesse</li>
            <li>Help met taalontwikkeling, ouditiewe ontwikkeling, fokus en soveel meer</li>
            <li>Nuwe stories elke maand + toegang tot die volledige versameling</li>
        </ul>

        <a class="join-promo-cta" href="/opsies">Sluit aan vir slegs R 79 p/maand</a>
    </div>
</section>

<section class="section-block stories-carousel-section" aria-labelledby="gratis-stories-heading">
    <h2 id="gratis-stories-heading">Kom probeer 3 van ons lekkerste stories</h2>
    <p class="section-intro">Dis op die huis!</p>

    <div class="stories-carousel" role="list" aria-label="Gratis stories">
        @foreach (var story in StoryCatalog.All)
        {
            <article class="story-carousel-item" role="listitem">
                <a class="story-carousel-link" href="@($"/gratis/{story.Slug}")" aria-label="Luister @story.Title">
                    <span class="story-carousel-cover">
                        <img class="@(story.Slug == "die-kwaaibok-se-klip" ? "story-carousel-image kwaaibok-home-cover" : "story-carousel-image")"
                             src="@story.ThumbnailPath"
                             srcset="@($"{story.ThumbnailPath} 640w, {story.ImagePath} 1024w")"
                             sizes="(max-width: 620px) 56vw, (max-width: 900px) 35vw, 240px"
                             alt="Voorblad van @story.Title" width="640" height="485" loading="lazy" decoding="async" />
                        <span class="story-cover-play" aria-hidden="true">
                            <span class="story-cover-play-icon">&#9654;</span>
                        </span>
                    </span>
                    <h3>@story.Title</h3>
                </a>
            </article>
        }
    </div>
</section>

<section class="section-block stories-carousel-section newest-stories-section" aria-labelledby="nuutste-stories-heading">
    <h2 id="nuutste-stories-heading">Top 10 nuutste stories</h2>
    <p class="section-intro">Kry 'n voorsmakie van ons nuutste uitgawes.</p>

    <div class="stories-carousel" role="list" aria-label="Top 10 nuutste stories">
        @foreach (var story in StoryCatalog.NewestTop10)
        {
            <article class="story-carousel-item" role="listitem">
                <a class="story-carousel-link" href="@story.LinkPath" aria-label="Sien storie: @story.Title">
                    <span class="story-carousel-cover">
                        <img class="story-carousel-image"
                             src="@story.CoverPath"
                             alt="Voorblad van @story.Title" width="600" height="775" loading="lazy" decoding="async" />
                        <span class="story-cover-play" aria-hidden="true">
                            <span class="story-cover-play-icon">&#9654;</span>
                        </span>
                    </span>
                    <h3>@story.Title</h3>
                </a>
            </article>
        }
    </div>
</section>

<section class="perfect-plan-section" aria-labelledby="perfekte-plan">
    <div class="perfect-plan-header">
        <h2 id="perfekte-plan">Vind jou perfekte plan</h2>
        <p>Vergelyk ons opsies en kies die intekening wat die beste by jou gesin pas.</p>
    </div>

    <div class="perfect-plan-grid">
        @foreach (var card in PerfectPlanCards)
        {
            <article class="@($"perfect-plan-card {(card.IsFeatured ? "is-featured" : null)}")">
                <p class="perfect-plan-badge">@card.Badge</p>
                <h3>@card.Title</h3>

                <ul class="perfect-plan-list">
                    @foreach (var benefit in card.Benefits)
                    {
                        <li>@benefit</li>
                    }
                </ul>

                <div class="perfect-plan-options" aria-label="@($"Prys opsies vir {card.Title}")">
                    @foreach (var option in card.Options)
                    {
                        var optionId = $"perfect-plan-{card.Key}-{option.Plan.Slug}";
                        var isSelected = IsSelectedPlanOption(option.Plan.Slug);

                        <label class="@($"perfect-plan-option {(isSelected ? "is-selected" : null)}")" for="@optionId">
                            <input id="@optionId"
                                   type="radio"
                                   name="perfect-plan-group-global"
                                   checked="@isSelected"
                                   @onchange="@(() => SelectPlanOption(option.Plan.Slug))" />
                            <span class="perfect-plan-option-indicator" aria-hidden="true"></span>
                            <span class="perfect-plan-option-text">
                                <span class="perfect-plan-option-price-line">
                                    <strong>@FormatAmount(option.Plan.Amount)</strong>
                                    <span>@GetBillingLabel(option.Plan)</span>
                                </span>
                                <span class="perfect-plan-option-caption">@option.Caption</span>
                            </span>
                        </label>
                    }
                </div>

                <a class="@($"perfect-plan-select {(CardHasSelectedOption(card) ? "is-linked-selected" : null)}")"
                   href="@GetSelectedPlanHref(card)">Kies plan</a>
            </article>
        }
    </div>
</section>

<section class="contact-section" aria-labelledby="kontak-ons">
    <div class="contact-inner">
        <h2 id="kontak-ons" class="contact-title">Kontak Ons</h2>

        <div class="contact-copy">
            <h3>Het jy vrae? Ons help graag.</h3>
            <p>
                Stuur vir ons 'n boodskap en ons kom so gou moontlik by jou terug.
            </p>
        </div>

        <div class="contact-form-shell">
            <EditForm class="contact-form" Model="ContactForm" OnValidSubmit="HandleContactSubmitAsync" aria-busy="@IsSubmitting">
                <DataAnnotationsValidator />

                <div class="contact-honeypot" aria-hidden="true">
                    <label for="contact-website">Webwerf</label>
                    <InputText id="contact-website" autocomplete="off" tabindex="-1" @bind-Value="ContactForm.Website" />
                </div>

                <div class="contact-fields-grid">
                    <div class="contact-field">
                        <label for="contact-name">Naam</label>
                        <InputText id="contact-name" autocomplete="name" @bind-Value="ContactForm.Name" />
                        <ValidationMessage For="@(() => ContactForm.Name)" />
                    </div>

                    <div class="contact-field">
                        <label for="contact-email">E-pos</label>
                        <InputText id="contact-email" type="email" autocomplete="email" @bind-Value="ContactForm.Email" />
                        <ValidationMessage For="@(() => ContactForm.Email)" />
                    </div>
                </div>

                <div class="contact-field">
                    <label for="contact-subject">Onderwerp</label>
                    <InputText id="contact-subject" autocomplete="off" @bind-Value="ContactForm.Subject" />
                    <ValidationMessage For="@(() => ContactForm.Subject)" />
                </div>

                <div class="contact-field">
                    <label for="contact-message">Boodskap</label>
                    <InputTextArea id="contact-message" rows="5" @bind-Value="ContactForm.Message" />
                    <ValidationMessage For="@(() => ContactForm.Message)" />
                </div>

                <button type="submit" class="contact-submit" disabled="@IsSubmitting">
                    @(IsSubmitting ? "Besig om te stuur..." : "Stuur boodskap")
                </button>

                @if (!string.IsNullOrWhiteSpace(FormStatusMessage))
                {
                    <p class="@($"contact-status {(SubmitSucceeded ? "contact-status-success" : "contact-status-error")}")"
                       role="@(SubmitSucceeded ? "status" : "alert")"
                       aria-live="polite">
                        @FormStatusMessage
                    </p>
                }
            </EditForm>
        </div>
    </div>
</section>

@code {
    private ContactFormModel ContactForm { get; set; } = new();
    private bool IsSubmitting { get; set; }
    private bool SubmitSucceeded { get; set; }
    private string? FormStatusMessage { get; set; }
    private bool HasHandledAuthenticatedRedirect { get; set; }
    private string? SelectedPlanSlug { get; set; }
    private IReadOnlyList<PerfectPlanCard> PerfectPlanCards =>
        BuildPerfectPlanCards();

    private IReadOnlyList<PerfectPlanCard> BuildPerfectPlanCards()
    {
        var cards = new List<PerfectPlanCard>();

        var storyHoekiePlan = PaymentPlanCatalog.All.FirstOrDefault(plan =>
            string.Equals(plan.TierCode, "story_corner_monthly", StringComparison.OrdinalIgnoreCase));

        if (storyHoekiePlan is not null)
        {
            var cardMeta = PerfectPlanCardMetaByKey["story-hoekie"];
            cards.Add(new PerfectPlanCard(
                Key: "story-hoekie",
                Title: storyHoekiePlan.Name,
                Badge: cardMeta.Badge,
                Benefits: cardMeta.Benefits,
                Options:
                [
                    new PerfectPlanOption(storyHoekiePlan, "Storie Hoekie-reeks")
                ],
                IsFeatured: cardMeta.IsFeatured));
        }

        var schinkPlans = PaymentPlanCatalog.All
            .Where(plan => string.Equals(plan.TierCode, "all_stories_monthly", StringComparison.OrdinalIgnoreCase) ||
                           string.Equals(plan.TierCode, "all_stories_yearly", StringComparison.OrdinalIgnoreCase))
            .OrderBy(plan => plan.BillingPeriodMonths)
            .ThenBy(plan => plan.Amount)
            .ToArray();

        if (schinkPlans.Length > 0)
        {
            var cardMeta = PerfectPlanCardMetaByKey["schink-stories"];
            cards.Add(new PerfectPlanCard(
                Key: "schink-stories",
                Title: "Schink Stories",
                Badge: cardMeta.Badge,
                Benefits: cardMeta.Benefits,
                Options: schinkPlans
                    .Select(plan => new PerfectPlanOption(plan, GetPlanOptionCaption(plan)))
                    .ToArray(),
                IsFeatured: cardMeta.IsFeatured));
        }

        return cards;
    }

    private string GetSelectedPlanHref(PerfectPlanCard card)
    {
        var selectedPlanSlug = GetCallToActionPlanSlug(card);
        return string.IsNullOrWhiteSpace(selectedPlanSlug)
            ? "/opsies"
            : $"/betaal/{selectedPlanSlug}";
    }

    private bool IsSelectedPlanOption(string planSlug) =>
        string.Equals(GetSelectedPlanSlug(), planSlug, StringComparison.OrdinalIgnoreCase);

    private string GetSelectedPlanSlug()
    {
        var allOptionSlugs = PerfectPlanCards
            .SelectMany(card => card.Options)
            .Select(option => option.Plan.Slug)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (SelectedPlanSlug is not null && allOptionSlugs.Contains(SelectedPlanSlug))
        {
            return SelectedPlanSlug;
        }

        return PerfectPlanCards
            .SelectMany(card => card.Options)
            .Select(option => option.Plan.Slug)
            .FirstOrDefault() ?? string.Empty;
    }

    private bool CardHasSelectedOption(PerfectPlanCard card)
    {
        var selectedSlug = GetSelectedPlanSlug();
        return card.Options.Any(option => string.Equals(option.Plan.Slug, selectedSlug, StringComparison.OrdinalIgnoreCase));
    }

    private string GetCallToActionPlanSlug(PerfectPlanCard card)
    {
        var selectedSlug = GetSelectedPlanSlug();
        return card.Options.Any(option => string.Equals(option.Plan.Slug, selectedSlug, StringComparison.OrdinalIgnoreCase))
            ? selectedSlug
            : card.Options.FirstOrDefault()?.Plan.Slug ?? string.Empty;
    }

    private void SelectPlanOption(string planSlug)
    {
        SelectedPlanSlug = planSlug;
    }

    private static string GetPlanOptionCaption(PaymentPlan plan) =>
        plan.BillingPeriodMonths switch
        {
            <= 1 => "Volledige toegang vir 1 maand",
            12 => "Volledige toegang vir 12 maande",
            _ => $"Volledige toegang vir {plan.BillingPeriodMonths} maande"
        };

    private static readonly IReadOnlyDictionary<string, PerfectPlanCardMeta> PerfectPlanCardMetaByKey =
        new Dictionary<string, PerfectPlanCardMeta>(StringComparer.OrdinalIgnoreCase)
        {
            ["story-hoekie"] = new(
                Badge: "STORIE HOEKIE",
                Benefits:
                [
                    "Toegang tot die Storie Hoekie-reeks.",
                    "Veilige stories sonder advertensies.",
                    "Nuwe episodes word gereeld bygevoeg."
                ],
                IsFeatured: false),
            ["schink-stories"] = new(
                Badge: "MEESTE WAARDE",
                Benefits:
                [
                    "Onbeperkte toegang tot alle Schink Stories.",
                    "Luister veilig op jou foon of tablet.",
                    "Nuwe stories elke maand + volle biblioteek."
                ],
                IsFeatured: true)
        };

    private string HomeCanonicalUrl => NavigationManager.ToAbsoluteUri("/").ToString();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || HasHandledAuthenticatedRedirect || HasHomeOverrideQuery())
        {
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var isAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;
        if (!isAuthenticated)
        {
            return;
        }

        HasHandledAuthenticatedRedirect = true;
        NavigationManager.NavigateTo("/gratis", replace: true);
    }

    private MarkupString HomeOrganizationJsonLd => new(JsonSerializer.Serialize(new
    {
        @context = "https://schema.org",
        @type = "Organization",
        name = "Schink Stories",
        url = HomeCanonicalUrl,
        logo = NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString(),
        sameAs = new[]
        {
            "https://www.facebook.com/SchinkPublishing",
            "https://www.instagram.com/schinkpublishing/"
        }
    }));

    private MarkupString HomeWebSiteJsonLd => new(JsonSerializer.Serialize(new
    {
        @context = "https://schema.org",
        @type = "WebSite",
        name = "Schink Stories",
        url = HomeCanonicalUrl,
        inLanguage = "af-ZA"
    }));

    private async Task HandleContactSubmitAsync()
    {
        if (IsSubmitting)
        {
            return;
        }

        IsSubmitting = true;
        SubmitSucceeded = false;
        FormStatusMessage = null;

        try
        {
            var client = HttpClientFactory.CreateClient();
            var endpoint = NavigationManager.ToAbsoluteUri("/api/contact");

            var payload = new ContactApiPayload(
                Name: ContactForm.Name.Trim(),
                Email: ContactForm.Email.Trim(),
                Subject: ContactForm.Subject.Trim(),
                Message: ContactForm.Message.Trim(),
                Website: ContactForm.Website.Trim());

            var response = await client.PostAsJsonAsync(endpoint, payload);

            if (response.IsSuccessStatusCode)
            {
                SubmitSucceeded = true;
                FormStatusMessage = "Dankie! Jou boodskap is gestuur.";
                ContactForm = new ContactFormModel();
                return;
            }

            SubmitSucceeded = false;
            FormStatusMessage = await ReadContactApiErrorAsync(response)
                ?? "Jammer, iets het verkeerd geloop. Probeer asseblief weer.";
        }
        catch
        {
            SubmitSucceeded = false;
            FormStatusMessage = "Jammer, iets het verkeerd geloop. Probeer asseblief weer.";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private static async Task<string?> ReadContactApiErrorAsync(HttpResponseMessage response)
    {
        try
        {
            await using var stream = await response.Content.ReadAsStreamAsync();
            using var doc = await JsonDocument.ParseAsync(stream);

            if (doc.RootElement.TryGetProperty("message", out var messageNode) &&
                messageNode.ValueKind == JsonValueKind.String)
            {
                var message = messageNode.GetString();
                if (!string.IsNullOrWhiteSpace(message))
                {
                    return message;
                }
            }

            if (doc.RootElement.TryGetProperty("errors", out var errorsNode) &&
                errorsNode.ValueKind == JsonValueKind.Object)
            {
                foreach (var property in errorsNode.EnumerateObject())
                {
                    if (property.Value.ValueKind == JsonValueKind.Array &&
                        property.Value.GetArrayLength() > 0 &&
                        property.Value[0].ValueKind == JsonValueKind.String)
                    {
                        var firstError = property.Value[0].GetString();
                        if (!string.IsNullOrWhiteSpace(firstError))
                        {
                            return firstError;
                        }
                    }
                }
            }
        }
        catch
        {
            // Ignore parsing errors and use fallback message.
        }

        return null;
    }

    private bool HasHomeOverrideQuery()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (!query.TryGetValue("home", out var value))
        {
            return false;
        }

        var token = value.ToString();
        return string.Equals(token, "1", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(token, "true", StringComparison.OrdinalIgnoreCase);
    }

    private static string FormatAmount(decimal amount)
    {
        var hasFraction = decimal.Truncate(amount) != amount;
        return hasFraction
            ? $"R{amount.ToString("0.00", CultureInfo.InvariantCulture)}"
            : $"R{amount.ToString("0", CultureInfo.InvariantCulture)}";
    }

    private static string GetBillingLabel(PaymentPlan plan) =>
        plan.BillingPeriodMonths switch
        {
            <= 1 => "maandeliks",
            12 => "jaarliks",
            _ => $"elke {plan.BillingPeriodMonths} maande"
        };

    private sealed record ContactApiPayload(
        string Name,
        string Email,
        string Subject,
        string Message,
        string Website);

    private sealed record PerfectPlanCard(
        string Key,
        string Title,
        string Badge,
        IReadOnlyList<string> Benefits,
        IReadOnlyList<PerfectPlanOption> Options,
        bool IsFeatured);

    private sealed record PerfectPlanOption(
        PaymentPlan Plan,
        string Caption);

    private sealed record PerfectPlanCardMeta(
        string Badge,
        IReadOnlyList<string> Benefits,
        bool IsFeatured);

    private sealed class ContactFormModel
    {
        [Required(ErrorMessage = "Vul asseblief jou naam in.")]
        [StringLength(120)]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Vul asseblief jou e-pos in.")]
        [EmailAddress(ErrorMessage = "Gebruik asseblief 'n geldige e-posadres.")]
        [StringLength(254)]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Vul asseblief 'n onderwerp in.")]
        [StringLength(140)]
        public string Subject { get; set; } = string.Empty;

        [Required(ErrorMessage = "Vul asseblief jou boodskap in.")]
        [StringLength(4000)]
        public string Message { get; set; } = string.Empty;

        public string Website { get; set; } = string.Empty;
    }
}

