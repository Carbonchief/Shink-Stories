@page "/error"
@page "/error/{StatusCode:int}"
@layout MainLayout
@using System.Diagnostics
@inject NavigationManager NavigationManager

<PageTitle>@PageTitleText</PageTitle>
<HeadContent>
    <meta name="description" content="@MetaDescription" />
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />
    <link rel="canonical" href="@NavigationManager.ToAbsoluteUri(CanonicalUrl).ToString()" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@PageTitleText" />
    <meta property="og:description" content="@MetaDescription" />
    <meta property="og:url" content="@NavigationManager.ToAbsoluteUri(CanonicalUrl).ToString()" />
    <meta property="og:image" content="@NavigationManager.ToAbsoluteUri("/media/imported/misc/2024/09/404_Rammetjie.png").ToString()" />
    <meta property="og:image:secure_url" content="@NavigationManager.ToAbsoluteUri("/media/imported/misc/2024/09/404_Rammetjie.png").ToString()" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="955" />
    <meta property="og:image:height" content="1280" />
    <meta property="og:image:alt" content="Rammetjie met sterre" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@PageTitleText" />
    <meta name="twitter:description" content="@MetaDescription" />
    <meta name="twitter:image" content="@NavigationManager.ToAbsoluteUri("/media/imported/misc/2024/09/404_Rammetjie.png").ToString()" />
    <meta name="twitter:image:alt" content="Rammetjie met sterre" />
</HeadContent>

<section class="error-shell" aria-labelledby="error-heading">
    <img class="error-image"
         src="/media/imported/misc/2024/09/404_Rammetjie.png"
         alt="Illustrasie vir 'n vriendelike foutblad"
         width="420"
         height="420"
         loading="eager"
         fetchpriority="high"
         decoding="async" />

    <div class="error-copy">
        <p class="error-kicker">@KickerText</p>
        <h1 id="error-heading">@PageHeading</h1>
        <p>@PageBodyText</p>

        @if (ShowRequestId)
        {
            <p class="error-request-id">
                <strong>Aanvraagnommer:</strong> <code>@RequestId</code>
            </p>
        }
        else if (IsServerError)
        {
            <p class="error-request-id-note">
                Probeer weer later of kontak ons met hierdie bladsy as die fout aanhou.
            </p>
        }

        <a class="error-home-btn" href="/">KEER TERUG NA DIE TUISBLAD</a>
    </div>
</section>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    [Parameter]
    public int? StatusCode { get; set; }

    private int ResolvedStatusCode { get; set; } = 500;
    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);
    private bool IsServerError => ResolvedStatusCode == 500;

    private string KickerText => IsServerError ? "500 - Bedienersfout" : "Oeps, blad nie gevind nie";
    private string PageTitleText => $"{ResolvedStatusCode} Fout | Schink Stories";
    private string MetaDescription => IsServerError
        ? "Die bladsy kon nie verwerk word nie. Ons werk reeds aan 'n regstelling."
        : "Die blad waarna jy soek bestaan nie op Schink Stories nie.";
    private string CanonicalUrl => $"/error/{ResolvedStatusCode}";
    private string PageHeading => IsServerError
        ? "Oeps, iets het skeefgeloop"
        : "Oeps, blad nie gevind nie";
    private string PageBodyText => IsServerError
        ? "Ons vra om verskoning. Die bediener het 'n fout teëgekom. Probeer die bladsy weer, of gaan terug huis toe."
        : "Die blad waarna jy gesoek het, bestaan nie op hierdie pad nie.";

    protected override void OnInitialized()
    {
        var responseStatus = HttpContext?.Response?.StatusCode;
        if (StatusCode is 404 or 500)
        {
            ResolvedStatusCode = StatusCode.Value;
        }
        else if (responseStatus is 404 or 500)
        {
            ResolvedStatusCode = responseStatus.Value;
        }

        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
    }
}
