@page "/not-found"
@layout MainLayout
@inject NavigationManager NavigationManager

<PageTitle>Blad nie gevind nie | Schink Stories</PageTitle>
<HeadContent>
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Blad nie gevind nie | Schink Stories" />
    <meta property="og:description" content="Die blad waarna jy soek bestaan nie op Schink Stories nie." />
    <meta property="og:url" content="@NavigationManager.ToAbsoluteUri("/not-found").ToString()" />
    <meta property="og:image" content="@NavigationManager.ToAbsoluteUri("/media/imported/misc/2024/09/404_Rammetjie.png").ToString()" />
    <meta property="og:image:secure_url" content="@NavigationManager.ToAbsoluteUri("/media/imported/misc/2024/09/404_Rammetjie.png").ToString()" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content="Rammetjie illustrasie vir blad nie gevind nie" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Blad nie gevind nie | Schink Stories" />
    <meta name="twitter:description" content="Die blad waarna jy soek bestaan nie op Schink Stories nie." />
    <meta name="twitter:image" content="@NavigationManager.ToAbsoluteUri("/media/imported/misc/2024/09/404_Rammetjie.png").ToString()" />
    <meta name="twitter:image:alt" content="Rammetjie illustrasie vir blad nie gevind nie" />
</HeadContent>

<section class="not-found-shell" aria-labelledby="not-found-heading">
    <img class="not-found-image"
         src="/media/imported/misc/2024/09/404_Rammetjie.png"
         alt="Rammetjie met sterretjies bo sy kop"
         width="420" height="420"
         loading="eager" fetchpriority="high" decoding="async" />

    <div class="not-found-copy">
        <h1 id="not-found-heading">Oeps, blad nie gevind nie</h1>
        <p>
            Die blad wat jy versoek het, het die pad byster geraak.
            Keer terug na die tuisblad en probeer weer. Jammer hieroor.
        </p>
        <a class="not-found-home-btn" href="/?home=1">KEER TERUG NA DIE TUISBLAD</a>
    </div>
</section>
