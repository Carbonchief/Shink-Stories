@page "/meer-oor-ons"

@using System.Text.Json
@using Microsoft.AspNetCore.Components
@inject NavigationManager NavigationManager

<PageTitle>Schink Stories | Meer oor Ons</PageTitle>
<HeadContent>
    <link rel="canonical" href="@MeerOorOnsCanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Schink Stories | Meer oor Ons" />
    <meta property="og:description" content="Leer meer oor Schink Stories se missie, visie en waardes vir veilige Afrikaanse kinderstories." />
    <meta property="og:url" content="@MeerOorOnsCanonicalUrl" />
    <meta property="og:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:secure_url" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content="Schink Stories logo" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Schink Stories | Meer oor Ons" />
    <meta name="twitter:description" content="Leer meer oor Schink Stories se missie, visie en waardes vir veilige Afrikaanse kinderstories." />
    <meta name="twitter:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta name="twitter:image:alt" content="Schink Stories logo" />
    <JsonLdScript Json="@MeerOorOnsJsonLd" />
</HeadContent>

<section class="about-page">
    <div class="about-hero">
        <img src="/branding/Schink_Die_Ware_Wenner_Schink_Stories_600x600.png"
             alt="Schink Die Ware Wenner" width="600" height="600"
             loading="eager" fetchpriority="high" decoding="async" />
    </div>

    <section class="about-title-block">
        <p class="eyebrow">Meer oor ons</p>
        <h1>Bou karakter - een storie op 'n slag.</h1>
    </section>

    <section class="about-block about-intro-block">
        <p>
            Ons hoop om vir gesinne 'n veilige plek te bied waar hulle stories kan ontdek wat kinders en
            ouers versterk. Elke storie dra waardes, lewenslesse en sleutels wat help om deure in die lewens
            van kinders oop te maak.
        </p>
        <p>
            In 'n wereld waar ouers nie altyd kan vertrou wat vir kinders gemaak word nie, wil ons 'n rusplek
            wees - 'n plek waar kreatiewe, opbouende en veilige inhoud kinders toerus om vandag en more
            staande te bly.
        </p>
        <p><strong>Bou saam met ons - vir jou kind en vir kinders oraloor.</strong></p>
    </section>

    <section class="about-block founder-block">
        <img src="/branding/Matin-Profile-Photo.webp" alt="Martin Schwella profiel foto"
             class="founder-photo" loading="lazy" decoding="async" />
        <p><strong>Martin Schwella</strong></p>
        <p><em>Stigter, Schink</em></p>
    </section>

    <section class="about-card mission-image-block">
        <img src="/branding/Aap.webp" alt="Schink Aap" class="mission-aap" loading="lazy" decoding="async" />
    </section>

    <div class="about-grid">
        <section class="about-card focus-card mission-card">
            <h2>Ons missie</h2>
            <p>
                Ons skep veilige, opbouende stories en kuns vir gesinne, wat kinders en ouers toerus met
                gesonde waardes, lewenslesse en karakter.
            </p>
        </section>

        <section class="about-card focus-card vision-card">
            <h2>Ons visie</h2>
            <p>
                Om gesinne regoor die wereld te "voed" met stories wat inspireer, leer en versterk. Ons droom
                is om Schink Stories uit te bou van oudiostories na boeke, musiek, video en animasie - alles
                met dieselfde waarborg: veilig, heilsame vermaak vir kinders.
            </p>
        </section>
    </div>

    <section class="about-card focus-card values-card">
        <h2>Ons waardes</h2>
        <ul>
            <li><strong>Kreatiwiteit</strong> - Ons glo elke storie is 'n unieke kunswerk.</li>
            <li><strong>Inspirasie</strong> - Ons wil hoop en geloof kweek in elke kind en ouer wat luister.</li>
            <li><strong>Gesinne</strong> - Alles wat ons doen, bou sterker families.</li>
        </ul>
    </section>

    <section class="about-block callout">
        <h2>Ons Belofte aan Ouer &amp; Kind</h2>
        <p>
            In 'n wereld waar jy nie meer alles kan vertrou wat vir kinders gemaak word nie, staan ons vas:
            <strong>Schink Stories is veilig, opbouend en geskik vir enige ouderdom.</strong>
        </p>
        <img src="/branding/Panda.webp" alt="Schink Panda" class="promise-panda" loading="lazy" decoding="async" />
    </section>

    <section class="about-grid">
        <section class="about-card">
            <h2>Wees deel van ons reis</h2>
            <p><strong>Wees deel van ons reis:</strong> Deel ons stories en laat ander ouers weet van Schink.</p>
            <p><strong>Help ons groei:</strong> Ons droom is om ook boeke, musiek en animasie te publiseer.</p>
        </section>

        <section class="about-card">
            <h2>Dra by</h2>
            <p>SCHINK PTY. LTD.<br />Absa Current Account<br />4093095923<br />Branch 632005</p>
        </section>
    </section>

    <section class="about-card testimonials">
        <h2>Wat ouers se</h2>
        <div class="review-grid">
            <article class="review-card">
                <p class="review-stars" aria-hidden="true">
                    <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                </p>
                <blockquote>
                    Ek love al Schink se stories. Dit is in goeie taal en daar is 'n goeie lessie in elke storie.
                    Maar, ek love Georgie se Radio want in die huis kan dinge loud raak.
                </blockquote>
                <p class="review-author">- Renske<br /><span class="review-role">Arbeidsterapeut</span></p>
            </article>

            <article class="review-card">
                <p class="review-stars" aria-hidden="true">
                    <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                </p>
                <blockquote>
                    Lief lief! Ons drie oudste kids se GUNSTELING! Schink Stories maak bedtyd 'n tyd om na uit te
                    sien. My drie-jarige se woordeskat het so verbeter vandat hy saam luister. Ons sien na nog baie stories!
                </blockquote>
                <p class="review-author">- Sivonne</p>
            </article>

            <article class="review-card">
                <p class="review-stars" aria-hidden="true">
                    <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                </p>
                <blockquote>
                    My dogtertjie was skaam om by haar maaitjie te gaan kuier en toe se sy dat sy soos Grotman Grootman
                    moet gaan. Dit is so mooi. Schink Stories help regtig kinders. Dit is wat mens wil he
                </blockquote>
                <p class="review-author">- Elmarette</p>
            </article>
        </div>
    </section>

    <section class="about-card who-we-are-intro">
        <h2>Wie ons is</h2>
        <img src="/branding/Schwella.webp" alt="Martin en Simone Schwella"
             class="who-we-are-photo" loading="lazy" decoding="async" />
    </section>

    <section class="about-card">
        <h2>Ons is Martin &amp; Simone</h2>
        <p>
            Ons is self ouers van vier en geniet dit vreeslik om stories met ons kinders te deel. Dit maak ons
            ook opgewonde om te sien hoe stories 'n werklike impak op ons kinders se lewens het.
        </p>
        <p>
            Ons wens vir Schink Stories is dat dit jou kinders ook sal help - sal help om te oorwin in situasies
            wat hulle by die skool, by die huis of net daar waar hulle hulself bevind te oorwin.
        </p>
        <p>Ons glo in stories wat motiveer, leer en inspireer.</p>
        <p>Ons hoop julle sluit by ons aan vir storietyd.</p>
        <p>Sien julle daar!</p>
    </section>

    <section class="about-block final-line">
        <p><strong>Motiveer. Leer. Inspireer.</strong></p>
        <a href="/luister" class="join-link">Sluit aan op Schink Stories</a>
    </section>
</section>

@code {
    private string MeerOorOnsCanonicalUrl => NavigationManager.ToAbsoluteUri("/meer-oor-ons").ToString();

    private MarkupString MeerOorOnsJsonLd => new(JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "AboutPage",
        ["name"] = "Schink Stories | Meer oor Ons",
        ["description"] = "Leer meer oor Schink Stories se missie, visie en waardes vir veilige Afrikaanse kinderstories.",
        ["url"] = MeerOorOnsCanonicalUrl,
        ["inLanguage"] = "af-ZA",
        ["isPartOf"] = new Dictionary<string, object?>
        {
            ["@type"] = "WebSite",
            ["name"] = "Schink Stories",
            ["url"] = NavigationManager.ToAbsoluteUri("/").ToString()
        },
        ["primaryImageOfPage"] = NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()
    }));
}
