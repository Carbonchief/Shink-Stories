@page "/karakters"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IAudioAccessService AudioAccessService
@inject ICharacterCatalogService CharacterCatalogService
@inject IJSRuntime JS
@inject IStoryTrackingService StoryTrackingService
@inject IStoryCatalogService StoryCatalogService
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

<PageTitle>Schink Stories | Karakters</PageTitle>
<HeadContent>
    <meta name="description" content="Ontsluit julle gunsteling Schink Stories karakters deur na hul stories te luister." />
    <link rel="canonical" href="@KaraktersCanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Schink Stories | Karakters" />
    <meta property="og:description" content="Ontsluit julle gunsteling Schink Stories karakters deur na hul stories te luister." />
    <meta property="og:url" content="@KaraktersCanonicalUrl" />
    <meta property="og:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Schink Stories | Karakters" />
    <meta name="twitter:description" content="Ontsluit julle gunsteling Schink Stories karakters deur na hul stories te luister." />
    <meta name="twitter:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
</HeadContent>

<section class="characters-page">
    <header class="characters-hero">
        <div class="characters-hero-copy">
            <img class="characters-hero-lineup"
                 src="/branding/Schink_Stories_Char_Line_up.png"
                 alt="Schink Stories karaktergroep"
                 loading="eager"
                 decoding="async" />
            <p class="characters-eyebrow">Schink Stories Karakters</p>            
            <h1>Ontmoet die karakters</h1>
            <p class="characters-intro">
                Op hierdie blad kan jy die Schink Stories-karakters sien, verken en hoor. Luister na stories om elke karakter se profiel op te sluit.
                Of luister meer as een keer na spesifieke stories en ontdek bonuskarakters.
            </p>
            @if (IsSignedIn)
            {
                <div class="characters-summary-card">
                    <strong>@UnlockedCharacterCount van @CharacterCards.Count karakters is oop</strong>
                </div>
            }
            else
            {
                <div class="characters-summary-card">
                    <strong>Teken in om julle ontsluitings te sien.</strong>
                    <a href="@LoginForCharactersHref">Teken in</a>
                </div>
            }
        </div>
    </header>

    @if (IsLoading)
    {
        <section class="characters-state" aria-live="polite">
            <h2>Laai karakters...</h2>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(LoadErrorMessage))
    {
        <section class="characters-state characters-state-error" aria-live="polite">
            <h2>Ons kon nie nou die karakterblad laai nie.</h2>
            <p>@LoadErrorMessage</p>
        </section>
    }
    else if (CharacterCards.Count == 0)
    {
        <section class="characters-state" aria-live="polite">
            <h2>Geen karakters is nog beskikbaar nie.</h2>
            <p>Kom kyk weer binnekort.</p>
        </section>
    }
    else
    {
        <section class="characters-grid" aria-label="Schink Stories karakters">
            @foreach (var card in CharacterCards)
            {
                if (card.IsUnlocked)
                {
                    <article class="character-card is-unlocked character-card-clickable"
                             @onclick="() => OpenCharacterProfile(card)"
                             @onkeydown="args => HandleCharacterCardKeyDown(args, card)"
                             tabindex="0"
                             role="button"
                             aria-label="Wys profiel vir @card.Character.DisplayName">
                        <div class="character-card-media">
                            <img src="@card.DisplayImagePath"
                                 alt="@card.ImageAlt"
                                 class="character-card-image"
                                 loading="lazy"
                                 decoding="async"
                                 onerror="this.onerror=null;this.src='/branding/schink-logo-green.png';" />
                            <button type="button"
                                    class="character-card-badge character-card-audio-trigger"
                                    @onclick="() => PlayCharacterAudioAsync(card)"
                                    @onclick:stopPropagation="true"
                                    disabled="@(!card.HasAudio)"
                                    aria-label="@(card.HasAudio ? $"Speel {card.Character.DisplayName} se stem" : $"{card.Character.DisplayName} het nog geen klankgreep nie")"
                                    title="@(card.HasAudio ? "Speel karakterklank" : "Geen karakterklank beskikbaar")">
                                <i class="fa-solid fa-volume-high" aria-hidden="true"></i>
                            </button>

                            @if (!string.IsNullOrWhiteSpace(card.CallToActionHref))
                            {
                                <button type="button"
                                        class="character-card-mobile-play"
                                        @onclick="() => HandleCallToActionAsync(card.CallToActionHref!)"
                                        @onclick:stopPropagation="true"
                                        disabled="@IsCallToActionLoading(card.CallToActionHref)"
                                        aria-label="@card.CallToActionLabel"
                                        title="@card.CallToActionLabel">
                                    <i class="fa-solid fa-play" aria-hidden="true"></i>
                                </button>
                            }
                        </div>

                        <div class="character-card-body">
                            <h2>@card.Heading</h2>
                            <p class="character-card-summary">@card.SummaryText</p>

                            @if (!string.IsNullOrWhiteSpace(card.CallToActionHref))
                            {
                                <button type="button"
                                        class="character-card-cta"
                                        @onclick="() => HandleCallToActionAsync(card.CallToActionHref!)"
                                        @onclick:stopPropagation="true"
                                        disabled="@IsCallToActionLoading(card.CallToActionHref)">
                                    @if (IsCallToActionLoading(card.CallToActionHref))
                                    {
                                        <span class="character-card-cta-spinner" aria-hidden="true"></span>
                                        <span>Loading</span>
                                    }
                                    else
                                    {
                                        <span>@card.CallToActionLabel</span>
                                    }
                                </button>
                            }
                        </div>

                    </article>
                }
                else
                {
                    <article class="character-card is-locked">
                        <div class="character-card-media">
                            <img src="@card.DisplayImagePath"
                                 alt="@card.ImageAlt"
                                 class="character-card-image"
                                 loading="lazy"
                                 decoding="async"
                                 onerror="this.onerror=null;this.src='/branding/schink-logo-green.png';" />
                            <span class="character-card-badge" aria-label="Nog gesluit" title="Nog gesluit">
                                <i class="fa-solid fa-lock" aria-hidden="true"></i>
                            </span>

                            @if (!string.IsNullOrWhiteSpace(card.CallToActionHref))
                            {
                                <button type="button"
                                        class="character-card-mobile-play"
                                        @onclick="() => HandleCallToActionAsync(card.CallToActionHref!)"
                                        @onclick:stopPropagation="true"
                                        disabled="@IsCallToActionLoading(card.CallToActionHref)"
                                        aria-label="@card.CallToActionLabel"
                                        title="@card.CallToActionLabel">
                                    <i class="fa-solid fa-play" aria-hidden="true"></i>
                                </button>
                            }
                        </div>

                        <div class="character-card-body">
                            <h2>@card.Heading</h2>
                            <p class="character-card-summary">@card.SummaryText</p>

                            @if (!string.IsNullOrWhiteSpace(card.CallToActionHref))
                            {
                                <button type="button"
                                        class="character-card-cta"
                                        @onclick="() => HandleCallToActionAsync(card.CallToActionHref!)"
                                        disabled="@IsCallToActionLoading(card.CallToActionHref)">
                                    @if (IsCallToActionLoading(card.CallToActionHref))
                                    {
                                        <span class="character-card-cta-spinner" aria-hidden="true"></span>
                                        <span>Loading</span>
                                    }
                                    else
                                    {
                                        <span>@card.CallToActionLabel</span>
                                    }
                                </button>
                            }
                        </div>

                    </article>
                }
            }
        </section>
    }
</section>

@if (ActiveProfileCard is not null)
{
    <div class="character-profile-popup-backdrop" role="presentation" @onclick="CloseCharacterProfile">
        <section class="character-profile-popup-card"
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="character-profile-popup-title"
                 @onclick:stopPropagation="true">
            <button type="button"
                    class="character-profile-popup-close"
                    @onclick="CloseCharacterProfile"
                    aria-label="Maak toe">
                <i class="fa-solid fa-xmark" aria-hidden="true"></i>
            </button>

            <button type="button"
                    class="character-profile-popup-image-button"
                    @onclick="CelebrateProfileImageAsync"
                    aria-label="Druk vir 'n verrassing">
                <img class="@($"character-profile-popup-image{(IsProfileImageCelebrating ? " is-celebrating" : string.Empty)}")"
                     src="@ResolveCharacterImagePath(ActiveProfileCard.Character.ImagePath)"
                     alt="Illustrasie van @ActiveProfileCard.Character.DisplayName"
                     loading="lazy"
                     decoding="async"
                     onerror="this.onerror=null;this.src='/branding/schink-logo-green.png';" />
            </button>

            <h2 id="character-profile-popup-title">@ActiveProfileCard.Character.DisplayName</h2>

            @if (!string.IsNullOrWhiteSpace(ActiveProfileCard.Character.Tagline))
            {
                <p class="character-profile-popup-summary">@ActiveProfileCard.Character.Tagline</p>
            }

            <div class="character-profile-popup-content">
                <dl class="character-profile-popup-details">
                    <div class="character-profile-popup-panel">
                        @CharacterField("Tipe", ActiveProfileCard.Character.Species)
                        @CharacterField("Blyplek", ActiveProfileCard.Character.Habitat)
                        @CharacterField("Sê-ding", ActiveProfileCard.Character.Catchphrase)
                        @CharacterField("Gunsteling-ding", ActiveProfileCard.Character.FavoriteThing)
                        @CharacterField("Eerste verskyning", ActiveProfileCard.Character.FirstAppearance)
                    </div>

                    <div class="character-profile-popup-panel character-profile-popup-panel-highlight">
                        @CharacterField("Kenmerk", ActiveProfileCard.Character.CharacterTrait)
                        @CharacterField("Goue Les", ActiveProfileCard.Character.GoldenLesson)
                        @CharacterField("Kernwaarde", ActiveProfileCard.Character.CoreValue)
                    </div>

                    <div class="character-profile-popup-panel">
                        @CharacterField("Vragie", ActiveProfileCard.Character.ReflectionQuestion)
                        @CharacterField("Uitdaging vir jou", ActiveProfileCard.Character.ChallengeText)
                        @FriendField("Maats", ActiveProfileCard.Character.Friends)
                    </div>
                </dl>

                @if (ActiveProfileCard.RelatedStories.Count > 0)
                {
                    <div class="character-related-stories character-profile-popup-related-stories">
                        <p>Stories met hierdie karakter:</p>
                        <div class="character-story-links">
                            @foreach (var story in ActiveProfileCard.RelatedStories)
                            {
                                <a href="@story.Path" class="character-profile-story-link">
                                    <img src="@story.CoverPath"
                                         alt="Voorblad van @story.Title"
                                         class="character-profile-story-cover"
                                         loading="lazy"
                                         decoding="async"
                                         onerror="this.onerror=null;this.src='/branding/schink-logo-green.png';" />
                                    <span>@story.Title</span>
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        </section>
    </div>
}

@code {
    private bool IsLoading { get; set; } = true;
    private bool IsSignedIn { get; set; }
    private string? LoadErrorMessage { get; set; }
    private IReadOnlyList<CharacterCardViewModel> CharacterCards { get; set; } = Array.Empty<CharacterCardViewModel>();
    private CharacterCardViewModel? ActiveProfileCard { get; set; }
    private string? LoadingCallToActionHref { get; set; }
    private bool IsProfileImageCelebrating { get; set; }
    private Guid? AnimatedFriendCharacterId { get; set; }
    private IJSObjectReference? _charactersModule;
    private int UnlockedCharacterCount => CharacterCards.Count(card => card.IsUnlocked);
    private string KaraktersCanonicalUrl => NavigationManager.ToAbsoluteUri("/karakters").ToString();
    private string LoginForCharactersHref => $"/teken-in?returnUrl={Uri.EscapeDataString("/karakters")}";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var signedInEmail = authState.User.FindFirst(ClaimTypes.Email)?.Value
                               ?? authState.User.Identity?.Name;
            IsSignedIn = authState.User.Identity?.IsAuthenticated == true && !string.IsNullOrWhiteSpace(signedInEmail);

            var charactersTask = CharacterCatalogService.GetPublishedCharactersAsync();
            var freeStoriesTask = StoryCatalogService.GetFreeStoriesAsync();
            var luisterStoriesTask = StoryCatalogService.GetLuisterStoriesAsync();
            Task<IReadOnlyList<UserStoryProgressItem>> progressTask = Task.FromResult<IReadOnlyList<UserStoryProgressItem>>(Array.Empty<UserStoryProgressItem>());

            if (IsSignedIn)
            {
                progressTask = StoryTrackingService.GetUserStoryProgressAsync(signedInEmail);
            }

            await Task.WhenAll(charactersTask, freeStoriesTask, luisterStoriesTask, progressTask);

            var storyLookup = BuildStoryLookup(freeStoriesTask.Result, luisterStoriesTask.Result);
            var progressLookup = progressTask.Result
                .GroupBy(progress => progress.StorySlug, StringComparer.OrdinalIgnoreCase)
                .ToDictionary(
                    group => group.Key,
                    group => group.OrderByDescending(item => item.LastListenedAtUtc).First(),
                    StringComparer.OrdinalIgnoreCase);

            CharacterCards = charactersTask.Result
                .OrderBy(character => character.SortOrder)
                .ThenBy(character => character.DisplayName, StringComparer.OrdinalIgnoreCase)
                .Select((character, index) => BuildCharacterCard(character, storyLookup, progressLookup, index + 1))
                .ToArray();
        }
        catch
        {
            LoadErrorMessage = "Herlaai asseblief die bladsy of probeer weer oor 'n rukkie.";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private RenderFragment CharacterField(string label, string? value) => builder =>
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return;
        }

        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "character-detail-row");
        builder.OpenElement(2, "dt");
        builder.AddAttribute(3, "style", "font-size:0.98rem;font-weight:700;letter-spacing:0.01em;text-transform:none;color:#183d49;");
        builder.AddContent(4, label);
        builder.CloseElement();
        builder.OpenElement(5, "dd");
        builder.AddAttribute(6, "style", "font-size:0.98rem;line-height:1.55;color:#26373e;");
        builder.AddContent(7, value);
        builder.CloseElement();
        builder.CloseElement();
    };

    private RenderFragment FriendField(string label, string? value) => builder =>
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return;
        }

        var friends = ResolveFriendCharacters(value);
        var unmatchedFriends = ResolveUnmatchedFriendNames(value, friends);

        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "character-detail-row character-friend-row");
        builder.OpenElement(2, "dt");
        builder.AddAttribute(3, "style", "font-size:0.98rem;font-weight:700;letter-spacing:0.01em;text-transform:none;color:#183d49;");
        builder.AddContent(4, label);
        builder.CloseElement();
        builder.OpenElement(5, "dd");
        builder.AddAttribute(6, "class", "character-friend-list");
        builder.AddAttribute(7, "style", "display:flex;flex-wrap:wrap;justify-content:center;gap:0.75rem;margin:0;");

        var sequence = 8;

        foreach (var friend in friends)
        {
            builder.OpenElement(sequence++, "button");
            builder.AddAttribute(sequence++, "type", "button");
            builder.AddAttribute(sequence++, "class", "character-friend-item character-friend-button");
            builder.AddAttribute(sequence++, "data-maat-tile", "true");
            builder.AddAttribute(sequence++, "style", "display:flex;flex-direction:column;align-items:center;gap:0.35rem;width:calc((100% - 1.5rem) / 3);max-width:88px;text-align:center;flex:0 0 calc((100% - 1.5rem) / 3);padding:0;border:none;background:transparent;cursor:pointer;");
            builder.AddAttribute(sequence++, "aria-label", $"Maak {friend.DisplayName} se profiel oop");
            builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => OpenCharacterProfile(friend.CharacterId)));

            builder.OpenElement(sequence++, "img");
            builder.AddAttribute(sequence++, "class", "character-friend-image");
            builder.AddAttribute(sequence++, "style", "width:64px;max-width:64px;height:auto;display:block;object-fit:contain;flex:0 0 auto;");
            builder.AddAttribute(sequence++, "src", ResolveCharacterImagePath(friend.ImagePath));
            builder.AddAttribute(sequence++, "alt", $"Illustrasie van {friend.DisplayName}");
            builder.AddAttribute(sequence++, "loading", "lazy");
            builder.AddAttribute(sequence++, "decoding", "async");
            builder.AddAttribute(sequence++, "onerror", "this.onerror=null;this.src='/branding/schink-logo-green.png';");
            builder.CloseElement();

            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "character-friend-name");
            builder.AddAttribute(sequence++, "style", "font-size:0.76rem;line-height:1.2;color:#26373e;");
            builder.AddContent(sequence++, friend.DisplayName);
            builder.CloseElement();

            builder.CloseElement();
        }

        foreach (var unmatchedFriend in unmatchedFriends)
        {
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "character-friend-item");
            builder.AddAttribute(sequence++, "data-maat-tile", "true");
            builder.AddAttribute(sequence++, "style", "display:flex;flex-direction:column;align-items:center;gap:0.35rem;width:calc((100% - 1.5rem) / 3);max-width:88px;text-align:center;flex:0 0 calc((100% - 1.5rem) / 3);");

            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "character-friend-name");
            builder.AddAttribute(sequence++, "style", "font-size:0.76rem;line-height:1.2;color:#26373e;");
            builder.AddContent(sequence++, unmatchedFriend);
            builder.CloseElement();

            builder.CloseElement();
        }

        builder.CloseElement();
        builder.CloseElement();
    };

    private void OpenCharacterProfile(CharacterCardViewModel card)
    {
        ActiveProfileCard = card;
        IsProfileImageCelebrating = false;
    }

    private void OpenCharacterProfile(Guid characterId)
    {
        var card = CharacterCards.FirstOrDefault(candidate => candidate.Character.CharacterId == characterId);
        if (card is not null)
        {
            ActiveProfileCard = card;
            IsProfileImageCelebrating = false;
        }
    }

    private IReadOnlyList<StoryCharacterItem> ResolveFriendCharacters(string? friends)
    {
        var friendNames = SplitFriendNames(friends);
        if (friendNames.Count == 0 || CharacterCards.Count == 0)
        {
            return Array.Empty<StoryCharacterItem>();
        }

        var characters = CharacterCards
            .Select(card => card.Character)
            .GroupBy(character => character.CharacterId)
            .Select(group => group.First())
            .ToArray();

        var matched = new List<StoryCharacterItem>();
        foreach (var friendName in friendNames)
        {
            var normalizedFriendName = NormalizeFriendToken(friendName);
            var match = characters.FirstOrDefault(character =>
                string.Equals(NormalizeFriendToken(character.DisplayName), normalizedFriendName, StringComparison.Ordinal) ||
                string.Equals(NormalizeFriendToken(character.Slug.Replace("-", " ")), normalizedFriendName, StringComparison.Ordinal));

            if (match is not null && matched.All(existing => existing.CharacterId != match.CharacterId))
            {
                matched.Add(match);
            }
        }

        return matched;
    }

    private IReadOnlyList<string> ResolveUnmatchedFriendNames(string? friends, IReadOnlyList<StoryCharacterItem> matchedFriends)
    {
        var matchedNames = matchedFriends
            .Select(friend => NormalizeFriendToken(friend.DisplayName))
            .ToHashSet(StringComparer.Ordinal);

        return SplitFriendNames(friends)
            .Where(friendName => !matchedNames.Contains(NormalizeFriendToken(friendName)))
            .ToArray();
    }

    private static IReadOnlyList<string> SplitFriendNames(string? friends)
    {
        if (string.IsNullOrWhiteSpace(friends))
        {
            return Array.Empty<string>();
        }

        return friends
            .Replace(" en ", ",", StringComparison.OrdinalIgnoreCase)
            .Replace("&", ",", StringComparison.OrdinalIgnoreCase)
            .Replace("/", ",", StringComparison.OrdinalIgnoreCase)
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .ToArray();
    }

    private static string NormalizeFriendToken(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return new string(value
            .Trim()
            .ToLowerInvariant()
            .Where(char.IsLetterOrDigit)
            .ToArray());
    }

    private void CloseCharacterProfile()
    {
        ActiveProfileCard = null;
        IsProfileImageCelebrating = false;
    }

    private async Task CelebrateProfileImageAsync()
    {
        if (ActiveProfileCard is null)
        {
            return;
        }

        IsProfileImageCelebrating = false;
        StateHasChanged();
        await Task.Yield();

        IsProfileImageCelebrating = true;
        StateHasChanged();

        var module = await TryGetCharactersModuleAsync();
        if (module is not null)
        {
            try
            {
                await module.InvokeVoidAsync("triggerCharacterHaptics");
            }
            catch
            {
                // Ignore haptic failures on unsupported browsers/devices.
            }
        }

        await Task.Delay(900);

        if (ActiveProfileCard is not null)
        {
            IsProfileImageCelebrating = false;
            StateHasChanged();
        }
    }

    private void HandleCharacterCardKeyDown(KeyboardEventArgs args, CharacterCardViewModel card)
    {
        if (args.Key is "Enter" or " ")
        {
            OpenCharacterProfile(card);
        }
    }

    private async Task PlayCharacterAudioAsync(CharacterCardViewModel card)
    {
        if (!card.IsUnlocked || !card.HasAudio)
        {
            return;
        }

        var clip = card.Character.AudioClips[Random.Shared.Next(card.Character.AudioClips.Count)];
        var module = await TryGetCharactersModuleAsync();
        if (module is null)
        {
            return;
        }

        await module.InvokeVoidAsync("playCharacterAudio", AudioAccessService.CreateSignedAudioUrl(clip.StreamSlug));
    }

    private bool IsCallToActionLoading(string? href) =>
        !string.IsNullOrWhiteSpace(href) &&
        string.Equals(LoadingCallToActionHref, href, StringComparison.Ordinal);

    private async Task HandleCallToActionAsync(string href)
    {
        if (string.IsNullOrWhiteSpace(href) || IsCallToActionLoading(href))
        {
            return;
        }

        LoadingCallToActionHref = href;
        StateHasChanged();
        await Task.Yield();
        NavigationManager.NavigateTo(href);
    }

    private CharacterCardViewModel BuildCharacterCard(
        StoryCharacterItem character,
        IReadOnlyDictionary<string, StoryLinkInfo> storyLookup,
        IReadOnlyDictionary<string, UserStoryProgressItem> progressLookup,
        int displayOrder)
    {
        var relatedSlugs = BuildUnlockStorySlugs(character);
        var unlocked = relatedSlugs.Any(slug => IsCharacterUnlocked(character, slug, progressLookup));
        var relatedStories = relatedSlugs
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Select(slug => storyLookup.TryGetValue(slug, out var story) ? story : null)
            .Where(static story => story is not null)
            .Cast<StoryLinkInfo>()
            .ToArray();
        var primaryStory = ResolvePrimaryStory(character, relatedStories);
        var ctaHref = ResolveCallToActionHref(primaryStory);
        var ctaLabel = unlocked
            ? "Luister weer na storie"
            : primaryStory is null
                ? string.Empty
                : "Luister en sluit oop";
        var summaryText = unlocked
            ? character.Tagline ?? "Hierdie karakter se profiel is nou oop."
            : "Luister na die storie om oop te sluit.";
        return new CharacterCardViewModel(
            Character: character,
            IsUnlocked: unlocked,
            HasAudio: character.AudioClips.Count > 0,
            Heading: unlocked ? character.DisplayName : "?????",
            SummaryText: summaryText,
            DisplayImagePath: unlocked
                ? ResolveCharacterImagePath(character.ImagePath)
                : ResolveCharacterImagePath(character.MysteryImagePath),
            ImageAlt: unlocked
                ? $"Illustrasie van {character.DisplayName}"
                : $"Mysterie illustrasie vir {character.DisplayName}",
            RelatedStories: relatedStories,
            CallToActionHref: ctaHref,
            CallToActionLabel: ctaLabel);
    }

    private bool IsCharacterUnlocked(
        StoryCharacterItem character,
        string slug,
        IReadOnlyDictionary<string, UserStoryProgressItem> progressLookup)
    {
        if (!progressLookup.TryGetValue(slug, out var progress))
        {
            return false;
        }

        return progress.IsCompleted || progress.TotalListenedSeconds >= character.UnlockThresholdSeconds;
    }

    private string[] BuildUnlockStorySlugs(StoryCharacterItem character)
    {
        var slugs = new List<string>();
        if (!string.IsNullOrWhiteSpace(character.UnlockStorySlug))
        {
            slugs.Add(character.UnlockStorySlug);
        }

        slugs.AddRange(character.RelatedStorySlugs.Where(slug => !string.IsNullOrWhiteSpace(slug)));
        return slugs
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private static IReadOnlyDictionary<string, StoryLinkInfo> BuildStoryLookup(
        IReadOnlyList<StoryItem> freeStories,
        IReadOnlyList<StoryItem> luisterStories)
    {
        return freeStories
            .Select(story => new StoryLinkInfo(story.Slug, story.Title, $"/gratis/{Uri.EscapeDataString(story.Slug)}", "free", story.ImagePath))
            .Concat(luisterStories.Select(story => new StoryLinkInfo(story.Slug, story.Title, $"/luister/{Uri.EscapeDataString(story.Slug)}", story.AccessLevel, story.ImagePath)))
            .GroupBy(story => story.Slug, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(group => group.Key, group => group.First(), StringComparer.OrdinalIgnoreCase);
    }

    private StoryLinkInfo? ResolvePrimaryStory(StoryCharacterItem character, IReadOnlyList<StoryLinkInfo> relatedStories)
    {
        if (!string.IsNullOrWhiteSpace(character.UnlockStorySlug))
        {
            var unlockStory = relatedStories.FirstOrDefault(story =>
                string.Equals(story.Slug, character.UnlockStorySlug, StringComparison.OrdinalIgnoreCase));
            if (unlockStory is not null)
            {
                return unlockStory;
            }
        }

        return relatedStories.FirstOrDefault();
    }

    private string? ResolveCallToActionHref(StoryLinkInfo? primaryStory)
    {
        if (primaryStory is null)
        {
            return null;
        }

        if (!IsSignedIn && !string.Equals(primaryStory.AccessLevel, "free", StringComparison.OrdinalIgnoreCase))
        {
            return $"/teken-in?returnUrl={Uri.EscapeDataString(primaryStory.Path)}";
        }

        return primaryStory.Path;
    }

    private static string ResolveCharacterImagePath(string? path) =>
        string.IsNullOrWhiteSpace(path)
            ? "/branding/schink-logo-green.png"
            : path;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await TryGetCharactersModuleAsync();
        }

        var module = await TryGetCharactersModuleAsync();
        if (module is null)
        {
            return;
        }

        if (ActiveProfileCard is null)
        {
            if (AnimatedFriendCharacterId is not null)
            {
                try
                {
                    await module.InvokeVoidAsync("stopMaatAnimation");
                }
                catch
                {
                    // Ignore disconnects while stopping popup-only effects.
                }

                AnimatedFriendCharacterId = null;
            }

            return;
        }

        if (AnimatedFriendCharacterId == ActiveProfileCard.Character.CharacterId)
        {
            return;
        }

        try
        {
            await module.InvokeVoidAsync("startMaatAnimation");
            AnimatedFriendCharacterId = ActiveProfileCard.Character.CharacterId;
        }
        catch
        {
            AnimatedFriendCharacterId = null;
        }
    }

    private async Task<IJSObjectReference?> TryGetCharactersModuleAsync()
    {
        if (_charactersModule is not null)
        {
            return _charactersModule;
        }

        try
        {
            _charactersModule = await JS.InvokeAsync<IJSObjectReference>("import", "/Components/Pages/Karakters.razor.js");
        }
        catch
        {
            _charactersModule = null;
        }

        return _charactersModule;
    }

    public async ValueTask DisposeAsync()
    {
        if (_charactersModule is not null)
        {
            try
            {
                await _charactersModule.InvokeVoidAsync("stopMaatAnimation");
                await _charactersModule.InvokeVoidAsync("stopCharacterAudio");
                await _charactersModule.DisposeAsync();
            }
            catch
            {
                // Ignore disconnects during disposal.
            }
        }
    }

    private sealed record StoryLinkInfo(
        string Slug,
        string Title,
        string Path,
        string AccessLevel,
        string CoverPath);

    private sealed record CharacterCardViewModel(
        StoryCharacterItem Character,
        bool IsUnlocked,
        bool HasAudio,
        string Heading,
        string SummaryText,
        string DisplayImagePath,
        string ImageAlt,
        IReadOnlyList<StoryLinkInfo> RelatedStories,
        string? CallToActionHref,
        string CallToActionLabel);
}
