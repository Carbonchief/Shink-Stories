    private static string? GetStorySynopsis(StoryItem? story)
    {
        if (story is null)
        {
            return null;
        }

        if (!string.IsNullOrWhiteSpace(story.Summary))
        {
            return story.Summary;
        }

        return string.IsNullOrWhiteSpace(story.Description) ? null : story.Description;
    }

    private static bool ShouldShowStoryLead(StoryItem? story)
    {
        if (story is null ||
            string.IsNullOrWhiteSpace(story.Description) ||
            string.IsNullOrWhiteSpace(story.Summary))
        {
            return false;
        }

        return !string.Equals(
            NormalizeStoryText(story.Description),
            NormalizeStoryText(story.Summary),
            StringComparison.OrdinalIgnoreCase);
    }

