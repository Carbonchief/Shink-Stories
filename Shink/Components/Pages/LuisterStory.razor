@page "/luister/{Slug}"
@rendermode InteractiveServer
@using System.Text.Json
@using System.Security.Claims
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Shink.Utilities
@inject IAudioAccessService AudioAccessService
@inject ICharacterCatalogService CharacterCatalogService
@inject ICharacterTrackingService CharacterTrackingService
@inject IStoryCatalogService StoryCatalogService
@inject IStoryTrackingService StoryTrackingService
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISubscriptionLedgerService SubscriptionLedgerService
@inject IStoryFavoriteService StoryFavoriteService
@inject IHttpContextAccessor HttpContextAccessor
@implements IAsyncDisposable

<PageTitle>@(CurrentStory is null ? "Storie nie gevind nie" : $"{CurrentStory.Title} | Schink Stories")</PageTitle>
<HeadContent>
    <link rel="canonical" href="@ShareCanonicalUrl" />
    <meta property="og:type" content="article" />
    <meta property="og:title" content="@ShareTitle" />
    <meta property="og:description" content="@ShareDescription" />
    <meta property="og:url" content="@ShareUrl" />
    <meta property="og:image" content="@ShareImageUrl" />
    <meta property="og:image:type" content="@ShareImageMimeType" />
    <meta property="og:image:alt" content="@ShareImageAlt" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@ShareTitle" />
    <meta name="twitter:description" content="@ShareDescription" />
    <meta name="twitter:image" content="@ShareImageUrl" />
    <meta name="twitter:image:alt" content="@ShareImageAlt" />
    <JsonLdScript Json="@StoryPageJsonLd" />
</HeadContent>

@if (IsStoryLoading)
{
    <section class="story-player-empty story-player-loading" aria-live="polite" aria-busy="true">
        <span class="story-loading-spinner" aria-hidden="true"></span>
        <span>Storie laai</span>
    </section>
}
else if (IsRedirectingToOpsies)
{
    <section class="story-player-empty">
        <h1>Hierdie storie is nog gesluit.</h1>
        <p>Teken in of kies 'n plan om hierdie storie te luister.</p>
        <a href="@StoryAccessPopupPrimaryHref">Gaan voort</a>
    </section>
}
else if (CurrentStory is null)
{
    <section class="story-player-empty">
        <h1>Ons kon nie daardie storie kry nie.</h1>
        <p>Gaan terug na die luister stories om 'n storie te kies.</p>
        <a href="/luister">Terug na luister stories</a>
    </section>
}
else
{
    <section class="story-player-page @(IsManualFullscreenFocus ? "manual-fullscreen-focus" : null)">
        <div class="story-player-content story-player-enhanced" oncontextmenu="return false;">
            <div class="story-cover-wrap">
                <img src="@CurrentStory.ThumbnailPath"
                     srcset="@($"{CurrentStory.ThumbnailPath} 640w, {CurrentStory.ImagePath} 1024w")"
                     sizes="(max-width: 640px) 100vw, (max-width: 1200px) 94vw, 1180px"
                     alt="Voorblad van @CurrentStory.Title" class="story-cover"
                     role="button"
                     tabindex="0"
                     aria-label="Speel of pouse storie"
                     aria-pressed="false"
                     title="Speel of pouse storie"
                     width="640" height="485" loading="eager" fetchpriority="high" decoding="async" />
                <span class="story-cover-play" aria-hidden="true">
                    <i class="story-cover-play-icon fa-solid fa-play" aria-hidden="true"></i>
                </span>

                <button type="button" class="story-fullscreen-toggle" @onclick="ToggleFullscreenFocusAsync"
                        aria-pressed="@IsManualFullscreenFocus"
                        aria-label="@(IsManualFullscreenFocus ? "Verlaat volskerm speler" : "Volskerm speler")"
                        title="@(IsManualFullscreenFocus ? "Verlaat volskerm speler" : "Volskerm speler")">
                    <i class="fa-solid fa-expand" aria-hidden="true"></i>
                    <span class="sr-only">@(IsManualFullscreenFocus ? "Verlaat volskerm speler" : "Volskerm speler")</span>
                </button>

                <button type="button"
                        class="story-favorite-toggle @(IsStoryFavorite(CurrentStory.Slug) ? "is-favorite" : null)"
                        @onclick="() => ToggleStoryFavoriteAsync(CurrentStory)"
                        aria-label="@(IsStoryFavorite(CurrentStory.Slug) ? $"Verwyder {CurrentStory.Title} uit jou gunstelinge" : $"Voeg {CurrentStory.Title} by jou gunstelinge")"
                        title="@(IsStoryFavorite(CurrentStory.Slug) ? "Verwyder uit gunstelinge" : "Voeg by gunstelinge")"
                        aria-pressed="@IsStoryFavorite(CurrentStory.Slug)"
                        disabled="@IsFavoriteBusy(CurrentStory.Slug)">
                    <i class="fa-@(IsStoryFavorite(CurrentStory.Slug) ? "solid" : "regular") fa-heart" aria-hidden="true"></i>
                </button>
            </div>

            <audio controls controlslist="nodownload noplaybackrate"
                   disablepictureinpicture preload="auto" class="story-audio story-audio-native"
                   playsinline webkit-playsinline="true"
                   src="@AudioUrl"
                   data-story-slug="@CurrentStory.Slug"
                   data-story-title="@CurrentStory.Title"
                   data-story-artist="Schink Stories"
                   data-story-image="@StoryArtworkUrl"
                   data-story-image-type="@StoryArtworkMimeType"
                    oncontextmenu="return false;">
                Jou blaaier ondersteun nie die oudioplayer nie.
            </audio>

            <div class="story-custom-player" role="group" aria-label="Storie speler">
                <div class="story-progress-wrap">
                    <input class="story-progress-slider"
                           type="range"
                           min="0"
                           max="100"
                           step="0.1"
                           value="0"
                           aria-label="Storie vordering" />
                </div>

                <div class="story-control-bar">
                    <div class="story-player-controls">
                        <button type="button"
                                class="story-control-btn story-story-prev"
                                aria-label="@(PreviousStory is null ? "Geen vorige storie beskikbaar" : $"Vorige storie: {PreviousStory.Title}")"
                                title="@(PreviousStory is null ? "Geen vorige storie beskikbaar" : "Vorige storie")"
                                disabled="@(PreviousStory is null)">
                            <i class="fa-solid fa-backward-step" aria-hidden="true"></i>
                            <span class="sr-only">Vorige storie</span>
                        </button>
                        <button type="button" class="story-control-btn story-play-toggle" aria-label="Speel storie" title="Speel/Pouse">
                            <i class="story-play-icon fa-solid fa-play" aria-hidden="true"></i>
                            <span class="sr-only">Speel storie</span>
                        </button>
                        <button type="button"
                                class="story-control-btn story-story-next"
                                aria-label="@(NextStory is null ? "Geen volgende storie beskikbaar" : $"Volgende storie: {NextStory.Title}")"
                                title="@(NextStory is null ? "Geen volgende storie beskikbaar" : "Volgende storie")"
                                disabled="@(NextStory is null)">
                            <i class="fa-solid fa-forward-step" aria-hidden="true"></i>
                            <span class="sr-only">Volgende storie</span>
                        </button>
                        <div class="story-time-row">
                            <span class="story-time-current">0:00</span>
                            <span class="story-time-total">0:00</span>
                        </div>
                    </div>

                    <div class="story-secondary-controls">
                        <button type="button" class="story-mini-btn story-mute-toggle" aria-label="Demp klank" title="Demp/ontdemp">
                            <i class="story-mute-icon fa-solid fa-volume-high" aria-hidden="true"></i>
                            <span class="sr-only">Demp klank</span>
                        </button>
                        <input class="story-volume-slider"
                               type="range"
                               min="0"
                               max="1"
                               step="0.01"
                               value="1"
                               aria-label="Volume" />
                        <button type="button" class="story-mini-btn story-speed-toggle" aria-label="Verander spoed" title="Spoed">
                            <span class="story-speed-label">1.0x</span>
                        </button>
                        <button type="button" class="story-mini-btn story-share-toggle" aria-label="Deel storie" title="Deel storie">
                            <i class="fa-solid fa-share-nodes" aria-hidden="true"></i>
                            <span class="sr-only">Deel storie</span>
                        </button>
                    </div>
                </div>
            </div>

            

            <div class="story-nav-proxies" hidden aria-hidden="true">
                @if (PreviousStory is not null)
                {
                    <a class="story-nav-prev"
                       href="@BuildStoryHref(PreviousStory.Slug)"
                       @onclick="() => NavigateToStoryAsync(PreviousStory.Slug)"
                       @onclick:preventDefault="true"
                       tabindex="-1"
                       aria-label="@($"Vorige storie: {PreviousStory.Title}")"
                       title="Vorige storie">
                        <span class="sr-only">Vorige storie</span>
                    </a>
                }

                @if (NextStory is not null)
                {
                    <a class="story-nav-next"
                       href="@BuildStoryHref(NextStory.Slug)"
                       @onclick="() => NavigateToStoryAsync(NextStory.Slug)"
                       @onclick:preventDefault="true"
                       tabindex="-1"
                       aria-label="@($"Volgende storie: {NextStory.Title}")"
                       title="Volgende storie">
                        <span class="sr-only">Volgende storie</span>
                    </a>
                }
            </div>
        </div>

        <section class="story-summary-card">
            <h1 class="story-summary-title">@CurrentStory.Title</h1>
            @if (ShouldShowStoryLead(CurrentStory))
            {
                <p class="story-summary-lead">@CurrentStory.Description</p>
            }

            @if (!string.IsNullOrWhiteSpace(GetStorySynopsis(CurrentStory)))
            {
                <div class="story-summary-block">
                    <h2>Waaroor gaan die storie?</h2>
                    <p>@GetStorySynopsis(CurrentStory)</p>
                </div>
            }

            @if (HasStoryValues(CurrentStory))
            {
                <div class="story-summary-block">
                    <h2>Waardes</h2>
                    <div class="story-summary-tags" aria-label="Waardes uit die storie">
                        @foreach (var valueTag in CurrentStory.ValueTags!)
                        {
                            <span class="story-summary-tag">@valueTag</span>
                        }
                    </div>
                </div>
            }

            @if (HasStoryLessons(CurrentStory))
            {
                <div class="story-summary-block">
                    <h2>@(CurrentStory.Lessons!.Count == 1 ? "Les" : "Lesse")</h2>
                    <ul class="story-summary-list">
                        @foreach (var lesson in CurrentStory.Lessons)
                        {
                            <li>@lesson</li>
                        }
                    </ul>
                </div>
            }

            @if (HasStoryQuestions(CurrentStory))
            {
                <div class="story-summary-block">
                    <h2>Gesels 'n bietjie</h2>
                    <ul class="story-summary-list">
                        @foreach (var question in CurrentStory.ConversationQuestions!)
                        {
                            <li>@question</li>
                        }
                    </ul>
                </div>
            }

            @if (HasStoryCharacters(CurrentStory))
            {
                var storyCharacterTiles = ResolveStoryCharacterTiles(CurrentStory);
                var visualCharacterTiles = storyCharacterTiles.Where(character => !character.IsTextOnly).ToArray();
                var textOnlyCharacterTiles = storyCharacterTiles.Where(character => character.IsTextOnly).ToArray();

                <div class="story-summary-block">
                    <h2>Karakters in die storie</h2>
                    @if (visualCharacterTiles.Length > 0)
                    {
                        <div class="story-character-list" aria-label="Karakters in die storie">
                            @foreach (var character in visualCharacterTiles)
                            {
                                @if (!string.IsNullOrWhiteSpace(character.ProfileHref))
                                {
                                    <a class="story-character-item story-character-link"
                                       href="@character.ProfileHref"
                                       aria-label="Maak @character.DisplayName se karakterprofiel oop">
                                        <img class="story-character-image"
                                             src="@character.ImagePath"
                                             alt="Illustrasie van @character.DisplayName"
                                             loading="lazy"
                                             decoding="async"
                                             onerror="this.onerror=null;this.src='/branding/schink-logo-green.png';" />
                                        <span class="story-character-name">@character.DisplayName</span>
                                    </a>
                                }
                                else
                                {
                                    <span class="story-character-item">
                                        <img class="story-character-image"
                                             src="@character.ImagePath"
                                             alt="@character.ImageAlt"
                                             loading="lazy"
                                             decoding="async"
                                             onerror="this.onerror=null;this.src='/branding/schink-logo-green.png';" />
                                        <span class="story-character-name">@character.DisplayName</span>
                                    </span>
                                }
                            }
                        </div>
                    }
                    @if (textOnlyCharacterTiles.Length > 0)
                    {
                        <div class="story-character-text-list" aria-label="Karakters sonder prente">
                            @foreach (var character in textOnlyCharacterTiles)
                            {
                                <span class="story-character-text-name">@character.DisplayName</span>
                            }
                        </div>
                    }
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(StoryVideoEmbedUrl))
            {
                <div class="story-summary-block">
                    <h2>Kyk saam op YouTube</h2>
                    <div class="story-video-embed">
                        <iframe src="@StoryVideoEmbedUrl"
                                title="@($"YouTube video van {CurrentStory.Title}")"
                                loading="lazy"
                                referrerpolicy="strict-origin-when-cross-origin"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                allowfullscreen></iframe>
                    </div>
                </div>
            }
        </section>

        <section class="story-carousel-section" aria-label="Ander luister stories">
            <h2>Ander luister stories</h2>
            <div class="story-carousel" role="list">
                @foreach (var story in LuisterStories)
                {
                    var isActiveStory = string.Equals(story.Slug, CurrentStory.Slug, StringComparison.OrdinalIgnoreCase);
                    <article class="story-carousel-item @(isActiveStory ? "is-active" : null)" role="listitem">
                        <div class="story-carousel-card-shell">
                            <a class="story-carousel-link"
                               href="@BuildStoryHref(story.Slug)"
                               @onclick="() => NavigateToStoryAsync(story.Slug)"
                               @onclick:preventDefault="true"
                               draggable="false"
                               aria-current="@(isActiveStory ? "page" : null)"
                               aria-label="@(isActiveStory ? $"Huidige storie: {story.Title}" : $"Gaan na {story.Title}")">
                                <span class="story-carousel-cover">
                                    <img src="@story.ThumbnailPath"
                                         srcset="@($"{story.ThumbnailPath} 640w, {story.ImagePath} 1024w")"
                                         sizes="(max-width: 620px) 68vw, (max-width: 980px) 42vw, 220px"
                                         class="story-carousel-image"
                                         draggable="false"
                                         alt="Voorblad van @story.Title"
                                         width="640" height="485" loading="lazy" decoding="async" />
                                    <span class="story-cover-play" aria-hidden="true">
                                        <i class="story-cover-play-icon fa-solid fa-play" aria-hidden="true"></i>
                                    </span>
                                </span>
                                 <div class="story-carousel-copy">
                                     <h3>@story.Title</h3>
                                     @if (isActiveStory)
                                     {
                                         <span class="story-carousel-status">Jy luister nou</span>
                                     }
                                 </div>
                             </a>
                            <button type="button"
                                    class="story-favorite-toggle story-favorite-toggle-small @(IsStoryFavorite(story.Slug) ? "is-favorite" : null)"
                                    @onclick="() => ToggleStoryFavoriteAsync(story)"
                                    aria-label="@(IsStoryFavorite(story.Slug) ? $"Verwyder {story.Title} uit jou gunstelinge" : $"Voeg {story.Title} by jou gunstelinge")"
                                    title="@(IsStoryFavorite(story.Slug) ? "Verwyder uit gunstelinge" : "Voeg by gunstelinge")"
                                    aria-pressed="@IsStoryFavorite(story.Slug)"
                                    disabled="@IsFavoriteBusy(story.Slug)">
                                <i class="fa-@(IsStoryFavorite(story.Slug) ? "solid" : "regular") fa-heart" aria-hidden="true"></i>
                            </button>
                        </div>
                    </article>
                }
            </div>
        </section>
    </section>
}

<StoryAccessPopup IsOpen="@ShowStoryAccessPopup"
                  PrimaryActionHref="@StoryAccessPopupPrimaryHref"
                  PlanActionHref="@StoryAccessPopupPlanHref"
                  OnClose="CloseStoryAccessPopupAsync" />

@code {
    [Parameter]
    public string? Slug { get; set; }

    [SupplyParameterFromQuery(Name = "playlist")]
    public string? PlaylistContextSlug { get; set; }

    [SupplyParameterFromQuery(Name = "playlistName")]
    public string? PlaylistContextTitle { get; set; }

    [SupplyParameterFromQuery(Name = "playlistView")]
    public string? PlaylistContextView { get; set; }

    private StoryItem? CurrentStory { get; set; }
    private string? AudioUrl { get; set; }
    private IJSObjectReference? _mediaSessionModule;
    private DotNetObjectReference<LuisterStory>? _dotNetRef;
    private bool _mediaSessionModuleLoadFailed;
    private bool _isDisposed;
    private bool IsManualFullscreenFocus { get; set; }
    private IReadOnlyList<StoryItem> LuisterStories { get; set; } = Array.Empty<StoryItem>();
    private IReadOnlyList<StoryCharacterItem> PublishedCharacters { get; set; } = Array.Empty<StoryCharacterItem>();
    private IReadOnlyDictionary<Guid, bool> CharacterUnlockStates { get; set; } = new Dictionary<Guid, bool>();
    private HashSet<string> FavoriteStorySlugs { get; } = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> FavoriteStoryBusySlugs { get; } = new(StringComparer.OrdinalIgnoreCase);
    private StoryItem? PreviousStory { get; set; }
    private StoryItem? NextStory { get; set; }
    private bool IsRedirectingToOpsies { get; set; }
    private bool IsStoryLoading { get; set; } = true;
    private string? SignedInEmail { get; set; }
    private bool ShowStoryAccessPopup { get; set; }
    private string PendingLockedStoryPath { get; set; } = "/luister";

    private string? StoryArtworkUrl =>
        CurrentStory is null ? null : NavigationManager.ToAbsoluteUri(CurrentStory.ImagePath).ToString();

    private string? StoryVideoEmbedUrl =>
        CurrentStory is null ? null : YouTubeUrlHelper.BuildEmbedUrl(CurrentStory.YouTubeUrl);

    private string StoryArtworkMimeType =>
        CurrentStory is null ? "image/jpeg" : GetImageMimeType(CurrentStory.ImageFileName);

    private string ShareTitle =>
        CurrentStory is null ? "Schink Stories | Luister stories" : $"{CurrentStory.Title} | Schink Stories";

    private string ShareDescription =>
        CurrentStory?.Description ?? "Luister na Afrikaanse kinderstories op Schink Stories.";

    private string ShareUrl =>
        CurrentStory is null
            ? NavigationManager.ToAbsoluteUri("/luister").ToString()
            : NavigationManager.ToAbsoluteUri($"/luister/{Uri.EscapeDataString(CurrentStory.Slug)}").ToString();

    private string ShareCanonicalUrl => ShareUrl;
    private bool IsSignedIn => !string.IsNullOrWhiteSpace(SignedInEmail);
    private string StoryAccessPopupPrimaryHref =>
        IsSignedIn
            ? BuildOpsiesHref(PendingLockedStoryPath)
            : $"/teken-in?returnUrl={Uri.EscapeDataString(PendingLockedStoryPath)}";
    private string StoryAccessPopupPlanHref => BuildOpsiesHref(PendingLockedStoryPath);

    private string ShareImageUrl =>
        CurrentStory is null
            ? NavigationManager.ToAbsoluteUri("/branding/DIS_STORIETYD.png").ToString()
            : NavigationManager.ToAbsoluteUri(CurrentStory.ImagePath).ToString();

    private string ShareImageMimeType =>
        CurrentStory is null ? "image/png" : GetImageMimeType(CurrentStory.ImageFileName);

    private string ShareImageAlt =>
        CurrentStory is null ? "Schink Stories luister stories" : $"Voorblad van {CurrentStory.Title}";

    private MarkupString StoryPageJsonLd => new(JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "Article",
        ["headline"] = ShareTitle,
        ["description"] = ShareDescription,
        ["url"] = ShareCanonicalUrl,
        ["inLanguage"] = "af-ZA",
        ["image"] = new[] { ShareImageUrl },
        ["author"] = new Dictionary<string, object?>
        {
            ["@type"] = "Organization",
            ["name"] = "Schink Stories"
        },
        ["publisher"] = new Dictionary<string, object?>
        {
            ["@type"] = "Organization",
            ["name"] = "Schink Stories",
            ["logo"] = new Dictionary<string, object?>
            {
                ["@type"] = "ImageObject",
                ["url"] = NavigationManager.ToAbsoluteUri("/branding/schink-logo-text.png").ToString()
            }
        },
        ["isPartOf"] = new Dictionary<string, object?>
        {
            ["@type"] = "WebSite",
            ["name"] = "Schink Stories",
            ["url"] = NavigationManager.ToAbsoluteUri("/").ToString()
        }
    }));

    protected override async Task OnParametersSetAsync()
    {
        IsStoryLoading = true;
        var isSocialPreviewRequest = SocialPreviewRequestDetector.IsSocialPreviewRequest(HttpContextAccessor.HttpContext);
        ShowStoryAccessPopup = false;
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        SignedInEmail = authState.User.Identity?.IsAuthenticated == true
            ? authState.User.FindFirst(ClaimTypes.Email)?.Value ?? authState.User.Identity?.Name
            : null;

        var luisterStoriesTask = StoryCatalogService.GetLuisterStoriesAsync();
        var currentStoryTask = StoryCatalogService.FindLuisterBySlugAsync(Slug);
        var charactersTask = TryLoadPublishedCharactersAsync();
        var unlockProgressTask = TryLoadCharacterUnlockProgressAsync(SignedInEmail);
        await Task.WhenAll(luisterStoriesTask, currentStoryTask, charactersTask, unlockProgressTask);

        LuisterStories = luisterStoriesTask.Result;
        CurrentStory = currentStoryTask.Result;
        PublishedCharacters = charactersTask.Result;
        CharacterUnlockStates = CharacterUnlockEvaluator.EvaluateUnlockStates(
            PublishedCharacters,
            unlockProgressTask.Result.ProgressLookup,
            unlockProgressTask.Result.ProfileListenLookup);

        var canAccessCurrentStory = CurrentStory is not null && await HasAccessToStoryAsync(authState.User, CurrentStory);
        if (authState.User.Identity?.IsAuthenticated != true && !canAccessCurrentStory)
        {
            IsRedirectingToOpsies = true;
            AudioUrl = null;
            FavoriteStorySlugs.Clear();
            FavoriteStoryBusySlugs.Clear();
            ResolveAdjacentStories();
            IsManualFullscreenFocus = false;

            PendingLockedStoryPath = GetCurrentPathAndQuery();
            ShowStoryAccessPopup = !isSocialPreviewRequest;
            IsStoryLoading = false;

            return;
        }

        IsRedirectingToOpsies = false;
        if (CurrentStory is not null && !canAccessCurrentStory)
        {
            IsRedirectingToOpsies = true;
            CurrentStory = null;
            AudioUrl = null;
            LuisterStories = Array.Empty<StoryItem>();
            PublishedCharacters = Array.Empty<StoryCharacterItem>();
            CharacterUnlockStates = new Dictionary<Guid, bool>();
            FavoriteStorySlugs.Clear();
            FavoriteStoryBusySlugs.Clear();
            ResolveAdjacentStories();
            IsManualFullscreenFocus = false;
            PendingLockedStoryPath = GetCurrentPathAndQuery();
            ShowStoryAccessPopup = true;
            IsStoryLoading = false;
            return;
        }

        _ = LoadFavoriteStorySlugsInBackgroundAsync();
        AudioUrl = CurrentStory is null ? null : AudioAccessService.CreateSignedAudioUrl(CurrentStory.Slug);
        ResolveAdjacentStories();
        IsManualFullscreenFocus = false;
        ShowStoryAccessPopup = false;
        IsStoryLoading = false;
    }

    private bool IsStoryFavorite(string slug) => FavoriteStorySlugs.Contains(slug);

    private bool IsFavoriteBusy(string slug) => FavoriteStoryBusySlugs.Contains(slug);

    private async Task ToggleStoryFavoriteAsync(StoryItem story)
    {
        if (string.IsNullOrWhiteSpace(story.Slug))
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(SignedInEmail))
        {
            PendingLockedStoryPath = GetCurrentPathAndQuery();
            ShowStoryAccessPopup = true;
            return;
        }

        var normalizedSlug = story.Slug.Trim();
        if (!FavoriteStoryBusySlugs.Add(normalizedSlug))
        {
            return;
        }

        var isCurrentlyFavorite = FavoriteStorySlugs.Contains(normalizedSlug);
        try
        {
            var updated = await StoryFavoriteService.SetStoryFavoriteAsync(
                SignedInEmail,
                new StoryFavoriteMutationRequest(
                    StorySlug: normalizedSlug,
                    StoryPath: $"/luister/{Uri.EscapeDataString(normalizedSlug)}",
                    Source: "luister",
                    IsFavorite: !isCurrentlyFavorite,
                    PlaylistSlug: PlaylistContextSlug));

            if (updated)
            {
                if (isCurrentlyFavorite)
                {
                    FavoriteStorySlugs.Remove(normalizedSlug);
                }
                else
                {
                    FavoriteStorySlugs.Add(normalizedSlug);
                }
            }
        }
        finally
        {
            FavoriteStoryBusySlugs.Remove(normalizedSlug);
        }
    }

    private Task CloseStoryAccessPopupAsync()
    {
        ShowStoryAccessPopup = false;
        return Task.CompletedTask;
    }

    private async Task LoadFavoriteStorySlugsAsync()
    {
        FavoriteStorySlugs.Clear();
        FavoriteStoryBusySlugs.Clear();

        if (string.IsNullOrWhiteSpace(SignedInEmail))
        {
            return;
        }

        var favoriteSlugs = await StoryFavoriteService.GetFavoriteStorySlugsAsync(SignedInEmail, "luister");
        foreach (var favoriteSlug in favoriteSlugs)
        {
            FavoriteStorySlugs.Add(favoriteSlug);
        }
    }

    private async Task LoadFavoriteStorySlugsInBackgroundAsync()
    {
        try
        {
            await LoadFavoriteStorySlugsAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // Keep the page responsive if favorites fail to load.
        }
    }

    private async Task<bool> HasAccessToStoryAsync(ClaimsPrincipal user, StoryItem story)
    {
        var requirement = StoryAccessPolicy.ResolveRequirement("luister", story);
        var email = user.FindFirst(ClaimTypes.Email)?.Value
                    ?? user.Identity?.Name;

        if (requirement == StoryAccessRequirement.Free)
        {
            return await HasAnyActiveStorySubscriptionAsync(email);
        }

        if (string.IsNullOrWhiteSpace(email))
        {
            return false;
        }

        var tierCodes = StoryAccessPolicy.GetAllowedTierCodes(requirement);
        if (tierCodes.Count == 0)
        {
            return false;
        }

        var tierChecks = tierCodes
            .Select(tierCode => SubscriptionLedgerService.HasActiveSubscriptionForTierAsync(email, tierCode))
            .ToArray();

        var tierResults = await Task.WhenAll(tierChecks);
        return tierResults.Any(result => result);
    }

    private async Task<bool> HasAnyActiveStorySubscriptionAsync(string? email)
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            return false;
        }

        var gratisTask = SubscriptionLedgerService.HasActiveSubscriptionForTierAsync(email, "gratis");
        var paidTask = SubscriptionLedgerService.HasActivePaidSubscriptionAsync(email);
        await Task.WhenAll(gratisTask, paidTask);
        return gratisTask.Result || paidTask.Result;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (CurrentStory is null || IsRedirectingToOpsies || _isDisposed)
        {
            return;
        }

        var module = await TryGetStoryPlayerModuleAsync();
        if (module is null)
        {
            return;
        }

        try
        {
            if (_isDisposed)
            {
                return;
            }

            _dotNetRef ??= DotNetObjectReference.Create(this);
            var dotNetRef = _dotNetRef;

            await module.InvokeVoidAsync("initializeStoryMediaSession");

            if (_isDisposed || dotNetRef is null)
            {
                return;
            }

            await module.InvokeVoidAsync("initializeStoryPlayerFullscreenExperience", dotNetRef);

            if (!_isDisposed && !IsManualFullscreenFocus)
            {
                var shouldResumeFullscreen = await module.InvokeAsync<bool>("consumePendingStoryPlayerFullscreenIntent");
                if (!_isDisposed && shouldResumeFullscreen)
                {
                    IsManualFullscreenFocus = true;
                    await module.InvokeVoidAsync("setStoryPlayerFullscreenIntent", true);
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (JSDisconnectedException)
        {
            // Browser disconnected while the player UI was initializing.
        }
        catch (ObjectDisposedException)
        {
            // Navigation can dispose the DotNetObjectReference while a render callback is still in flight.
        }
        catch (JSException)
        {
            _mediaSessionModuleLoadFailed = true;
        }
    }

    private async Task ToggleFullscreenFocusAsync()
    {
        IsManualFullscreenFocus = !IsManualFullscreenFocus;

        var module = await TryGetStoryPlayerModuleAsync();
        if (module is null)
        {
            return;
        }

        try
        {
            await module.InvokeVoidAsync("setStoryPlayerFullscreenIntent", IsManualFullscreenFocus);
        }
        catch (JSException)
        {
            _mediaSessionModuleLoadFailed = true;
            IsManualFullscreenFocus = false;
        }
        catch (JSDisconnectedException)
        {
            IsManualFullscreenFocus = false;
        }
        catch (ObjectDisposedException)
        {
            IsManualFullscreenFocus = false;
        }
    }

    private async Task<IJSObjectReference?> TryGetStoryPlayerModuleAsync()
    {
        if (_mediaSessionModuleLoadFailed)
        {
            return null;
        }

        if (_isDisposed)
        {
            return null;
        }

        if (_mediaSessionModule is not null)
        {
            return _mediaSessionModule;
        }

        try
        {
            _mediaSessionModule = await JS.InvokeAsync<IJSObjectReference>("import", "/Components/Pages/GratisStory.razor.js");
            return _mediaSessionModule;
        }
        catch (JSException)
        {
            _mediaSessionModuleLoadFailed = true;
            return null;
        }
        catch (JSDisconnectedException)
        {
            return null;
        }
        catch (ObjectDisposedException)
        {
            return null;
        }
    }

    private async Task HandleBackLinkAsync()
    {
        await PrepareForNavigationAsync();
        NavigationManager.NavigateTo("/luister");
    }

    private async Task NavigateToStoryAsync(string slug)
    {
        await PrepareForNavigationAsync();
        NavigationManager.NavigateTo(BuildStoryHref(slug));
    }

    private async Task PrepareForNavigationAsync()
    {
        if (_mediaSessionModule is null)
        {
            return;
        }

        try
        {
            using var stopCts = new CancellationTokenSource(TimeSpan.FromMilliseconds(250));
            await _mediaSessionModule.InvokeVoidAsync("stopStoryAudioPlayback", stopCts.Token);
        }
        catch (OperationCanceledException)
        {
            // Do not block navigation when cleanup takes too long.
        }
        catch (JSException)
        {
            // Ignore browser-specific cleanup failures.
        }
        catch (JSDisconnectedException)
        {
            // Ignore cleanup when browser connection is gone.
        }
    }

    [JSInvokable]
    public Task HandleFullscreenExitedFromBrowser()
    {
        if (_isDisposed || !IsManualFullscreenFocus)
        {
            return Task.CompletedTask;
        }

        IsManualFullscreenFocus = false;
        return InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        _isDisposed = true;

        try
        {
            if (_mediaSessionModule is not null)
            {
                await PrepareForNavigationAsync();

                using var disposeUiCts = new CancellationTokenSource(TimeSpan.FromMilliseconds(250));
                await _mediaSessionModule.InvokeVoidAsync("disposeStoryPlayerFullscreenExperience", disposeUiCts.Token);

                await _mediaSessionModule.DisposeAsync().AsTask().WaitAsync(TimeSpan.FromMilliseconds(250));
            }
        }
        catch (TimeoutException)
        {
            // Ignore slow JS module disposal so route transitions stay responsive.
        }
        catch (OperationCanceledException)
        {
            // Ignore cancellation during route transitions and disposal races.
        }
        catch (JSException)
        {
            // Ignore browser-specific disposal failures on older Safari/WebKit.
        }
        catch (JSDisconnectedException)
        {
            // Ignore disposal errors when the browser connection is already closed.
        }
        finally
        {
            _dotNetRef?.Dispose();
            _dotNetRef = null;
        }
    }

    private static string GetImageMimeType(string fileName)
    {
        var extension = Path.GetExtension(fileName).ToLowerInvariant();
        return extension switch
        {
            ".png" => "image/png",
            ".webp" => "image/webp",
            ".jpg" => "image/jpeg",
            ".jpeg" => "image/jpeg",
            _ => "image/jpeg"
        };
    }

    private string BuildStoryHref(string slug)
    {
        var path = $"/luister/{Uri.EscapeDataString(slug)}";

        if (string.IsNullOrWhiteSpace(PlaylistContextSlug) || string.IsNullOrWhiteSpace(PlaylistContextTitle))
        {
            return path;
        }

        var queryParams = new Dictionary<string, string?>
        {
            ["playlist"] = PlaylistContextSlug.Trim(),
            ["playlistName"] = PlaylistContextTitle.Trim()
        };

        if (!string.IsNullOrWhiteSpace(PlaylistContextView))
        {
            queryParams["playlistView"] = PlaylistContextView.Trim();
        }

        return QueryHelpers.AddQueryString(path, queryParams);
    }

    private void ResolveAdjacentStories()
    {
        PreviousStory = null;
        NextStory = null;

        if (CurrentStory is null || LuisterStories.Count < 2)
        {
            return;
        }

        var stories = LuisterStories;
        var index = stories
            .Select((story, idx) => new { story.Slug, idx })
            .FirstOrDefault(x => string.Equals(x.Slug, CurrentStory.Slug, StringComparison.OrdinalIgnoreCase))?.idx ?? -1;

        if (index < 0)
        {
            return;
        }

        var previousIndex = index == 0 ? stories.Count - 1 : index - 1;
        var nextIndex = index == stories.Count - 1 ? 0 : index + 1;

        PreviousStory = stories[previousIndex];
        NextStory = stories[nextIndex];
    }

    private string GetCurrentPathAndQuery()
    {
        var currentUri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
