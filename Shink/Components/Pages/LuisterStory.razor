    private async Task<CharacterUnlockProgress> TryLoadCharacterUnlockProgressAsync(string? email)
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            return CharacterUnlockProgress.Empty;
        }

        try
        {
            var progressTask = StoryTrackingService.GetUserStoryProgressAsync(email);
            var profileListenTask = CharacterTrackingService.GetUserProfileListenStatsAsync(email);

            await Task.WhenAll(progressTask, profileListenTask);

            var progressLookup = progressTask.Result
                .GroupBy(progress => progress.StorySlug, StringComparer.OrdinalIgnoreCase)
                .ToDictionary(
                    group => group.Key,
                    group => group.OrderByDescending(item => item.LastListenedAtUtc).First(),
                    StringComparer.OrdinalIgnoreCase);
            var profileListenLookup = profileListenTask.Result
                .GroupBy(item => item.CharacterSlug, StringComparer.OrdinalIgnoreCase)
                .ToDictionary(
                    group => group.Key,
                    group => group.Sum(item => item.ListenCount),
                    StringComparer.OrdinalIgnoreCase);

            return new CharacterUnlockProgress(progressLookup, profileListenLookup);
        }
        catch
        {
            return CharacterUnlockProgress.Empty;
        }
    }

    private IReadOnlyList<StoryCharacterTile> ResolveStoryCharacterTiles(StoryItem? story)
    {
        if (story?.Characters is not { Count: > 0 })
        {
            return Array.Empty<StoryCharacterTile>();
        }

        return story.Characters
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .Select(ResolveStoryCharacterTile)
            .ToArray();
    }

    private StoryCharacterTile ResolveStoryCharacterTile(string characterName)
    {
        var displayName = characterName.Trim();
        var normalizedName = NormalizeCharacterToken(displayName);
        var matchedCharacter = PublishedCharacters.FirstOrDefault(character =>
            string.Equals(NormalizeCharacterToken(character.DisplayName), normalizedName, StringComparison.Ordinal) ||
            string.Equals(NormalizeCharacterToken(character.Slug.Replace("-", " ")), normalizedName, StringComparison.Ordinal));

        if (matchedCharacter is null)
        {
            return new StoryCharacterTile(displayName, null, null, null, true);
        }

        var isUnlocked = CharacterUnlockStates.TryGetValue(matchedCharacter.CharacterId, out var unlocked) && unlocked;
        var imagePath = isUnlocked ? matchedCharacter.ImagePath : matchedCharacter.MysteryImagePath;
        var resolvedImagePath = ResolveCharacterImagePath(imagePath, matchedCharacter.UpdatedAt);
        var resolvedDisplayName = isUnlocked ? matchedCharacter.DisplayName : "?????";
        var imageAlt = isUnlocked
            ? $"Illustrasie van {matchedCharacter.DisplayName}"
            : "Mysterie karakter illustrasie";

        return new StoryCharacterTile(
            resolvedDisplayName,
            resolvedImagePath,
            imageAlt,
            isUnlocked && !string.IsNullOrWhiteSpace(resolvedImagePath)
                ? $"/karakters?karakter={Uri.EscapeDataString(matchedCharacter.Slug)}"
                : null,
            string.IsNullOrWhiteSpace(resolvedImagePath));
    }

    private static string NormalizeCharacterToken(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return new string(value
            .Trim()
            .ToLowerInvariant()
            .Where(char.IsLetterOrDigit)
            .ToArray());
    }

    private static string ResolveCharacterImagePath(string? path, DateTimeOffset? updatedAt = null)
    {
        var resolvedPath = RewriteCharacterImagePath(path);
        if (updatedAt is null)
        {
            return resolvedPath;
        }

        var separator = resolvedPath.Contains('?', StringComparison.Ordinal) ? '&' : '?';
        return $"{resolvedPath}{separator}v={updatedAt.Value.ToUnixTimeSeconds()}";
    }

    private static string RewriteCharacterImagePath(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return "/branding/schink-logo-green.png";
        }

        var trimmedPath = path.Trim();
        if (Uri.TryCreate(trimmedPath, UriKind.Absolute, out var absoluteUri) &&
            (string.Equals(absoluteUri.Scheme, Uri.UriSchemeHttp, StringComparison.OrdinalIgnoreCase) ||
             string.Equals(absoluteUri.Scheme, Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase)))
        {
            if (string.Equals(absoluteUri.Host, "media.prioritybit.co.za", StringComparison.OrdinalIgnoreCase))
            {
                return $"/media/image?src={Uri.EscapeDataString(absoluteUri.ToString())}";
            }

            return absoluteUri.ToString();
        }

        return EncodeLocalCharacterImagePath(trimmedPath);
    }

    private static string EncodeLocalCharacterImagePath(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "/branding/schink-logo-green.png";
        }

        var normalized = value.Replace('\\', '/');
        var suffixStart = normalized.IndexOfAny(['?', '#']);
        var pathPart = suffixStart >= 0 ? normalized[..suffixStart] : normalized;
        var suffixPart = suffixStart >= 0 ? normalized[suffixStart..] : string.Empty;

        var encodedPath = "/" + string.Join(
            '/',
            pathPart
                .Split('/', StringSplitOptions.RemoveEmptyEntries)
                .Select(Uri.EscapeDataString));

        return encodedPath + suffixPart;
    }

    private static string NormalizeStoryText(string value) =>
        string.Join(' ', value.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries));

    private sealed record StoryCharacterTile(
        string DisplayName,
        string? ImagePath,
        string? ImageAlt,
        string? ProfileHref,
        bool IsTextOnly);

    private sealed record CharacterUnlockProgress(
        IReadOnlyDictionary<string, UserStoryProgressItem> ProgressLookup,
        IReadOnlyDictionary<string, int> ProfileListenLookup)
    {
        public static CharacterUnlockProgress Empty { get; } = new(
            new Dictionary<string, UserStoryProgressItem>(StringComparer.OrdinalIgnoreCase),
            new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase));
    }
