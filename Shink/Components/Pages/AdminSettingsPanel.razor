    private async Task SaveCodeAsync()
    {
        var effectiveAdminEmail = await ResolveAdminEmailAsync();
        if (string.IsNullOrWhiteSpace(effectiveAdminEmail) || DiscountCodeEditor is null)
        {
            if (DiscountCodeEditor is not null)
            {
                SetError(T(
                    "Kon nie jou admin rekening vir hierdie paneel bepaal nie.",
                    "Could not resolve your admin account for this panel."));
            }
            return;
        }

        IsSavingCode = true;
        ClearMessages();
        try
        {
            var editingSubcode = DiscountCodeEditor.IsGroupCode;
            var parentCodeId = editingSubcode
                ? DiscountCodeEditor.ParentDiscountCodeId ?? SelectedParentCodeId
                : null;
            var result = await AdminManagementService.SaveSubscriptionDiscountCodeAsync(
                effectiveAdminEmail,
                new AdminSubscriptionDiscountCodeSaveRequest(
                    DiscountCodeEditor.DiscountCodeId,
                    DiscountCodeEditor.Code,
                    DiscountCodeEditor.DisplayName,
                    DiscountCodeEditor.Description,
                    editingSubcode,
                    parentCodeId,
                    ToDateTimeOffset(DiscountCodeEditor.StartsOn),
                    ToDateTimeOffset(DiscountCodeEditor.ExpiresOn),
                    DiscountCodeEditor.MaxUses,
                    DiscountCodeEditor.OneUsePerUser,
                    DiscountCodeEditor.BypassPayment,
                    DiscountCodeEditor.IsActive,
                    DiscountCodeEditor.TierMappings.Select(tier => new AdminSubscriptionDiscountCodeTierSaveItem(
                        tier.TierCode,
                        0,
                        0,
                        0,
                        null,
                        null,
                        0,
                        0,
                        tier.ExpirationNumber,
                        string.IsNullOrWhiteSpace(tier.ExpirationPeriod) ? null : tier.ExpirationPeriod)).ToArray()));

            if (result.IsSuccess)
            {
                SetStatus(T("Kode is gestoor.", "Code was saved."));
                Snackbar.Add(StatusMessage!, Severity.Success);
                await LoadAsync(effectiveAdminEmail);
                if (result.EntityId is Guid entityId && entityId != Guid.Empty)
                {
                    var selected = DiscountCodes.FirstOrDefault(code => code.DiscountCodeId == entityId);
                    if (selected is not null)
                    {
                        SelectedParentCodeId = selected.IsGroupCode
                            ? selected.ParentDiscountCodeId
                            : selected.DiscountCodeId;
                        DiscountCodeEditor = EditableDiscountCode.From(selected);
                    }
                }
                else if (!editingSubcode && DiscountCodeEditor?.DiscountCodeId is Guid savedParentId)
                {
                    SelectedParentCodeId = savedParentId;
                }
            }
            else
            {
                SetError(result.ErrorMessage ?? T("Kon nie kode nou stoor nie.", "Could not save the code right now."));
            }
        }
        finally
        {
            IsSavingCode = false;
        }
    }

