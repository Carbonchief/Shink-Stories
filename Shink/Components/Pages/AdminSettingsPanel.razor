    protected override async Task OnParametersSetAsync()
    {
        var effectiveAdminEmail = await ResolveAdminEmailAsync();
        if (string.IsNullOrWhiteSpace(effectiveAdminEmail))
        {
            IsLoading = false;
            SetError(T(
                "Kon nie jou admin rekening vir hierdie paneel bepaal nie.",
                "Could not resolve your admin account for this panel."));
            return;
        }

        if (string.Equals(LoadedAdminEmail, effectiveAdminEmail, StringComparison.OrdinalIgnoreCase) && !IsLoading)
        {
            return;
        }

        await LoadAsync(effectiveAdminEmail);
    }

    private async Task<string?> ResolveAdminEmailAsync()
    {
        if (string.IsNullOrWhiteSpace(AdminEmail))
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            return authState.User.FindFirst(ClaimTypes.Email)?.Value
                   ?? authState.User.Identity?.Name;
        }

        return AdminEmail;
    }

    private async Task LoadAsync(string effectiveAdminEmail)
    {
        IsLoading = true;
        ClearMessages();

        try
        {
            var snapshot = await AdminManagementService.GetSubscriptionSettingsAsync(effectiveAdminEmail);
            SignupCodeBypassEnabled = snapshot.SignupCodeBypassEnabled;
            SubscriptionTypeEditors = snapshot.SubscriptionTypes.Select(EditableSubscriptionType.From).ToList();
            DiscountCodes = snapshot.DiscountCodes.ToList();
            if (DiscountCodeEditor?.DiscountCodeId is Guid selectedId)
            {
                var selectedCode = DiscountCodes.FirstOrDefault(code => code.DiscountCodeId == selectedId);
                if (selectedCode is not null)
                {
                    DiscountCodeEditor = EditableDiscountCode.From(selectedCode);
                }
            }

            LoadedAdminEmail = effectiveAdminEmail;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Admin settings load failed.");
            SetError(T("Kon nie instellings nou laai nie.", "Could not load settings right now."));
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task ReloadAsync()
    {
        var effectiveAdminEmail = await ResolveAdminEmailAsync();
        if (string.IsNullOrWhiteSpace(effectiveAdminEmail))
        {
            SetError(T(
                "Kon nie jou admin rekening vir hierdie paneel bepaal nie.",
                "Could not resolve your admin account for this panel."));
            return;
        }

        await LoadAsync(effectiveAdminEmail);
    }

