@page "/admin"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IAsyncDisposable
@using System.Globalization
@using System.Security.Claims
@using System.Text
@using System.Text.Encodings.Web
@using System.Text.Json
@using Microsoft.Extensions.Options
@using Microsoft.AspNetCore.Components.Authorization
@using SixLabors.ImageSharp.Formats.Jpeg
@using SixLabors.ImageSharp.Formats.Webp
@using SixLabors.ImageSharp.Processing
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IAdminManagementService AdminManagementService
@inject IStoryMediaStorageService StoryMediaStorageService
@inject IWebHostEnvironment WebHostEnvironment
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject ILogger<Admin> Logger
@inject ISnackbar Snackbar
@inject IOptions<CloudflareR2Options> CloudflareR2OptionsAccessor

<PageTitle>@AdminMetaTitle</PageTitle>
<HeadContent>
    <meta name="description" content="@AdminMetaDescription" />
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />
    <link rel="canonical" href="@AdminCanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@AdminMetaTitle" />
    <meta property="og:description" content="@AdminMetaDescription" />
    <meta property="og:url" content="@AdminCanonicalUrl" />
    <meta property="og:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:secure_url" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content="@T("Schink Stories logo", "Schink Stories logo")" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@AdminMetaTitle" />
    <meta name="twitter:description" content="@AdminMetaDescription" />
    <meta name="twitter:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta name="twitter:image:alt" content="@T("Schink Stories logo", "Schink Stories logo")" />
</HeadContent>

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<section class="admin-page">
    @if (IsEditModalOpening)
    {
        <div class="admin-modal-loading" role="status" aria-live="polite" aria-label='@T("Maak redigeerder oop...", "Opening editor...")'>
            <div class="admin-modal-loading-card">
                <span class="admin-modal-spinner" aria-hidden="true"></span>
                <span>@T("Maak redigeerder oop...", "Opening editor...")</span>
            </div>
        </div>
    }

    <header class="admin-hero">
        <div class="admin-hero-top">
            <div>
                <h1>@T("Bestuursportaal", "Admin Portal")</h1>
            </div>
            <div class="admin-language">
                <MudSelect T="string"
                           Label="@T("Taal", "Language")"
                           Value="CurrentLanguageCode"
                           ValueChanged="OnLanguageChangedAsync"
                           Dense="true"
                           Variant="Variant.Outlined">
                    <MudSelectItem Value="@("af")">Afrikaans</MudSelectItem>
                    <MudSelectItem Value="@("en")">English</MudSelectItem>
                </MudSelect>
            </div>
        </div>
    </header>

    @if (IsRedirectingToLogin)
    {
        <section class="admin-state">
            <h2>@T("Neem jou na teken in...", "Taking you to sign in...")</h2>
            <p>@T("Jy moet ingeteken wees om die bestuursportaal te gebruik.", "You need to be signed in to use the admin portal.")</p>
        </section>
    }
    else if (IsAccessDenied)
    {
        <section class="admin-state">
            <h2>@T("Toegang geweier", "Access denied")</h2>
            <p>@T("Jou rekening het nie admin regte vir hierdie blad nie.", "Your account does not have admin rights for this page.")</p>
        </section>
    }
    else if (IsLoading)
    {
        <section class="admin-state">
            <h2>@T("Laai bestuursdata...", "Loading admin data...")</h2>
        </section>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <p class="admin-feedback is-error">@ErrorMessage</p>
        }
        else if (!string.IsNullOrWhiteSpace(StatusMessage))
        {
            <p class="admin-feedback is-success">@StatusMessage</p>
        }

        <div class="admin-tabs-shell">
        <MudTabs Class="admin-tabs"
                 Rounded="true">
            <MudTabPanel Text='@T("Intekenaars", "Subscribers")'>
                <section class="admin-section">
                    <div class="admin-section-head admin-subscriber-section-head">
                        <div class="admin-subscriber-submenu">
                            <span class="admin-subscriber-submenu-label">@T("Verslagtipes", "Report types")</span>
                            <div class="admin-subscriber-submenu-links"
                                 role="navigation"
                                 aria-label='@T("Intekenaar verslagtipes", "Subscriber report types")'>
                                @foreach (var subscriberView in SubscriberViews)
                                {
                                    var isActiveSubscriberView = ActiveSubscriberView == subscriberView;
                                    <button type="button"
                                            class='@($"admin-subscriber-submenu-link{(isActiveSubscriberView ? " is-active" : string.Empty)}")'
                                            @onclick='() => SelectSubscriberViewAsync(subscriberView)'
                                            aria-pressed="@isActiveSubscriberView"
                                            title="@GetSubscriberViewLabel(subscriberView)">
                                        @GetSubscriberViewLabel(subscriberView)
                                    </button>
                                }
                            </div>
                        </div>

                        @if (IsShowingSubscriberGrid)
                        {
                            <div class="admin-search">
                                <div class="admin-search-field">
                                    <MudTextField T="string"
                                                  @bind-Value="SubscriberSearch"
                                                  Placeholder='@T("Soek e-pos of naam", "Search email or name")'
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Immediate="true" />
                                </div>
                                <div class="admin-search-actions">
                                    <MudButton Class="admin-icon-btn admin-mobile-cta"
                                               Variant="Variant.Filled"
                                               Color="Color.Secondary"
                                               OnClick="StartNewSubscriber"
                                               aria-label='@T("Skep intekenaar", "Create subscriber")'
                                               title='@T("Skep intekenaar", "Create subscriber")'>
                                        <i class="fa-solid fa-user-plus" aria-hidden="true"></i>
                                        <span class="admin-btn-text">@T("Nuwe intekenaar", "New subscriber")</span>
                                    </MudButton>
                                    <MudButton Class="admin-icon-btn admin-mobile-cta"
                                               Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               OnClick="SearchSubscribersAsync"
                                               aria-label='@T("Soek intekenaars", "Search subscribers")'
                                               title='@T("Soek intekenaars", "Search subscribers")'>
                                        <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                                        <span class="admin-btn-text">@T("Soek", "Search")</span>
                                        <span class="sr-only">@T("Soek intekenaars", "Search subscribers")</span>
                                    </MudButton>
                                    <MudButton Class="admin-icon-btn admin-mobile-cta"
                                               Variant="Variant.Text"
                                               Color="Color.Default"
                                               Disabled="@(!HasActiveSubscriberColumnFilters)"
                                               OnClick="ClearSubscriberColumnFiltersAsync"
                                               aria-label='@T("Maak intekenaarfilters skoon", "Clear subscriber filters")'
                                               title='@T("Maak intekenaarfilters skoon", "Clear subscriber filters")'>
                                        <i class="fa-solid fa-filter-circle-xmark" aria-hidden="true"></i>
                                        <span class="admin-btn-text">@T("Maak filters skoon", "Clear filters")</span>
                                        <span class="sr-only">@T("Maak intekenaarfilters skoon", "Clear subscriber filters")</span>
                                    </MudButton>
                                    <MudButton Class="admin-icon-btn admin-mobile-cta"
                                               Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               OnClick="ReloadSubscribersAsync"
                                               aria-label='@T("Verfris intekenaars", "Refresh subscribers")'
                                               title='@T("Verfris intekenaars", "Refresh subscribers")'>
                                        <i class="fa-solid fa-rotate-right" aria-hidden="true"></i>
                                        <span class="admin-btn-text">@T("Verfris", "Refresh")</span>
                                        <span class="sr-only">@T("Verfris intekenaars", "Refresh subscribers")</span>
                                    </MudButton>
                                    <MudButton Class="admin-icon-btn admin-mobile-cta"
                                               Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               OnClick="ExportFilteredSubscribersAsync"
                                               aria-label='@T("Voer gefilterde intekenaars uit", "Export filtered subscribers")'
                                               title='@T("Voer gefilterde intekenaars uit", "Export filtered subscribers")'>
                                        <i class="fa-solid fa-file-csv" aria-hidden="true"></i>
                                        <span class="admin-btn-text">@T("Voer uit", "Export")</span>
                                    </MudButton>
                                </div>
                            </div>
                            @if (SelectedSubscriberIds.Count > 0)
                            {
                                <div class="admin-bulk-toolbar" role="region" aria-label='@T("Gekose intekenaar aksies", "Selected subscriber actions")'>
                                    <span>@T($"{SelectedSubscriberIds.Count} gekies", $"{SelectedSubscriberIds.Count} selected")</span>
                                    <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="ExportSelectedSubscribersAsync">
                                        @T("Voer gekies uit", "Export selected")
                                    </MudButton>
                                    <MudButton Variant="Variant.Text" Color="Color.Warning" OnClick='() => RunSelectedSubscriberBulkActionAsync(AdminSubscriberBulkAction.Disable)'>
                                        @T("Deaktiveer", "Disable")
                                    </MudButton>
                                    <MudButton Variant="Variant.Text" Color="Color.Success" OnClick='() => RunSelectedSubscriberBulkActionAsync(AdminSubscriberBulkAction.Enable)'>
                                        @T("Heraktiveer", "Enable")
                                    </MudButton>
                                    <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick='() => RunSelectedSubscriberBulkActionAsync(AdminSubscriberBulkAction.SendPasswordReset)'>
                                        @T("Stuur herstel", "Send reset")
                                    </MudButton>
                                    <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="ClearSubscriberSelection">
                                        @T("Maak keuse skoon", "Clear selection")
                                    </MudButton>
                                </div>
                            }
                        }
                    </div>

                    @if (IsShowingSubscriberGrid)
                    {
                        <MudTable T="AdminSubscriberRecord"
                                  @ref="SubscribersTable"
                                  Class="admin-grid admin-subscriber-grid"
                                  ServerData="LoadSubscribersPageAsync"
                                  SortLabel='@T("Sorteer volgens", "Sort by")'
                                  Loading="IsRefreshingSubscribers"
                                  RowsPerPage="100"
                                  Dense="true"
                                  Hover="true"
                                  Bordered="true"
                                  Elevation="0"
                                  Breakpoint="Breakpoint.Sm"
                                  RowClassFunc="GetSubscriberRowClass"
                                  OnRowClick="OnSubscriberRowClick">
                            <HeaderContent>
                                <MudTh Class="admin-selection-cell">
                                    <MudCheckBox T="bool"
                                                 Value="AreAllVisibleSubscribersSelected"
                                                 ValueChanged="ToggleVisibleSubscriberSelection"
                                                 aria-label='@T("Kies alle sigbare intekenaars", "Select all visible subscribers")'
                                                 @onclick:stopPropagation="true" />
                                </MudTh>
                                <MudTh>
                                    <div class="admin-header-cell">
                                        <MudTableSortLabel T="AdminSubscriberRecord" SortLabel="subscriber">
                                            @T("Intekenaar", "Subscriber")
                                        </MudTableSortLabel>
                                        <details class='@($"admin-header-filter{(string.IsNullOrWhiteSpace(SubscriberColumnFilters.SubscriberText) ? string.Empty : " is-active")}")'
                                                 @onclick:stopPropagation="true">
                                            <summary class="admin-header-filter-toggle"
                                                     @onclick:stopPropagation="true"
                                                     title='@T("Filter intekenaar", "Filter subscriber")'>
                                                <i class="fa-solid fa-filter" aria-hidden="true"></i>
                                                <span class="sr-only">@T("Filter intekenaar", "Filter subscriber")</span>
                                            </summary>
                                            <div class="admin-header-filter-popover" @onclick:stopPropagation="true">
                                                <label class="admin-header-filter-label" for="subscriber-filter-text">
                                                    @T("Naam of e-pos", "Name or email")
                                                </label>
                                                <input id="subscriber-filter-text"
                                                       class="admin-header-filter-input"
                                                       type="search"
                                                       @bind="SubscriberTextFilterDraft"
                                                       @bind:event="oninput"
                                                       placeholder='@T("Tik om te filter", "Type to filter")' />
                                                <div class="admin-header-filter-actions-row">
                                                    <button type="button"
                                                            class="admin-header-filter-action"
                                                            @onclick='() => ApplySubscriberTextFilterAsync("subscriber")'>
                                                        @T("Pas toe", "Apply")
                                                    </button>
                                                    <button type="button"
                                                            class="admin-header-filter-action is-secondary"
                                                            @onclick='() => ClearSubscriberTextFilterAsync("subscriber")'>
                                                        @T("Maak skoon", "Clear")
                                                    </button>
                                                </div>
                                            </div>
                                        </details>
                                    </div>
                                </MudTh>
                                <MudTh>
                                    <div class="admin-header-cell">
                                        <MudTableSortLabel T="AdminSubscriberRecord" SortLabel="mobile">
                                            @T("Selfoon", "Mobile")
                                        </MudTableSortLabel>
                                        <details class='@($"admin-header-filter{(string.IsNullOrWhiteSpace(SubscriberColumnFilters.MobileText) ? string.Empty : " is-active")}")'
                                                 @onclick:stopPropagation="true">
                                            <summary class="admin-header-filter-toggle"
                                                     @onclick:stopPropagation="true"
                                                     title='@T("Filter selfoon", "Filter mobile")'>
                                                <i class="fa-solid fa-filter" aria-hidden="true"></i>
                                                <span class="sr-only">@T("Filter selfoon", "Filter mobile")</span>
                                            </summary>
                                            <div class="admin-header-filter-popover" @onclick:stopPropagation="true">
                                                <label class="admin-header-filter-label" for="subscriber-filter-mobile">
                                                    @T("Selfoon bevat", "Mobile contains")
                                                </label>
                                                <input id="subscriber-filter-mobile"
                                                       class="admin-header-filter-input"
                                                       type="search"
                                                       @bind="SubscriberMobileFilterDraft"
                                                       @bind:event="oninput"
                                                       placeholder='@T("Tik om te filter", "Type to filter")' />
                                                <div class="admin-header-filter-actions-row">
                                                    <button type="button"
                                                            class="admin-header-filter-action"
                                                            @onclick='() => ApplySubscriberTextFilterAsync("mobile")'>
                                                        @T("Pas toe", "Apply")
                                                    </button>
                                                    <button type="button"
                                                            class="admin-header-filter-action is-secondary"
                                                            @onclick='() => ClearSubscriberTextFilterAsync("mobile")'>
                                                        @T("Maak skoon", "Clear")
                                                    </button>
                                                </div>
                                            </div>
                                        </details>
                                    </div>
                                </MudTh>
                                <MudTh>
                                    <div class="admin-header-cell">
                                        <MudTableSortLabel T="AdminSubscriberRecord" SortLabel="tiers">
                                            @T("Vlakke", "Tiers")
                                        </MudTableSortLabel>
                                        <details class='@($"admin-header-filter{(string.IsNullOrWhiteSpace(SubscriberColumnFilters.TierText) ? string.Empty : " is-active")}")'
                                                 @onclick:stopPropagation="true">
                                            <summary class="admin-header-filter-toggle"
                                                     @onclick:stopPropagation="true"
                                                     title='@T("Filter vlakke", "Filter tiers")'>
                                                <i class="fa-solid fa-filter" aria-hidden="true"></i>
                                                <span class="sr-only">@T("Filter vlakke", "Filter tiers")</span>
                                            </summary>
                                            <div class="admin-header-filter-popover" @onclick:stopPropagation="true">
                                                <label class="admin-header-filter-label" for="subscriber-filter-tier">
                                                    @T("Vlak bevat", "Tier contains")
                                                </label>
                                                <input id="subscriber-filter-tier"
                                                       class="admin-header-filter-input"
                                                       type="search"
                                                       @bind="SubscriberTierFilterDraft"
                                                       @bind:event="oninput"
                                                       placeholder='@T("Tik om te filter", "Type to filter")' />
                                                <div class="admin-header-filter-actions-row">
                                                    <button type="button"
                                                            class="admin-header-filter-action"
                                                            @onclick='() => ApplySubscriberTextFilterAsync("tiers")'>
                                                        @T("Pas toe", "Apply")
                                                    </button>
                                                    <button type="button"
                                                            class="admin-header-filter-action is-secondary"
                                                            @onclick='() => ClearSubscriberTextFilterAsync("tiers")'>
                                                        @T("Maak skoon", "Clear")
                                                    </button>
                                                </div>
                                            </div>
                                        </details>
                                    </div>
                                </MudTh>
                                <MudTh>
                                    <div class="admin-header-cell">
                                        <MudTableSortLabel T="AdminSubscriberRecord" SortLabel="source">
                                            @T("Bron", "Source")
                                        </MudTableSortLabel>
                                        <details class='@($"admin-header-filter{(string.IsNullOrWhiteSpace(SubscriberColumnFilters.SourceSystem) ? string.Empty : " is-active")}")'
                                                 @onclick:stopPropagation="true">
                                            <summary class="admin-header-filter-toggle"
                                                     @onclick:stopPropagation="true"
                                                     title='@T("Filter bron", "Filter source")'>
                                                <i class="fa-solid fa-filter" aria-hidden="true"></i>
                                                <span class="sr-only">@T("Filter bron", "Filter source")</span>
                                            </summary>
                                            <div class="admin-header-filter-popover" @onclick:stopPropagation="true">
                                                <label class="admin-header-filter-label" for="subscriber-filter-source">
                                                    @T("Bron", "Source")
                                                </label>
                                                <select id="subscriber-filter-source"
                                                        class="admin-header-filter-select"
                                                        value="@SubscriberColumnFilters.SourceSystem"
                                                        @onchange="OnSubscriberSourceFilterChanged">
                                                    <option value="@AdminGridFilterOptionValues.All">@T("Alles", "All")</option>
                                                    <option value="@AdminGridFilterOptionValues.None">@T("Geen", "None")</option>
                                                    <option value="wordpress_pmpro">WordPress / PMPro</option>
                                                    <option value="shink_app">@T("App", "App")</option>
                                                </select>
                                            </div>
                                        </details>
                                    </div>
                                </MudTh>
                                <MudTh>
                                    <div class="admin-header-cell">
                                        <MudTableSortLabel T="AdminSubscriberRecord" SortLabel="provider">
                                            @T("Betaalverskaffer", "Payment Provider")
                                        </MudTableSortLabel>
                                        <details class='@($"admin-header-filter{(string.IsNullOrWhiteSpace(SubscriberColumnFilters.PaymentProvider) ? string.Empty : " is-active")}")'
                                                 @onclick:stopPropagation="true">
                                            <summary class="admin-header-filter-toggle"
                                                     @onclick:stopPropagation="true"
                                                     title='@T("Filter betaalverskaffer", "Filter payment provider")'>
                                                <i class="fa-solid fa-filter" aria-hidden="true"></i>
                                                <span class="sr-only">@T("Filter betaalverskaffer", "Filter payment provider")</span>
                                            </summary>
                                            <div class="admin-header-filter-popover" @onclick:stopPropagation="true">
                                                <label class="admin-header-filter-label" for="subscriber-filter-provider">
                                                    @T("Betaalverskaffer", "Payment Provider")
                                                </label>
                                                <select id="subscriber-filter-provider"
                                                        class="admin-header-filter-select"
                                                        value="@SubscriberColumnFilters.PaymentProvider"
                                                        @onchange="OnSubscriberProviderFilterChanged">
                                                    <option value="@AdminGridFilterOptionValues.All">@T("Alles", "All")</option>
                                                    <option value="@AdminGridFilterOptionValues.None">@T("Geen", "None")</option>
                                                    <option value="payfast">PayFast</option>
                                                    <option value="paystack">Paystack</option>
                                                    <option value="free">@T("Gratis", "Free")</option>
                                                </select>
                                            </div>
                                        </details>
                                    </div>
                                </MudTh>
                                <MudTh>
                                    <div class="admin-header-cell">
                                        <MudTableSortLabel T="AdminSubscriberRecord" SortLabel="status">
                                            @T("Status", "Status")
                                        </MudTableSortLabel>
                                        <details class='@($"admin-header-filter{(string.IsNullOrWhiteSpace(SubscriberColumnFilters.SubscriptionStatus) ? string.Empty : " is-active")}")'
                                                 @onclick:stopPropagation="true">
                                            <summary class="admin-header-filter-toggle"
                                                     @onclick:stopPropagation="true"
                                                     title='@T("Filter status", "Filter status")'>
                                                <i class="fa-solid fa-filter" aria-hidden="true"></i>
                                                <span class="sr-only">@T("Filter status", "Filter status")</span>
                                            </summary>
                                            <div class="admin-header-filter-popover" @onclick:stopPropagation="true">
                                                <label class="admin-header-filter-label" for="subscriber-filter-status">
                                                    @T("Status", "Status")
                                                </label>
                                                <select id="subscriber-filter-status"
                                                        class="admin-header-filter-select"
                                                        value="@SubscriberColumnFilters.SubscriptionStatus"
                                                        @onchange="OnSubscriberStatusFilterChanged">
                                                    <option value="@AdminGridFilterOptionValues.All">@T("Alles", "All")</option>
                                                    <option value="@AdminGridFilterOptionValues.None">@T("Geen", "None")</option>
                                                    <option value="active">@T("Aktief", "Active")</option>
                                                    <option value="pending">@T("Hangend", "Pending")</option>
                                                    <option value="cancelled">@T("Gekanselleer", "Cancelled")</option>
                                                    <option value="failed">@T("Misluk", "Failed")</option>
                                                </select>
                                            </div>
                                        </details>
                                    </div>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel T="AdminSubscriberRecord" SortLabel="subscribed_at">
                                        @T("Ingeteken op", "Subscribed On")
                                    </MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel T="AdminSubscriberRecord" SortLabel="next_payment">
                                        @T("Volgende betaling", "Next Payment")
                                    </MudTableSortLabel>
                                </MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                @{
                                    var subscriberPrimaryLabel = BuildSubscriberPrimaryLabel(context);
                                    var subscriberSecondaryLabel = BuildSubscriberSecondaryLabel(context);
                                }
                                <MudTd Class="admin-selection-cell" DataLabel="">
                                    <MudCheckBox T="bool"
                                                 Value="@SelectedSubscriberIds.Contains(context.SubscriberId)"
                                                 ValueChanged="@((bool isSelected) => ToggleSubscriberSelection(context.SubscriberId, isSelected))"
                                                 aria-label='@T("Kies intekenaar", "Select subscriber")'
                                                 @onclick:stopPropagation="true" />
                                </MudTd>
                                <MudTd DataLabel='@T("Intekenaar", "Subscriber")'>
                                    <div class="admin-subscriber-cell">
                                        <span class="admin-subscriber-avatar" aria-hidden="true">
                                            @if (!string.IsNullOrWhiteSpace(context.ProfileImageUrl))
                                            {
                                                <img class="admin-subscriber-avatar-image"
                                                     src="@context.ProfileImageUrl"
                                                     alt=""
                                                     loading="lazy"
                                                     decoding="async" />
                                            }
                                            else
                                            {
                                                <span class="admin-subscriber-avatar-fallback">@BuildSubscriberInitials(context)</span>
                                            }
                                        </span>
                                        <div class="admin-subscriber-meta">
                                            <span class="admin-subscriber-primary">@HighlightSearchMatch(subscriberPrimaryLabel, SubscriberSearch)</span>
                                            @if (!string.IsNullOrWhiteSpace(subscriberSecondaryLabel))
                                            {
                                                <span class="admin-subscriber-secondary">@HighlightSearchMatch(subscriberSecondaryLabel, SubscriberSearch)</span>
                                            }
                                        </div>
                                    </div>
                                </MudTd>
                                <MudTd DataLabel='@T("Selfoon", "Mobile")'>@HighlightSearchMatch(context.MobileNumber ?? "-", SubscriberSearch)</MudTd>
                                <MudTd DataLabel='@T("Vlakke", "Tiers")'>@BuildTierSummary(context.ActiveTierCodes)</MudTd>
                                <MudTd DataLabel='@T("Bron", "Source")'>@BuildSubscriptionSourceLabel(context.SubscriptionSourceSystem)</MudTd>
                                <MudTd DataLabel='@T("Betaalverskaffer", "Payment Provider")'>@BuildPaymentProviderLabel(context.PaymentProvider)</MudTd>
                                <MudTd DataLabel='@T("Status", "Status")'>@BuildSubscriptionStatusLabel(context)</MudTd>
                                <MudTd DataLabel='@T("Ingeteken op", "Subscribed On")'>@FormatAdminDate(context.SubscribedAt)</MudTd>
                                <MudTd DataLabel='@T("Volgende betaling", "Next Payment")'>@FormatAdminDate(context.NextPaymentDueAt)</MudTd>
                            </RowTemplate>
                            <NoRecordsContent>
