    private async Task SaveSubscriberAsync()
    {
        if (SubscriberEditor is null)
        {
            return;
        }

        IsSavingSubscriber = true;
        ClearFeedback();

        try
        {
            var result = SubscriberEditor.IsNew
                ? await AdminManagementService.CreateSubscriberAsync(
                    CurrentAdminEmail,
                    new AdminSubscriberCreateRequest(
                        SubscriberEditor.Email,
                        SubscriberEditor.FirstName,
                        SubscriberEditor.LastName,
                        SubscriberEditor.DisplayName,
                        SubscriberEditor.MobileNumber,
                        SendNewSubscriberReset,
                        NavigationManager.ToAbsoluteUri("/reset-password").ToString()))
                : await AdminManagementService.UpdateSubscriberAsync(
                    CurrentAdminEmail,
                    new AdminSubscriberUpdateRequest(
                        SubscriberEditor.SubscriberId,
                        SubscriberEditor.FirstName,
                        SubscriberEditor.LastName,
                        SubscriberEditor.DisplayName,
                        SubscriberEditor.MobileNumber,
                        SubscriberEditor.Email));

            if (!HandleOperationResult(result, SubscriberEditor.IsNew
                    ? T("Intekenaar is geskep.", "Subscriber created.")
                    : T("Intekenaar is opgedateer.", "Subscriber updated.")))
            {
                return;
            }

            if (result.EntityId is Guid entityId && entityId != Guid.Empty)
            {
                SubscriberEditor.SubscriberId = entityId;
                SubscriberEditor.IsNew = false;
                await LoadSubscriberDetailAsync(entityId);
            }

            await RefreshSubscribersAsync();
            if (SubscriberEditor is not null && !SubscriberEditor.IsNew)
            {
                await LoadSubscriberDetailAsync(SubscriberEditor.SubscriberId);
            }
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to save subscriber.");
            SetError(T("Kon nie intekenaar nou stoor nie.", "Could not save subscriber right now."));
        }
        finally
        {
            IsSavingSubscriber = false;
        }
    }

