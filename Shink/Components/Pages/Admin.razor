    private string? ValidateNewStoryDraft(NewStoryDraft draft)
    {
        if (string.IsNullOrWhiteSpace(draft.Title))
        {
            return T("Gee asseblief 'n titel vir die storie.", "Please enter a title for the story.");
        }

        if (draft.CoverFile is null)
        {
            return T("Kies asseblief 'n cover image.", "Please choose a cover image.");
        }

        if (draft.CoverFile.Size <= 0 || draft.CoverFile.Size > MaxImageUploadBytes)
        {
            return T("Die cover image moet kleiner as 10 MB wees.", "The cover image must be smaller than 10 MB.");
        }

        if (draft.ThumbnailFile is not null &&
            (draft.ThumbnailFile.Size <= 0 || draft.ThumbnailFile.Size > MaxImageUploadBytes))
        {
            return T("Die thumbnail image moet kleiner as 10 MB wees.", "The thumbnail image must be smaller than 10 MB.");
        }

        if (draft.AudioFile is null)
        {
            return T("Kies asseblief 'n audio file.", "Please choose an audio file.");
        }

        if (draft.AudioFile.Size <= 0 || draft.AudioFile.Size > MaxAudioUploadBytes)
        {
            return T("Die audio file moet kleiner as 256 MB wees.", "The audio file must be smaller than 256 MB.");
        }

        return null;
    }

    private string? ValidateStoryMediaDraft(EditableStory draft)
    {
        if (draft.CoverFile is not null &&
            (draft.CoverFile.Size <= 0 || draft.CoverFile.Size > MaxImageUploadBytes))
        {
            return T("Die cover image moet kleiner as 10 MB wees.", "The cover image must be smaller than 10 MB.");
        }

        if (draft.ThumbnailFile is not null &&
            (draft.ThumbnailFile.Size <= 0 || draft.ThumbnailFile.Size > MaxImageUploadBytes))
        {
            return T("Die thumbnail image moet kleiner as 10 MB wees.", "The thumbnail image must be smaller than 10 MB.");
        }

        if (draft.AudioFile is not null &&
            (draft.AudioFile.Size <= 0 || draft.AudioFile.Size > MaxAudioUploadBytes))
        {
            return T("Die audio file moet kleiner as 256 MB wees.", "The audio file must be smaller than 256 MB.");
        }

        return null;
    }

    private async Task UploadSelectedFileToR2Async(string inputId, DirectStoryMediaUpload upload)
    {
        var module = await GetAdminUploadModuleAsync();
        await module.InvokeVoidAsync(
            "uploadSelectedFileToR2",
            inputId,
            upload.UploadUrl,
            upload.ContentType);
    }

    private async Task<UploadedStoryImage> UploadImageWithFallbackAsync(
        string slug,
        StoryImageKind kind,
        IBrowserFile file,
        string inputId)
    {
        var normalizedContentType = NormalizeImageContentType(file);
        var directUpload = await StoryMediaStorageService.CreateImageDirectUploadAsync(
            slug,
            kind,
            file.Name,
            normalizedContentType);

        try
        {
            await UploadSelectedFileToR2Async(inputId, directUpload);
            return new UploadedStoryImage(
                directUpload.ObjectKey,
                directUpload.PublicUrl ?? throw new InvalidOperationException("Direct image upload did not provide a public URL."),
                directUpload.ContentType);
        }
        catch (Exception exception)
        {
            Logger.LogWarning(
                exception,
                "Direct image upload failed for story {StorySlug}. Falling back to server-side upload.",
                slug);

            await using var stream = file.OpenReadStream(MaxImageUploadBytes);
            return await StoryMediaStorageService.UploadImageAsync(
                slug,
                kind,
                file.Name,
                normalizedContentType,
                stream);
        }
    }

    private async Task<UploadedStoryAudio> UploadAudioWithFallbackAsync(
        string slug,
        IBrowserFile file,
        string inputId)
    {
        var normalizedContentType = NormalizeAudioContentType(file);
        var directUpload = await StoryMediaStorageService.CreateAudioDirectUploadAsync(
            slug,
            file.Name,
            normalizedContentType);

        try
        {
            await UploadSelectedFileToR2Async(inputId, directUpload);
            return new UploadedStoryAudio(
                directUpload.Bucket,
                directUpload.ObjectKey,
                directUpload.ContentType);
        }
        catch (Exception exception)
        {
            Logger.LogWarning(
                exception,
                "Direct audio upload failed for story {StorySlug}. Falling back to server-side upload.",
                slug);

            await using var stream = file.OpenReadStream(MaxAudioUploadBytes);
            return await StoryMediaStorageService.UploadAudioAsync(
                slug,
                file.Name,
                normalizedContentType,
                stream);
        }
    }

    private async Task<IJSObjectReference> GetAdminUploadModuleAsync()
    {
        if (AdminUploadModule is not null)
        {
            return AdminUploadModule;
        }

        AdminUploadModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "/js/admin-r2-upload.js");
        return AdminUploadModule;
    }

    private async Task CleanupUploadedStoryObjectsAsync(IEnumerable<string> objectKeys)
    {
        foreach (var objectKey in objectKeys
                     .Where(key => !string.IsNullOrWhiteSpace(key))
                     .Distinct(StringComparer.OrdinalIgnoreCase))
        {
            await StoryMediaStorageService.DeleteObjectIfExistsAsync(objectKey);
        }
    }

    private bool HandleOperationResult(AdminOperationResult result, string successMessage)
    {
        if (!result.IsSuccess)
        {
            SetError(result.ErrorMessage ?? T("Die aksie kon nie nou voltooi word nie.", "The action could not be completed right now."));
            return false;
        }

        SetStatus(successMessage);
        return true;
    }

    private void ClearFeedback()
    {
        ErrorMessage = null;
        StatusMessage = null;
    }

    private void SetError(string message)
    {
        ErrorMessage = LocalizeKnownServiceMessage(message);
        StatusMessage = null;
        ShowToast(ErrorMessage, Severity.Error);
    }

    private void SetStatus(string message)
    {
        StatusMessage = message;
        ErrorMessage = null;
        ShowToast(StatusMessage, Severity.Success);
    }

    private void ShowToast(string? message, Severity severity)
    {
        if (string.IsNullOrWhiteSpace(message))
        {
            return;
        }

        Snackbar.Clear();
        Snackbar.Add(message, severity);
    }

    private string T(string afrikaans, string english)
    {
        return CurrentLanguage == AdminLanguage.English
            ? english
            : afrikaans;
    }

    private string LocalizeKnownServiceMessage(string message)
    {
        if (CurrentLanguage == AdminLanguage.Afrikaans)
        {
            return message;
        }

        return message switch
        {
            "Jy het nie admin toegang nie." => "You do not have admin access.",
            "Kies asseblief 'n geldige intekenaar." => "Please select a valid subscriber.",
            "Supabase URL is nog nie opgestel nie." => "Supabase URL is not configured yet.",
            "Supabase ServiceRoleKey is nog nie opgestel nie." => "Supabase ServiceRoleKey is not configured yet.",
            "Selfoonnommer moet 7 tot 20 syfers wees." => "Mobile number must contain 7 to 20 digits.",
            "Kon nie intekenaar nou opdateer nie." => "Could not update subscriber right now.",
            "Kies asseblief 'n geldige storie." => "Please select a valid story.",
            "Die storie slug is ongeldig." => "The story slug is invalid.",
            "Storie titel is verpligtend." => "Story title is required.",
            "Audio provider moet 'local' of 'r2' wees." => "Audio provider must be 'local' or 'r2'.",
            "Toegangsvlak moet 'free' of 'subscriber' wees." => "Access level must be 'free' or 'subscriber'.",
