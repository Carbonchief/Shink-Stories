    private string BuildSubscriptionStatusLabel(AdminSubscriberRecord subscriber)
    {
        if (!string.IsNullOrWhiteSpace(subscriber.SubscriptionStatus))
        {
            return subscriber.SubscriptionStatus.Trim().ToLowerInvariant() switch
            {
                "active" => T("Aktief", "Active"),
                "pending" => T("Hangend", "Pending"),
                "cancelled" => T("Gekanselleer", "Cancelled"),
                "failed" => T("Misluk", "Failed"),
                "disabled" => T("Gedeaktiveer", "Disabled"),
                _ => subscriber.SubscriptionStatus
            };
        }

        return subscriber.CancelledAt is not null
            ? T("Gekanselleer", "Cancelled")
            : T("Geen", "None");
    }

    private static string? BuildAdminStoryOpenPath(AdminStoryRecord story)
    {
        if (string.IsNullOrWhiteSpace(story.Slug))
        {
            return null;
        }

        var encodedSlug = Uri.EscapeDataString(story.Slug.Trim());
        return string.Equals(story.AccessLevel, "free", StringComparison.OrdinalIgnoreCase)
            ? $"/gratis/{encodedSlug}"
            : $"/luister/{encodedSlug}";
    }

