    private static MarkupString HighlightSearchMatch(string? value, string? searchTerm)
    {
        var text = value ?? string.Empty;
        var normalizedSearch = searchTerm?.Trim();
        if (string.IsNullOrWhiteSpace(text))
        {
            return new MarkupString(string.Empty);
        }

        if (string.IsNullOrWhiteSpace(normalizedSearch))
        {
            return new MarkupString(HtmlEncoder.Default.Encode(text));
        }

        var builder = new StringBuilder();
        var currentIndex = 0;

        while (currentIndex < text.Length)
        {
            var matchIndex = text.IndexOf(normalizedSearch, currentIndex, StringComparison.OrdinalIgnoreCase);
            if (matchIndex < 0)
            {
                builder.Append(HtmlEncoder.Default.Encode(text[currentIndex..]));
                break;
            }

            if (matchIndex > currentIndex)
            {
                builder.Append(HtmlEncoder.Default.Encode(text[currentIndex..matchIndex]));
            }

            var matchLength = normalizedSearch.Length;
            builder.Append("<mark class=\"admin-search-highlight\">");
            builder.Append(HtmlEncoder.Default.Encode(text.Substring(matchIndex, matchLength)));
            builder.Append("</mark>");

            currentIndex = matchIndex + matchLength;
        }

        return new MarkupString(builder.ToString());
    }

    private string FormatAdminDate(DateTimeOffset? value)
    {
        if (value is null)
        {
            return "-";
        }

        var culture = CurrentLanguage == AdminLanguage.English
            ? CultureInfo.GetCultureInfo("en-ZA")
            : CultureInfo.GetCultureInfo("af-ZA");

        return value.Value.ToLocalTime().ToString("d MMM yyyy", culture);
    }

