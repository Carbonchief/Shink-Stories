    private static IReadOnlyList<AdminSubscriberRecord> FilterSubscribers(
        IReadOnlyList<AdminSubscriberRecord> source,
        string? searchTerm)
    {
        if (source.Count == 0)
        {
            return source;
        }

        var normalizedSearch = searchTerm?.Trim();
        if (string.IsNullOrWhiteSpace(normalizedSearch))
        {
            return source;
        }

        return source.Where(subscriber =>
                subscriber.Email.Contains(normalizedSearch, StringComparison.OrdinalIgnoreCase) ||
                BuildSubscriberName(subscriber).Contains(normalizedSearch, StringComparison.OrdinalIgnoreCase) ||
                (subscriber.MobileNumber?.Contains(normalizedSearch, StringComparison.OrdinalIgnoreCase) ?? false))
            .ToArray();
    }

