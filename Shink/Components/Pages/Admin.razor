    private async Task SaveNewStoryAsync()
    {
        if (NewStoryEditor is null)
        {
            return;
        }

        ClearFeedback();

        var validationMessage = ValidateNewStoryDraft(NewStoryEditor);
        if (!string.IsNullOrWhiteSpace(validationMessage))
        {
            SetError(validationMessage);
            return;
        }

        IsCreatingStory = true;
        var uploadedObjectKeys = new List<string>();

        try
        {
            var allStories = await AdminManagementService.GetStoriesAsync(CurrentAdminEmail);
            var generatedSlug = CreateUniqueStorySlug(NewStoryEditor.Title, allStories);
            if (string.IsNullOrWhiteSpace(generatedSlug))
            {
                SetError(T("Gee asseblief 'n geldige titel vir die storie.", "Please enter a valid title for the story."));
                return;
            }

            var coverFile = NewStoryEditor.CoverFile!;
            var audioFile = NewStoryEditor.AudioFile!;
            var summary = AutofillStorySummary(NewStoryEditor.Summary, NewStoryEditor.Description);
            var description = AutofillStoryDescription(NewStoryEditor.Description, summary);

            var coverUpload = await UploadImageWithFallbackAsync(
                generatedSlug,
                StoryImageKind.Cover,
                coverFile,
                NewStoryCoverInputId);
            uploadedObjectKeys.Add(coverUpload.ObjectKey);

            var thumbnailPath = coverUpload.PublicUrl;
            if (NewStoryEditor.ThumbnailFile is not null)
            {
                var thumbnailUpload = await UploadImageWithFallbackAsync(
                    generatedSlug,
                    StoryImageKind.Thumbnail,
                    NewStoryEditor.ThumbnailFile,
                    NewStoryThumbnailInputId);
                uploadedObjectKeys.Add(thumbnailUpload.ObjectKey);
                thumbnailPath = thumbnailUpload.PublicUrl;
            }

            var audioUpload = await UploadAudioWithFallbackAsync(
                generatedSlug,
                audioFile,
                NewStoryAudioInputId);
            uploadedObjectKeys.Add(audioUpload.ObjectKey);

            var result = await AdminManagementService.CreateStoryAsync(
                CurrentAdminEmail,
                new AdminStoryCreateRequest(
                    Slug: generatedSlug,
                    Title: NewStoryEditor.Title,
                    Summary: summary,
                    Description: description,
                    CoverImagePath: coverUpload.PublicUrl,
                    ThumbnailImagePath: thumbnailPath,
                    AudioBucket: audioUpload.Bucket,
                    AudioObjectKey: audioUpload.ObjectKey,
                    AudioContentType: audioUpload.ContentType,
                    AccessLevel: NewStoryEditor.AccessLevel,
                    Status: NewStoryEditor.PublishNow ? "published" : "draft",
                    IsFeatured: false,
                    SortOrder: BuildNextStorySortOrder(allStories),
                    PublishedAt: NewStoryEditor.PublishNow ? DateTimeOffset.Now : null,
                    DurationSeconds: null));

            if (!result.IsSuccess)
            {
                await CleanupUploadedStoryObjectsAsync(uploadedObjectKeys);
                SetError(result.ErrorMessage ?? T("Kon nie nuwe storie skep nie.", "Could not create the new story."));
                return;
            }

            await RefreshStoriesAsync(result.EntityId);
            NewStoryEditor = null;
            IsNewStoryDialogOpen = false;
            if (string.IsNullOrWhiteSpace(ErrorMessage))
            {
                SetStatus(T("Nuwe storie is geskep en opgelaai.", "New story was created and uploaded."));
            }
        }
        catch (Exception exception)
        {
            await CleanupUploadedStoryObjectsAsync(uploadedObjectKeys);
            Logger.LogError(exception, "Failed to create story from admin upload.");
            SetError(LocalizeNewStoryException(exception));
        }
        finally
        {
            IsCreatingStory = false;
        }
    }

    private async Task SaveStoryAsync()
    {
        if (StoryEditor is null)
        {
            return;
        }

        IsSavingStory = true;
        ClearFeedback();
        var uploadedObjectKeys = new List<string>();

        try
        {
            if ((StoryEditor.CoverFile is not null || StoryEditor.ThumbnailFile is not null) &&
                string.IsNullOrWhiteSpace(StoryEditor.Slug))
            {
                SetError(T("Storie slug ontbreek. Verfris asseblief en probeer weer.", "Story slug is missing. Please refresh and try again."));
                return;
            }

            var validationMessage = ValidateStoryMediaDraft(StoryEditor);
            if (!string.IsNullOrWhiteSpace(validationMessage))
            {
                SetError(validationMessage);
                return;
            }

            if (StoryEditor.CoverFile is not null)
            {
                var coverUpload = await UploadImageWithFallbackAsync(
                    StoryEditor.Slug,
                    StoryImageKind.Cover,
                    StoryEditor.CoverFile,
                    EditStoryCoverInputId);
                uploadedObjectKeys.Add(coverUpload.ObjectKey);
                StoryEditor.CoverImagePath = coverUpload.PublicUrl;
            }

            if (StoryEditor.ThumbnailFile is not null)
            {
                var thumbnailUpload = await UploadImageWithFallbackAsync(
                    StoryEditor.Slug,
                    StoryImageKind.Thumbnail,
                    StoryEditor.ThumbnailFile,
                    EditStoryThumbnailInputId);
                uploadedObjectKeys.Add(thumbnailUpload.ObjectKey);
                StoryEditor.ThumbnailImagePath = thumbnailUpload.PublicUrl;
            }

            if (StoryEditor.AudioFile is not null)
            {
                var audioUpload = await UploadAudioWithFallbackAsync(
                    StoryEditor.Slug,
                    StoryEditor.AudioFile,
                    EditStoryAudioInputId);
                uploadedObjectKeys.Add(audioUpload.ObjectKey);
                StoryEditor.AudioProvider = "r2";
                StoryEditor.AudioBucket = audioUpload.Bucket;
                StoryEditor.AudioObjectKey = audioUpload.ObjectKey;
                StoryEditor.AudioContentType = audioUpload.ContentType;
            }

            var publishedAt = ParseOptionalLocalDateTime(StoryEditor.PublishedAtLocal);
            var result = await AdminManagementService.UpdateStoryAsync(
                CurrentAdminEmail,
                new AdminStoryUpdateRequest(
                    StoryEditor.StoryId,
                    StoryEditor.Slug,
                    StoryEditor.Title,
                    StoryEditor.Summary,
                    StoryEditor.Description,
                    StoryEditor.CoverImagePath,
                    StoryEditor.ThumbnailImagePath,
                    StoryEditor.AudioProvider,
                    StoryEditor.AudioBucket,
                    StoryEditor.AudioObjectKey,
                    StoryEditor.AudioContentType,
                    StoryEditor.AccessLevel,
                    StoryEditor.Status,
                    StoryEditor.IsFeatured,
                    StoryEditor.SortOrder,
                    publishedAt,
                    StoryEditor.DurationSeconds));

            if (!HandleOperationResult(result, T("Storie is opgedateer.", "Story updated.")))
            {
                await CleanupUploadedStoryObjectsAsync(uploadedObjectKeys);
                return;
            }

            StoryEditor.CoverFile = null;
            StoryEditor.CoverFileName = null;
            StoryEditor.ThumbnailFile = null;
            StoryEditor.ThumbnailFileName = null;
            StoryEditor.AudioFile = null;
            StoryEditor.AudioFileName = null;

            await RefreshStoriesAsync(StoryEditor.StoryId);
        }
        catch (Exception exception)
        {
            await CleanupUploadedStoryObjectsAsync(uploadedObjectKeys);
            Logger.LogError(exception, "Failed to save story.");
            SetError(LocalizeStoryEditException(exception));
        }
        finally
        {
            IsSavingStory = false;
        }
    }

