    private MarkupString RenderSubscriberSubscriptions()
    {
        if (SubscriberDetail is null)
        {
            return RenderSubscriberDetailEmpty(T("Geen toegangbesonderhede is gelaai nie.", "No access details loaded."));
        }

        if (SubscriberDetail.Subscriptions.Count == 0)
        {
            return RenderSubscriberDetailEmpty(T("Geen intekening- of toegangrye is gevind nie.", "No subscription or access rows found."));
        }

        var builder = new StringBuilder();
        AppendDetailTableStart(builder, [
            T("Vlak", "Tier"),
            T("Bron", "Source"),
            T("Verskaffer", "Provider"),
            T("Status", "Status"),
            T("Begin", "Started"),
            T("Verval/volgende", "Expires/next"),
            T("Verwysing", "Reference")
        ], "admin-access-table");

        foreach (var subscription in SubscriberDetail.Subscriptions)
        {
            AppendDetailRow(
                builder,
                subscription.TierName,
                subscription.IsAdminOverride ? T("Admin-toegang", "Admin access") : BuildSubscriptionSourceLabel(subscription.SourceSystem),
                BuildPaymentProviderLabel(subscription.Provider),
                subscription.Status,
                FormatAdminDate(subscription.SubscribedAt),
                FormatAdminDate(subscription.NextRenewalAt),
                subscription.ProviderPaymentId ?? subscription.ProviderTransactionId ?? "-");
