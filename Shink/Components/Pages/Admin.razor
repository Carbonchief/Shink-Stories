                    <MudTd DataLabel='@T("Titel", "Title")'>
                        @HighlightSearchMatch(
                            context.IsSystemPlaylist
                                ? $"{context.Title} ({T("Sisteem", "System")})"
                                : context.Title,
                            PlaylistSearch)
                    </MudTd>
                    <MudTd DataLabel='@T("Aktief", "Active")'>
                        <div class="admin-toggle-cell" @onclick:stopPropagation="true">
                            <MudSwitch T="bool"
                                       Value="@context.IsEnabled"
                                       ValueChanged="@(value => TogglePlaylistEnabledAsync(context, value))"
                                       Color="Color.Success"
                                       Disabled="@(IsSavingPlaylistsOrder || IsSavingPlaylist || TogglingPlaylistIds.Contains(context.PlaylistId))" />
                        </div>
                    </MudTd>
                    <MudTd DataLabel='@T("Tuisblad", "Home")'>
                        <div class="admin-toggle-cell" @onclick:stopPropagation="true">
                            <MudSwitch T="bool"
                                       Value="@context.ShowOnHome"
                                       ValueChanged="@(value => TogglePlaylistHomeAsync(context, value))"
                                       Color="Color.Success"
                                       Disabled="@(IsSavingPlaylistsOrder || IsSavingPlaylist || TogglingPlaylistIds.Contains(context.PlaylistId))" />
                        </div>
                    </MudTd>
                    <MudTd DataLabel='@T("Showcase op Luister", "Showcase on Luister")'>
                        <div class="admin-toggle-cell" @onclick:stopPropagation="true">
                            <MudSwitch T="bool"
                                       Value="@context.ShowShowcaseImageOnLuisterPage"
                                       ValueChanged="@(value => TogglePlaylistShowcaseOnLuisterAsync(context, value))"
                                       Color="Color.Success"
                                       Disabled="@(IsSavingPlaylistsOrder || IsSavingPlaylist || TogglingPlaylistIds.Contains(context.PlaylistId))" />
                        </div>
                    </MudTd>
                    <MudTd Class="admin-col-center" DataLabel='@T("Aksies", "Actions")'>
                        <div class="admin-table-actions admin-playlist-actions">
                            @if (!string.IsNullOrWhiteSpace(playlistPlayerPath))
                            {
                                <a class="admin-icon-btn"
                                   href="@playlistPlayerPath"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   @onclick:stopPropagation="true"
                                   aria-label='@T("Maak playlist speler oop in nuwe oortjie", "Open playlist player in new tab")'
                                   title='@T("Maak playlist speler oop in nuwe oortjie", "Open playlist player in new tab")'>
                                    <i class="fa-solid fa-play" aria-hidden="true"></i>
                                    <span class="sr-only">@T("Maak playlist speler oop in nuwe oortjie", "Open playlist player in new tab")</span>
                                </a>
                            }
                            @if (!string.IsNullOrWhiteSpace(playlistShowcasePath))
                            {
                                <a class="admin-icon-btn"
                                   href="@playlistShowcasePath"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   @onclick:stopPropagation="true"
                                   aria-label='@T("Maak playlist showcase oop in nuwe oortjie", "Open playlist showcase in new tab")'
                                   title='@T("Maak playlist showcase oop in nuwe oortjie", "Open playlist showcase in new tab")'>
                                    <i class="fa-solid fa-images" aria-hidden="true"></i>
                                    <span class="sr-only">@T("Maak playlist showcase oop in nuwe oortjie", "Open playlist showcase in new tab")</span>
                                </a>
                            }
                            <button type="button"
                                    class="admin-icon-btn"
                                    @onclick="() => MovePlaylistAsync(context.PlaylistId, -1)"
                                    @onclick:stopPropagation="true"
                                    disabled="@(playlistIndex <= 0 || IsSavingPlaylistsOrder)"
                                    aria-label='@T("Skuif playlist op", "Move playlist up")'
                                    title='@T("Skuif playlist op", "Move playlist up")'>
                                <i class="fa-solid fa-arrow-up" aria-hidden="true"></i>
                                <span class="sr-only">@T("Skuif playlist op", "Move playlist up")</span>
                            </button>
                            <button type="button"
                                    class="admin-icon-btn"
                                    @onclick="() => MovePlaylistAsync(context.PlaylistId, 1)"
                                    @onclick:stopPropagation="true"
                                    disabled="@(playlistIndex < 0 || playlistIndex == Playlists.Count - 1 || IsSavingPlaylistsOrder)"
                                    aria-label='@T("Skuif playlist af", "Move playlist down")'
                                    title='@T("Skuif playlist af", "Move playlist down")'>
                                <i class="fa-solid fa-arrow-down" aria-hidden="true"></i>
                                <span class="sr-only">@T("Skuif playlist af", "Move playlist down")</span>
                            </button>
                        </div>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2">
                        @(string.IsNullOrWhiteSpace(PlaylistSearch)
                            ? T("Geen playlists gevind nie.", "No playlists found.")
                            : T("Geen playlists pas by jou soektog nie.", "No playlists match your search."))
                    </MudText>
                </NoRecordsContent>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>

                </section>
            </MudTabPanel>

            <MudTabPanel Text='@T("Karakters", "Characters")'>
                <AdminCharactersPanel CurrentLanguageCode="@CurrentLanguageCode" />
            </MudTabPanel>

            <MudTabPanel Text='@T("Hulpbronne", "Resources")'>
                <AdminResourceTypesPanel CurrentLanguageCode="@CurrentLanguageCode" />
            </MudTabPanel>

            <MudTabPanel Text='@T("Winkel", "Shop")'>
                <AdminStorePanel CurrentLanguageCode="@CurrentLanguageCode" />
            </MudTabPanel>

            <MudTabPanel Text='@T("Blog", "Blog")'>
                <AdminBlogPanel CurrentLanguageCode="@CurrentLanguageCode" />
            </MudTabPanel>

            <MudTabPanel Text='@T("Analitika", "Analytics")'>
                <section class="admin-section admin-analytics-section">
                    <div class="admin-section-head">
                        <div class="admin-analytics-copy">
                            <h2>@T("Gebruiksanalitika", "Usage analytics")</h2>
                            <p class="admin-form-note">
                                @T(
                                    "Hier wys ons die storie-kyke, luistersessies, gunstelinge en karakter-profiel klankspeelaksies wat tans reeds nagespoor word.",
                                    "This shows the story views, listen sessions, favorites, and character profile audio plays that are currently being tracked.")
                            </p>
                        </div>
                        <MudButton Class="admin-mobile-cta"
                                   Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   OnClick="RefreshAnalyticsAsync"
                                   Disabled="IsRefreshingAnalytics"
                                   aria-label='@T("Verfris analitika", "Refresh analytics")'
                                   title='@T("Verfris analitika", "Refresh analytics")'>
                            <i class="fa-solid fa-rotate-right" aria-hidden="true"></i>
                            <span class="admin-btn-text">
                                @(IsRefreshingAnalytics ? T("Verfris...", "Refreshing...") : T("Verfris", "Refresh"))
                            </span>
                        </MudButton>
                    </div>

                    @if (!HasAnalyticsData)
                    {
                        <section class="admin-state">
                            <h2>@T("Nog geen analitika beskikbaar nie", "No analytics available yet")</h2>
                            <p>
                                @T(
                                    "Sodra stories of karakterprofiele gebruik word, sal die nagespoorde data hier verskyn.",
                                    "As stories or character profiles get used, the tracked data will appear here.")
                            </p>
                        </section>
                    }
                    else
                    {
                        <div class="admin-analytics-grid">
                            <article class="admin-analytics-card">
                                <p class="admin-analytics-label">@T("Storie-kyke", "Story views")</p>
                                <p class="admin-analytics-value">@FormatAnalyticsNumber(Analytics.StorySummary.TotalViews)</p>
                                <div class="admin-analytics-meta">
                                    <span>@T("Unieke kykers", "Unique viewers")</span>
                                    <strong>@FormatAnalyticsNumber(Analytics.StorySummary.UniqueViewers)</strong>
                                </div>
                                <div class="admin-analytics-meta">
                                    <span>@T("Stories met kyke", "Stories with views")</span>
                                    <strong>@FormatAnalyticsNumber(Analytics.StorySummary.UniqueViewedStories)</strong>
                                </div>
                                <p class="admin-analytics-footnote">
                                    @T("Laaste kyk", "Last view"): @FormatAdminDateTime(Analytics.StorySummary.LastViewAt)
                                </p>
                            </article>

                            <article class="admin-analytics-card">
                                <p class="admin-analytics-label">@T("Luistersessies", "Listen sessions")</p>
                                <p class="admin-analytics-value">@FormatAnalyticsNumber(Analytics.StorySummary.TotalListenSessions)</p>
                                <div class="admin-analytics-meta">
                                    <span>@T("Luister-events", "Listen events")</span>
                                    <strong>@FormatAnalyticsNumber(Analytics.StorySummary.TotalListenEvents)</strong>
                                </div>
                                <div class="admin-analytics-meta">
                                    <span>@T("Unieke luisteraars", "Unique listeners")</span>
                                    <strong>@FormatAnalyticsNumber(Analytics.StorySummary.UniqueListeners)</strong>
                                </div>
                                <p class="admin-analytics-footnote">
                                    @T("Laaste luister", "Last listen"): @FormatAdminDateTime(Analytics.StorySummary.LastListenAt)
                                </p>
                            </article>

                            <article class="admin-analytics-card">
                                <p class="admin-analytics-label">@T("Totale luistertyd", "Total listening time")</p>
                                <p class="admin-analytics-value">@FormatAnalyticsDuration(Analytics.StorySummary.TotalListenedSeconds)</p>
                                <div class="admin-analytics-meta">
                                    <span>@T("Gemiddeld per sessie", "Average per session")</span>
                                    <strong>@FormatAnalyticsDuration(Analytics.StorySummary.AverageListenedSecondsPerSession)</strong>
                                </div>
                                <div class="admin-analytics-meta">
                                    <span>@T("Stories wat geluister is", "Stories listened to")</span>
                                    <strong>@FormatAnalyticsNumber(Analytics.StorySummary.UniqueListenedStories)</strong>
                                </div>
                                <p class="admin-analytics-footnote">
                                    @T("Laas verfris", "Last refreshed"): @FormatAdminDateTime(Analytics.GeneratedAt)
                                </p>
                            </article>

                            <article class="admin-analytics-card">
                                <p class="admin-analytics-label">@T("Gunstelinge", "Favorites")</p>
                                <p class="admin-analytics-value">@FormatAnalyticsNumber(Analytics.StorySummary.TotalFavorites)</p>
                                <div class="admin-analytics-meta">
                                    <span>@T("Unieke mense", "Unique people")</span>
                                    <strong>@FormatAnalyticsNumber(Analytics.StorySummary.UniqueFavoriters)</strong>
                                </div>
                                <div class="admin-analytics-meta">
                                    <span>@T("Bron", "Source")</span>
                                    <strong>@T("Luister", "Luister")</strong>
                                </div>
                                <p class="admin-analytics-footnote">
                                    @T("Laaste gunsteling", "Last favorite"): @FormatAdminDateTime(Analytics.StorySummary.LastFavoriteAt)
                                </p>
                            </article>

                            <article class="admin-analytics-card">
                                <p class="admin-analytics-label">@T("Karakter-klankspelings", "Character audio plays")</p>
                                <p class="admin-analytics-value">@FormatAnalyticsNumber(Analytics.CharacterSummary.TotalAudioPlays)</p>
                                <div class="admin-analytics-meta">
                                    <span>@T("Unieke karakters", "Unique characters")</span>
                                    <strong>@FormatAnalyticsNumber(Analytics.CharacterSummary.UniqueCharacters)</strong>
                                </div>
                                <div class="admin-analytics-meta">
                                    <span>@T("Unieke intekenaars", "Unique subscribers")</span>
                                    <strong>@FormatAnalyticsNumber(Analytics.CharacterSummary.UniqueSubscribers)</strong>
                                </div>
                                <p class="admin-analytics-footnote">
                                    @T("Laaste klankspeling", "Last audio play"): @FormatAdminDateTime(Analytics.CharacterSummary.LastAudioPlayAt)
                                </p>
                            </article>
                        </div>

                        <div class="admin-analytics-layout">
                            <section class="admin-analytics-panel">
                                <div class="admin-analytics-panel-head">
                                    <div>
                                        <h3>@T("Laaste 14 dae", "Last 14 days")</h3>
                                        <p>@T("Dag-vir-dag gebruik vir die events wat ons reeds log.", "Day-by-day usage for the events we already log.")</p>
                                    </div>
                                </div>

                                <div class="admin-activity-list">
                                    @foreach (var activity in Analytics.DailyActivity)
                                    {
                                        <article class="admin-activity-row">
                                            <div class="admin-activity-date">
                                                <strong>@FormatAnalyticsDay(activity.ActivityDate)</strong>
                                            </div>
                                            <div class="admin-activity-metrics">
                                                <span>@T("Kyke", "Views"): @FormatAnalyticsNumber(activity.TotalViews)</span>
                                                <span>@T("Sessies", "Sessions"): @FormatAnalyticsNumber(activity.TotalListenSessions)</span>
                                                <span>@T("Luistertyd", "Listening time"): @FormatAnalyticsDuration(activity.TotalListenedSeconds)</span>
                                                <span>@T("Gunstelinge", "Favorites"): @FormatAnalyticsNumber(activity.TotalFavorites)</span>
                                            </div>
                                        </article>
                                    }
                                </div>
                            </section>

                            <section class="admin-analytics-panel">
                                <div class="admin-analytics-panel-head">
                                    <div>
                                        <h3>@T("Top karakters", "Top characters")</h3>
                                        <p>@T("Karakterprofiele waarvan die klank die meeste gespeel is.", "Character profiles whose audio has been played the most.")</p>
                                    </div>
                                </div>

                                @if (Analytics.TopCharacters.Count == 0)
                                {
                                    <p class="admin-form-note">@T("Nog geen karakter-klankspelings nie.", "No character audio plays yet.")</p>
                                }
                                else
                                {
                                    <div class="admin-character-analytics-list">
                                        @foreach (var character in Analytics.TopCharacters)
                                        {
                                            <article class="admin-character-analytics-item">
                                                <div>
                                                    <strong>@character.DisplayName</strong>
                                                    <span>@character.CharacterSlug</span>
                                                </div>
                                                <div class="admin-character-analytics-stats">
                                                    <span>@T("Spelings", "Plays"): @FormatAnalyticsNumber(character.TotalAudioPlays)</span>
                                                    <span>@T("Mense", "People"): @FormatAnalyticsNumber(character.UniqueSubscribers)</span>
                                                    <span>@T("Laaste", "Last"): @FormatAdminDateTime(character.LastActivityAt)</span>
                                                </div>
                                            </article>
                                        }
                                    </div>
                                }
                            </section>

                            <section class="admin-analytics-panel admin-analytics-panel-wide">
                                <div class="admin-analytics-panel-head">
                                    <div>
                                        <h3>@T("Top stories", "Top stories")</h3>
                                        <p>@T("Gerangskik volgens luistertyd, en dan kyke en gunstelinge.", "Ranked by listening time, then views and favorites.")</p>
                                    </div>
                                </div>

                                <MudTable T="AdminAnalyticsTopStoryRecord"
                                          Class="admin-grid"
                                          Items="Analytics.TopStories"
                                          RowsPerPage="10"
                                          Dense="true"
                                          Hover="true"
                                          Bordered="true"
                                          Elevation="0"
                                          Breakpoint="Breakpoint.Md">
                                    <HeaderContent>
                                        <MudTh>@T("Titel", "Title")</MudTh>
                                        <MudTh>@T("Kyke", "Views")</MudTh>
                                        <MudTh>@T("Sessies", "Sessions")</MudTh>
                                        <MudTh>@T("Luistertyd", "Listening time")</MudTh>
                                        <MudTh>@T("Gunstelinge", "Favorites")</MudTh>
                                        <MudTh>@T("Laaste aktiwiteit", "Last activity")</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel='@T("Titel", "Title")'>
                                            <div class="admin-analytics-story-cell">
                                                <strong>@context.Title</strong>
                                                <span>@context.StorySlug</span>
                                            </div>
                                        </MudTd>
                                        <MudTd DataLabel='@T("Kyke", "Views")'>@FormatAnalyticsNumber(context.TotalViews)</MudTd>
                                        <MudTd DataLabel='@T("Sessies", "Sessions")'>@FormatAnalyticsNumber(context.TotalListenSessions)</MudTd>
                                        <MudTd DataLabel='@T("Luistertyd", "Listening time")'>@FormatAnalyticsDuration(context.TotalListenedSeconds)</MudTd>
                                        <MudTd DataLabel='@T("Gunstelinge", "Favorites")'>@FormatAnalyticsNumber(context.TotalFavorites)</MudTd>
                                        <MudTd DataLabel='@T("Laaste aktiwiteit", "Last activity")'>@FormatAdminDateTime(context.LastActivityAt)</MudTd>
                                    </RowTemplate>
                                    <NoRecordsContent>
                                        <MudText Typo="Typo.body2">@T("Nog geen storie-analitika nie.", "No story analytics yet.")</MudText>
                                    </NoRecordsContent>
                                </MudTable>
                            </section>
                        </div>
                    }
                </section>
            </MudTabPanel>

        </MudTabs>
        </div>

        @if (SubscriberEditor is not null)
        {
            <MudDialog Visible="IsSubscriberDialogOpen"
                       VisibleChanged="OnSubscriberDialogVisibleChanged"
                       Class="admin-solid-dialog"
                       ContentClass="admin-solid-dialog-content"
                       Options="SubscriberEditorDialogOptions">
                <TitleContent>
                    <MudText Typo="Typo.h6">
                        @(SubscriberEditor.IsNew ? T("Skep intekenaar", "Create subscriber") : T("Bestuur intekenaar", "Manage subscriber"))
                    </MudText>
                </TitleContent>
                <DialogContent>
                    <div class="admin-solid-dialog-body">
                        <MudTabs Class="admin-detail-tabs" Rounded="true">
                            <MudTabPanel Text='@T("Rekening", "Account")'>
                                <div class="admin-form-grid">
                                <MudTextField T="string"
                                              Label='@T("E-pos", "Email")'
                                              @bind-Value="SubscriberEditor.Email"
                                              Disabled="@(!SubscriberEditor.IsNew && IsSavingSubscriber)"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                                <MudTextField T="string"
                                              Label='@T("Voornaam", "First name")'
                                              @bind-Value="SubscriberEditor.FirstName"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                                <MudTextField T="string"
                                              Label='@T("Van", "Last name")'
                                              @bind-Value="SubscriberEditor.LastName"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                                <MudTextField T="string"
                                              Label='@T("Vertoonnaam", "Display name")'
                                              @bind-Value="SubscriberEditor.DisplayName"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                                <MudTextField T="string"
                                              Label='@T("Selfoon", "Mobile")'
                                              @bind-Value="SubscriberEditor.MobileNumber"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                                @if (SubscriberEditor.IsNew)
                                {
                                    <MudCheckBox T="bool"
                                                 Class="admin-span-2"
                                                 Label='@T("Stuur wagwoordherstel e-pos", "Send password reset email")'
                                                 @bind-Value="SendNewSubscriberReset" />
                                }
                                </div>
                                @if (!SubscriberEditor.IsNew)
                                {
                                    <div class="admin-action-grid">
                                        <MudTextField T="string"
                                                      Label='@T("Rede vir deaktivering", "Disable reason")'
                                                      @bind-Value="SubscriberDisableReason"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense" />
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="@(SubscriberEditor.DisabledAt is null ? Color.Warning : Color.Success)"
                                                   Disabled="@IsSavingSubscriberAction"
                                                   OnClick="ToggleSubscriberDisabledAsync">
                                            @(SubscriberEditor.DisabledAt is null ? T("Deaktiveer intekenaar", "Disable subscriber") : T("Heraktiveer intekenaar", "Enable subscriber"))
                                        </MudButton>
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   Disabled="@IsSavingSubscriberAction"
                                                   OnClick="SendSubscriberPasswordResetAsync">
                                            @T("Stuur wagwoordherstel", "Send password reset")
                                        </MudButton>
                                    </div>
                                }
                            </MudTabPanel>
                            <MudTabPanel Text='@T("Toegang", "Access")'>
                                @if (IsLoadingSubscriberDetail)
                                {
                                    <p class="admin-form-note">@T("Laai intekenaarbesonderhede...", "Loading subscriber details...")</p>
                                }
                                else
                                {
                                    @RenderSubscriberSubscriptions()
                                    <div class="admin-override-header">
                                        <h4>@T("Override", "Override")</h4>
                                        <p>@T("Gebruik hierdie velde om handmatige admin-toegang by te voeg. Verskaffer- en invoerintekeninge bly leesalleen.", "Use these fields to add manual admin access. Provider and imported subscriptions remain read-only.")</p>
                                    </div>
                                    <div class="admin-action-grid">
                                        <MudSelect T="string"
                                                   Label='@T("Toegangsvlak", "Access tier")'
                                                   @bind-Value="ManualAccessTierCode"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense">
                                            @foreach (var tier in SubscriberDetail?.TierOptions.Where(tier => tier.IsActive) ?? Array.Empty<AdminSubscriptionTierOption>())
                                            {
                                                <MudSelectItem Value="@tier.TierCode">@tier.DisplayName</MudSelectItem>
                                            }
                                        </MudSelect>
                                        <MudDatePicker Label='@T("Verval op", "Expires on")'
                                                       Date="ManualAccessExpiryDate"
                                                       DateChanged="OnManualAccessExpiryChanged"
                                                       Variant="Variant.Outlined"
                                                       Margin="Margin.Dense" />
                                        <MudTextField T="string"
                                                      Label='@T("Nota", "Note")'
                                                      @bind-Value="ManualAccessReason"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense" />
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Disabled="@IsSavingSubscriberAction"
                                                   OnClick="GrantSubscriberAccessAsync">
                                            @T("Gee handmatige toegang", "Grant manual access")
                                        </MudButton>
                                        @if (SubscriberDetail?.Subscriptions.Any(subscription => subscription.IsAdminOverride && string.Equals(subscription.Status, "active", StringComparison.OrdinalIgnoreCase)) == true)
                                        {
                                            <MudSelect T="Guid"
                                                       Label='@T("Handmatige toegang om te kanselleer", "Manual access to cancel")'
                                                       @bind-Value="SelectedAdminOverrideSubscriptionId"
                                                       Variant="Variant.Outlined"
                                                       Margin="Margin.Dense">
                                                @foreach (var subscription in SubscriberDetail.Subscriptions.Where(subscription => subscription.IsAdminOverride && string.Equals(subscription.Status, "active", StringComparison.OrdinalIgnoreCase)))
                                                {
                                                    <MudSelectItem Value="@subscription.SubscriptionId">@($"{subscription.TierName} - {FormatAdminDate(subscription.NextRenewalAt)}")</MudSelectItem>
                                                }
                                            </MudSelect>
                                            <MudTextField T="string"
                                                          Label='@T("Kansellasie nota", "Cancellation note")'
                                                          @bind-Value="SubscriberAccessCancelReason"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense" />
                                            <MudButton Variant="Variant.Outlined"
                                                       Color="Color.Warning"
                                                       Disabled="@IsSavingSubscriberAction"
                                                       OnClick="CancelSelectedSubscriberAccessAsync">
                                                @T("Kanselleer handmatige toegang", "Cancel manual access")
                                            </MudButton>
                                        }
                                    </div>
                                }
                            </MudTabPanel>
                            <MudTabPanel Text='@T("Betaling", "Billing")'>
                                @RenderSubscriberBilling()
                            </MudTabPanel>
                            <MudTabPanel Text='@T("Aktiwiteit", "Activity")'>
                                @RenderSubscriberActivity()
                            </MudTabPanel>
                            <MudTabPanel Text='@T("Herstel", "Recoveries")'>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Disabled="@IsSavingSubscriberAction"
                                           OnClick="ResendSubscriberRecoveryEmailAsync">
                                    @T("Stuur aktiewe herstel-e-pos weer", "Resend active recovery email")
                                </MudButton>
                                @RenderSubscriberRecoveries()
                            </MudTabPanel>
                        </MudTabs>
                    </div>
                </DialogContent>
                <DialogActions>
                    <div class="admin-dialog-actions-row">
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Default"
                                   OnClick="CloseSubscriberDialogAsync">
                            @T("Sluit", "Close")
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Class="admin-btn"
                                   Disabled="@IsSavingSubscriber"
                                   OnClick="SaveSubscriberAsync">
                            @(IsSavingSubscriber ? T("Stoor...", "Saving...") : SubscriberEditor.IsNew ? T("Skep intekenaar", "Create subscriber") : T("Stoor intekenaar", "Save subscriber"))
                        </MudButton>
                    </div>
                </DialogActions>
