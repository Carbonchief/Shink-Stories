        }

        return $"/luister/speellys/{Uri.EscapeDataString(playlist.Slug.Trim())}";
    }

    private static string? BuildAdminPlaylistShowcasePath(AdminPlaylistRecord playlist)
    {
        var playerPath = BuildAdminPlaylistPlayerPath(playlist);
        return string.IsNullOrWhiteSpace(playerPath)
            ? null
            : $"{playerPath}/stories";
    }

