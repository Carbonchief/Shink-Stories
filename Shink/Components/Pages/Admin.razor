    private async Task<UploadedStoryImage> UploadImageWithFallbackAsync(
        string slug,
        StoryImageKind kind,
        IBrowserFile file,
        string inputId)
    {
        var normalizedContentType = NormalizeImageContentType(file);
        var directUpload = await StoryMediaStorageService.CreateImageDirectUploadAsync(
            slug,
            kind,
            file.Name,
            normalizedContentType);

        try
        {
            await UploadSelectedFileToR2Async(inputId, directUpload);
            return new UploadedStoryImage(
                directUpload.ObjectKey,
                directUpload.PublicUrl ?? throw new InvalidOperationException("Direct image upload did not provide a public URL."),
                directUpload.ContentType);
        }
        catch (Exception exception)
        {
            Logger.LogWarning(
                exception,
                "Direct image upload failed for story {StorySlug}. Falling back to server-side upload.",
                slug);

            await using var stream = file.OpenReadStream(MaxImageUploadBytes);
            return await StoryMediaStorageService.UploadImageAsync(
                slug,
                kind,
                file.Name,
                normalizedContentType,
                stream);
        }
    }

    private async Task<UploadedStoryImage> UploadGeneratedThumbnailAsync(string slug, IBrowserFile coverFile)
    {
        await using var generatedThumbnail = await CreateGeneratedThumbnailAsync(coverFile);
        generatedThumbnail.Content.Position = 0;

        return await StoryMediaStorageService.UploadImageAsync(
            slug,
            StoryImageKind.Thumbnail,
            generatedThumbnail.FileName,
            generatedThumbnail.ContentType,
            generatedThumbnail.Content);
    }

    private async Task<GeneratedThumbnailUpload> CreateGeneratedThumbnailAsync(IBrowserFile coverFile)
    {
        var normalizedContentType = NormalizeImageContentType(coverFile);
        if (!IsSupportedImageContentType(normalizedContentType))
        {
            throw new InvalidOperationException("Unsupported cover image format for thumbnail generation.");
        }

        await using var sourceStream = coverFile.OpenReadStream(MaxImageUploadBytes);
        using var image = await SixLabors.ImageSharp.Image.LoadAsync(sourceStream);
        image.Mutate(operation =>
        {
            operation.AutoOrient();
            operation.Resize(new ResizeOptions
            {
                Mode = SixLabors.ImageSharp.Processing.ResizeMode.Max,
                Size = new SixLabors.ImageSharp.Size(GeneratedThumbnailMaxDimension, GeneratedThumbnailMaxDimension),
                Sampler = KnownResamplers.Lanczos3
            });
        });

        image.Metadata.ExifProfile = null;
        image.Metadata.IccProfile = null;
        image.Metadata.XmpProfile = null;

        var output = new MemoryStream();
        var baseFileName = Path.GetFileNameWithoutExtension(coverFile.Name);
        if (string.IsNullOrWhiteSpace(baseFileName))
        {
            baseFileName = "story-thumbnail";
        }

        string fileName;
        string contentType;

        if (normalizedContentType is "image/png" or "image/webp")
        {
            fileName = $"{baseFileName}-thumb.webp";
            contentType = "image/webp";
            await image.SaveAsync(output, new WebpEncoder
            {
                Quality = GeneratedThumbnailQuality
            });
        }
        else
        {
            fileName = $"{baseFileName}-thumb.jpg";
            contentType = "image/jpeg";
            await image.SaveAsync(output, new JpegEncoder
            {
                Quality = GeneratedThumbnailQuality
            });
        }

        output.Position = 0;
        return new GeneratedThumbnailUpload(fileName, contentType, output);
    }

    private async Task<PlaylistImageUploadResult> UploadPlaylistImageAsync(
        string playlistSlug,
        PlaylistImageAssetKind kind,
        IBrowserFile file,
        string inputId)
    {
        if (IsR2UploadConfigured)
        {
            var uploaded = await UploadImageWithFallbackAsync(
                playlistSlug,
                kind == PlaylistImageAssetKind.Logo ? StoryImageKind.Thumbnail : StoryImageKind.Cover,
                file,
                inputId);

            return new PlaylistImageUploadResult(
                PublicPath: uploaded.PublicUrl,
                R2ObjectKey: uploaded.ObjectKey);
        }

        var localUpload = await UploadPlaylistImageToLocalAsync(playlistSlug, kind, file);
        return new PlaylistImageUploadResult(
            PublicPath: localUpload.PublicPath,
            LocalFilePath: localUpload.PhysicalPath);
    }

    private async Task<(string PublicPath, string PhysicalPath)> UploadPlaylistImageToLocalAsync(
        string playlistSlug,
        PlaylistImageAssetKind kind,
        IBrowserFile file)
    {
        var normalizedSlug = CreatePlaylistSlug(playlistSlug);
        if (string.IsNullOrWhiteSpace(normalizedSlug))
        {
            normalizedSlug = "playlist";
        }

        var normalizedContentType = NormalizeImageContentType(file);
        var extension = normalizedContentType switch
        {
            "image/jpeg" => ".jpg",
            "image/png" => ".png",
            "image/webp" => ".webp",
            _ => Path.GetExtension(file.Name).Trim().ToLowerInvariant()
        };

        var timestamp = DateTimeOffset.UtcNow;
        var year = timestamp.ToString("yyyy");
        var month = timestamp.ToString("MM");
        var suffix = kind == PlaylistImageAssetKind.Logo ? "logo" : "backdrop";
        var fileName = $"{normalizedSlug}-{suffix}-{timestamp:yyyyMMddHHmmss}-{Guid.NewGuid():N}{extension}";

        var rootPath = string.IsNullOrWhiteSpace(WebHostEnvironment.WebRootPath)
            ? Path.Combine(Directory.GetCurrentDirectory(), "wwwroot")
            : WebHostEnvironment.WebRootPath;
        var directoryPath = Path.Combine(rootPath, "branding", "uploaded", "playlists", year, month);
        Directory.CreateDirectory(directoryPath);

        var physicalPath = Path.Combine(directoryPath, fileName);
        await using (var sourceStream = file.OpenReadStream(MaxImageUploadBytes))
        await using (var destinationStream = File.Create(physicalPath))
        {
            await sourceStream.CopyToAsync(destinationStream);
        }

        var publicPath = $"/branding/uploaded/playlists/{year}/{month}/{fileName}";
        return (publicPath, physicalPath);
    }

    private async Task<UploadedStoryAudio> UploadAudioWithFallbackAsync(
