    private async Task RunSelectedSubscriberBulkActionAsync(AdminSubscriberBulkAction action)
    {
        var selectedIds = SelectedSubscriberIds
            .Where(id => Subscribers.Any(subscriber => subscriber.SubscriberId == id))
            .ToArray();
        if (selectedIds.Length == 0)
        {
            SetError(T("Kies eers ten minste een sigbare intekenaar.", "Select at least one visible subscriber first."));
            return;
        }

        IsSavingSubscriberAction = true;
        ClearFeedback();

        try
        {
            var result = await AdminManagementService.RunSubscriberBulkActionAsync(
                CurrentAdminEmail,
                new AdminSubscriberBulkActionRequest(
                    action,
                    selectedIds,
                    SubscriberBulkReason,
                    BuildPasswordResetUrl()));

            if (result.SucceededCount > 0)
            {
                SetStatus(T(
                    $"{result.SucceededCount} van {result.RequestedCount} intekenaars is opgedateer.",
                    $"{result.SucceededCount} of {result.RequestedCount} subscribers updated."));
                SelectedSubscriberIds.Clear();
                await RefreshSubscribersAsync();
                if (SubscriberEditor is not null && !SubscriberEditor.IsNew)
                {
                    await LoadSubscriberDetailAsync(SubscriberEditor.SubscriberId);
                }
                return;
            }

            SetError(result.ErrorMessages.Count > 0
                ? string.Join(" ", result.ErrorMessages.Select(LocalizeKnownServiceMessage))
                : T("Die grootmaataksie kon nie voltooi word nie.", "The bulk action could not be completed."));
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to run subscriber bulk action {Action}.", action);
            SetError(T("Kon nie die grootmaataksie nou voltooi nie.", "Could not complete the bulk action right now."));
        }
        finally
        {
            IsSavingSubscriberAction = false;
        }
    }

