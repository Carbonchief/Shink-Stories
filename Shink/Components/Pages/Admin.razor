    private async Task LoadSubscriberDetailAsync(Guid subscriberId)
    {
        if (subscriberId == Guid.Empty)
        {
            SubscriberDetail = null;
            return;
        }

        IsLoadingSubscriberDetail = true;
        try
        {
            SubscriberDetail = await AdminManagementService.GetSubscriberDetailAsync(CurrentAdminEmail, subscriberId);
            var activeAdminOverride = SubscriberDetail?.Subscriptions
                .Where(subscription => subscription.IsAdminOverride && string.Equals(subscription.Status, "active", StringComparison.OrdinalIgnoreCase))
                .OrderByDescending(subscription => subscription.NextRenewalAt)
                .FirstOrDefault();
            SelectedAdminOverrideSubscriptionId = activeAdminOverride?.SubscriptionId ?? Guid.Empty;
            ManualAccessTierCode = string.Empty;
            ManualAccessExpiryDate = null;
            ManualAccessReason = string.Empty;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to load subscriber detail.");
            SubscriberDetail = null;
            SetError(T("Kon nie intekenaarbesonderhede nou laai nie.", "Could not load subscriber details right now."));
        }
        finally
        {
            IsLoadingSubscriberDetail = false;
        }
    }

