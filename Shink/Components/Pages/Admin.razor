    private async Task RefreshStoriesAsync(Guid? selectedStoryId = null)
    {
        try
        {
            var targetStoryId = selectedStoryId ?? StoryEditor?.StoryId;
            Stories = await AdminManagementService.GetStoriesAsync(CurrentAdminEmail, StorySearch);
            var selectedStory = targetStoryId is not null
                ? Stories.FirstOrDefault(story => story.StoryId == targetStoryId.Value)
                : Stories.FirstOrDefault();
            StoryEditor = selectedStory is null ? null : EditableStory.From(selectedStory);
            StoryEditorStateSignature = StoryEditor is null
                ? null
                : BuildStoryEditorStateSignature(StoryEditor);
            if (StoryEditor is null)
            {
                IsStoryDialogOpen = false;
            }
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to refresh stories.");
            Stories = Array.Empty<AdminStoryRecord>();
            StoryEditor = null;
            StoryEditorStateSignature = null;
            IsStoryDialogOpen = false;
            SetError(T("Kon nie stories nou laai nie.", "Could not load stories right now."));
        }
    }

    private async Task RefreshPlaylistsAsync(Guid? selectedPlaylistId = null)
    {
        try
        {
            var targetPlaylistId = selectedPlaylistId ?? PlaylistEditor?.PlaylistId;
            Playlists = await AdminManagementService.GetPlaylistsAsync(CurrentAdminEmail);

            var selectedPlaylist = targetPlaylistId is not null
                ? Playlists.FirstOrDefault(playlist => playlist.PlaylistId == targetPlaylistId.Value)
                : Playlists.FirstOrDefault();

            if (selectedPlaylist is null)
            {
                PlaylistEditor = null;
                PlaylistStoryEditor = [];
                PlaylistEditorStateSignature = null;
                StoryToAddIdString = string.Empty;
                IsPlaylistDialogOpen = false;
                return;
            }

            PlaylistEditor = EditablePlaylist.From(selectedPlaylist);
            PlaylistStoryEditor = selectedPlaylist.Stories
                .OrderBy(story => story.SortOrder)
                .Select(EditablePlaylistStoryItem.From)
                .ToList();
            EnsurePlaylistShowcaseSelection();
            ReindexPlaylistStories();
            PlaylistEditorStateSignature = BuildPlaylistEditorStateSignature(PlaylistEditor, PlaylistStoryEditor);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to refresh playlists.");
            Playlists = Array.Empty<AdminPlaylistRecord>();
            PlaylistEditor = null;
            PlaylistStoryEditor = [];
            PlaylistEditorStateSignature = null;
            StoryToAddIdString = string.Empty;
            IsPlaylistDialogOpen = false;
            SetError(T("Kon nie playlists nou laai nie.", "Could not load playlists right now."));
        }
    }

