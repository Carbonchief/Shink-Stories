    private async Task MovePlaylistAsync(Guid playlistId, int direction)
    {
        if (direction is 0)
        {
            return;
        }

        var ordered = Playlists
            .OrderBy(playlist => playlist.SortOrder)
            .ThenBy(playlist => playlist.Title, StringComparer.OrdinalIgnoreCase)
            .ToList();

        var currentIndex = ordered.FindIndex(playlist => playlist.PlaylistId == playlistId);
        if (currentIndex < 0)
        {
            return;
        }

        var targetIndex = currentIndex + direction;
        if (targetIndex < 0 || targetIndex >= ordered.Count)
        {
            return;
        }

        (ordered[currentIndex], ordered[targetIndex]) = (ordered[targetIndex], ordered[currentIndex]);

        IsSavingPlaylistsOrder = true;
        ClearFeedback();
        try
        {
            var result = await AdminManagementService.SavePlaylistOrderAsync(
                CurrentAdminEmail,
                ordered.Select(playlist => playlist.PlaylistId).ToArray());

            if (!HandleOperationResult(result, T("Playlist volgorde is gestoor.", "Playlist order saved.")))
            {
                return;
            }

            await RefreshPlaylistsAsync(playlistId);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to move playlist. playlist_id={PlaylistId}", playlistId);
            SetError(T("Kon nie playlist volgorde nou stoor nie.", "Could not save playlist order right now."));
        }
        finally
        {
            IsSavingPlaylistsOrder = false;
        }
    }

    private void AddStoryToPlaylist()
    {
        if (PlaylistEditor?.IsSystemPlaylist == true)
        {
            SetError(T(
                "Sisteem playlists word outomaties gevul en kan nie handmatig gewysig word nie.",
                "System playlists are auto-populated and cannot be edited manually."));
            return;
        }

        if (!Guid.TryParse(StoryToAddIdString, out var storyId))
        {
            return;
        }

        if (PlaylistStoryEditor.Any(item => item.StoryId == storyId))
        {
            return;
        }

        var story = Stories.FirstOrDefault(item => item.StoryId == storyId);
        if (story is null)
        {
            return;
        }

        PlaylistStoryEditor.Add(new EditablePlaylistStoryItem
        {
            StoryId = story.StoryId,
            StorySlug = story.Slug,
            StoryTitle = story.Title,
            IsShowcase = false
        });
        EnsurePlaylistShowcaseSelection();
        ReindexPlaylistStories();
        StoryToAddIdString = string.Empty;
    }

    private void MovePlaylistStory(int index, int direction)
    {
        if (PlaylistEditor?.IsSystemPlaylist == true)
        {
            return;
        }

        var targetIndex = index + direction;
        if (index < 0 || index >= PlaylistStoryEditor.Count ||
            targetIndex < 0 || targetIndex >= PlaylistStoryEditor.Count)
        {
            return;
        }

        (PlaylistStoryEditor[index], PlaylistStoryEditor[targetIndex]) = (PlaylistStoryEditor[targetIndex], PlaylistStoryEditor[index]);
        ReindexPlaylistStories();
    }

    private void RemovePlaylistStory(int index)
    {
        if (PlaylistEditor?.IsSystemPlaylist == true)
        {
            return;
        }

        if (index < 0 || index >= PlaylistStoryEditor.Count)
        {
            return;
        }

        PlaylistStoryEditor.RemoveAt(index);
        EnsurePlaylistShowcaseSelection();
        ReindexPlaylistStories();
    }

    private async Task SavePlaylistStoriesAsync()
    {
        if (PlaylistEditor?.IsSystemPlaylist == true)
        {
            SetError(T(
                "Sisteem playlists word outomaties gevul en kan nie handmatig gewysig word nie.",
                "System playlists are auto-populated and cannot be edited manually."));
            return;
        }

        if (PlaylistEditor?.PlaylistId is not Guid playlistId || playlistId == Guid.Empty)
        {
            SetError(T("Stoor eers die playlist metadata voordat jy stories orden.", "Save the playlist metadata first before ordering stories."));
            return;
        }

        IsSavingPlaylistStories = true;
        ClearFeedback();

        try
        {
            EnsurePlaylistShowcaseSelection();
            var storyItems = PlaylistStoryEditor
                .Select(item => new AdminPlaylistStorySaveItem(item.StoryId, item.IsShowcase))
                .ToArray();
            var result = await AdminManagementService.SavePlaylistStoriesAsync(CurrentAdminEmail, playlistId, storyItems);

            if (!HandleOperationResult(result, T("Playlist stories is gestoor.", "Playlist stories saved.")))
            {
                return;
            }

            await RefreshPlaylistsAsync(playlistId);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to save playlist stories. playlist_id={PlaylistId}", playlistId);
            SetError(T("Kon nie playlist stories nou stoor nie.", "Could not save playlist stories right now."));
        }
        finally
        {
            IsSavingPlaylistStories = false;
        }
    }

    private int GetPlaylistIndex(Guid playlistId)
    {
        for (var index = 0; index < Playlists.Count; index++)
        {
            if (Playlists[index].PlaylistId == playlistId)
            {
                return index;
            }
        }

        return -1;
    }

    private int GetPlaylistStoryIndex(Guid storyId)
    {
        for (var index = 0; index < PlaylistStoryEditor.Count; index++)
        {
            if (PlaylistStoryEditor[index].StoryId == storyId)
            {
                return index;
            }
        }

        return -1;
    }

    private void ReindexPlaylistStories()
    {
        for (var index = 0; index < PlaylistStoryEditor.Count; index++)
        {
            PlaylistStoryEditor[index].SortOrder = index + 1;
        }
    }

    private void EnsurePlaylistShowcaseSelection()
    {
        if (PlaylistEditor?.IsSystemPlaylist == true || PlaylistStoryEditor.Count == 0)
        {
            foreach (var story in PlaylistStoryEditor)
            {
                story.IsShowcase = false;
            }

            return;
        }

        var selectedStory = PlaylistStoryEditor.FirstOrDefault(story => story.IsShowcase);
        if (selectedStory is null)
        {
            return;
        }

        foreach (var story in PlaylistStoryEditor)
        {
            story.IsShowcase = story.StoryId == selectedStory.StoryId;
        }
    }

    private void TogglePlaylistStoryShowcase(Guid storyId, bool isShowcase)
    {
        if (PlaylistEditor?.IsSystemPlaylist == true)
        {
            return;
        }

        var selectedStory = PlaylistStoryEditor.FirstOrDefault(item => item.StoryId == storyId);
        if (selectedStory is null)
        {
            return;
        }

        if (!isShowcase)
        {
            selectedStory.IsShowcase = false;
            return;
        }

        foreach (var story in PlaylistStoryEditor)
        {
            story.IsShowcase = story.StoryId == storyId;
        }
    }

    private string? ValidateNewStoryDraft(NewStoryDraft draft)
    {
        if (string.IsNullOrWhiteSpace(draft.Title))
        {
            return T("Gee asseblief 'n titel vir die storie.", "Please enter a title for the story.");
        }

        if (draft.CoverFile is null)
        {
            return T("Kies asseblief 'n cover image.", "Please choose a cover image.");
        }

        if (draft.CoverFile.Size <= 0 || draft.CoverFile.Size > MaxImageUploadBytes)
        {
            return T("Die cover image moet kleiner as 10 MB wees.", "The cover image must be smaller than 10 MB.");
        }

        if (draft.ThumbnailFile is not null &&
            (draft.ThumbnailFile.Size <= 0 || draft.ThumbnailFile.Size > MaxImageUploadBytes))
        {
            return T("Die thumbnail image moet kleiner as 10 MB wees.", "The thumbnail image must be smaller than 10 MB.");
        }

        if (draft.AudioFile is null)
        {
            return T("Kies asseblief 'n audio file.", "Please choose an audio file.");
        }

        if (draft.AudioFile.Size <= 0 || draft.AudioFile.Size > MaxAudioUploadBytes)
        {
            return T("Die audio file moet kleiner as 256 MB wees.", "The audio file must be smaller than 256 MB.");
        }

        return null;
    }

    private string? ValidateStoryMediaDraft(EditableStory draft)
    {
        if (draft.CoverFile is not null &&
            (draft.CoverFile.Size <= 0 || draft.CoverFile.Size > MaxImageUploadBytes))
        {
            return T("Die cover image moet kleiner as 10 MB wees.", "The cover image must be smaller than 10 MB.");
        }

        if (draft.ThumbnailFile is not null &&
            (draft.ThumbnailFile.Size <= 0 || draft.ThumbnailFile.Size > MaxImageUploadBytes))
        {
            return T("Die thumbnail image moet kleiner as 10 MB wees.", "The thumbnail image must be smaller than 10 MB.");
        }

        if (draft.AudioFile is not null &&
            (draft.AudioFile.Size <= 0 || draft.AudioFile.Size > MaxAudioUploadBytes))
        {
            return T("Die audio file moet kleiner as 256 MB wees.", "The audio file must be smaller than 256 MB.");
        }

        return null;
    }

    private string? ValidatePlaylistMediaDraft(EditablePlaylist draft)
    {
        if (draft.LogoFile is not null &&
            (draft.LogoFile.Size <= 0 || draft.LogoFile.Size > MaxImageUploadBytes))
        {
            return T("Die logo image moet kleiner as 10 MB wees.", "The logo image must be smaller than 10 MB.");
        }

        if (draft.LogoFile is not null && !IsSupportedImageFile(draft.LogoFile))
        {
            return T("Ondersteunde logo images is JPG, PNG of WEBP.", "Supported logo image types are JPG, PNG, or WEBP.");
        }

        if (draft.BackdropFile is not null &&
            (draft.BackdropFile.Size <= 0 || draft.BackdropFile.Size > MaxImageUploadBytes))
        {
            return T("Die agtergrond image moet kleiner as 10 MB wees.", "The backdrop image must be smaller than 10 MB.");
        }

        if (draft.BackdropFile is not null && !IsSupportedImageFile(draft.BackdropFile))
        {
            return T("Ondersteunde agtergrond images is JPG, PNG of WEBP.", "Supported backdrop image types are JPG, PNG, or WEBP.");
        }

        return null;
    }

