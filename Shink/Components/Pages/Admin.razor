    private NewStoryDraft? NewStoryEditor { get; set; }
    private EditablePlaylist? PlaylistEditor { get; set; }
    private List<EditablePlaylistStoryItem> PlaylistStoryEditor { get; set; } = [];
    private string? SubscriberEditorStateSignature { get; set; }
    private string? StoryEditorStateSignature { get; set; }
    private string? NewStoryEditorStateSignature { get; set; }
    private string? PlaylistEditorStateSignature { get; set; }
    private string NewStoryDialogInstanceKey { get; set; } = Guid.NewGuid().ToString("N");
    private IJSObjectReference? AdminUploadModule { get; set; }
    private IJSObjectReference? AdminGridModule { get; set; }
    private bool SubscriberGridEnhancementPending { get; set; } = true;
    private bool SubscriberTableReloadPending { get; set; } = true;
    private TableState? LastSubscriberTableState { get; set; }

    private IReadOnlyList<AdminStoryRecord> AvailableStoriesForPlaylist =>
        Stories
            .Where(story => PlaylistStoryEditor.All(item => item.StoryId != story.StoryId))
            .OrderBy(story => story.Title, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private bool HasAnalyticsData =>
        Analytics.StorySummary.TotalViews > 0 ||
        Analytics.StorySummary.TotalListenEvents > 0 ||
        Analytics.StorySummary.TotalFavorites > 0 ||
        Analytics.CharacterSummary.TotalAudioPlays > 0;

    private bool HasActiveSubscriberColumnFilters => SubscriberColumnFilters.HasActiveFilters;
    private bool HasActiveStoryColumnFilters => StoryColumnFilters.HasActiveFilters;
    private bool HasActivePlaylistColumnFilters => PlaylistColumnFilters.HasActiveFilters;

    private string CurrentLanguageCode => CurrentLanguage == AdminLanguage.English ? "en" : "af";
    private bool IsR2UploadConfigured
    {
        get
        {
            var options = CloudflareR2OptionsAccessor.Value;
            if (string.IsNullOrWhiteSpace(options.AccountId) ||
                string.IsNullOrWhiteSpace(options.BucketName) ||
                string.IsNullOrWhiteSpace(options.AccessKeyId) ||
                string.IsNullOrWhiteSpace(options.SecretAccessKey))
            {
                return false;
            }

            return Uri.TryCreate(options.PublicBaseUrl, UriKind.Absolute, out var publicBaseUri) &&
                   (string.Equals(publicBaseUri.Scheme, Uri.UriSchemeHttp, StringComparison.OrdinalIgnoreCase) ||
                    string.Equals(publicBaseUri.Scheme, Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase));
        }
    }
    private string AdminMetaTitle => $"Schink Stories | {T("Bestuur", "Admin")}";
    private string AdminMetaDescription => T(
        "Schink bestuursportaal.",
        "Schink admin portal.");
    private string AdminCanonicalUrl => NavigationManager.ToAbsoluteUri("/admin").ToString();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            if (authState.User.Identity?.IsAuthenticated != true)
            {
                IsRedirectingToLogin = true;
                IsLoading = false;
                var returnUrl = Uri.EscapeDataString("/admin");
                NavigationManager.NavigateTo($"/teken-in?returnUrl={returnUrl}");
                return;
            }

            CurrentAdminEmail = authState.User.FindFirst(ClaimTypes.Email)?.Value
                               ?? authState.User.Identity?.Name;
            var isAdmin = await AdminManagementService.IsAdminAsync(CurrentAdminEmail);
            if (!isAdmin)
            {
                IsAccessDenied = true;
                IsLoading = false;
                return;
            }

            await LoadAllAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Admin page initialization failed.");
            SetError(T(
                "Kon nie die bestuursblad nou laai nie. Probeer asseblief weer.",
                "Could not load the admin page right now. Please try again."));
            IsLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (ClearModalLoadingOnNextRender &&
            (IsSubscriberDialogOpen || IsStoryDialogOpen || IsNewStoryDialogOpen || IsPlaylistDialogOpen))
        {
            ClearModalLoadingOnNextRender = false;
            IsEditModalOpening = false;
            await InvokeAsync(StateHasChanged);
        }

        if (firstRender)
        {
            try
            {
                var storedLanguageCode = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", AdminLanguageStorageKey);
                var storedLanguage = ParseLanguage(storedLanguageCode);
                if (storedLanguage != CurrentLanguage)
                {
                    CurrentLanguage = storedLanguage;
                    SubscriberGridEnhancementPending = true;
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (Exception exception)
            {
                // Ignore storage availability issues (private mode / blocked storage).
                Logger.LogDebug(exception, "Admin language preference load skipped.");
            }

            try
            {
                AdminUploadModule = await GetAdminUploadModuleAsync();
            }
            catch (Exception exception)
            {
                Logger.LogWarning(exception, "Admin direct-upload module could not be loaded during first render.");
            }
        }

        if (!SubscriberGridEnhancementPending)
        {
            if (!IsLoading &&
                SubscriberTableReloadPending &&
                SubscribersTable is not null)
            {
                SubscriberTableReloadPending = false;
                await RefreshSubscribersAsync();
            }

            return;
        }

        try
        {
            var gridModule = await GetAdminGridModuleAsync();
            await gridModule.InvokeVoidAsync(
                "enhanceSubscriberGrid",
                ".admin-subscriber-grid",
                "shink.admin.subscribers.column-widths",
                T("Verstel kolomwydte", "Resize column width"),
                T("Dubbelkliek om kolom outomaties te pas", "Double-click to autofit column"));
            SubscriberGridEnhancementPending = false;
        }
        catch (JSDisconnectedException)
        {
            // Ignore disconnects during teardown/reconnect.
        }
        catch (Exception exception)
        {
            Logger.LogDebug(exception, "Admin subscriber grid enhancement skipped.");
        }

        if (!IsLoading &&
            SubscriberTableReloadPending &&
            SubscribersTable is not null)
        {
            SubscriberTableReloadPending = false;
            await RefreshSubscribersAsync();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (AdminGridModule is not null)
        {
            try
            {
                await AdminGridModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Ignore disconnects during teardown.
            }
        }

        if (AdminUploadModule is not null)
        {
            try
            {
                await AdminUploadModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Ignore disconnects during teardown.
            }
        }
    }

    private async Task OnLanguageChangedAsync(string? selectedLanguageCode)
    {
        var requestedLanguage = ParseLanguage(selectedLanguageCode);
        if (requestedLanguage == CurrentLanguage)
        {
            return;
        }

        CurrentLanguage = requestedLanguage;
        ErrorMessage = null;
        StatusMessage = null;

        try
        {
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", AdminLanguageStorageKey, CurrentLanguageCode);
        }
        catch (Exception exception)
        {
            // Ignore storage availability issues (private mode / blocked storage).
            Logger.LogDebug(exception, "Admin language preference save skipped.");
        }
    }

    private AdminLanguage ParseLanguage(string? code)
    {
        return string.Equals(code, "en", StringComparison.OrdinalIgnoreCase)
            ? AdminLanguage.English
            : AdminLanguage.Afrikaans;
    }

    private async Task LoadAllAsync()
    {
        IsLoading = true;
        var storiesTask = RefreshStoriesAsync();
        var playlistsTask = RefreshPlaylistsAsync();
        var analyticsTask = RefreshAnalyticsAsync();
        await Task.WhenAll(storiesTask, playlistsTask, analyticsTask);
        IsLoading = false;
    }

    private async Task SearchSubscribersAsync() =>
        await RefreshSubscribersAsync(resetToFirstPage: true);

    private async Task ReloadSubscribersAsync() =>
        await RefreshSubscribersAsync();

    private async Task RefreshSubscribersAsync(bool resetToFirstPage = false)
    {
        if (SubscribersTable is null)
        {
            SubscriberTableReloadPending = true;
            return;
        }

        if (resetToFirstPage)
        {
            SubscribersTable.NavigateTo(0);
        }

        await SubscribersTable.ReloadServerData();
    }

    private async Task<TableData<AdminSubscriberRecord>> LoadSubscribersPageAsync(TableState state, CancellationToken cancellationToken)
    {
        IsRefreshingSubscribers = true;
        LastSubscriberTableState = state;

        try
        {
            var page = await AdminManagementService.GetSubscribersPageAsync(
                CurrentAdminEmail,
                BuildCurrentSubscriberPageRequest(state.Page, state.PageSize, state.SortLabel, state.SortDirection),
                cancellationToken);

            Subscribers = page.Items;
            SelectedSubscriberIds.IntersectWith(Subscribers.Select(subscriber => subscriber.SubscriberId));
            SubscriberGridEnhancementPending = true;

            var selectedSubscriberId = SubscriberEditor?.SubscriberId;
            var selectedSubscriber = selectedSubscriberId is not null
                ? Subscribers.FirstOrDefault(subscriber => subscriber.SubscriberId == selectedSubscriberId.Value)
                : Subscribers.FirstOrDefault();
            SubscriberEditor = selectedSubscriber is null ? null : EditableSubscriber.From(selectedSubscriber);
            SubscriberEditorStateSignature = SubscriberEditor is null
                ? null
                : BuildSubscriberEditorStateSignature(SubscriberEditor);
            if (SubscriberEditor is null)
            {
                IsSubscriberDialogOpen = false;
            }

            return new TableData<AdminSubscriberRecord>
            {
                Items = Subscribers,
                TotalItems = page.TotalCount
            };
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to refresh subscribers.");
            Subscribers = Array.Empty<AdminSubscriberRecord>();
            SubscriberEditor = null;
            SubscriberEditorStateSignature = null;
            IsSubscriberDialogOpen = false;
            SetError(T("Kon nie intekenaars nou laai nie.", "Could not load subscribers right now."));

            return new TableData<AdminSubscriberRecord>
            {
                Items = Subscribers,
                TotalItems = 0
            };
        }
        finally
        {
            IsRefreshingSubscribers = false;
        }
    }

    private AdminSubscriberPageRequest BuildCurrentSubscriberPageRequest(
        int? pageIndex = null,
        int? pageSize = null,
        string? sortLabel = null,
        SortDirection? sortDirection = null)
    {
        var tableState = LastSubscriberTableState;
        var resolvedSortDirection = sortDirection ?? tableState?.SortDirection ?? SortDirection.None;
        return new AdminSubscriberPageRequest(
            PageIndex: pageIndex ?? tableState?.Page ?? 0,
            PageSize: pageSize ?? tableState?.PageSize ?? 500,
            Search: SubscriberSearch,
            SortLabel: sortLabel ?? tableState?.SortLabel,
            SortDescending: resolvedSortDirection == SortDirection.Descending,
            SubscriberText: SubscriberColumnFilters.SubscriberText,
            MobileText: SubscriberColumnFilters.MobileText,
            TierText: SubscriberColumnFilters.TierText,
            SourceSystem: SubscriberColumnFilters.SourceSystem,
            PaymentProvider: SubscriberColumnFilters.PaymentProvider,
            SubscriptionStatus: SubscriberColumnFilters.SubscriptionStatus);
    }

    private async Task ApplySubscriberTextFilterAsync(string filterKey)
    {
        switch (filterKey)
        {
            case "subscriber":
                SubscriberColumnFilters.SubscriberText = SubscriberTextFilterDraft.Trim();
                break;
            case "mobile":
                SubscriberColumnFilters.MobileText = SubscriberMobileFilterDraft.Trim();
                break;
            case "tiers":
                SubscriberColumnFilters.TierText = SubscriberTierFilterDraft.Trim();
                break;
        }

        await RefreshSubscribersAsync(resetToFirstPage: true);
    }

    private async Task ClearSubscriberTextFilterAsync(string filterKey)
    {
        switch (filterKey)
        {
            case "subscriber":
                SubscriberTextFilterDraft = string.Empty;
                SubscriberColumnFilters.SubscriberText = string.Empty;
                break;
            case "mobile":
                SubscriberMobileFilterDraft = string.Empty;
                SubscriberColumnFilters.MobileText = string.Empty;
                break;
