        var name = BuildSubscriberName(subscriber);
        return string.Equals(name, "-", StringComparison.Ordinal)
            ? subscriber.Email
            : name;
    }

    private static string? BuildSubscriberSecondaryLabel(AdminSubscriberRecord? subscriber)
    {
