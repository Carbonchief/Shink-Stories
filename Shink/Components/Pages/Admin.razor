    private DateTimeOffset? BuildManualAccessExpiry()
    {
        if (ManualAccessExpiryDate is null)
        {
            return null;
        }

        var localEndOfDay = DateTime.SpecifyKind(
            ManualAccessExpiryDate.Value.Date.AddDays(1).AddTicks(-1),
            DateTimeKind.Local);
        return new DateTimeOffset(localEndOfDay);
    }

