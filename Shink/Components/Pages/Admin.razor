    private static string CreatePlaylistSlug(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var normalized = value.Normalize(System.Text.NormalizationForm.FormD);
        var slugBuilder = new System.Text.StringBuilder();
        var previousWasDash = false;

        foreach (var ch in normalized)
        {
            var category = CharUnicodeInfo.GetUnicodeCategory(ch);
            if (category == UnicodeCategory.NonSpacingMark)
            {
                continue;
            }

            var lower = char.ToLowerInvariant(ch);
            if (char.IsLetterOrDigit(lower))
            {
                slugBuilder.Append(lower);
                previousWasDash = false;
                continue;
            }

            if (previousWasDash)
            {
                continue;
            }

            slugBuilder.Append('-');
            previousWasDash = true;
        }

        return slugBuilder.ToString().Trim('-');
    }

    private static string BuildSubscriberName(AdminSubscriberRecord? subscriber)
    {
        if (subscriber is null)
        {
            return "-";
        }

        var tokens = new[]
        {
            subscriber.FirstName?.Trim(),
            subscriber.LastName?.Trim()
        }
        .Where(token => !string.IsNullOrWhiteSpace(token))
        .ToArray();

        if (tokens.Length > 0)
        {
            return string.Join(' ', tokens);
        }

        return string.IsNullOrWhiteSpace(subscriber.DisplayName)
            ? "-"
            : subscriber.DisplayName!;
    }

    private string BuildTierSummary(IReadOnlyList<string>? tiers) =>
        tiers is null || tiers.Count == 0 ? T("Geen", "None") : string.Join(", ", tiers);

    private static string BuildTierSortKey(IReadOnlyList<string>? tiers) =>
        tiers is null || tiers.Count == 0 ? string.Empty : string.Join(", ", tiers);

    private string FormatAdminDate(DateTimeOffset? value)
    {
        if (value is null)
        {
            return "-";
        }

        var culture = CurrentLanguage == AdminLanguage.English
            ? CultureInfo.GetCultureInfo("en-ZA")
            : CultureInfo.GetCultureInfo("af-ZA");

        return value.Value.ToLocalTime().ToString("d MMM yyyy", culture);
    }

    private string BuildPaymentProviderLabel(string? provider) =>
        provider?.Trim().ToLowerInvariant() switch
        {
            "payfast" => "PayFast",
            "paystack" => "Paystack",
            null or "" => "-",
            _ => CultureInfo.InvariantCulture.TextInfo.ToTitleCase(provider.Trim().ToLowerInvariant())
        };

    private string BuildSubscriptionStatusLabel(AdminSubscriberRecord subscriber)
    {
        if (!string.IsNullOrWhiteSpace(subscriber.SubscriptionStatus))
        {
            return subscriber.SubscriptionStatus.Trim().ToLowerInvariant() switch
            {
                "active" => T("Aktief", "Active"),
                "pending" => T("Hangend", "Pending"),
                "cancelled" => T("Gekanselleer", "Cancelled"),
                "failed" => T("Misluk", "Failed"),
                _ => subscriber.SubscriptionStatus
            };
        }

        return subscriber.CancelledAt is not null
            ? T("Gekanselleer", "Cancelled")
            : T("Geen", "None");
    }

