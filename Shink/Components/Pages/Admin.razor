    private static void AppendDetailSectionTitle(StringBuilder builder, string title)
    {
        builder.Append("<h4 class=\"admin-detail-subtitle\">");
        builder.Append(HtmlEncoder.Default.Encode(title));
        builder.Append("</h4>");
    }

    private static void AppendDetailEmpty(StringBuilder builder, string message)
    {
        builder.Append("<p class=\"admin-detail-empty\">");
        builder.Append(HtmlEncoder.Default.Encode(message));
        builder.Append("</p>");
    }

    private static void AppendDetailTableStart(
        StringBuilder builder,
        IReadOnlyList<string> headers,
        string? tableClass = null)
    {
        builder.Append("<div class=\"admin-detail-table-wrap\"><table class=\"admin-detail-table");
        if (!string.IsNullOrWhiteSpace(tableClass))
        {
            builder.Append(' ');
            builder.Append(HtmlEncoder.Default.Encode(tableClass));
        }

        builder.Append("\"><thead><tr>");
        foreach (var header in headers)
        {
            builder.Append("<th>");
            builder.Append(HtmlEncoder.Default.Encode(header));
            builder.Append("</th>");
        }

        builder.Append("</tr></thead><tbody>");
    }

    private static void AppendDetailRow(StringBuilder builder, params string?[] cells)
    {
        builder.Append("<tr>");
        foreach (var cell in cells)
        {
            builder.Append("<td>");
            builder.Append(HtmlEncoder.Default.Encode(string.IsNullOrWhiteSpace(cell) ? "-" : cell));
            builder.Append("</td>");
        }

        builder.Append("</tr>");
    }

    private static void AppendDetailTableEnd(StringBuilder builder) =>
        builder.Append("</tbody></table></div>");

