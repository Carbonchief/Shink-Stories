    private static MarkupString HighlightSearchMatch(string? value, string? searchTerm)
    {
        var text = value ?? string.Empty;
        var normalizedSearch = searchTerm?.Trim();
        if (string.IsNullOrWhiteSpace(text))
        {
            return new MarkupString(string.Empty);
        }

        if (string.IsNullOrWhiteSpace(normalizedSearch))
        {
            return new MarkupString(HtmlEncoder.Default.Encode(text));
        }

        var builder = new StringBuilder();
        var currentIndex = 0;

        while (currentIndex < text.Length)
        {
            var matchIndex = text.IndexOf(normalizedSearch, currentIndex, StringComparison.OrdinalIgnoreCase);
            if (matchIndex < 0)
            {
                builder.Append(HtmlEncoder.Default.Encode(text[currentIndex..]));
                break;
            }

            if (matchIndex > currentIndex)
            {
                builder.Append(HtmlEncoder.Default.Encode(text[currentIndex..matchIndex]));
            }

            var matchLength = normalizedSearch.Length;
            builder.Append("<mark class=\"admin-search-highlight\">");
            builder.Append(HtmlEncoder.Default.Encode(text.Substring(matchIndex, matchLength)));
            builder.Append("</mark>");

            currentIndex = matchIndex + matchLength;
        }

        return new MarkupString(builder.ToString());
    }

    private CultureInfo GetAdminCulture() =>
        CurrentLanguage == AdminLanguage.English
            ? CultureInfo.GetCultureInfo("en-ZA")
            : CultureInfo.GetCultureInfo("af-ZA");

    private string FormatAnalyticsNumber(int value) =>
        value.ToString("N0", GetAdminCulture());

    private string FormatCurrency(decimal value) =>
        $"R {value.ToString("N2", GetAdminCulture())}";

    private string FormatReportPercentage(decimal value) =>
        $"{value.ToString("N1", GetAdminCulture())}%";

    private string FormatAnalyticsDay(DateOnly value) =>
        value.ToDateTime(TimeOnly.MinValue).ToString("ddd d MMM", GetAdminCulture());

    private string FormatAdminDateTime(DateTimeOffset? value)
    {
        if (value is null)
        {
            return "-";
        }

        return value.Value.ToLocalTime().ToString("d MMM yyyy HH:mm", GetAdminCulture());
    }

    private static string FormatAnalyticsDuration(decimal totalSeconds)
    {
        var roundedSeconds = Math.Max(0, decimal.ToInt32(decimal.Round(totalSeconds, MidpointRounding.AwayFromZero)));
        var duration = TimeSpan.FromSeconds(roundedSeconds);
        if (duration.TotalHours >= 1)
        {
            return $"{(int)duration.TotalHours}:{duration.Minutes:00}:{duration.Seconds:00}";
        }

        return $"{(int)duration.TotalMinutes}:{duration.Seconds:00}";
    }

    private string FormatAdminDate(DateTimeOffset? value)
    {
        if (value is null)
        {
            return "-";
        }

        return value.Value.ToLocalTime().ToString("d MMM yyyy", GetAdminCulture());
    }

