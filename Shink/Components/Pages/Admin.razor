@page "/admin"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using System.Globalization
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IAdminManagementService AdminManagementService
@inject IStoryMediaStorageService StoryMediaStorageService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject ILogger<Admin> Logger
@inject ISnackbar Snackbar

<PageTitle>@($"Schink Stories | {T("Bestuur", "Admin")}")</PageTitle>

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<section class="admin-page">
    <header class="admin-hero">
        <div class="admin-hero-top">
            <div>
                <h1>@T("Bestuursportaal", "Admin Portal")</h1>
                <p>@T("Bestuur intekenaars, stories en playlists op een plek.", "Manage subscribers, stories, and playlists in one place.")</p>
            </div>
            <div class="admin-language">
                <MudSelect T="string"
                           Label="@T("Taal", "Language")"
                           Value="CurrentLanguageCode"
                           ValueChanged="OnLanguageChangedAsync"
                           Dense="true"
                           Variant="Variant.Outlined">
                    <MudSelectItem Value="@("af")">Afrikaans</MudSelectItem>
                    <MudSelectItem Value="@("en")">English</MudSelectItem>
                </MudSelect>
            </div>
        </div>
    </header>

    @if (IsRedirectingToLogin)
    {
        <section class="admin-state">
            <h2>@T("Neem jou na teken in...", "Taking you to sign in...")</h2>
            <p>@T("Jy moet ingeteken wees om die bestuursportaal te gebruik.", "You need to be signed in to use the admin portal.")</p>
        </section>
    }
    else if (IsAccessDenied)
    {
        <section class="admin-state">
            <h2>@T("Toegang geweier", "Access denied")</h2>
            <p>@T("Jou rekening het nie admin regte vir hierdie blad nie.", "Your account does not have admin rights for this page.")</p>
        </section>
    }
    else if (IsLoading)
    {
        <section class="admin-state">
            <h2>@T("Laai bestuursdata...", "Loading admin data...")</h2>
        </section>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <p class="admin-feedback is-error">@ErrorMessage</p>
        }
        else if (!string.IsNullOrWhiteSpace(StatusMessage))
        {
            <p class="admin-feedback is-success">@StatusMessage</p>
        }

        <div class="admin-tabs-shell">
        <MudTabs Class="admin-tabs"
                 Rounded="true">
            <MudTabPanel Text='@T("Intekenaars", "Subscribers")'>
                <section class="admin-section">
            <div class="admin-section-head">
                <h2>@T("Intekenaars", "Subscribers")</h2>
                <div class="admin-search">
                    <MudTextField T="string"
                                  @bind-Value="SubscriberSearch"
                                  Placeholder='@T("Soek e-pos of naam", "Search email or name")'
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true" />
                    <MudButton Class="admin-icon-btn admin-mobile-cta"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="RefreshSubscribersAsync"
                               aria-label='@T("Soek intekenaars", "Search subscribers")'
                               title='@T("Soek intekenaars", "Search subscribers")'>
                        <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                        <span class="admin-btn-text">@T("Soek", "Search")</span>
                        <span class="sr-only">@T("Soek intekenaars", "Search subscribers")</span>
                    </MudButton>
                </div>
            </div>

            <MudTable T="AdminSubscriberRecord"
                      Class="admin-grid"
                      Items="Subscribers"
                      SortLabel='@T("Sorteer volgens", "Sort by")'
                      RowsPerPage="10"
                      Dense="true"
                      Hover="true"
                      Bordered="true"
                      Elevation="0"
                      Breakpoint="Breakpoint.Sm"
                      RowClassFunc="GetSubscriberRowClass"
                      OnRowClick="OnSubscriberRowClick">
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel SortBy="new Func<AdminSubscriberRecord, object?>(subscriber => subscriber.Email)">
                            @T("E-pos", "Email")
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel SortBy="new Func<AdminSubscriberRecord, object?>(subscriber => BuildSubscriberName(subscriber))">
                            @T("Naam", "Name")
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel SortBy="new Func<AdminSubscriberRecord, object?>(subscriber => BuildTierSortKey(subscriber.ActiveTierCodes))">
                            @T("Vlakke", "Tiers")
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel SortBy="new Func<AdminSubscriberRecord, object?>(subscriber => BuildPaymentProviderLabel(subscriber.PaymentProvider))">
                            @T("Betaalverskaffer", "Payment Provider")
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel SortBy="new Func<AdminSubscriberRecord, object?>(subscriber => BuildSubscriptionStatusLabel(subscriber))">
                            @T("Status", "Status")
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel SortBy="new Func<AdminSubscriberRecord, object?>(subscriber => subscriber.SubscribedAt ?? DateTimeOffset.MinValue)">
                            @T("Ingeteken op", "Subscribed On")
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel SortBy="new Func<AdminSubscriberRecord, object?>(subscriber => subscriber.NextPaymentDueAt ?? DateTimeOffset.MinValue)">
                            @T("Volgende betaling", "Next Payment")
                        </MudTableSortLabel>
                    </MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel='@T("E-pos", "Email")'>@context.Email</MudTd>
                    <MudTd DataLabel='@T("Naam", "Name")'>@BuildSubscriberName(context)</MudTd>
                    <MudTd DataLabel='@T("Vlakke", "Tiers")'>@BuildTierSummary(context.ActiveTierCodes)</MudTd>
                    <MudTd DataLabel='@T("Betaalverskaffer", "Payment Provider")'>@BuildPaymentProviderLabel(context.PaymentProvider)</MudTd>
                    <MudTd DataLabel='@T("Status", "Status")'>@BuildSubscriptionStatusLabel(context)</MudTd>
                    <MudTd DataLabel='@T("Ingeteken op", "Subscribed On")'>@FormatAdminDate(context.SubscribedAt)</MudTd>
                    <MudTd DataLabel='@T("Volgende betaling", "Next Payment")'>@FormatAdminDate(context.NextPaymentDueAt)</MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2">@T("Geen intekenaars gevind nie.", "No subscribers found.")</MudText>
                </NoRecordsContent>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
                </section>
            </MudTabPanel>

            <MudTabPanel Text='@T("Stories", "Stories")'>
                <section class="admin-section">
            <div class="admin-section-head">
                <h2>@T("Stories", "Stories")</h2>
                <div class="admin-search">
                    <MudTextField T="string"
                                  @bind-Value="StorySearch"
                                  Placeholder='@T("Soek titel of slug", "Search title or slug")'
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true" />
                    <MudButton Class="admin-icon-btn admin-mobile-cta"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="@(() => RefreshStoriesAsync())"
                               aria-label='@T("Soek stories", "Search stories")'
                               title='@T("Soek stories", "Search stories")'>
                        <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                        <span class="admin-btn-text">@T("Soek", "Search")</span>
                        <span class="sr-only">@T("Soek stories", "Search stories")</span>
                    </MudButton>
                    <MudButton Class="admin-btn admin-btn-secondary admin-icon-btn admin-mobile-cta"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               OnClick="StartNewStory"
                               aria-label='@T("Nuwe storie", "New story")'
                               title='@T("Nuwe storie", "New story")'>
                        <i class="fa-solid fa-plus" aria-hidden="true"></i>
                        <span class="admin-btn-text">@T("Nuwe storie", "New story")</span>
                        <span class="sr-only">@T("Nuwe storie", "New story")</span>
                    </MudButton>
                </div>
            </div>

            <MudTable T="AdminStoryRecord"
                      Class="admin-grid"
                      Items="Stories"
                      SortLabel='@T("Sorteer volgens", "Sort by")'
                      RowsPerPage="10"
                      Dense="true"
                      Hover="true"
                      Bordered="true"
                      Elevation="0"
                      Breakpoint="Breakpoint.Sm"
                      RowClassFunc="GetStoryRowClass"
                      OnRowClick="OnStoryRowClick">
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel SortBy="new Func<AdminStoryRecord, object?>(story => story.Title)">
                            @T("Titel", "Title")
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel SortBy="new Func<AdminStoryRecord, object?>(story => story.Status)">
                            @T("Status", "Status")
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel SortBy="new Func<AdminStoryRecord, object?>(story => story.AccessLevel)">
                            @T("Toegang", "Access")
                        </MudTableSortLabel>
                    </MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel='@T("Titel", "Title")'>@context.Title</MudTd>
                    <MudTd DataLabel='@T("Status", "Status")'>@context.Status</MudTd>
                    <MudTd DataLabel='@T("Toegang", "Access")'>@context.AccessLevel</MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2">@T("Geen stories gevind nie.", "No stories found.")</MudText>
                </NoRecordsContent>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
                </section>
            </MudTabPanel>

            <MudTabPanel Text='@T("Playlists", "Playlists")'>
                <section class="admin-section">
            <div class="admin-section-head">
                <h2>@T("Playlists", "Playlists")</h2>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Class="admin-btn admin-btn-secondary admin-icon-btn admin-mobile-cta"
                           OnClick="StartNewPlaylist"
                           aria-label='@T("Nuwe playlist", "New playlist")'
                           title='@T("Nuwe playlist", "New playlist")'>
                    <i class="fa-solid fa-plus" aria-hidden="true"></i>
                    <span class="admin-btn-text">@T("Nuwe playlist", "New playlist")</span>
                    <span class="sr-only">@T("Nuwe playlist", "New playlist")</span>
                </MudButton>
            </div>

            <MudTable T="AdminPlaylistRecord"
                      Class="admin-grid admin-playlist-grid"
                      Items="Playlists"
                      RowsPerPage="10"
                      Dense="true"
                      Hover="true"
                      Bordered="true"
                      Elevation="0"
                      Breakpoint="Breakpoint.Sm"
                      RowClassFunc="GetPlaylistRowClass"
                      OnRowClick="OnPlaylistRowClick">
                <HeaderContent>
                    <MudTh>@T("Titel", "Title")</MudTh>
                    <MudTh>@T("Aktief", "Active")</MudTh>
                    <MudTh>@T("Tuisblad", "Home")</MudTh>
                    <MudTh Class="admin-col-center">@T("Aksies", "Actions")</MudTh>
                </HeaderContent>
                <RowTemplate>
                    @{
                        var playlistIndex = GetPlaylistIndex(context.PlaylistId);
                    }
                    <MudTd DataLabel='@T("Titel", "Title")'>@context.Title</MudTd>
                    <MudTd DataLabel='@T("Aktief", "Active")'>
                        <div class="admin-toggle-cell" @onclick:stopPropagation="true">
                            <MudSwitch T="bool"
                                       Value="@context.IsEnabled"
                                       ValueChanged="@(value => TogglePlaylistEnabledAsync(context, value))"
                                       Color="Color.Success"
                                       Disabled="@(IsSavingPlaylistsOrder || IsSavingPlaylist || TogglingPlaylistIds.Contains(context.PlaylistId))" />
                        </div>
                    </MudTd>
                    <MudTd DataLabel='@T("Tuisblad", "Home")'>
                        <div class="admin-toggle-cell" @onclick:stopPropagation="true">
                            <MudSwitch T="bool"
                                       Value="@context.ShowOnHome"
                                       ValueChanged="@(value => TogglePlaylistHomeAsync(context, value))"
                                       Color="Color.Success"
                                       Disabled="@(IsSavingPlaylistsOrder || IsSavingPlaylist || TogglingPlaylistIds.Contains(context.PlaylistId))" />
                        </div>
                    </MudTd>
                    <MudTd Class="admin-col-center" DataLabel='@T("Aksies", "Actions")'>
                        <div class="admin-playlist-actions">
                            <button type="button"
                                    class="admin-icon-btn"
                                    @onclick="() => MovePlaylistAsync(context.PlaylistId, -1)"
                                    @onclick:stopPropagation="true"
                                    disabled="@(playlistIndex <= 0 || IsSavingPlaylistsOrder)"
                                    aria-label='@T("Skuif playlist op", "Move playlist up")'
                                    title='@T("Skuif playlist op", "Move playlist up")'>
                                <i class="fa-solid fa-arrow-up" aria-hidden="true"></i>
                                <span class="sr-only">@T("Skuif playlist op", "Move playlist up")</span>
                            </button>
                            <button type="button"
                                    class="admin-icon-btn"
                                    @onclick="() => MovePlaylistAsync(context.PlaylistId, 1)"
                                    @onclick:stopPropagation="true"
                                    disabled="@(playlistIndex < 0 || playlistIndex == Playlists.Count - 1 || IsSavingPlaylistsOrder)"
                                    aria-label='@T("Skuif playlist af", "Move playlist down")'
                                    title='@T("Skuif playlist af", "Move playlist down")'>
                                <i class="fa-solid fa-arrow-down" aria-hidden="true"></i>
                                <span class="sr-only">@T("Skuif playlist af", "Move playlist down")</span>
                            </button>
                        </div>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2">@T("Geen playlists gevind nie.", "No playlists found.")</MudText>
                </NoRecordsContent>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>

                </section>
            </MudTabPanel>
        </MudTabs>
        </div>

        @if (SubscriberEditor is not null)
        {
            <MudDialog @bind-Visible="IsSubscriberDialogOpen"
                       Options="EditorDialogOptions">
                <TitleContent>
                    <MudText Typo="Typo.h6">@T("Wysig intekenaar", "Edit subscriber")</MudText>
                </TitleContent>
                <DialogContent>
                    <div class="admin-form-grid">
                        <MudTextField T="string"
                                      Label='@T("E-pos", "Email")'
                                      Value="SubscriberEditor.Email"
                                      Disabled="true"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                        <MudTextField T="string"
                                      Label='@T("Voornaam", "First name")'
                                      @bind-Value="SubscriberEditor.FirstName"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                        <MudTextField T="string"
                                      Label='@T("Van", "Last name")'
                                      @bind-Value="SubscriberEditor.LastName"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                        <MudTextField T="string"
                                      Label='@T("Vertoonnaam", "Display name")'
                                      @bind-Value="SubscriberEditor.DisplayName"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                        <MudTextField T="string"
                                      Label='@T("Selfoon", "Mobile")'
                                      @bind-Value="SubscriberEditor.MobileNumber"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </div>
                </DialogContent>
                <DialogActions>
                    <div class="admin-dialog-actions-row">
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Default"
                                   OnClick="CloseSubscriberDialog">
                            @T("Sluit", "Close")
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Class="admin-btn"
                                   Disabled="@IsSavingSubscriber"
                                   OnClick="SaveSubscriberAsync">
                            @(IsSavingSubscriber ? T("Stoor...", "Saving...") : T("Stoor intekenaar", "Save subscriber"))
                        </MudButton>
                    </div>
                </DialogActions>
            </MudDialog>
        }

        @if (NewStoryEditor is not null)
        {
            <MudDialog @bind-Visible="IsNewStoryDialogOpen"
                       Options="EditorDialogOptions">
                <TitleContent>
                    <MudText Typo="Typo.h6">@T("Laai nuwe storie op", "Upload new story")</MudText>
                </TitleContent>
                <DialogContent>
                    <div class="admin-editor" @key="NewStoryDialogInstanceKey">
                        <p class="admin-form-note">
                            @T(
                                "Slug, sort order, R2-audio en die thumbnail-pad word outomaties ingevul waar moontlik. As jy nie 'n thumbnail kies nie, gebruik ons die cover image.",
                                "Slug, sort order, R2 audio, and the thumbnail path are autofilled where possible. If you do not choose a thumbnail, we use the cover image.")
                        </p>

                        <div class="admin-form-grid">
                            <MudTextField T="string"
                                          Label='@T("Titel", "Title")'
                                          @bind-Value="NewStoryEditor.Title"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense" />
                            <MudSelect T="string"
                                       Label='@T("Toegang", "Access")'
                                       @bind-Value="NewStoryEditor.AccessLevel"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense">
                                <MudSelectItem Value="@("subscriber")">subscriber</MudSelectItem>
                                <MudSelectItem Value="@("free")">free</MudSelectItem>
                            </MudSelect>
                            <MudCheckBox T="bool"
                                         Class="admin-span-2"
                                         Label='@T("Publiseer onmiddellik", "Publish immediately")'
                                         @bind-Value="NewStoryEditor.PublishNow" />
                            <MudTextField T="string"
                                          Class="admin-span-2"
                                          Label='@T("Opsomming", "Summary")'
                                          @bind-Value="NewStoryEditor.Summary"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Lines="2" />
                            <MudTextField T="string"
                                          Class="admin-span-2"
                                          Label='@T("Beskrywing", "Description")'
                                          @bind-Value="NewStoryEditor.Description"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Lines="4" />

                            <div class="admin-upload-card">
                                <div class="admin-upload-head">
                                    <h4>@T("Cover image", "Cover image")</h4>
                                    <p>@T("Verpligtend", "Required")</p>
                                </div>
                                <label class="admin-upload-btn">
                                    @T("Kies image", "Choose image")
                                    <InputFile id="@NewStoryCoverInputId"
                                               class="admin-file-input"
                                               OnChange="OnNewStoryCoverSelected"
                                               accept=".jpg,.jpeg,.png,.webp,image/*" />
                                </label>
                                <p class="admin-upload-file-name">@GetSelectedFileLabel(NewStoryEditor.CoverFileName, T("Nog geen file gekies nie.", "No file selected yet."))</p>
                            </div>

                            <div class="admin-upload-card">
                                <div class="admin-upload-head">
                                    <h4>@T("Thumbnail image", "Thumbnail image")</h4>
                                    <p>@T("Opsioneel", "Optional")</p>
                                </div>
                                <label class="admin-upload-btn">
                                    @T("Kies image", "Choose image")
                                    <InputFile id="@NewStoryThumbnailInputId"
                                               class="admin-file-input"
                                               OnChange="OnNewStoryThumbnailSelected"
                                               accept=".jpg,.jpeg,.png,.webp,image/*" />
                                </label>
                                <p class="admin-upload-file-name">@GetSelectedFileLabel(NewStoryEditor.ThumbnailFileName, T("Gebruik cover image as jy dit leeg laat.", "Uses the cover image if left empty."))</p>
                            </div>

                            <div class="admin-upload-card admin-span-2">
                                <div class="admin-upload-head">
                                    <h4>@T("Audio file", "Audio file")</h4>
                                    <p>@T("Laai op na Cloudflare R2", "Uploads to Cloudflare R2")</p>
                                </div>
                                <label class="admin-upload-btn">
                                    @T("Kies audio", "Choose audio")
                                    <InputFile id="@NewStoryAudioInputId"
                                               class="admin-file-input"
                                               OnChange="OnNewStoryAudioSelected"
                                               accept=".mp3,.mpeg,.m4a,.wav,.ogg,audio/*" />
                                </label>
                                <p class="admin-upload-file-name">@GetSelectedFileLabel(NewStoryEditor.AudioFileName, T("Nog geen file gekies nie.", "No file selected yet."))</p>
                            </div>
                        </div>
                    </div>
                </DialogContent>
                <DialogActions>
                    <div class="admin-dialog-actions-row">
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Default"
                                   OnClick="CloseNewStoryDialog">
                            @T("Sluit", "Close")
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Class="admin-btn"
                                   Disabled="@IsCreatingStory"
                                   OnClick="SaveNewStoryAsync">
                            @(IsCreatingStory ? T("Laai op...", "Uploading...") : T("Skep storie", "Create story"))
                        </MudButton>
                    </div>
                </DialogActions>
            </MudDialog>
        }

        @if (StoryEditor is not null)
        {
            var coverPreviewUrl = ResolvePreviewImageUrl(StoryEditor.CoverImagePath);
            var thumbnailPreviewUrl = ResolvePreviewImageUrl(StoryEditor.ThumbnailImagePath);
            var carouselPreviewUrl = !string.IsNullOrWhiteSpace(thumbnailPreviewUrl) ? thumbnailPreviewUrl : coverPreviewUrl;
            var playerPreviewUrl = !string.IsNullOrWhiteSpace(thumbnailPreviewUrl) ? thumbnailPreviewUrl : coverPreviewUrl;

            <MudDialog @bind-Visible="IsStoryDialogOpen"
                       Options="EditorDialogOptions">
                <TitleContent>
                    <MudText Typo="Typo.h6">@T("Wysig storie", "Edit story")</MudText>
                </TitleContent>
                <DialogContent>
                    <div class="admin-form-grid">
                        <MudTextField T="string"
                                      Label='@T("Titel", "Title")'
                                      @bind-Value="StoryEditor.Title"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                        <MudSelect T="string"
                                   Label='@T("Toegang", "Access")'
                                   @bind-Value="StoryEditor.AccessLevel"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense">
                            <MudSelectItem Value="@("subscriber")">subscriber</MudSelectItem>
                            <MudSelectItem Value="@("free")">free</MudSelectItem>
                        </MudSelect>
                        <MudSelect T="string"
                                   Label='@T("Status", "Status")'
                                   @bind-Value="StoryEditor.Status"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense">
                            <MudSelectItem Value="@("draft")">draft</MudSelectItem>
                            <MudSelectItem Value="@("published")">published</MudSelectItem>
                            <MudSelectItem Value="@("archived")">archived</MudSelectItem>
                        </MudSelect>
                        <MudNumericField T="int"
                                         Label='@T("Sort order", "Sort order")'
                                         @bind-Value="StoryEditor.SortOrder"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense" />
                        <MudNumericField T="int?"
                                         Label='@T("Duur sekondes", "Duration seconds")'
                                         @bind-Value="StoryEditor.DurationSeconds"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense" />
                        <div class="admin-upload-card">
                            <div class="admin-upload-head">
                                <h4>@T("Vervang cover image", "Replace cover image")</h4>
                                <p>@T("Opsioneel", "Optional")</p>
                            </div>
                            <label class="admin-upload-btn">
                                @T("Kies image", "Choose image")
                                <InputFile id="@EditStoryCoverInputId"
                                           class="admin-file-input"
                                           OnChange="OnStoryCoverSelected"
                                           accept=".jpg,.jpeg,.png,.webp,image/*" />
                            </label>
                            <p class="admin-upload-file-name">@GetSelectedFileLabel(StoryEditor.CoverFileName, T("Hou huidige cover as jy niks kies nie.", "Keeps the current cover if you do not choose a file."))</p>
                        </div>
                        <div class="admin-upload-card">
                            <div class="admin-upload-head">
                                <h4>@T("Vervang thumbnail", "Replace thumbnail")</h4>
                                <p>@T("Opsioneel", "Optional")</p>
                            </div>
                            <label class="admin-upload-btn">
                                @T("Kies image", "Choose image")
                                <InputFile id="@EditStoryThumbnailInputId"
                                           class="admin-file-input"
                                           OnChange="OnStoryThumbnailSelected"
                                           accept=".jpg,.jpeg,.png,.webp,image/*" />
                            </label>
                            <p class="admin-upload-file-name">@GetSelectedFileLabel(StoryEditor.ThumbnailFileName, T("Hou huidige thumbnail as jy niks kies nie.", "Keeps the current thumbnail if you do not choose a file."))</p>
                        </div>
                        <div class="admin-upload-card admin-span-2">
                            <div class="admin-upload-head">
                                <h4>@T("Vervang audio file", "Replace audio file")</h4>
                                <p>@T("Laai op na Cloudflare R2", "Uploads to Cloudflare R2")</p>
                            </div>
                            <label class="admin-upload-btn">
                                @T("Kies audio", "Choose audio")
                                <InputFile id="@EditStoryAudioInputId"
                                           class="admin-file-input"
                                           OnChange="OnStoryAudioSelected"
                                           accept=".mp3,.mpeg,.m4a,.wav,.ogg,audio/*" />
                            </label>
                            <p class="admin-upload-file-name">@GetSelectedFileLabel(StoryEditor.AudioFileName, T("Hou huidige audio as jy niks kies nie.", "Keeps the current audio if you do not choose a file."))</p>
                        </div>
                        <div class="admin-image-preview-grid admin-span-2">
                            <article class="admin-image-preview-card admin-luister-preview-card">
                                <h4>@T("Carousel voorskou", "Carousel preview")</h4>
                                @if (!string.IsNullOrWhiteSpace(carouselPreviewUrl))
                                {
                                    <div class="admin-luister-carousel">
                                        <article class="admin-luister-carousel-item">
                                            <div class="admin-luister-carousel-link" aria-hidden="true">
                                                <span class="admin-luister-carousel-cover">
                                                    <img src="@carouselPreviewUrl"
                                                         class="admin-luister-carousel-image"
                                                         alt='@T("Carousel voorskou beeld", "Carousel preview image")'
                                                         loading="lazy"
                                                         decoding="async" />
                                                    <span class="admin-luister-cover-play" aria-hidden="true">
                                                        <i class="admin-luister-cover-play-icon fa-solid fa-play" aria-hidden="true"></i>
                                                    </span>
                                                </span>
                                                <h5>@StoryEditor.Title</h5>
                                            </div>
                                        </article>
                                    </div>
                                }
                                else
                                {
                                    <p>@T("Geen image beskikbaar vir carousel voorskou nie.", "No image available for carousel preview.")</p>
                                }
                            </article>
                            <article class="admin-image-preview-card admin-luister-preview-card">
                                <h4>@T("Speler voorskou", "Player preview")</h4>
                                @if (!string.IsNullOrWhiteSpace(playerPreviewUrl))
                                {
                                    <div class="admin-luister-player" aria-hidden="true">
                                        <div class="admin-luister-player-cover-wrap">
                                            <img src="@playerPreviewUrl"
                                                 class="admin-luister-player-cover"
                                                 alt='@T("Speler voorskou beeld", "Player preview image")'
                                                 loading="lazy"
                                                 decoding="async" />
                                            <span class="admin-luister-cover-play" aria-hidden="true">
                                                <i class="admin-luister-cover-play-icon fa-solid fa-play" aria-hidden="true"></i>
                                            </span>
                                        </div>
                                        <h5 class="admin-luister-player-title">@StoryEditor.Title</h5>
                                        <div class="admin-luister-player-controls">
                                            <span class="admin-luister-control-dot"></span>
                                            <span class="admin-luister-control-main"></span>
                                            <span class="admin-luister-control-dot"></span>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <p>@T("Geen image beskikbaar vir speler voorskou nie.", "No image available for player preview.")</p>
                                }
                            </article>
                        </div>
                        <MudTextField T="string"
                                      Label='@T("Published at (local)", "Published at (local)")'
                                      Placeholder="YYYY-MM-DDTHH:mm"
                                      @bind-Value="StoryEditor.PublishedAtLocal"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                        <MudCheckBox T="bool"
                                     Label='@T("Gekenmerk", "Featured")'
                                     @bind-Value="StoryEditor.IsFeatured" />
                        <MudTextField T="string"
                                      Class="admin-span-2"
                                      Label='@T("Opsomming", "Summary")'
                                      @bind-Value="StoryEditor.Summary"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Lines="2" />
                        <MudTextField T="string"
                                      Class="admin-span-2"
                                      Label='@T("Beskrywing", "Description")'
                                      @bind-Value="StoryEditor.Description"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Lines="4" />
                    </div>
                </DialogContent>
                <DialogActions>
                    <div class="admin-dialog-actions-row">
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Default"
                                   OnClick="CloseStoryDialog">
                            @T("Sluit", "Close")
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Class="admin-btn"
                                   Disabled="@IsSavingStory"
                                   OnClick="SaveStoryAsync">
                            @(IsSavingStory ? T("Stoor...", "Saving...") : T("Stoor storie", "Save story"))
                        </MudButton>
                    </div>
                </DialogActions>
            </MudDialog>
        }

        @if (PlaylistEditor is not null)
        {
            <MudDialog @bind-Visible="IsPlaylistDialogOpen"
                       Options="EditorDialogOptions">
                <TitleContent>
                    <MudText Typo="Typo.h6">@T("Wysig playlist", "Edit playlist")</MudText>
                </TitleContent>
                <DialogContent>
                    <div class="admin-tabs-shell">
                    <MudTabs Class="admin-tabs admin-dialog-tabs"
                             Rounded="true">
                        <MudTabPanel Text='@T("Playlist inligting", "Playlist info")'>
                            <div class="admin-editor">
                                <div class="admin-form-grid">
                                    <MudTextField T="string"
                                                  Label='@T("Titel", "Title")'
                                                  @bind-Value="PlaylistEditor.Title"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense" />
                                    <MudNumericField T="int?"
                                                     Label='@T("Maks items", "Max items")'
                                                     @bind-Value="PlaylistEditor.MaxItems"
                                                     Variant="Variant.Outlined"
                                                     Margin="Margin.Dense" />
                                    <MudCheckBox T="bool"
                                                 Label='@T("Aktief", "Active")'
                                                 @bind-Value="PlaylistEditor.IsEnabled" />
                                    <MudCheckBox T="bool"
                                                 Label='@T("Wys op tuisblad", "Show on home")'
                                                 @bind-Value="PlaylistEditor.ShowOnHome" />
                                    <MudTextField T="string"
                                                  Class="admin-span-2"
                                                  Label='@T("Beskrywing", "Description")'
                                                  @bind-Value="PlaylistEditor.Description"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Lines="3" />
                                </div>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Class="admin-btn"
                                           Disabled="@IsSavingPlaylist"
                                           OnClick="SavePlaylistAsync">
                                    @(IsSavingPlaylist ? T("Stoor...", "Saving...") : T("Stoor playlist", "Save playlist"))
                                </MudButton>
                            </div>
                        </MudTabPanel>

                        <MudTabPanel Text='@T("Playlist items", "Playlist items")'>
                            @if (PlaylistEditor.PlaylistId is Guid playlistId && playlistId != Guid.Empty)
                            {
                                <div class="admin-editor">
                                    <h3>@T("Playlist stories", "Playlist stories")</h3>
                                    <div class="admin-story-picker">
                                        <MudSelect T="string"
                                                   @bind-Value="StoryToAddIdString"
                                                   Label='@T("Kies storie om by te voeg", "Choose a story to add")'
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense">
                                            <MudSelectItem Value="@string.Empty">@T("Kies storie om by te voeg", "Choose a story to add")</MudSelectItem>
                                            @foreach (var story in AvailableStoriesForPlaylist)
                                            {
                                                <MudSelectItem Value="@story.StoryId.ToString("D")">@story.Title</MudSelectItem>
                                            }
                                        </MudSelect>
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Class="admin-icon-btn admin-mobile-cta"
                                                   OnClick="AddStoryToPlaylist"
                                                   aria-label='@T("Voeg storie by", "Add story")'
                                                   title='@T("Voeg storie by", "Add story")'>
                                            <i class="fa-solid fa-plus" aria-hidden="true"></i>
                                            <span class="admin-btn-text">@T("Voeg by", "Add")</span>
                                            <span class="sr-only">@T("Voeg storie by", "Add story")</span>
                                        </MudButton>
                                    </div>

                                    <MudTable T="EditablePlaylistStoryItem"
                                              Class="admin-grid"
                                              Items="PlaylistStoryEditor"
                                              Dense="true"
                                              Hover="true"
                                              Bordered="true"
                                              Elevation="0"
                                              Breakpoint="Breakpoint.Sm">
                                        <HeaderContent>
                                            <MudTh>#</MudTh>
                                            <MudTh>@T("Titel", "Title")</MudTh>
                                            <MudTh>Slug</MudTh>
                                            <MudTh>@T("Aksies", "Actions")</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            @{
                                                var storyIndex = GetPlaylistStoryIndex(context.StoryId);
                                            }
                                            <MudTd DataLabel="#">@context.SortOrder</MudTd>
                                            <MudTd DataLabel='@T("Titel", "Title")'>@context.StoryTitle</MudTd>
                                            <MudTd DataLabel="Slug">@context.StorySlug</MudTd>
                                            <MudTd DataLabel='@T("Aksies", "Actions")'>
                                                <div class="admin-playlist-actions">
                                                    <button type="button"
                                                            class="admin-icon-btn"
                                                            @onclick="() => MovePlaylistStory(storyIndex, -1)"
                                                            @onclick:stopPropagation="true"
                                                            disabled="@(storyIndex <= 0)"
                                                            aria-label='@T("Skuif storie op", "Move story up")'
                                                            title='@T("Skuif storie op", "Move story up")'>
                                                        <i class="fa-solid fa-arrow-up" aria-hidden="true"></i>
                                                        <span class="sr-only">@T("Skuif storie op", "Move story up")</span>
                                                    </button>
                                                    <button type="button"
                                                            class="admin-icon-btn"
                                                            @onclick="() => MovePlaylistStory(storyIndex, 1)"
                                                            @onclick:stopPropagation="true"
                                                            disabled="@(storyIndex < 0 || storyIndex == PlaylistStoryEditor.Count - 1)"
                                                            aria-label='@T("Skuif storie af", "Move story down")'
                                                            title='@T("Skuif storie af", "Move story down")'>
                                                        <i class="fa-solid fa-arrow-down" aria-hidden="true"></i>
                                                        <span class="sr-only">@T("Skuif storie af", "Move story down")</span>
                                                    </button>
                                                    <button type="button"
                                                            class="admin-icon-btn is-danger"
                                                            @onclick="() => RemovePlaylistStory(storyIndex)"
                                                            @onclick:stopPropagation="true"
                                                            disabled="@(storyIndex < 0)"
                                                            aria-label='@T("Verwyder storie", "Remove story")'
                                                            title='@T("Verwyder storie", "Remove story")'>
                                                        <i class="fa-solid fa-trash" aria-hidden="true"></i>
                                                        <span class="sr-only">@T("Verwyder storie", "Remove story")</span>
                                                    </button>
                                                </div>
                                            </MudTd>
                                        </RowTemplate>
                                        <NoRecordsContent>
                                            <MudText Typo="Typo.body2">@T("Geen stories in hierdie playlist nie.", "No stories in this playlist.")</MudText>
                                        </NoRecordsContent>
                                    </MudTable>

                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Class="admin-btn"
                                               Disabled="@IsSavingPlaylistStories"
                                               OnClick="SavePlaylistStoriesAsync">
                                        @(IsSavingPlaylistStories ? T("Stoor...", "Saving...") : T("Stoor playlist stories", "Save playlist stories"))
                                    </MudButton>
                                </div>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2">
                                    @T("Stoor eers die playlist inligting om items te bestuur.", "Save the playlist info first to manage playlist items.")
                                </MudText>
                            }
                        </MudTabPanel>
                    </MudTabs>
                    </div>
                </DialogContent>
                <DialogActions>
                    <div class="admin-dialog-actions-row">
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Default"
                                   OnClick="ClosePlaylistDialog">
                            @T("Sluit", "Close")
                        </MudButton>
                    </div>
                </DialogActions>
            </MudDialog>
        }
    }
</section>

@code {
    private bool IsLoading { get; set; } = true;
    private bool IsRedirectingToLogin { get; set; }
    private bool IsAccessDenied { get; set; }
    private string? CurrentAdminEmail { get; set; }
    private string? ErrorMessage { get; set; }
    private string? StatusMessage { get; set; }
    private AdminLanguage CurrentLanguage { get; set; } = AdminLanguage.Afrikaans;

    private const string AdminLanguageStorageKey = "shink.admin.language";
    private const string NewStoryCoverInputId = "admin-new-story-cover";
    private const string NewStoryThumbnailInputId = "admin-new-story-thumbnail";
    private const string NewStoryAudioInputId = "admin-new-story-audio";
    private const string EditStoryCoverInputId = "admin-edit-story-cover";
    private const string EditStoryThumbnailInputId = "admin-edit-story-thumbnail";
    private const string EditStoryAudioInputId = "admin-edit-story-audio";

    private bool IsSavingSubscriber { get; set; }
    private bool IsSavingStory { get; set; }
    private bool IsCreatingStory { get; set; }
    private bool IsSavingPlaylist { get; set; }
    private bool IsSavingPlaylistsOrder { get; set; }
    private bool IsSavingPlaylistStories { get; set; }
    private bool IsSubscriberDialogOpen { get; set; }
    private bool IsStoryDialogOpen { get; set; }
    private bool IsNewStoryDialogOpen { get; set; }
    private bool IsPlaylistDialogOpen { get; set; }
    private HashSet<Guid> TogglingPlaylistIds { get; } = [];
    private const long MaxImageUploadBytes = 10 * 1024 * 1024;
    private const long MaxAudioUploadBytes = 256L * 1024 * 1024;
    private static readonly DialogOptions EditorDialogOptions = new()
    {
        MaxWidth = MaxWidth.Large,
        FullWidth = true,
        CloseButton = true,
        BackdropClick = false
    };

    private string SubscriberSearch { get; set; } = string.Empty;
    private string StorySearch { get; set; } = string.Empty;
    private string StoryToAddIdString { get; set; } = string.Empty;

    private IReadOnlyList<AdminSubscriberRecord> Subscribers { get; set; } = Array.Empty<AdminSubscriberRecord>();
    private IReadOnlyList<AdminStoryRecord> Stories { get; set; } = Array.Empty<AdminStoryRecord>();
    private IReadOnlyList<AdminPlaylistRecord> Playlists { get; set; } = Array.Empty<AdminPlaylistRecord>();

    private EditableSubscriber? SubscriberEditor { get; set; }
    private EditableStory? StoryEditor { get; set; }
    private NewStoryDraft? NewStoryEditor { get; set; }
    private EditablePlaylist? PlaylistEditor { get; set; }
    private List<EditablePlaylistStoryItem> PlaylistStoryEditor { get; set; } = [];
    private string NewStoryDialogInstanceKey { get; set; } = Guid.NewGuid().ToString("N");
    private IJSObjectReference? AdminUploadModule { get; set; }

    private IReadOnlyList<AdminStoryRecord> AvailableStoriesForPlaylist =>
        Stories
            .Where(story => PlaylistStoryEditor.All(item => item.StoryId != story.StoryId))
            .OrderBy(story => story.Title, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private string CurrentLanguageCode => CurrentLanguage == AdminLanguage.English ? "en" : "af";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            if (authState.User.Identity?.IsAuthenticated != true)
            {
                IsRedirectingToLogin = true;
                IsLoading = false;
                var returnUrl = Uri.EscapeDataString("/admin");
                NavigationManager.NavigateTo($"/teken-in?returnUrl={returnUrl}");
                return;
            }

            CurrentAdminEmail = authState.User.FindFirst(ClaimTypes.Email)?.Value
                               ?? authState.User.Identity?.Name;
            var isAdmin = await AdminManagementService.IsAdminAsync(CurrentAdminEmail);
            if (!isAdmin)
            {
                IsAccessDenied = true;
                IsLoading = false;
                return;
            }

            await LoadAllAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Admin page initialization failed.");
            SetError(T(
                "Kon nie die bestuursblad nou laai nie. Probeer asseblief weer.",
                "Could not load the admin page right now. Please try again."));
            IsLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            var storedLanguageCode = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", AdminLanguageStorageKey);
            var storedLanguage = ParseLanguage(storedLanguageCode);
            if (storedLanguage == CurrentLanguage)
            {
                return;
            }

            CurrentLanguage = storedLanguage;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception exception)
        {
            // Ignore storage availability issues (private mode / blocked storage).
            Logger.LogDebug(exception, "Admin language preference load skipped.");
        }

        try
        {
            AdminUploadModule = await GetAdminUploadModuleAsync();
        }
        catch (Exception exception)
        {
            Logger.LogWarning(exception, "Admin direct-upload module could not be loaded during first render.");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (AdminUploadModule is null)
        {
            return;
        }

        try
        {
            await AdminUploadModule.DisposeAsync();
        }
        catch (JSDisconnectedException)
        {
            // Ignore disconnects during teardown.
        }
    }

    private async Task OnLanguageChangedAsync(string? selectedLanguageCode)
    {
        var requestedLanguage = ParseLanguage(selectedLanguageCode);
        if (requestedLanguage == CurrentLanguage)
        {
            return;
        }

        CurrentLanguage = requestedLanguage;
        ErrorMessage = null;
        StatusMessage = null;

        try
        {
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", AdminLanguageStorageKey, CurrentLanguageCode);
        }
        catch (Exception exception)
        {
            // Ignore storage availability issues (private mode / blocked storage).
            Logger.LogDebug(exception, "Admin language preference save skipped.");
        }
    }

    private AdminLanguage ParseLanguage(string? code)
    {
        return string.Equals(code, "en", StringComparison.OrdinalIgnoreCase)
            ? AdminLanguage.English
            : AdminLanguage.Afrikaans;
    }

    private async Task LoadAllAsync()
    {
        IsLoading = true;
        var subscribersTask = RefreshSubscribersAsync();
        var storiesTask = RefreshStoriesAsync();
        var playlistsTask = RefreshPlaylistsAsync();
        await Task.WhenAll(subscribersTask, storiesTask, playlistsTask);
        IsLoading = false;
    }

    private async Task RefreshSubscribersAsync()
    {
        try
        {
            var selectedSubscriberId = SubscriberEditor?.SubscriberId;
            Subscribers = await AdminManagementService.GetSubscribersAsync(CurrentAdminEmail, SubscriberSearch);
            var selectedSubscriber = selectedSubscriberId is not null
                ? Subscribers.FirstOrDefault(subscriber => subscriber.SubscriberId == selectedSubscriberId.Value)
                : Subscribers.FirstOrDefault();
            SubscriberEditor = selectedSubscriber is null ? null : EditableSubscriber.From(selectedSubscriber);
            if (SubscriberEditor is null)
            {
                IsSubscriberDialogOpen = false;
            }
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to refresh subscribers.");
            Subscribers = Array.Empty<AdminSubscriberRecord>();
            SubscriberEditor = null;
            IsSubscriberDialogOpen = false;
            SetError(T("Kon nie intekenaars nou laai nie.", "Could not load subscribers right now."));
        }
    }

    private async Task RefreshStoriesAsync(Guid? selectedStoryId = null)
    {
        try
        {
            var targetStoryId = selectedStoryId ?? StoryEditor?.StoryId;
            Stories = await AdminManagementService.GetStoriesAsync(CurrentAdminEmail, StorySearch);
            var selectedStory = targetStoryId is not null
                ? Stories.FirstOrDefault(story => story.StoryId == targetStoryId.Value)
                : Stories.FirstOrDefault();
            StoryEditor = selectedStory is null ? null : EditableStory.From(selectedStory);
            if (StoryEditor is null)
            {
                IsStoryDialogOpen = false;
            }
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to refresh stories.");
            Stories = Array.Empty<AdminStoryRecord>();
            StoryEditor = null;
            IsStoryDialogOpen = false;
            SetError(T("Kon nie stories nou laai nie.", "Could not load stories right now."));
        }
    }

    private async Task RefreshPlaylistsAsync(Guid? selectedPlaylistId = null)
    {
        try
        {
            var targetPlaylistId = selectedPlaylistId ?? PlaylistEditor?.PlaylistId;
            Playlists = await AdminManagementService.GetPlaylistsAsync(CurrentAdminEmail);

            var selectedPlaylist = targetPlaylistId is not null
                ? Playlists.FirstOrDefault(playlist => playlist.PlaylistId == targetPlaylistId.Value)
                : Playlists.FirstOrDefault();

            if (selectedPlaylist is null)
            {
                PlaylistEditor = null;
                PlaylistStoryEditor = [];
                StoryToAddIdString = string.Empty;
                IsPlaylistDialogOpen = false;
                return;
            }

            PlaylistEditor = EditablePlaylist.From(selectedPlaylist);
            PlaylistStoryEditor = selectedPlaylist.Stories
                .OrderBy(story => story.SortOrder)
                .Select(EditablePlaylistStoryItem.From)
                .ToList();
            ReindexPlaylistStories();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to refresh playlists.");
            Playlists = Array.Empty<AdminPlaylistRecord>();
            PlaylistEditor = null;
            PlaylistStoryEditor = [];
            StoryToAddIdString = string.Empty;
            IsPlaylistDialogOpen = false;
            SetError(T("Kon nie playlists nou laai nie.", "Could not load playlists right now."));
        }
    }

    private string GetSubscriberRowClass(AdminSubscriberRecord subscriber, int rowNumber)
    {
        _ = rowNumber;
        return subscriber is not null &&
               SubscriberEditor?.SubscriberId == subscriber.SubscriberId
            ? "admin-grid-row-selected"
            : string.Empty;
    }

    private string GetStoryRowClass(AdminStoryRecord story, int rowNumber)
    {
        _ = rowNumber;
        return story is not null &&
               StoryEditor?.StoryId == story.StoryId
            ? "admin-grid-row-selected"
            : string.Empty;
    }

    private string GetPlaylistRowClass(AdminPlaylistRecord playlist, int rowNumber)
    {
        _ = rowNumber;
        return playlist is not null &&
               PlaylistEditor?.PlaylistId == playlist.PlaylistId
            ? "admin-grid-row-selected"
            : string.Empty;
    }

    private Task OnSubscriberRowClick(TableRowClickEventArgs<AdminSubscriberRecord> args)
    {
        if (args.Item is not null)
        {
            SelectSubscriber(args.Item.SubscriberId);
            IsSubscriberDialogOpen = SubscriberEditor is not null;
        }

        return Task.CompletedTask;
    }

    private Task OnStoryRowClick(TableRowClickEventArgs<AdminStoryRecord> args)
    {
        if (args.Item is not null)
        {
            SelectStory(args.Item.StoryId);
            IsStoryDialogOpen = StoryEditor is not null;
        }

        return Task.CompletedTask;
    }

    private async Task OnPlaylistRowClick(TableRowClickEventArgs<AdminPlaylistRecord> args)
    {
        if (args.Item is null)
        {
            return;
        }

        await SelectPlaylist(args.Item.PlaylistId);
        IsPlaylistDialogOpen = PlaylistEditor is not null;
    }

    private void SelectSubscriber(Guid subscriberId)
    {
        var selected = Subscribers.FirstOrDefault(subscriber => subscriber.SubscriberId == subscriberId);
        if (selected is null)
        {
            return;
        }

        SubscriberEditor = EditableSubscriber.From(selected);
    }

    private void SelectStory(Guid storyId)
    {
        var selected = Stories.FirstOrDefault(story => story.StoryId == storyId);
        if (selected is null)
        {
            return;
        }

        StoryEditor = EditableStory.From(selected);
    }

    private void StartNewStory()
    {
        NewStoryEditor = new NewStoryDraft
        {
            AccessLevel = "subscriber",
            PublishNow = true
        };
        NewStoryDialogInstanceKey = Guid.NewGuid().ToString("N");
        IsNewStoryDialogOpen = true;
    }

    private async Task SelectPlaylist(Guid playlistId)
    {
        await RefreshPlaylistsAsync(playlistId);
    }

    private void StartNewPlaylist()
    {
        PlaylistEditor = new EditablePlaylist();
        PlaylistStoryEditor = [];
        StoryToAddIdString = string.Empty;
        IsPlaylistDialogOpen = true;
