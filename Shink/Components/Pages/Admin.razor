    private static string? ResolvePreviewImageUrl(string? imagePath)
    {
        if (string.IsNullOrWhiteSpace(imagePath))
        {
            return null;
        }

        var candidate = imagePath.Trim();
        if (candidate.StartsWith("data:image/", StringComparison.OrdinalIgnoreCase))
        {
            return candidate;
        }

        if (Uri.TryCreate(candidate, UriKind.Absolute, out var absoluteUri))
        {
            if (string.Equals(absoluteUri.Scheme, Uri.UriSchemeHttp, StringComparison.OrdinalIgnoreCase) ||
                string.Equals(absoluteUri.Scheme, Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase))
            {
                return absoluteUri.ToString();
            }

            return null;
        }

        if (candidate.StartsWith("//", StringComparison.Ordinal))
        {
            return null;
        }

        if (candidate.StartsWith("~/", StringComparison.Ordinal))
        {
            candidate = $"/{candidate[2..]}";
        }

        return candidate.StartsWith("/", StringComparison.Ordinal)
            ? candidate
            : $"/{candidate.TrimStart('/')}";
    }

    private static DateTimeOffset? ParseOptionalLocalDateTime(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        if (!DateTime.TryParse(value, CultureInfo.CurrentCulture, DateTimeStyles.AssumeLocal, out var parsed))
        {
            return null;
        }

        return new DateTimeOffset(parsed);
    }

    private static string NormalizeAudioContentType(IBrowserFile file) =>
        file.ContentType?.Trim().ToLowerInvariant() switch
        {
            "audio/mpeg" or "audio/mp3" => "audio/mpeg",
            "audio/mp4" or "audio/x-m4a" => "audio/mp4",
            "audio/wav" or "audio/x-wav" or "audio/wave" => "audio/wav",
            "audio/ogg" => "audio/ogg",
            _ => Path.GetExtension(file.Name).Trim().ToLowerInvariant() switch
            {
                ".mp3" or ".mpeg" => "audio/mpeg",
                ".m4a" => "audio/mp4",
                ".wav" => "audio/wav",
                ".ogg" => "audio/ogg",
                _ => file.ContentType ?? string.Empty
            }
        };

    private static string NormalizeImageContentType(IBrowserFile file) =>
        file.ContentType?.Trim().ToLowerInvariant() switch
        {
            "image/jpeg" or "image/jpg" => "image/jpeg",
            "image/png" => "image/png",
            "image/webp" => "image/webp",
            _ => Path.GetExtension(file.Name).Trim().ToLowerInvariant() switch
            {
                ".jpg" or ".jpeg" => "image/jpeg",
                ".png" => "image/png",
                ".webp" => "image/webp",
                _ => file.ContentType ?? string.Empty
            }
        };

    private async Task<string?> ReadImageFileAsDataUrlAsync(IBrowserFile file)
    {
        try
        {
            var normalizedContentType = NormalizeImageContentType(file);
            if (!IsSupportedImageContentType(normalizedContentType))
            {
                return null;
            }

            await using var stream = file.OpenReadStream(MaxImageUploadBytes);
            using var buffer = new MemoryStream();
            await stream.CopyToAsync(buffer);
            var base64 = Convert.ToBase64String(buffer.ToArray());
            return $"data:{normalizedContentType};base64,{base64}";
        }
        catch (Exception exception) when (exception is IOException or InvalidOperationException)
        {
            Logger.LogDebug(exception, "Inline image preview generation skipped.");
            return null;
        }
    }

    private static bool IsSupportedImageFile(IBrowserFile file)
    {
        var normalizedContentType = NormalizeImageContentType(file);
        return IsSupportedImageContentType(normalizedContentType);
    }

    private static bool IsSupportedImageContentType(string normalizedContentType) =>
        normalizedContentType is "image/jpeg" or "image/png" or "image/webp";

    private static string CreateUniqueStorySlug(string? value, IReadOnlyList<AdminStoryRecord> existingStories)
    {
        var baseSlug = CreatePlaylistSlug(value);
        if (string.IsNullOrWhiteSpace(baseSlug))
        {
            return string.Empty;
        }

        var existingSlugs = existingStories
            .Select(story => story.Slug)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (!existingSlugs.Contains(baseSlug))
        {
            return baseSlug;
        }

        for (var suffix = 2; suffix < 10_000; suffix++)
        {
            var candidate = $"{baseSlug}-{suffix}";
            if (!existingSlugs.Contains(candidate))
            {
                return candidate;
            }
        }

        return $"{baseSlug}-{Guid.NewGuid():N}"[..Math.Min(baseSlug.Length + 7, 64)];
    }

    private static int BuildNextStorySortOrder(IReadOnlyList<AdminStoryRecord> existingStories)
    {
        if (existingStories.Count == 0)
        {
            return 10;
        }

        return existingStories.Max(story => story.SortOrder) + 10;
    }

    private static string? AutofillStorySummary(string? summary, string? description)
    {
        if (!string.IsNullOrWhiteSpace(summary))
        {
            return summary.Trim();
        }

        if (string.IsNullOrWhiteSpace(description))
        {
            return null;
        }

        var trimmed = description.Trim();
        if (trimmed.Length <= 240)
        {
            return trimmed;
        }

        var candidate = trimmed[..240];
        var lastSpace = candidate.LastIndexOf(' ');
        return (lastSpace > 80 ? candidate[..lastSpace] : candidate).Trim();
    }

    private static string? AutofillStoryDescription(string? description, string? summary)
    {
        if (!string.IsNullOrWhiteSpace(description))
        {
            return description.Trim();
        }

        return string.IsNullOrWhiteSpace(summary)
            ? null
            : summary.Trim();
    }

