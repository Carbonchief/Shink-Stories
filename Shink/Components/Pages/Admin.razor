    private async Task SaveNewStoryAsync()
    {
        if (NewStoryEditor is null)
        {
            return;
        }

        ClearFeedback();

        var validationMessage = ValidateNewStoryDraft(NewStoryEditor);
        if (!string.IsNullOrWhiteSpace(validationMessage))
        {
            SetError(validationMessage);
            return;
        }

        IsCreatingStory = true;
        var uploadedObjectKeys = new List<string>();

        try
        {
            var allStories = await AdminManagementService.GetStoriesAsync(CurrentAdminEmail);
            var generatedSlug = CreateUniqueStorySlug(NewStoryEditor.Title, allStories);
            if (string.IsNullOrWhiteSpace(generatedSlug))
            {
                SetError(T("Gee asseblief 'n geldige titel vir die storie.", "Please enter a valid title for the story."));
                return;
            }

            var coverFile = NewStoryEditor.CoverFile!;
            var audioFile = NewStoryEditor.AudioFile!;
            var summary = AutofillStorySummary(NewStoryEditor.Summary, NewStoryEditor.Description);
            var description = AutofillStoryDescription(NewStoryEditor.Description, summary);

            var coverUpload = await UploadImageWithFallbackAsync(
                generatedSlug,
                StoryImageKind.Cover,
                coverFile,
                NewStoryCoverInputId);
            uploadedObjectKeys.Add(coverUpload.ObjectKey);

            var thumbnailPath = coverUpload.PublicUrl;
            if (NewStoryEditor.ThumbnailFile is not null)
            {
                var thumbnailUpload = await UploadImageWithFallbackAsync(
                    generatedSlug,
                    StoryImageKind.Thumbnail,
                    NewStoryEditor.ThumbnailFile,
                    NewStoryThumbnailInputId);
                uploadedObjectKeys.Add(thumbnailUpload.ObjectKey);
                thumbnailPath = thumbnailUpload.PublicUrl;
            }
            else
            {
                var thumbnailUpload = await UploadGeneratedThumbnailAsync(generatedSlug, coverFile);
                uploadedObjectKeys.Add(thumbnailUpload.ObjectKey);
                thumbnailPath = thumbnailUpload.PublicUrl;
            }

            var audioUpload = await UploadAudioWithFallbackAsync(
                generatedSlug,
                audioFile,
                NewStoryAudioInputId);
            uploadedObjectKeys.Add(audioUpload.ObjectKey);

            var result = await AdminManagementService.CreateStoryAsync(
                CurrentAdminEmail,
                new AdminStoryCreateRequest(
                    Slug: generatedSlug,
                    Title: NewStoryEditor.Title,
                    Summary: summary,
                    Description: description,
                    CoverImagePath: coverUpload.PublicUrl,
                    ThumbnailImagePath: thumbnailPath,
                    AudioBucket: audioUpload.Bucket,
                    AudioObjectKey: audioUpload.ObjectKey,
                    AudioContentType: audioUpload.ContentType,
                    AccessLevel: NewStoryEditor.AccessLevel,
                    Status: NewStoryEditor.PublishNow ? "published" : "draft",
                    SortOrder: BuildNextStorySortOrder(allStories),
                    PublishedAt: NewStoryEditor.PublishNow ? DateTimeOffset.Now : null,
                    DurationSeconds: null));

            if (!result.IsSuccess)
            {
                await CleanupUploadedStoryObjectsAsync(uploadedObjectKeys);
                SetError(result.ErrorMessage ?? T("Kon nie nuwe storie skep nie.", "Could not create the new story."));
                return;
            }

            await RefreshStoriesAsync(result.EntityId);
            NewStoryEditor = null;
            IsNewStoryDialogOpen = false;
            if (string.IsNullOrWhiteSpace(ErrorMessage))
            {
                SetStatus(T("Nuwe storie is geskep en opgelaai.", "New story was created and uploaded."));
            }
        }
        catch (Exception exception)
        {
            await CleanupUploadedStoryObjectsAsync(uploadedObjectKeys);
            Logger.LogError(exception, "Failed to create story from admin upload.");
            SetError(LocalizeNewStoryException(exception));
        }
        finally
        {
            IsCreatingStory = false;
        }
    }

    private async Task SaveStoryAsync()
    {
        if (StoryEditor is null)
        {
            return;
        }

        IsSavingStory = true;
        ClearFeedback();
        var uploadedObjectKeys = new List<string>();

        try
        {
            if ((StoryEditor.CoverFile is not null || StoryEditor.ThumbnailFile is not null) &&
                string.IsNullOrWhiteSpace(StoryEditor.Slug))
            {
                SetError(T("Storie slug ontbreek. Verfris asseblief en probeer weer.", "Story slug is missing. Please refresh and try again."));
                return;
            }

            var validationMessage = ValidateStoryMediaDraft(StoryEditor);
            if (!string.IsNullOrWhiteSpace(validationMessage))
            {
                SetError(validationMessage);
                return;
            }

            if (StoryEditor.CoverFile is not null)
            {
                var coverUpload = await UploadImageWithFallbackAsync(
                    StoryEditor.Slug,
                    StoryImageKind.Cover,
                    StoryEditor.CoverFile,
                    EditStoryCoverInputId);
                uploadedObjectKeys.Add(coverUpload.ObjectKey);
                StoryEditor.CoverImagePath = coverUpload.PublicUrl;
            }

            if (StoryEditor.ThumbnailFile is not null)
            {
                var thumbnailUpload = await UploadImageWithFallbackAsync(
                    StoryEditor.Slug,
                    StoryImageKind.Thumbnail,
                    StoryEditor.ThumbnailFile,
                    EditStoryThumbnailInputId);
                uploadedObjectKeys.Add(thumbnailUpload.ObjectKey);
                StoryEditor.ThumbnailImagePath = thumbnailUpload.PublicUrl;
            }
            else if (StoryEditor.CoverFile is not null)
            {
                var thumbnailUpload = await UploadGeneratedThumbnailAsync(StoryEditor.Slug, StoryEditor.CoverFile);
                uploadedObjectKeys.Add(thumbnailUpload.ObjectKey);
                StoryEditor.ThumbnailImagePath = thumbnailUpload.PublicUrl;
            }

            if (StoryEditor.AudioFile is not null)
            {
                var audioUpload = await UploadAudioWithFallbackAsync(
                    StoryEditor.Slug,
                    StoryEditor.AudioFile,
                    EditStoryAudioInputId);
                uploadedObjectKeys.Add(audioUpload.ObjectKey);
                StoryEditor.AudioProvider = "r2";
                StoryEditor.AudioBucket = audioUpload.Bucket;
                StoryEditor.AudioObjectKey = audioUpload.ObjectKey;
                StoryEditor.AudioContentType = audioUpload.ContentType;
            }

            var publishedAt = ParseOptionalLocalDateTime(StoryEditor.PublishedAtLocal);
            var result = await AdminManagementService.UpdateStoryAsync(
                CurrentAdminEmail,
                new AdminStoryUpdateRequest(
                    StoryEditor.StoryId,
                    StoryEditor.Slug,
                    StoryEditor.Title,
                    StoryEditor.Summary,
                    StoryEditor.Description,
                    StoryEditor.CoverImagePath,
                    StoryEditor.ThumbnailImagePath,
                    StoryEditor.AudioProvider,
                    StoryEditor.AudioBucket,
                    StoryEditor.AudioObjectKey,
                    StoryEditor.AudioContentType,
                    StoryEditor.AccessLevel,
                    StoryEditor.Status,
                    StoryEditor.SortOrder,
                    publishedAt,
                    StoryEditor.DurationSeconds));

            if (!HandleOperationResult(result, T("Storie is opgedateer.", "Story updated.")))
            {
                await CleanupUploadedStoryObjectsAsync(uploadedObjectKeys);
                return;
            }

            StoryEditor.CoverFile = null;
            StoryEditor.CoverFileName = null;
            StoryEditor.CoverPreviewDataUrl = null;
            StoryEditor.ThumbnailFile = null;
            StoryEditor.ThumbnailFileName = null;
            StoryEditor.ThumbnailPreviewDataUrl = null;
            StoryEditor.AudioFile = null;
            StoryEditor.AudioFileName = null;

            await RefreshStoriesAsync(StoryEditor.StoryId);
        }
        catch (Exception exception)
        {
            await CleanupUploadedStoryObjectsAsync(uploadedObjectKeys);
            Logger.LogError(exception, "Failed to save story.");
            SetError(LocalizeStoryEditException(exception));
        }
        finally
        {
            IsSavingStory = false;
        }
    }

    private async Task SavePlaylistAsync()
    {
        if (PlaylistEditor is null)
        {
            return;
        }

        IsSavingPlaylist = true;
        ClearFeedback();
        var uploadedObjectKeys = new List<string>();
        var uploadedLocalFilePaths = new List<string>();

        try
        {
            var playlistSlug = string.IsNullOrWhiteSpace(PlaylistEditor.Slug)
                ? CreatePlaylistSlug(PlaylistEditor.Title)
                : PlaylistEditor.Slug.Trim();
            if (string.IsNullOrWhiteSpace(playlistSlug))
            {
                SetError(T("Gee asseblief 'n geldige titel vir die playlist.", "Please enter a valid title for the playlist."));
                return;
            }

            var validationMessage = ValidatePlaylistMediaDraft(PlaylistEditor);
            if (!string.IsNullOrWhiteSpace(validationMessage))
            {
                SetError(validationMessage);
                return;
            }

            if (PlaylistEditor.LogoFile is not null)
            {
                var logoUpload = await UploadPlaylistImageAsync(
                    playlistSlug,
                    PlaylistImageAssetKind.Logo,
                    PlaylistEditor.LogoFile,
                    EditPlaylistLogoInputId);
                if (!string.IsNullOrWhiteSpace(logoUpload.R2ObjectKey))
                {
                    uploadedObjectKeys.Add(logoUpload.R2ObjectKey);
                }

                if (!string.IsNullOrWhiteSpace(logoUpload.LocalFilePath))
                {
                    uploadedLocalFilePaths.Add(logoUpload.LocalFilePath);
                }

                PlaylistEditor.LogoImagePath = logoUpload.PublicPath;
            }

            if (PlaylistEditor.BackdropFile is not null)
            {
                var backdropUpload = await UploadPlaylistImageAsync(
                    playlistSlug,
                    PlaylistImageAssetKind.Backdrop,
                    PlaylistEditor.BackdropFile,
                    EditPlaylistBackdropInputId);
                if (!string.IsNullOrWhiteSpace(backdropUpload.R2ObjectKey))
                {
                    uploadedObjectKeys.Add(backdropUpload.R2ObjectKey);
                }

                if (!string.IsNullOrWhiteSpace(backdropUpload.LocalFilePath))
                {
                    uploadedLocalFilePaths.Add(backdropUpload.LocalFilePath);
                }

                PlaylistEditor.BackdropImagePath = backdropUpload.PublicPath;
            }

            var result = await AdminManagementService.SavePlaylistAsync(
                CurrentAdminEmail,
                new AdminPlaylistUpdateRequest(
                    PlaylistEditor.PlaylistId,
                    playlistSlug,
                    PlaylistEditor.Title,
                    PlaylistEditor.Description,
                    PlaylistEditor.LogoImagePath,
                    PlaylistEditor.BackdropImagePath,
                    PlaylistEditor.SortOrder,
                    PlaylistEditor.MaxItems,
                    PlaylistEditor.IsEnabled,
                    PlaylistEditor.ShowOnHome,
                    PlaylistEditor.ShowShowcaseImageOnLuisterPage));

            if (!HandleOperationResult(result, T("Playlist is gestoor.", "Playlist saved.")))
            {
                await CleanupUploadedStoryObjectsAsync(uploadedObjectKeys);
                await CleanupUploadedLocalFilesAsync(uploadedLocalFilePaths);
                return;
            }

            PlaylistEditor.LogoFile = null;
            PlaylistEditor.LogoFileName = null;
            PlaylistEditor.BackdropFile = null;
            PlaylistEditor.BackdropFileName = null;

            var selectedPlaylistId = result.EntityId ?? PlaylistEditor.PlaylistId;
            await RefreshPlaylistsAsync(selectedPlaylistId);
        }
        catch (Exception exception)
        {
            await CleanupUploadedStoryObjectsAsync(uploadedObjectKeys);
            await CleanupUploadedLocalFilesAsync(uploadedLocalFilePaths);
            Logger.LogError(exception, "Failed to save playlist.");
            SetError(LocalizePlaylistEditException(exception));
        }
        finally
        {
            IsSavingPlaylist = false;
        }
    }

    private async Task TogglePlaylistEnabledAsync(AdminPlaylistRecord playlist, bool isEnabled)
    {
        if (playlist.PlaylistId == Guid.Empty || playlist.IsEnabled == isEnabled)
        {
            return;
        }

        if (!TogglingPlaylistIds.Add(playlist.PlaylistId))
        {
            return;
        }

        ClearFeedback();

        try
        {
            var result = await AdminManagementService.SavePlaylistAsync(
                CurrentAdminEmail,
                new AdminPlaylistUpdateRequest(
                    playlist.PlaylistId,
                    playlist.Slug,
                    playlist.Title,
                    playlist.Description,
                    playlist.LogoImagePath,
                    playlist.BackdropImagePath,
                    playlist.SortOrder,
                    playlist.MaxItems,
                    isEnabled,
                    playlist.ShowOnHome,
                    playlist.ShowShowcaseImageOnLuisterPage));

            if (!HandleOperationResult(
                    result,
                    isEnabled
                        ? T("Playlist is geaktiveer.", "Playlist activated.")
                        : T("Playlist is gedeaktiveer.", "Playlist deactivated.")))
            {
                return;
            }

            await RefreshPlaylistsAsync(playlist.PlaylistId);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to toggle playlist status. playlist_id={PlaylistId}", playlist.PlaylistId);
            SetError(T("Kon nie playlist status nou opdateer nie.", "Could not update playlist status right now."));
        }
        finally
        {
            TogglingPlaylistIds.Remove(playlist.PlaylistId);
        }
    }

