    private static string CreatePlaylistSlug(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var normalized = value.Normalize(System.Text.NormalizationForm.FormD);
        var slugBuilder = new System.Text.StringBuilder();
        var previousWasDash = false;

        foreach (var ch in normalized)
        {
            var category = CharUnicodeInfo.GetUnicodeCategory(ch);
            if (category == UnicodeCategory.NonSpacingMark)
            {
                continue;
            }

            var lower = char.ToLowerInvariant(ch);
            if (char.IsLetterOrDigit(lower))
            {
                slugBuilder.Append(lower);
                previousWasDash = false;
                continue;
            }

            if (previousWasDash)
            {
                continue;
            }

            slugBuilder.Append('-');
            previousWasDash = true;
        }

        return slugBuilder.ToString().Trim('-');
    }

    private static string BuildSubscriberName(AdminSubscriberRecord? subscriber)
    {
        if (subscriber is null)
        {
            return "-";
        }

        var tokens = new[]
        {
            subscriber.FirstName?.Trim(),
            subscriber.LastName?.Trim()
        }
        .Where(token => !string.IsNullOrWhiteSpace(token))
        .ToArray();

        if (tokens.Length > 0)
        {
            return string.Join(' ', tokens);
        }

        return string.IsNullOrWhiteSpace(subscriber.DisplayName)
            ? "-"
            : subscriber.DisplayName!;
    }

