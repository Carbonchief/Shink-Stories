@page "/blog"
@using System.Globalization
@using System.Text.Json
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.WebUtilities
@inject IBlogCatalogService BlogCatalogService
@inject NavigationManager NavigationManager

<PageTitle>@PageTitleText</PageTitle>
<HeadContent>
    <meta name="description" content="@PageDescription" />
    <link rel="canonical" href="@CanonicalUrl" />
    <link rel="alternate" type="application/rss+xml" title="Schink Stories Blog RSS" href="@RssUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@PageTitleText" />
    <meta property="og:description" content="@PageDescription" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:image" content="@ShareImageUrl" />
    <meta property="og:image:secure_url" content="@ShareImageUrl" />
    <meta property="og:image:type" content="@ShareImageMimeType" />
    <meta property="og:image:alt" content="@ShareImageAlt" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@PageTitleText" />
    <meta name="twitter:description" content="@PageDescription" />
    <meta name="twitter:image" content="@ShareImageUrl" />
    <meta name="twitter:image:alt" content="@ShareImageAlt" />
    <JsonLdScript Json="@BlogJsonLd" />
</HeadContent>

<section class="blog-page">
    <header class="blog-hero">
        <div class="blog-hero-copy">
            <p class="blog-eyebrow">Blog</p>
            <h1>Stories, wenke en nuus</h1>
            <p class="blog-lead">
                Lees meer oor storietyd, luistergewoontes en alles wat by Schink Stories gebeur.
            </p>
        </div>

        <a class="blog-rss-link" href="/blog/rss.xml">
            <i class="fa-solid fa-rss" aria-hidden="true"></i>
            <span>RSS</span>
        </a>
    </header>

    <form class="blog-filters" action="/blog" method="get">
        <label class="blog-filter-field">
            <span>Soek</span>
            <input type="search"
                   name="q"
                   value="@CurrentQuery"
                   placeholder="Soek titel of inhoud" />
        </label>

        @if (AvailableCategories.Count > 0)
        {
            <label class="blog-filter-field">
                <span>Kategorie</span>
                <select name="category">
                    <option value="">Alle kategorieë</option>
                    @foreach (var category in AvailableCategories)
                    {
                        <option value="@category.Slug" selected="@IsCategorySelected(category.Slug)">@category.Name</option>
                    }
                </select>
            </label>
        }

        @if (AvailableTags.Count > 0)
        {
            <label class="blog-filter-field">
                <span>Etiket</span>
                <select name="tag">
                    <option value="">Alle etikette</option>
                    @foreach (var tag in AvailableTags)
                    {
                        <option value="@tag.Slug" selected="@IsTagSelected(tag.Slug)">@tag.Name</option>
                    }
                </select>
            </label>
        }

        <div class="blog-filter-actions">
            <button type="submit" class="blog-filter-submit">Soek</button>
            @if (HasActiveFilters)
            {
                <a class="blog-filter-clear" href="/blog">Maak skoon</a>
            }
        </div>
    </form>

    @if (HasActiveFilters)
    {
        <div class="blog-active-filters" aria-label="Aktiewe filters">
            @if (!string.IsNullOrWhiteSpace(CurrentQuery))
            {
                <a class="blog-active-filter" href="@BuildBlogUrl(string.Empty, CurrentCategorySlug, CurrentTagSlug, 1)">
                    <span>Soek: @CurrentQuery</span>
                    <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                </a>
            }

            @if (SelectedCategory is not null)
            {
                <a class="blog-active-filter" href="@BuildBlogUrl(CurrentQuery, string.Empty, CurrentTagSlug, 1)">
                    <span>Kategorie: @SelectedCategory.Name</span>
                    <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                </a>
            }

            @if (SelectedTag is not null)
            {
                <a class="blog-active-filter" href="@BuildBlogUrl(CurrentQuery, CurrentCategorySlug, string.Empty, 1)">
                    <span>Etiket: @SelectedTag.Name</span>
                    <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                </a>
            }
        </div>
    }

    @if (IsLoading)
    {
        <section class="blog-state" aria-live="polite">
            <h2>Laai blog plasings...</h2>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="blog-state blog-state-error" aria-live="polite">
            <h2>Ons kon nie die blog nou laai nie.</h2>
            <p>@ErrorMessage</p>
        </section>
    }
    else if (FilteredPosts.Count == 0)
    {
        <section class="blog-state">
            <h2>Geen blog plasings gevind nie</h2>
            <p>Probeer 'n ander soekterm of maak jou filters skoon.</p>
        </section>
    }
    else
    {
        <div class="blog-results-meta">
            <p>@ResultsSummaryText</p>
        </div>

        <div class="blog-grid">
            @foreach (var post in VisiblePosts)
            {
                var featuredImageUrl = ResolveBrowserImageUrl(post.FeaturedImageUrl);

                <article class="blog-card">
                    @if (!string.IsNullOrWhiteSpace(featuredImageUrl))
                    {
                        <a class="blog-card-image-link" href="@BuildPostUrl(post)">
                            <img class="blog-card-image"
                                 src="@featuredImageUrl"
                                 alt="Voorblad vir @post.Title"
                                 loading="lazy"
                                 decoding="async" />
                        </a>
                    }

                    <div class="blog-card-body">
                        <div class="blog-card-meta">
                            <time datetime="@post.PublishedAt.ToString("O")">@FormatBlogDate(post.PublishedAt)</time>
                            <span>@BuildReadingTimeLabel(post)</span>
                            @if (!string.IsNullOrWhiteSpace(post.AuthorName))
                            {
                                <span>@post.AuthorName</span>
                            }
                        </div>

                        <h2><a href="@BuildPostUrl(post)">@post.Title</a></h2>
                        <p>@post.Summary</p>

                        <div class="blog-card-taxonomy">
                            @if (post.Category is not null)
                            {
                                <a class="blog-chip" href="@BuildBlogUrl(CurrentQuery, post.Category.Slug, CurrentTagSlug, 1)">
                                    @post.Category.Name
                                </a>
                            }

                            @foreach (var tag in post.Tags.Take(3))
                            {
                                <a class="blog-chip blog-chip-secondary" href="@BuildBlogUrl(CurrentQuery, CurrentCategorySlug, tag.Slug, 1)">
                                    @tag.Name
                                </a>
                            }
                        </div>

                        <a class="blog-read-more" href="@BuildPostUrl(post)">Lees meer</a>
                    </div>
                </article>
            }
        </div>

        @if (TotalPages > 1)
        {
            <nav class="blog-pagination" aria-label="Bladsy navigasie">
                <a class="blog-pagination-link @(CurrentPage <= 1 ? "is-disabled" : null)"
                   href="@(CurrentPage <= 1 ? null : BuildBlogUrl(CurrentQuery, CurrentCategorySlug, CurrentTagSlug, CurrentPage - 1))"
                   aria-disabled="@(CurrentPage <= 1)">
                    Vorige
                </a>

                @foreach (var pageNumber in PaginationPages)
                {
                    <a class="blog-pagination-link @(pageNumber == CurrentPage ? "is-current" : null)"
                       href="@BuildBlogUrl(CurrentQuery, CurrentCategorySlug, CurrentTagSlug, pageNumber)"
                       aria-current="@(pageNumber == CurrentPage ? "page" : null)">
                        @pageNumber
                    </a>
                }

                <a class="blog-pagination-link @(CurrentPage >= TotalPages ? "is-disabled" : null)"
                   href="@(CurrentPage >= TotalPages ? null : BuildBlogUrl(CurrentQuery, CurrentCategorySlug, CurrentTagSlug, CurrentPage + 1))"
                   aria-disabled="@(CurrentPage >= TotalPages)">
                    Volgende
                </a>
            </nav>
        }
    }
</section>

@code {
    private const int PageSize = 6;

    [SupplyParameterFromQuery(Name = "q")]
    public string? Query { get; set; }

    [SupplyParameterFromQuery(Name = "category")]
    public string? Category { get; set; }

    [SupplyParameterFromQuery(Name = "tag")]
    public string? Tag { get; set; }

    [SupplyParameterFromQuery(Name = "page")]
    public int? Page { get; set; }

    private IReadOnlyList<BlogPostListItem> AllPosts { get; set; } = Array.Empty<BlogPostListItem>();
    private IReadOnlyList<BlogPostListItem> FilteredPosts { get; set; } = Array.Empty<BlogPostListItem>();
    private IReadOnlyList<BlogPostListItem> VisiblePosts { get; set; } = Array.Empty<BlogPostListItem>();
    private IReadOnlyList<BlogCategoryItem> AvailableCategories { get; set; } = Array.Empty<BlogCategoryItem>();
    private IReadOnlyList<BlogTagItem> AvailableTags { get; set; } = Array.Empty<BlogTagItem>();
    private BlogCategoryItem? SelectedCategory { get; set; }
    private BlogTagItem? SelectedTag { get; set; }
    private string CurrentQuery { get; set; } = string.Empty;
    private string CurrentCategorySlug { get; set; } = string.Empty;
    private string CurrentTagSlug { get; set; } = string.Empty;
    private bool IsLoading { get; set; } = true;
    private string? ErrorMessage { get; set; }
    private int CurrentPage { get; set; } = 1;
    private int TotalPages { get; set; } = 1;
    private string CanonicalUrl => NavigationManager.ToAbsoluteUri(BuildBlogUrl(CurrentQuery, CurrentCategorySlug, CurrentTagSlug, CurrentPage)).ToString();
    private string RssUrl => NavigationManager.ToAbsoluteUri("/blog/rss.xml").ToString();
    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(CurrentQuery) ||
        !string.IsNullOrWhiteSpace(CurrentCategorySlug) ||
        !string.IsNullOrWhiteSpace(CurrentTagSlug);

    private string PageTitleText =>
        HasActiveFilters
            ? $"Schink Stories | Blog ({FilteredPosts.Count})"
            : "Schink Stories | Blog";

    private string PageDescription =>
        HasActiveFilters
            ? $"Lees {FilteredPosts.Count} blog plasings op Schink Stories wat pas by jou soektog of filters."
            : "Lees Afrikaanse stories, wenke en nuus van Schink Stories se blog.";

    private string ShareImageUrl =>
        NavigationManager.ToAbsoluteUri(ResolveBrowserImageUrl(VisiblePosts.FirstOrDefault(post => !string.IsNullOrWhiteSpace(post.FeaturedImageUrl))?.FeaturedImageUrl)
                                        ?? "/branding/schink-logo-green.png").ToString();

    private string ShareImageMimeType => GetImageMimeType(VisiblePosts.FirstOrDefault(post => !string.IsNullOrWhiteSpace(post.FeaturedImageUrl))?.FeaturedImageUrl);

    private string ShareImageAlt =>
        VisiblePosts.FirstOrDefault(post => !string.IsNullOrWhiteSpace(post.FeaturedImageUrl)) is { } postWithImage
            ? $"Voorblad vir {postWithImage.Title}"
            : "Schink Stories blog";

    private IReadOnlyList<int> PaginationPages =>
        Enumerable.Range(1, TotalPages)
            .Where(pageNumber => pageNumber == 1 || pageNumber == TotalPages || Math.Abs(pageNumber - CurrentPage) <= 1)
            .ToArray();

    private string ResultsSummaryText =>
        FilteredPosts.Count == 1
            ? "1 plasing gevind"
            : $"{FilteredPosts.Count} plasings gevind";

    private MarkupString BlogJsonLd => new(JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "CollectionPage",
        ["name"] = "Schink Stories | Blog",
        ["description"] = PageDescription,
        ["url"] = CanonicalUrl,
        ["inLanguage"] = "af-ZA",
        ["isPartOf"] = new Dictionary<string, object?>
        {
            ["@type"] = "WebSite",
            ["name"] = "Schink Stories",
            ["url"] = NavigationManager.ToAbsoluteUri("/").ToString()
        },
        ["mainEntity"] = new Dictionary<string, object?>
        {
            ["@type"] = "ItemList",
            ["itemListElement"] = VisiblePosts.Select((post, index) => new Dictionary<string, object?>
            {
                ["@type"] = "ListItem",
                ["position"] = index + 1,
                ["url"] = NavigationManager.ToAbsoluteUri(BuildPostUrl(post)).ToString(),
                ["name"] = post.Title
            }).ToArray()
        }
    }));

    protected override async Task OnParametersSetAsync()
    {
        IsLoading = true;
        ErrorMessage = null;

        CurrentQuery = Query?.Trim() ?? string.Empty;
        CurrentCategorySlug = Category?.Trim() ?? string.Empty;
        CurrentTagSlug = Tag?.Trim() ?? string.Empty;

        try
        {
            AllPosts = await BlogCatalogService.GetPublishedPostsAsync();
            AvailableCategories = AllPosts
                .Where(post => post.Category is not null)
                .Select(post => post.Category!)
                .DistinctBy(category => category.CategoryId)
                .OrderBy(category => category.Name, StringComparer.OrdinalIgnoreCase)
                .ToArray();

            AvailableTags = AllPosts
                .SelectMany(post => post.Tags)
                .DistinctBy(tag => tag.TagId)
                .OrderBy(tag => tag.Name, StringComparer.OrdinalIgnoreCase)
                .ToArray();

            SelectedCategory = AvailableCategories.FirstOrDefault(category =>
                string.Equals(category.Slug, CurrentCategorySlug, StringComparison.OrdinalIgnoreCase));
            SelectedTag = AvailableTags.FirstOrDefault(tag =>
                string.Equals(tag.Slug, CurrentTagSlug, StringComparison.OrdinalIgnoreCase));

            FilteredPosts = ApplyFilters(AllPosts, CurrentQuery, SelectedCategory?.Slug, SelectedTag?.Slug);

            TotalPages = Math.Max(1, (int)Math.Ceiling(FilteredPosts.Count / (double)PageSize));
            CurrentPage = FilteredPosts.Count == 0
                ? 1
                : Math.Clamp(Page ?? 1, 1, TotalPages);

            VisiblePosts = FilteredPosts
                .Skip((CurrentPage - 1) * PageSize)
                .Take(PageSize)
                .ToArray();
        }
        catch (Exception)
        {
            AllPosts = Array.Empty<BlogPostListItem>();
            FilteredPosts = Array.Empty<BlogPostListItem>();
            VisiblePosts = Array.Empty<BlogPostListItem>();
            AvailableCategories = Array.Empty<BlogCategoryItem>();
            AvailableTags = Array.Empty<BlogTagItem>();
            SelectedCategory = null;
            SelectedTag = null;
            TotalPages = 1;
            CurrentPage = 1;
            ErrorMessage = "Probeer asseblief weer oor 'n oomblik.";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private static IReadOnlyList<BlogPostListItem> ApplyFilters(
        IReadOnlyList<BlogPostListItem> posts,
        string query,
        string? categorySlug,
        string? tagSlug)
    {
        var filtered = posts.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(query))
        {
            filtered = filtered.Where(post =>
                post.Title.Contains(query, StringComparison.OrdinalIgnoreCase) ||
                post.Summary.Contains(query, StringComparison.OrdinalIgnoreCase) ||
                post.PlainTextContent.Contains(query, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(categorySlug))
        {
            filtered = filtered.Where(post =>
                string.Equals(post.Category?.Slug, categorySlug, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(tagSlug))
        {
            filtered = filtered.Where(post =>
                post.Tags.Any(tag => string.Equals(tag.Slug, tagSlug, StringComparison.OrdinalIgnoreCase)));
        }

        return filtered
            .OrderByDescending(post => post.PublishedAt)
            .ThenBy(post => post.Title, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private string BuildPostUrl(BlogPostListItem post) => $"/blog/{Uri.EscapeDataString(post.Slug)}";

    private static string FormatBlogDate(DateTimeOffset value) =>
        value.ToLocalTime().ToString("d MMMM yyyy", CultureInfo.GetCultureInfo("af-ZA"));

    private static string BuildReadingTimeLabel(BlogPostListItem post)
    {
        var words = post.PlainTextContent
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Length;
        var readingTime = Math.Max(1, (int)Math.Ceiling(words / 220d));
        return readingTime == 1 ? "1 min lees" : $"{readingTime} min lees";
    }

    private bool IsCategorySelected(string slug) =>
        string.Equals(CurrentCategorySlug, slug, StringComparison.OrdinalIgnoreCase);

    private bool IsTagSelected(string slug) =>
        string.Equals(CurrentTagSlug, slug, StringComparison.OrdinalIgnoreCase);

    private static string GetImageMimeType(string? pathOrUrl)
    {
        var extension = Path.GetExtension(pathOrUrl ?? string.Empty).ToLowerInvariant();
        return extension switch
        {
            ".png" => "image/png",
            ".webp" => "image/webp",
            ".jpg" or ".jpeg" => "image/jpeg",
            _ => "image/png"
        };
    }

    private static string? ResolveBrowserImageUrl(string? imageUrl) =>
        string.IsNullOrWhiteSpace(imageUrl) ? null : StoryItem.RewriteImagePathForBrowser(imageUrl);

    private static string BuildBlogUrl(string? query, string? category, string? tag, int? page)
    {
        var parameters = new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase);

        if (!string.IsNullOrWhiteSpace(query))
        {
            parameters["q"] = query.Trim();
        }

        if (!string.IsNullOrWhiteSpace(category))
        {
            parameters["category"] = category.Trim();
        }

        if (!string.IsNullOrWhiteSpace(tag))
        {
            parameters["tag"] = tag.Trim();
        }

        if (page is > 1)
        {
            parameters["page"] = page.Value.ToString(CultureInfo.InvariantCulture);
        }

        return parameters.Count == 0
            ? "/blog"
            : QueryHelpers.AddQueryString("/blog", parameters);
    }
}
