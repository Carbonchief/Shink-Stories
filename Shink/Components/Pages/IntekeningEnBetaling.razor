@page "/intekening-en-betaling"
@page "/intekening-en-betaaling"
@using System.ComponentModel.DataAnnotations
@using System.Globalization
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISubscriptionLedgerService SubscriptionLedgerService
@inject IJSRuntime JS
@inject NavigationManager NavigationManager

<PageTitle>Schink Stories | Intekening en betaling</PageTitle>
<HeadContent>
    <link href="/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <meta name="description" content="Bestuur jou intekening, betalings en rekeningbesonderhede op Schink Stories." />
    <meta name="robots" content="noindex, follow, noarchive, nosnippet" />
    <link rel="canonical" href="@BillingCanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Schink Stories | Intekening en betaling" />
    <meta property="og:description" content="Bestuur jou intekening, betalings en rekeningbesonderhede op Schink Stories." />
    <meta property="og:url" content="@BillingCanonicalUrl" />
    <meta property="og:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:secure_url" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content="Schink Stories logo" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Schink Stories | Intekening en betaling" />
    <meta name="twitter:description" content="Bestuur jou intekening, betalings en rekeningbesonderhede op Schink Stories." />
    <meta name="twitter:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta name="twitter:image:alt" content="Schink Stories logo" />
</HeadContent>

<section class="billing-page">
    <header class="billing-hero">
        <div class="billing-hero-copy">
            <p class="billing-kicker">Jou rekening</p>
            <h1>Intekening en betaling</h1>
            <p class="billing-hero-lead">
                Bestuur jou profiel, kyk jou toegang en kies die Schink Stories plan wat die beste by julle storietyd pas.
            </p>

            <div class="billing-hero-points" aria-label="Wat jy hier kan doen">
                <div class="billing-hero-point">
                    <strong>Hou besonderhede netjies</strong>
                    <span>Werk jou naam en selfoonnommer by sodat jou rekening altyd op datum bly.</span>
                </div>
                <div class="billing-hero-point">
                    <strong>Beheer jou rekening veilig</strong>
                    <span>Verander jou e-pos met Supabase bevestiging en hou jou toegang veilig.</span>
                </div>
            </div>
        </div>

        <aside class="billing-hero-panel" aria-label="Vinnige rekening oorsig">
            <img class="billing-hero-logo" src="/branding/schink-logo-text.png" alt="Schink" loading="eager" decoding="async" />
            <p class="billing-section-kicker">Vinnige oorsig</p>

            @if (IsLoading)
            {
                <h2>Besig om te laai</h2>
                <p>Ons haal nou jou jongste intekeninginligting.</p>
            }
            else if (IsRedirectingToLogin)
            {
                <h2>Teken in om voort te gaan</h2>
                <p>Jy moet ingeteken wees om jou rekening en betalings te bestuur.</p>
            }
            else if (IsEmailChangeCallbackRequest())
            {
                <h2>Ons bevestig jou nuwe e-posadres</h2>
                <p>Hou asseblief hierdie blad oop terwyl ons jou Supabase bevestiging afrond.</p>
            }
            else if (HasActivePaidSubscription)
            {
                <h2>Jou volle toegang is aktief</h2>
                <p>Jy is tans ingeteken en kan direk na al jou stories teruggaan.</p>

                @if (!string.IsNullOrWhiteSpace(UserEmail))
                {
                    <p class="billing-hero-email">@UserEmail</p>
                }

                <div class="billing-hero-panel-actions">
                    <a class="btn btn-warning billing-primary-btn" href="/luister">Gaan na alle stories</a>
                </div>
            }
            else
            {
                <h2>Jy luister tans gratis</h2>
                <p>Kies enige tyd 'n betaalde plan om al die stories oop te maak.</p>

                @if (!string.IsNullOrWhiteSpace(UserEmail))
                {
                    <p class="billing-hero-email">@UserEmail</p>
                }

                <div class="billing-hero-panel-actions">
                    <a class="btn btn-outline-secondary billing-secondary-btn" href="/opsies">Kies 'n plan</a>
                </div>
            }
        </aside>
    </header>

    @if (IsRedirectingToLogin)
    {
        <section class="billing-state-card billing-state-card-neutral">
            <div class="billing-state-copy">
                <p class="billing-section-kicker">Teken in</p>
                <h2>Neem jou nou na teken in...</h2>
                <p>Jy moet ingeteken wees om jou intekening en rekeningbesonderhede te bestuur.</p>
            </div>
        </section>
    }
    else if (IsLoading)
    {
        <section class="billing-state-card billing-state-card-neutral">
            <div class="spinner-border billing-state-spinner" role="status" aria-hidden="true"></div>
            <div class="billing-state-copy">
                <p class="billing-section-kicker">Laai</p>
                <h2>Laai jou intekening...</h2>
                <p>Ons bring nou jou profiel- en toegangsinligting in.</p>
            </div>
        </section>
    }
    else if (IsEmailChangeCallbackRequest())
    {
        <section class="billing-state-card billing-state-card-neutral">
            @if (IsCompletingEmailChange)
            {
                <div class="spinner-border billing-state-spinner" role="status" aria-hidden="true"></div>
            }

            <div class="billing-state-copy">
                <p class="billing-section-kicker">Bevestig e-pos</p>
                <h2>@(IsCompletingEmailChange ? "Ons verifieer jou nuwe e-posadres..." : "E-posbevestiging")</h2>
                <p>
                    @if (!string.IsNullOrWhiteSpace(EmailChangeCallbackMessage))
                    {
                        @EmailChangeCallbackMessage
                    }
                    else
                    {
                        <text>Ons verifieer nou jou nuwe e-posadres en sal jou terugstuur sodra dit klaar is.</text>
                    }
                </p>
            </div>
        </section>
    }
    else
    {
        <div class="billing-content-grid">
            <section class="billing-panel billing-profile-card" aria-label="Jou profiel">
                <div class="billing-panel-heading">
                    <p class="billing-section-kicker">Profiel</p>
                    <h2>Hou jou rekeningbesonderhede op datum</h2>
                    <p>Gebruik die vorm hieronder om jou besonderhede netjies en op datum te hou.</p>
                </div>

                <EditForm FormName="billing-profile-form" class="billing-profile-form" Model="ProfileForm" OnValidSubmit="SaveProfileAsync" aria-busy="@IsSavingProfile">
                    <DataAnnotationsValidator />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="billing-first-name">Voornaam</label>
                            <InputText id="billing-first-name" class="form-control form-control-lg" autocomplete="given-name" @bind-Value="ProfileForm.FirstName" />
                            <ValidationMessage class="invalid-feedback d-block" For="@(() => ProfileForm.FirstName)" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label" for="billing-last-name">Van</label>
                            <InputText id="billing-last-name" class="form-control form-control-lg" autocomplete="family-name" @bind-Value="ProfileForm.LastName" />
                            <ValidationMessage class="invalid-feedback d-block" For="@(() => ProfileForm.LastName)" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label" for="billing-display-name">Publieke naam</label>
                            <InputText id="billing-display-name" class="form-control form-control-lg" autocomplete="nickname" @bind-Value="ProfileForm.DisplayName" />
                            <ValidationMessage class="invalid-feedback d-block" For="@(() => ProfileForm.DisplayName)" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label" for="billing-mobile-number">Selfoonnommer</label>
                            <InputText id="billing-mobile-number" class="form-control form-control-lg" type="tel" autocomplete="tel" @bind-Value="ProfileForm.MobileNumber" />
                            <ValidationMessage class="invalid-feedback d-block" For="@(() => ProfileForm.MobileNumber)" />
                        </div>

                        <div class="col-12">
                            <label class="form-label" for="billing-email">Huidige e-posadres</label>
                            <input id="billing-email"
                                   class="form-control form-control-lg billing-readonly-input"
                                   value="@UserEmail"
                                   autocomplete="email"
                                   aria-describedby="billing-email-help"
                                   readonly />
                            <div id="billing-email-help" class="form-text billing-form-hint">
                                Jou huidige e-posadres word hier gewys. Gebruik die knoppie hieronder om dit veilig met Supabase te verander.
                            </div>
                        </div>
                    </div>

                    <div class="billing-form-actions d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-warning btn-lg billing-primary-btn" disabled="@IsSavingProfile">
                            @(IsSavingProfile ? "Stoor..." : "Stoor profiel")
                        </button>
                        <button type="button"
                                class="btn btn-outline-secondary btn-lg billing-secondary-btn"
                                @onclick="OpenEmailChangeModal">
                            Verander e-posadres
                        </button>
                        <a class="btn btn-outline-secondary btn-lg billing-secondary-btn" href="/opsies">Sien plan opsies</a>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(ProfileStatusMessage))
                    {
                        <div class="alert @(ProfileSaveSucceeded ? "alert-success" : "alert-danger") billing-profile-status"
                             role="@(ProfileSaveSucceeded ? "status" : "alert")"
                             aria-live="polite">
                            @ProfileStatusMessage
                        </div>
                    }
                </EditForm>
            </section>

            <aside class="billing-panel billing-status-card @(HasActivePaidSubscription ? "is-active" : "is-free")" aria-live="polite">
                <div class="billing-panel-heading">
                    <p class="billing-section-kicker">Toegang</p>
                    @if (HasActivePaidSubscription)
                    {
                        <h2>Jou betaalde intekening is aktief</h2>
                        <p>Jy het tans toegang tot betaalde stories. Dankie dat jy deel is van Schink Stories.</p>
                    }
                    else
                    {
                        <h2>Jy is tans op die gratis opsie</h2>
                        <p>Sluit aan by 'n betaalde plan vir volle toegang tot ons stories wanneer julle gereed is.</p>
                    }
                </div>

                <ul class="billing-status-list">
                    @if (HasActivePaidSubscription)
                    {
                        <li>Volle toegang tot die betaalde stories en reekse.</li>
                        <li>Jou profielbesonderhede en betalings bly op een plek beskikbaar.</li>
                        <li>Jy kan steeds enige tyd na plan opsies teruggaan.</li>
                    }
                    else
                    {
                        <li>Jou gratis stories bly beskikbaar terwyl jy besluit.</li>
                        <li>Jy kan enige tyd opgradeer na volle toegang.</li>
                        <li>Vergelyk planne voordat jy 'n betaling begin.</li>
                    }
                </ul>

                <div class="billing-status-actions d-grid gap-2">
                    @if (HasActivePaidSubscription)
                    {
                        <a class="btn btn-warning btn-lg billing-primary-btn" href="/luister">Gaan na alle stories</a>
                        <a class="btn btn-outline-secondary btn-lg billing-secondary-btn" href="/opsies">Sien plan opsies</a>
                    }
                    else
                    {
                        <a class="btn btn-warning btn-lg billing-primary-btn" href="/opsies">Kies 'n plan</a>
                        <a class="btn btn-outline-secondary btn-lg billing-secondary-btn" href="/gratis">Gaan na gratis stories</a>
                    }
                </div>
            </aside>
        </div>

        @if (IsEmailChangeModalOpen)
        {
            <div class="billing-modal-backdrop" @onclick="CloseEmailChangeModal">
                <div class="billing-modal"
                     role="dialog"
                     aria-modal="true"
                     aria-labelledby="billing-email-modal-title"
                     @onclick:stopPropagation="true">
                    <div class="billing-modal-header">
                        <div class="billing-modal-heading">
                            <p class="billing-section-kicker">Veilige e-posverandering</p>
                            <h2 id="billing-email-modal-title">Verander jou e-posadres</h2>
                            <p>
                                Vul jou nuwe e-posadres en huidige wagwoord in. Supabase stuur dan 'n bevestiging-skakel
                                om jou verandering veilig klaar te maak.
                            </p>
                        </div>

                        <button type="button"
                                class="billing-modal-close"
                                aria-label="Maak toe"
                                @onclick="CloseEmailChangeModal">
                            ×
                        </button>
                    </div>

                    <EditForm FormName="billing-email-change-form"
                              class="billing-profile-form billing-email-form"
                              EditContext="EmailChangeEditContext"
                              OnSubmit="HandleEmailChangeSubmitAsync"
                              aria-busy="@IsSubmittingEmailChange">
                        <DataAnnotationsValidator />

                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label" for="billing-email-change-new">Nuwe e-posadres</label>
                                <InputText id="billing-email-change-new"
                                           class="form-control form-control-lg"
                                           type="email"
                                           autocomplete="email"
                                           @bind-Value="EmailChangeForm.NewEmail" />
                                <ValidationMessage class="invalid-feedback d-block" For="@(() => EmailChangeForm.NewEmail)" />
                            </div>

                            <div class="col-12">
                                <label class="form-label" for="billing-email-change-password">Huidige wagwoord</label>
                                <InputText id="billing-email-change-password"
                                           class="form-control form-control-lg"
                                           type="password"
                                           autocomplete="current-password"
                                           @bind-Value="EmailChangeForm.CurrentPassword" />
                                <ValidationMessage class="invalid-feedback d-block" For="@(() => EmailChangeForm.CurrentPassword)" />
                            </div>
                        </div>

                        <p class="billing-email-note">
                            Gebruik 'n e-posadres waartoe jy nou toegang het. As Supabase twee bevestigings vereis,
                            maak asseblief albei skakels oop.
                        </p>

                        <div class="billing-form-actions d-flex flex-wrap gap-2">
                            <button type="submit" class="btn btn-warning btn-lg billing-primary-btn" disabled="@IsSubmittingEmailChange">
                                @(IsSubmittingEmailChange ? "Besig..." : "Stuur bevestiging")
                            </button>
                            <button type="button"
                                    class="btn btn-outline-secondary btn-lg billing-secondary-btn"
                                    @onclick="CloseEmailChangeModal">
                                Kanselleer
                            </button>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(EmailChangeStatusMessage))
                        {
                            <div class="alert @(EmailChangeStatusIsSuccess ? "alert-success" : "alert-danger") billing-profile-status"
                                 role="@(EmailChangeStatusIsSuccess ? "status" : "alert")"
                                 aria-live="polite">
                                @EmailChangeStatusMessage
                            </div>
                        }
                    </EditForm>
                </div>
            </div>
        }

        <section class="billing-plans" aria-label="Betaal planne">
            <div class="billing-section-heading">
                <p class="billing-section-kicker">Plan keuses</p>
                <h2>Vinnige opsies vir jou gesin</h2>
                <p>Begin direk by die regte plan, of gaan na <a href="/opsies">Opsies</a> vir die volledige vergelyking.</p>
            </div>

            <div class="billing-plan-grid">
                @foreach (var plan in PaymentPlanCatalog.All)
                {
                    <article class="billing-plan-card @(IsYearlyAllStoriesPlan(plan) ? "is-highlighted" : string.Empty)">
                        <p class="billing-plan-badge">@(plan.BillingPeriodMonths <= 1 ? "Maandeliks" : "Jaarliks")</p>
                        <h3>@plan.Name</h3>
                        <p class="billing-price">@FormatRand(plan.Amount) <span>@ResolveBillingLabel(plan.BillingPeriodMonths)</span></p>
                        @if (IsYearlyAllStoriesPlan(plan))
                        {
                            <p class="billing-save-badge">2 maande gratis</p>
                        }
                        <p class="billing-description">@plan.ItemDescription</p>
                        <div class="billing-plan-actions">
                            <a class="btn btn-warning billing-primary-btn" href="@($"/betaal/{plan.Slug}")">Kies hierdie plan</a>
                        </div>
                    </article>
                }
            </div>
        </section>
    }
</section>

@code {
    private string BillingCanonicalUrl => NavigationManager.ToAbsoluteUri("/intekening-en-betaling").ToString();
    private bool IsLoading { get; set; } = true;
    private bool IsRedirectingToLogin { get; set; }
    private bool IsAuthenticatedUser { get; set; }
    private bool HasActivePaidSubscription { get; set; }
    private bool IsCompletingEmailChange { get; set; }
    private bool IsEmailChangeModalOpen { get; set; }
    private string UserEmail { get; set; } = string.Empty;
    private ProfileFormModel ProfileForm { get; set; } = new();
    private EmailChangeFormModel EmailChangeForm { get; set; } = new();
    private EditContext EmailChangeEditContext { get; set; } = default!;
    private bool IsSavingProfile { get; set; }
    private bool IsSubmittingEmailChange { get; set; }
    private bool ProfileSaveSucceeded { get; set; }
    private bool EmailChangeStatusIsSuccess { get; set; }
    private bool EmailChangeCallbackIsSuccess { get; set; }
    private string? ProfileStatusMessage { get; set; }
    private string? EmailChangeStatusMessage { get; set; }
    private string? EmailChangeCallbackMessage { get; set; }
    private IJSObjectReference? _authModule;

    [SupplyParameterFromQuery(Name = "emailChange")]
    public string? EmailChange { get; set; }

    [SupplyParameterFromQuery(Name = "emailChangeState")]
    public string? EmailChangeState { get; set; }

    protected override void OnInitialized()
    {
        EmailChangeEditContext = new EditContext(EmailChangeForm);
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        IsAuthenticatedUser = authState.User.Identity?.IsAuthenticated == true;

        if (!IsAuthenticatedUser)
        {
            if (IsEmailChangeCallbackRequest())
            {
                IsLoading = false;
                return;
            }

            IsRedirectingToLogin = true;
            IsLoading = false;

            var currentPathAndQuery = new Uri(NavigationManager.Uri).PathAndQuery;
            var safeReturnPath = string.IsNullOrWhiteSpace(currentPathAndQuery)
                ? "/intekening-en-betaling"
                : currentPathAndQuery;
            var returnUrl = Uri.EscapeDataString(safeReturnPath);
            NavigationManager.NavigateTo($"/teken-in?returnUrl={returnUrl}");
            return;
        }

        try
        {
            UserEmail = authState.User.FindFirst(ClaimTypes.Email)?.Value
                        ?? authState.User.Identity?.Name
                        ?? string.Empty;

            var hasActivePaidSubscriptionTask = SubscriptionLedgerService.HasActivePaidSubscriptionAsync(UserEmail);
            var subscriberProfileTask = SubscriptionLedgerService.GetSubscriberProfileAsync(UserEmail);
            await Task.WhenAll(hasActivePaidSubscriptionTask, subscriberProfileTask);

            HasActivePaidSubscription = hasActivePaidSubscriptionTask.Result;
            HydrateProfileForm(subscriberProfileTask.Result, authState.User);

            if (string.Equals(EmailChange, "success", StringComparison.OrdinalIgnoreCase))
            {
                EmailChangeStatusIsSuccess = true;
                EmailChangeStatusMessage = "Jou e-posadres is suksesvol opgedateer.";
                IsEmailChangeModalOpen = true;
            }
        }
        catch
        {
            HasActivePaidSubscription = false;
            HydrateProfileForm(profile: null, authState.User);
        }
        finally
        {
            IsLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !IsEmailChangeCallbackRequest())
        {
            return;
        }

        await HandleEmailChangeCallbackAsync();
    }

    private async Task SaveProfileAsync()
    {
        if (IsSavingProfile || string.IsNullOrWhiteSpace(UserEmail))
        {
            return;
        }

        IsSavingProfile = true;
        ProfileSaveSucceeded = false;
        ProfileStatusMessage = null;

        try
        {
            var saved = await SubscriptionLedgerService.UpsertSubscriberProfileAsync(
                email: UserEmail,
                firstName: NormalizeOptionalField(ProfileForm.FirstName),
                lastName: NormalizeOptionalField(ProfileForm.LastName),
                displayName: NormalizeOptionalField(ProfileForm.DisplayName),
                mobileNumber: NormalizeOptionalField(ProfileForm.MobileNumber));

            if (!saved)
            {
                ProfileSaveSucceeded = false;
                ProfileStatusMessage = "Ons kon nie nou jou profiel stoor nie. Probeer asseblief weer.";
                return;
            }

            ProfileSaveSucceeded = true;
            ProfileStatusMessage = "Jou profiel is suksesvol opgedateer.";
        }
        catch
        {
            ProfileSaveSucceeded = false;
            ProfileStatusMessage = "Ons kon nie nou jou profiel stoor nie. Probeer asseblief weer.";
        }
        finally
        {
            IsSavingProfile = false;
        }
    }

    private async Task HandleEmailChangeSubmitAsync(EditContext editContext)
    {
        await SyncEmailChangeInputsFromDomAsync();

        if (!editContext.Validate() || IsSubmittingEmailChange)
        {
            return;
        }

        IsSubmittingEmailChange = true;
        EmailChangeStatusIsSuccess = false;
        EmailChangeStatusMessage = null;
        await ShowSubmittingStateAsync();

        try
        {
            var authModule = await EnsureAuthModuleAsync();
            var response = await authModule.InvokeAsync<AuthBrowserResponse>(
                "postAuthJson",
                "/api/auth/email-change/request",
                new EmailChangeRequestPayload(
                    EmailChangeForm.NewEmail.Trim(),
                    EmailChangeForm.CurrentPassword));

            EmailChangeStatusIsSuccess = response.Ok;
            EmailChangeStatusMessage = response.Message ?? (response.Ok
                ? "Ons het 'n bevestiging-skakel vir jou e-posverandering gestuur."
                : "Kon nie nou jou e-posadres verander nie. Probeer asseblief weer.");

            if (response.Ok)
            {
                EmailChangeForm.CurrentPassword = string.Empty;
            }
        }
        catch
        {
            EmailChangeStatusIsSuccess = false;
            EmailChangeStatusMessage = "Kon nie nou jou e-posadres verander nie. Probeer asseblief weer.";
        }
        finally
        {
            IsSubmittingEmailChange = false;
        }
    }

    private void OpenEmailChangeModal()
    {
        IsEmailChangeModalOpen = true;
    }

    private void CloseEmailChangeModal()
    {
        IsEmailChangeModalOpen = false;
        EmailChangeForm.CurrentPassword = string.Empty;
    }

    private async Task HandleEmailChangeCallbackAsync()
    {
        if (IsCompletingEmailChange)
        {
            return;
        }

        IsCompletingEmailChange = true;
        EmailChangeCallbackIsSuccess = false;
        EmailChangeCallbackMessage = null;
        await ShowSubmittingStateAsync();

        try
        {
            var authModule = await EnsureAuthModuleAsync();
            var browserState = await authModule.InvokeAsync<RecoveryBrowserState>("readSupabaseRecoveryState");

            if (!string.IsNullOrWhiteSpace(browserState.ErrorDescription))
            {
                EmailChangeCallbackMessage = browserState.ErrorDescription.Trim();
                return;
            }

            if (string.IsNullOrWhiteSpace(browserState.AccessToken) ||
                string.IsNullOrWhiteSpace(browserState.RefreshToken))
            {
                EmailChangeCallbackMessage = "Kon nie die bevestiging-skakel lees nie. Probeer asseblief weer vanaf jou e-pos.";
                return;
            }

            var response = await authModule.InvokeAsync<AuthBrowserResponse>(
                "postAuthJson",
                "/api/auth/email-change/complete",
                new EmailChangeCompletePayload(
                    browserState.AccessToken,
                    browserState.RefreshToken,
                    EmailChangeState));

            EmailChangeCallbackIsSuccess = response.Ok;
            EmailChangeCallbackMessage = response.Message ?? (response.Ok
                ? "Jou e-posadres is suksesvol opgedateer."
                : "Kon nie nou jou e-posadres bevestig nie. Probeer asseblief weer.");

            if (response.Ok && !string.IsNullOrWhiteSpace(response.RedirectPath))
            {
                await RedirectToTargetAsync(response.RedirectPath);
            }
        }
        catch
        {
            EmailChangeCallbackIsSuccess = false;
            EmailChangeCallbackMessage = "Kon nie nou jou e-posadres bevestig nie. Probeer asseblief weer.";
        }
        finally
        {
            IsCompletingEmailChange = false;
            StateHasChanged();
        }
    }

    private async Task SyncEmailChangeInputsFromDomAsync()
    {
        try
        {
            var authModule = await EnsureAuthModuleAsync();
            var values = await authModule.InvokeAsync<Dictionary<string, string>>(
                "readInputValues",
                new[] { "billing-email-change-new", "billing-email-change-password" });

            if (values.TryGetValue("billing-email-change-new", out var newEmailValue))
            {
                EmailChangeForm.NewEmail = newEmailValue?.Trim() ?? string.Empty;
            }

            if (values.TryGetValue("billing-email-change-password", out var passwordValue))
            {
                EmailChangeForm.CurrentPassword = passwordValue ?? string.Empty;
            }
        }
        catch
        {
            // Keep existing bound values if DOM reads fail.
        }
    }

    private async Task ShowSubmittingStateAsync()
    {
        StateHasChanged();
        await Task.Yield();
    }

    private async Task RedirectToTargetAsync(string? target)
    {
        var safeTarget = string.IsNullOrWhiteSpace(target)
            ? "/intekening-en-betaling?emailChange=success"
            : target;

        try
        {
            var authModule = await EnsureAuthModuleAsync();
            await authModule.InvokeVoidAsync("redirectTo", safeTarget);
        }
        catch
        {
            NavigationManager.NavigateTo(safeTarget, forceLoad: true);
        }
    }

    private async Task<IJSObjectReference> EnsureAuthModuleAsync()
    {
        if (_authModule is not null)
        {
            return _authModule;
        }

        _authModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/auth-browser.js");
        return _authModule;
    }

    private bool IsEmailChangeCallbackRequest() =>
        string.Equals(EmailChange, "complete", StringComparison.OrdinalIgnoreCase) &&
        !string.IsNullOrWhiteSpace(EmailChangeState);

    private void HydrateProfileForm(SubscriberProfile? profile, ClaimsPrincipal user)
    {
        ProfileForm = new ProfileFormModel
        {
            FirstName = profile?.FirstName ?? user.FindFirst(ClaimTypes.GivenName)?.Value ?? string.Empty,
            LastName = profile?.LastName ?? user.FindFirst(ClaimTypes.Surname)?.Value ?? string.Empty,
            DisplayName = profile?.DisplayName ?? string.Empty,
            MobileNumber = profile?.MobileNumber ?? string.Empty
        };
    }

    private static string? NormalizeOptionalField(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return value.Trim();
    }

    private static string ResolveBillingLabel(int billingPeriodMonths) =>
        billingPeriodMonths <= 1 ? "per maand" : "per jaar";

    private static bool IsYearlyAllStoriesPlan(PaymentPlan plan) =>
        string.Equals(plan.TierCode, "all_stories_yearly", StringComparison.OrdinalIgnoreCase);

    private static string FormatRand(decimal amount)
    {
        var culture = CultureInfo.GetCultureInfo("en-ZA");
        return $"R {amount.ToString("0.00", culture)}";
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_authModule is not null)
            {
                await _authModule.DisposeAsync();
            }
        }
        catch
        {
            // Ignore module disposal failures.
        }
    }

    private sealed record RecoveryBrowserState(
        string? AccessToken,
        string? RefreshToken,
        string? Type,
        string? ErrorCode,
        string? ErrorDescription);

    private sealed record AuthBrowserResponse(bool Ok, int Status, string? Message, string? RedirectPath);

    private sealed record EmailChangeRequestPayload(string NewEmail, string CurrentPassword);

    private sealed record EmailChangeCompletePayload(string? AccessToken, string? RefreshToken, string? EmailChangeState);

    private sealed class ProfileFormModel
    {
        [StringLength(80, ErrorMessage = "Voornaam mag nie langer as 80 karakters wees nie.")]
        public string FirstName { get; set; } = string.Empty;

        [StringLength(80, ErrorMessage = "Van mag nie langer as 80 karakters wees nie.")]
        public string LastName { get; set; } = string.Empty;

        [RegularExpression(@"^$|.{2,120}$", ErrorMessage = "Publieke naam moet tussen 2 en 120 karakters wees.")]
        public string DisplayName { get; set; } = string.Empty;

        [RegularExpression(@"^\+?[0-9\s\-\(\)]{7,24}$", ErrorMessage = "Gebruik asseblief 'n geldige selfoonnommer.")]
        public string MobileNumber { get; set; } = string.Empty;
    }

    private sealed class EmailChangeFormModel
    {
        [Required(ErrorMessage = "Vul asseblief jou nuwe e-pos in.")]
        [EmailAddress(ErrorMessage = "Gebruik asseblief 'n geldige nuwe e-posadres.")]
        [StringLength(254)]
        public string NewEmail { get; set; } = string.Empty;

        [Required(ErrorMessage = "Vul asseblief jou huidige wagwoord in.")]
        [StringLength(200, MinimumLength = 6, ErrorMessage = "Jou wagwoord moet tussen 6 en 200 karakters wees.")]
        public string CurrentPassword { get; set; } = string.Empty;
    }
}
