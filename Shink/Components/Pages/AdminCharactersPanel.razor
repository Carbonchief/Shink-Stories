@using System.Globalization
@using System.Security.Claims
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Options
@using Microsoft.JSInterop
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ICharacterAdminService CharacterAdminService
@inject IAdminManagementService AdminManagementService
@inject IStoryMediaStorageService StoryMediaStorageService
@inject IWebHostEnvironment WebHostEnvironment
@inject IJSRuntime JSRuntime
@inject ILogger<AdminCharactersPanel> Logger
@inject IOptions<CloudflareR2Options> CloudflareR2OptionsAccessor

<section class="admin-section">
    <div class="admin-section-head">
        <div class="admin-search">
            <input class="characters-admin-search"
                   type="search"
                   @bind="CharacterSearch"
                   @bind:event="oninput"
                   placeholder="@T("Soek naam of slug", "Search name or slug")" />
            <div class="characters-admin-view-toggle" role="group" aria-label="@T("Karakteraansig", "Character view")">
                <button type="button"
                        class="characters-admin-btn characters-admin-btn-secondary @(ViewMode == CharacterDisplayMode.List ? "is-active" : null)"
                        aria-pressed="@(ViewMode == CharacterDisplayMode.List)"
                        aria-label='@T("Lys", "List")'
                        title='@T("Lys", "List")'
                        @onclick="() => SetViewMode(CharacterDisplayMode.List)">
                    <i class="fa-solid fa-list" aria-hidden="true"></i>
                    <span class="sr-only">@T("Lys", "List")</span>
                </button>
                <button type="button"
                        class="characters-admin-btn characters-admin-btn-secondary @(ViewMode == CharacterDisplayMode.Grid ? "is-active" : null)"
                        aria-pressed="@(ViewMode == CharacterDisplayMode.Grid)"
                        aria-label='@T("Beeldraster", "Image grid")'
                        title='@T("Beeldraster", "Image grid")'
                        @onclick="() => SetViewMode(CharacterDisplayMode.Grid)">
                    <i class="fa-solid fa-table-cells-large" aria-hidden="true"></i>
                    <span class="sr-only">@T("Beeldraster", "Image grid")</span>
                </button>
            </div>
            <MudButton Class="characters-admin-new-action-btn"
                       Variant="Variant.Outlined"
                       Color="Color.Primary"
                       OnClick="BeginCreateCharacter"
                       aria-label='@T("Nuwe karakter", "New character")'
                       title='@T("Nuwe karakter", "New character")'>
                <i class="fa-solid fa-plus" aria-hidden="true"></i>
            </MudButton>
            <MudButton Class="admin-btn admin-btn-secondary admin-icon-btn"
                       Variant="Variant.Outlined"
                       Color="Color.Primary"
                       OnClick="ReloadAsync"
                       aria-label='@T("Herlaai", "Refresh")'
                       title='@T("Herlaai", "Refresh")'>
                <i class="fa-solid fa-arrows-rotate" aria-hidden="true"></i>
                <span class="sr-only">@T("Herlaai", "Refresh")</span>
            </MudButton>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <p class="admin-feedback is-error">@ErrorMessage</p>
    }
    else if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <p class="admin-feedback is-success">@StatusMessage</p>
    }

    @if (IsLoading)
    {
        <section class="admin-state">
            <h2>@T("Laai karakters...", "Loading characters...")</h2>
        </section>
    }
    else
    {
        <div class="characters-admin-layout">
            <aside class="characters-admin-list">
                <div class="characters-admin-list-header">
                    <span>@FilteredCharacters.Count @T("karakters", "characters")</span>
                </div>

                @if (FilteredCharacters.Count == 0)
                {
                    <p class="characters-admin-empty">@T("Geen karakters pas by jou soektog nie.", "No characters match your search.")</p>
                }
                else if (ViewMode == CharacterDisplayMode.Grid)
                {
                    <div class="characters-admin-grid">
                        @foreach (var character in FilteredCharacters)
                        {
                            var isSelected = Editor?.CharacterId == character.CharacterId;
                            <button type="button"
                                    class="characters-admin-grid-item @(isSelected ? "is-selected" : null)"
                                    @onclick="() => SelectCharacter(character)">
                                <span class="characters-admin-grid-thumb-wrap">
                                    <img class="characters-admin-grid-thumb"
                                         src="@ResolveCharacterAdminThumbnailPath(character)"
                                         alt=""
                                         width="192"
                                         height="192"
                                         loading="lazy"
                                         decoding="async"
                                         fetchpriority="low"
                                         onerror="this.onerror=null;this.src='/branding/schink-logo-green.png';" />
                                    <span class="characters-admin-grid-badge">@BuildStatusLabel(character.Status)</span>
                                </span>

                                <span class="characters-admin-grid-copy">
                                    <span class="characters-admin-grid-title">@character.DisplayName</span>
                                    <span class="characters-admin-grid-meta">@BuildCharacterCategoryLabel(character.CharacterCategory)</span>
                                </span>
                            </button>
                        }
                    </div>
                }
                else
                {
                    @foreach (var character in FilteredCharacters)
                    {
                        var isSelected = Editor?.CharacterId == character.CharacterId;
                        <button type="button"
                                class="characters-admin-list-item @(isSelected ? "is-selected" : null)"
                                @onclick="() => SelectCharacter(character)">
                            <span class="characters-admin-list-copy">
                                <span class="characters-admin-list-title">@character.DisplayName</span>
                                <span class="characters-admin-list-meta">@BuildCharacterCategoryLabel(character.CharacterCategory)</span>
                                <span class="characters-admin-list-status">@BuildStatusLabel(character.Status)</span>
                            </span>
                            <img class="characters-admin-list-preview"
                                 src="@ResolveCharacterAdminThumbnailPath(character)"
                                 alt=""
                                 width="56"
                                 height="56"
                                 loading="lazy"
                                 decoding="async"
                                 fetchpriority="low"
                                 onerror="this.onerror=null;this.src='/branding/schink-logo-green.png';" />
                        </button>
                    }
                }
            </aside>
        </div>
    }

    @if (Editor is not null)
    {
        <MudDialog Visible="IsCharacterDialogOpen"
                   VisibleChanged="OnCharacterDialogVisibleChanged"
                   Class="characters-admin-dialog"
                   ContentClass="characters-admin-dialog-content"
                   Gutters="false"
                   Options="CharacterDialogOptions">
            <DialogContent>
                <div class="characters-admin-dialog-surface">
                    <section class="characters-admin-editor" @key="Editor.CharacterId ?? Guid.Empty">
                        <div class="characters-admin-editor-head">
                            <div>
                                <h3>@(IsNewCharacter ? T("Nuwe karakter", "New character") : Editor.DisplayName)</h3>
                                <p>@Editor.SlugPreview</p>
                            </div>
                            <div class="characters-admin-editor-actions">
                                <button type="button"
                                        class="characters-admin-btn characters-admin-save-btn"
                                        @onclick="SaveCharacterAsync"
                                        disabled="@IsSaving"
                                        aria-label='@(IsSaving ? T("Stoor...", "Saving...") : T("Stoor karakter", "Save character"))'
                                        title='@(IsSaving ? T("Stoor...", "Saving...") : T("Stoor karakter", "Save character"))'>
                                    <i class="fa-solid @(IsSaving ? "fa-spinner fa-spin" : "fa-floppy-disk")" aria-hidden="true"></i>
                                    <span class="sr-only">@(IsSaving ? T("Stoor...", "Saving...") : T("Stoor karakter", "Save character"))</span>
                                </button>

                                <button type="button"
                                        class="characters-admin-btn characters-admin-btn-secondary characters-admin-close-btn"
                                        @onclick="CloseCharacterDialogAsync"
                                        aria-label='@T("Sluit", "Close")'
                                        title='@T("Sluit", "Close")'>
                                    <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                                    <span class="sr-only">@T("Sluit", "Close")</span>
                                </button>
                            </div>
                        </div>

                        <div class="characters-admin-form-grid">
                            <section class="characters-admin-card">
                                <h4>@T("Basies", "Basics")</h4>

                            <label class="characters-admin-field">
                                <span>@T("Naam", "Name")</span>
                                <input type="text" @bind="Editor.DisplayName" />
                            </label>

                            <label class="characters-admin-field">
                                <span>@T("Slug", "Slug")</span>
                                <input type="text" @bind="Editor.Slug" />
                            </label>

                            <label class="characters-admin-field">
                                <span>@T("Kort beskrywing", "Short description")</span>
                                <textarea rows="3" @bind="Editor.Tagline"></textarea>
                            </label>

                            <div class="characters-admin-field-row">
                                <label class="characters-admin-field">
                                    <span>@T("Kategorie", "Category")</span>
                                    <select @bind="Editor.CharacterCategory">
                                        <option value="hoofkarakter">@T("Hoofkarakter", "Main character")</option>
                                        <option value="ander">@T("Ander", "Other")</option>
                                        <option value="bonus">@T("Bonus", "Bonus")</option>
                                        <option value="bonus-2">@T("Bonus 2", "Bonus 2")</option>
                                    </select>
                                </label>

                                <label class="characters-admin-field">
                                    <span>@T("Status", "Status")</span>
                                    <select @bind="Editor.Status">
                                        <option value="draft">@T("Konsep", "Draft")</option>
                                        <option value="published">@T("Gepubliseer", "Published")</option>
                                        <option value="archived">@T("Geargiveer", "Archived")</option>
                                    </select>
                                </label>

                                <label class="characters-admin-field">
                                    <span>@T("Sorteer", "Sort order")</span>
                                    <input type="number" @bind="Editor.SortOrder" />
                                </label>

                                <label class="characters-admin-field">
                                    <span>@T("Ontsluit na (sekondes)", "Unlock after (seconds)")</span>
                                    <input type="number" min="1" max="3600" @bind="Editor.UnlockThresholdSeconds" />
                                </label>
                            </div>
                            </section>

                            <section class="characters-admin-card">
                                <h4>@T("Profiel", "Profile")</h4>

                            <div class="characters-admin-field-row">
                                <label class="characters-admin-field">
                                    <span>@T("Tipe", "Type")</span>
                                    <input type="text" @bind="Editor.Species" />
                                </label>

                                <label class="characters-admin-field">
                                    <span>@T("Blyplek", "Habitat")</span>
                                    <input type="text" @bind="Editor.Habitat" />
                                </label>
                            </div>

                            <label class="characters-admin-field">
                                <span>@T("Sê-ding", "Catchphrase")</span>
                                <textarea rows="2" @bind="Editor.Catchphrase"></textarea>
                            </label>

                            <label class="characters-admin-field">
                                <span>@T("Gunsteling-ding", "Favorite thing")</span>
                                <textarea rows="2" @bind="Editor.FavoriteThing"></textarea>
                            </label>

                            <label class="characters-admin-field">
                                <span>@T("Kenmerk", "Trait")</span>
                                <textarea rows="2" @bind="Editor.CharacterTrait"></textarea>
                            </label>

                            <div class="characters-admin-field-row">
                                <label class="characters-admin-field">
                                    <span>@T("Goue Les", "Golden lesson")</span>
                                    <input type="text" @bind="Editor.GoldenLesson" />
                                </label>

                                <label class="characters-admin-field">
                                    <span>@T("Kernwaarde", "Core value")</span>
                                    <input type="text" @bind="Editor.CoreValue" />
                                </label>
                            </div>

                            <label class="characters-admin-field">
                                <span>@T("Eerste verskyning", "First appearance")</span>
                                <input type="text" @bind="Editor.FirstAppearance" />
                            </label>

                            <label class="characters-admin-field">
                                <span>@T("Soek karakters vir maats", "Search characters for friends")</span>
                                <input type="search"
                                       @bind="FriendSearch"
                                       @bind:event="oninput"
                                       placeholder="@T("Soek naam of slug", "Search name or slug")" />
                            </label>

                            <div class="characters-admin-story-picker">
                                @foreach (var friend in FilteredFriendOptions)
                                {
                                    var isSelected = Editor.FriendSlugs.Contains(friend.Slug);
                                    <label class="characters-admin-story-option @(isSelected ? "is-selected" : null)">
                                        <input type="checkbox"
                                               checked="@isSelected"
                                               @onchange="args => ToggleFriend(friend.Slug, args)" />
                                        <span>@friend.DisplayName</span>
                                    </label>
                                }
                            </div>

                            <label class="characters-admin-field">
                                <span>@T("Ander maats (opsioneel)", "Other friends (optional)")</span>
                                <textarea rows="2" @bind="Editor.ManualFriends"></textarea>
                            </label>

                            <label class="characters-admin-field">
                                <span>@T("Vragie", "Reflection question")</span>
                                <textarea rows="3" @bind="Editor.ReflectionQuestion"></textarea>
                            </label>

                            <label class="characters-admin-field">
                                <span>@T("Uitdaging vir jou", "Challenge")</span>
                                <textarea rows="3" @bind="Editor.ChallengeText"></textarea>
                            </label>
                            </section>

                            <section class="characters-admin-card">
                                <h4>@T("Ontsluit stories", "Unlock stories")</h4>

                            <label class="characters-admin-field">
                                <span>@T("Hoofstory vir ontsluit", "Primary unlock story")</span>
                                <select @bind="Editor.UnlockStorySlug">
                                    <option value="">@T("Kies 'n storie", "Choose a story")</option>
                                    @foreach (var story in StoryOptions)
                                    {
                                        <option value="@story.Slug">@story.Title</option>
                                    }
                                </select>
                            </label>

                            <label class="characters-admin-field">
                                <span>@T("Soek stories vir hierdie karakter", "Search stories for this character")</span>
                                <input type="search"
                                       @bind="RelatedStorySearch"
                                       @bind:event="oninput"
                                       placeholder="@T("Soek titel of slug", "Search title or slug")" />
                            </label>

                            <div class="characters-admin-story-picker">
                                @foreach (var story in FilteredStoryOptions)
                                {
                                    var isSelected = Editor.RelatedStorySlugs.Contains(story.Slug);
                                    <label class="characters-admin-story-option @(isSelected ? "is-selected" : null)">
                                        <input type="checkbox"
                                               checked="@isSelected"
                                               @onchange="args => ToggleRelatedStory(story.Slug, args)" />
                                        <span>@story.Title</span>
                                    </label>
                                }
                            </div>

                            <div class="characters-admin-rule-section">
                                <div class="characters-admin-rule-header">
                                    <h5>@T("Ontsluit reëls", "Unlock rules")</h5>
                                    <button type="button"
                                            class="characters-admin-btn characters-admin-btn-secondary"
                                            @onclick="AddUnlockRule">
                                        @T("Voeg reël by", "Add rule")
                                    </button>
                                </div>

                                <p class="characters-admin-rule-help">
                                    @T("As geen reëls hieronder gestel is nie, gebruik die karakter steeds die hoofstorie en sekondes hierbo.", "If no rules are configured below, the character still uses the primary story and seconds above.")
                                </p>

                                @if (Editor.UnlockRules.Count == 0)
                                {
                                    <p class="characters-admin-empty">@T("Nog geen ekstra ontsluit reëls nie.", "No extra unlock rules yet.")</p>
                                }
                                else
                                {
                                    <div class="characters-admin-rule-list">
                                        @foreach (var rule in Editor.UnlockRules)
                                        {
                                            <article class="characters-admin-rule-item">
                                                <div class="characters-admin-field-row">
                                                    <label class="characters-admin-field">
                                                        <span>@T("Reëltipe", "Rule type")</span>
                                                        <select @bind="rule.RuleType">
                                                            <option value="@CharacterUnlockEvaluator.RuleTypeStoryListenSeconds">@T("Luistertyd op storie", "Story listen time")</option>
                                                            <option value="@CharacterUnlockEvaluator.RuleTypeStoryRepeatCount">@T("Herhalings van storie", "Story repeat count")</option>
                                                            <option value="@CharacterUnlockEvaluator.RuleTypeStoryCount">@T("Hoeveel stories geluister", "Number of stories listened")</option>
                                                            <option value="@CharacterUnlockEvaluator.RuleTypeUnlockedCharacterCount">@T("Hoeveel karakters oop", "Number of unlocked characters")</option>
                                                            <option value="@CharacterUnlockEvaluator.RuleTypeProfileListenCount">@T("Hoeveel profiel-luisters", "Number of profile listens")</option>
                                                        </select>
                                                    </label>

                                                    @if (UnlockRuleUsesTargets(rule.RuleType))
                                                    {
                                                        <label class="characters-admin-field">
                                                            <span>@T("Teiken modus", "Target mode")</span>
                                                            <select @bind="rule.TargetMatchMode">
                                                                <option value="@CharacterUnlockEvaluator.MatchModeAny">@T("Enige een", "Any one")</option>
                                                                <option value="@CharacterUnlockEvaluator.MatchModeAll">@T("Almal", "All")</option>
                                                            </select>
                                                        </label>
                                                    }

                                                    @if (UnlockRuleUsesCount(rule.RuleType))
                                                    {
                                                        <label class="characters-admin-field">
                                                            <span>@T("Minimum telling", "Minimum count")</span>
                                                            <input type="number" min="1" @bind="rule.MinimumCount" />
                                                        </label>
                                                    }

                                                    @if (UnlockRuleUsesSeconds(rule.RuleType))
                                                    {
                                                        <label class="characters-admin-field">
                                                            <span>@T("Minimum sekondes", "Minimum seconds")</span>
                                                            <input type="number" min="1" @bind="rule.MinimumSeconds" />
                                                        </label>
                                                    }
                                                </div>

                                                @if (UnlockRuleUsesTargets(rule.RuleType))
                                                {
                                                    <label class="characters-admin-field">
                                                        <span>@BuildUnlockRuleTargetsLabel(rule.RuleType)</span>
                                                        <textarea rows="2"
                                                                  @bind="rule.TargetSlugsText"
                                                                  placeholder="@BuildUnlockRuleTargetsPlaceholder(rule.RuleType)"></textarea>
                                                    </label>
                                                }

                                                <p class="characters-admin-rule-help">@BuildUnlockRuleHelpText(rule.RuleType)</p>

                                                <button type="button"
                                                        class="characters-admin-btn characters-admin-btn-secondary"
                                                        @onclick="() => RemoveUnlockRule(rule)">
                                                    @T("Verwyder reël", "Remove rule")
                                                </button>
                                            </article>
                                        }
                                    </div>
                                }
                            </div>
                            </section>

                            <section class="characters-admin-card">
                                <h4>@T("Karakterklanke", "Character audio")</h4>

                            <label class="characters-admin-file-picker">
                                <span>@T("Laai karakterklanke op", "Upload character audio")</span>
                                <InputFile OnChange="OnAudioFilesSelectedAsync" multiple accept=".mp3,.mpeg,.m4a,.wav,.ogg,audio/*" />
                            </label>

                            @if (Editor.AudioClips.Count == 0)
                            {
                                <p class="characters-admin-empty">@T("Nog geen karakterklanke opgelaai nie.", "No character audio uploaded yet.")</p>
                            }
                            else
                            {
                                <div class="characters-admin-audio-list">
                                    @foreach (var clip in Editor.AudioClips.OrderBy(item => item.SortOrder).ThenBy(item => item.Title, StringComparer.OrdinalIgnoreCase))
                                    {
                                        <article class="characters-admin-audio-item">
                                            <div class="characters-admin-field-row characters-admin-field-row-audio">
                                                <label class="characters-admin-field">
                                                    <span>@T("Titel", "Title")</span>
                                                    <input type="text" @bind="clip.Title" />
                                                </label>

                                                <label class="characters-admin-field">
                                                    <span>@T("Sorteer", "Sort order")</span>
                                                    <input type="number" @bind="clip.SortOrder" />
                                                </label>
                                            </div>

                                            <label class="characters-admin-field">
                                                <span>@T("Stream slug", "Stream slug")</span>
                                                <input type="text" value="@clip.StreamSlugPreview" readonly />
                                            </label>

                                            <p class="characters-admin-audio-meta">
                                                @(clip.IsPendingUpload
                                                    ? T($"Wag om op te laai: {clip.FileName}", $"Waiting to upload: {clip.FileName}")
                                                    : T($"Gestoorde pad: {clip.AudioObjectKey}", $"Stored path: {clip.AudioObjectKey}"))
                                            </p>

                                            <button type="button"
                                                    class="characters-admin-btn characters-admin-btn-secondary"
                                                    @onclick="() => RemoveAudioClip(clip)">
                                                @T("Verwyder klank", "Remove audio")
                                            </button>
                                        </article>
                                    }
                                </div>
                            }
                            </section>

                            <section class="characters-admin-card">
                                <h4>@T("Prente", "Images")</h4>

                            <div class="characters-admin-image-grid">
                                <div class="characters-admin-image-panel">
                                    <div class="characters-admin-image-preview">
                                        <img src="@Editor.MainImagePreviewPath"
                                             alt="@T("Hoofprent voorskou", "Main image preview")"
                                             onerror="this.onerror=null;this.src='/branding/schink-logo-green.png';" />
                                        @if (CanRemoveMainImage())
                                        {
                                            <button type="button"
                                                    class="characters-admin-image-remove"
                                                    @onclick="RemoveMainImageAsync"
                                                    aria-label='@T("Verwyder hoofprent", "Remove main image")'
                                                    title='@T("Verwyder hoofprent", "Remove main image")'>
                                                <i class="fa-solid fa-trash-can" aria-hidden="true"></i>
                                            </button>
                                        }
                                    </div>
                                    <label class="characters-admin-file-picker">
                                        <span>@T("Laai nuwe hoofprent op", "Upload new main image")</span>
                                        <InputFile OnChange="OnMainImageSelectedAsync" accept="image/png,image/jpeg,image/webp" />
                                    </label>
                                </div>

                                <div class="characters-admin-image-panel">
                                    <div class="characters-admin-image-preview">
                                        <img src="@Editor.MysteryImagePreviewPath"
                                             alt="@T("Mysterieprent voorskou", "Mystery image preview")"
                                             onerror="this.onerror=null;this.src='/branding/schink-logo-green.png';" />
                                        @if (CanRemoveMysteryImage())
                                        {
                                            <button type="button"
                                                    class="characters-admin-image-remove"
                                                    @onclick="RemoveMysteryImageAsync"
                                                    aria-label='@T("Verwyder mysterieprent", "Remove mystery image")'
                                                    title='@T("Verwyder mysterieprent", "Remove mystery image")'>
                                                <i class="fa-solid fa-trash-can" aria-hidden="true"></i>
                                            </button>
                                        }
                                    </div>
                                    <label class="characters-admin-file-picker">
                                        <span>@T("Laai nuwe mysterieprent op", "Upload new mystery image")</span>
                                        <InputFile OnChange="OnMysteryImageSelectedAsync" accept="image/png,image/jpeg,image/webp" />
                                    </label>
                                </div>
                            </div>
                            </section>
                        </div>
                    </section>
                </div>
            </DialogContent>
        </MudDialog>
    }
</section>

@code {
    private const long MaxImageUploadBytes = 10 * 1024 * 1024;
    private const long MaxAudioUploadBytes = 256 * 1024 * 1024;
    private const string ViewModeStorageKey = "shink.admin.characters.view-mode";

    [Parameter]
    public string CurrentLanguageCode { get; set; } = "af";

    private bool IsLoading { get; set; } = true;
    private bool IsSaving { get; set; }
    private bool IsCharacterDialogOpen { get; set; }
    private string CharacterSearch { get; set; } = string.Empty;
    private string RelatedStorySearch { get; set; } = string.Empty;
    private string FriendSearch { get; set; } = string.Empty;
    private CharacterDisplayMode ViewMode { get; set; } = CharacterDisplayMode.List;
    private string? SignedInEmail { get; set; }
    private string? ErrorMessage { get; set; }
    private string? StatusMessage { get; set; }
    private IReadOnlyList<AdminCharacterRecord> Characters { get; set; } = Array.Empty<AdminCharacterRecord>();
    private IReadOnlyList<AdminStoryRecord> StoryOptions { get; set; } = Array.Empty<AdminStoryRecord>();
    private CharacterEditorModel? Editor { get; set; }
    private string? CharacterEditorStateSignature { get; set; }
    private bool IsNewCharacter => Editor?.CharacterId is null;
    private static readonly DialogOptions CharacterDialogOptions = new()
    {
        MaxWidth = MaxWidth.Large,
        FullWidth = true,
        NoHeader = true,
        CloseButton = false,
        BackdropClick = false,
        Position = DialogPosition.TopCenter,
        BackgroundClass = "characters-admin-dialog-background"
    };
    private bool IsR2UploadConfigured =>
        !string.IsNullOrWhiteSpace(CloudflareR2OptionsAccessor.Value.AccountId) &&
        !string.IsNullOrWhiteSpace(CloudflareR2OptionsAccessor.Value.BucketName) &&
