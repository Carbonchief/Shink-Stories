    private static string ResolveCharacterListPreviewPath(AdminCharacterRecord character) =>
        !string.IsNullOrWhiteSpace(character.ImagePath)
            ? ResolveBrowserImagePath(character.ImagePath)
            : !string.IsNullOrWhiteSpace(character.MysteryImagePath)
                ? ResolveBrowserImagePath(character.MysteryImagePath)
                : "/branding/schink-logo-green.png";

    private static string ResolveCharacterAdminThumbnailPath(AdminCharacterRecord character)
    {
        var previewPath = ResolveCharacterListPreviewPath(character);
        const string characterAssetPrefix = "/branding/characters/";

        if (!previewPath.StartsWith(characterAssetPrefix, StringComparison.OrdinalIgnoreCase) ||
            previewPath.Contains("/thumbs/", StringComparison.OrdinalIgnoreCase))
        {
            return previewPath;
        }

        var fileNameStart = previewPath.LastIndexOf('/') + 1;
        var extensionStart = previewPath.LastIndexOf('.');
        if (fileNameStart <= 0 || extensionStart <= fileNameStart)
        {
            return previewPath;
        }

        var slug = previewPath[fileNameStart..extensionStart];
        return $"{characterAssetPrefix}thumbs/{slug}.webp";
    }

    private static string ResolveBrowserImagePath(string? imagePath) =>
        string.IsNullOrWhiteSpace(imagePath)
            ? "/branding/schink-logo-green.png"
            : StoryItem.RewriteImagePathForBrowser(imagePath);

    private static string? BuildFriendsValue(CharacterEditorModel editor, IReadOnlyList<AdminCharacterRecord> characters)
    {
        var selectedFriends = characters
            .Where(character => character.CharacterId != editor.CharacterId)
            .Where(character => editor.FriendSlugs.Contains(character.Slug))
            .OrderBy(character => character.DisplayName, StringComparer.OrdinalIgnoreCase)
            .Select(character => character.DisplayName.Trim());

        var manualFriends = SplitFriendTokens(editor.ManualFriends);
        var combined = selectedFriends
            .Concat(manualFriends)
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();

        return combined.Length == 0 ? null : string.Join(", ", combined);
    }

    private static (HashSet<string> FriendSlugs, string ManualFriends) ParseFriendSelection(
        string? friends,
        IReadOnlyList<AdminCharacterRecord> characters,
        Guid? currentCharacterId)
    {
        var selectedFriendSlugs = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var manualFriends = new List<string>();

        foreach (var friend in SplitFriendTokens(friends))
        {
            var match = characters.FirstOrDefault(character =>
                character.CharacterId != currentCharacterId &&
                (string.Equals(character.DisplayName, friend, StringComparison.OrdinalIgnoreCase) ||
                 string.Equals(character.Slug, friend, StringComparison.OrdinalIgnoreCase)));

            if (match is not null)
            {
                selectedFriendSlugs.Add(match.Slug);
                continue;
            }

            if (!manualFriends.Contains(friend, StringComparer.OrdinalIgnoreCase))
            {
                manualFriends.Add(friend);
            }
        }

        return (selectedFriendSlugs, string.Join(", ", manualFriends));
    }

    private static IReadOnlyList<string> SplitFriendTokens(string? value) =>
        string.IsNullOrWhiteSpace(value)
            ? Array.Empty<string>()
            : value
                .Split([',', ';', '\r', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Where(token => !string.IsNullOrWhiteSpace(token))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToArray();

    private static string[] NormalizeDirtyTextValues(IEnumerable<string>? values) =>
        values is null
            ? Array.Empty<string>()
            : values
                .Select(NormalizeDirtyText)
                .Where(value => !string.IsNullOrWhiteSpace(value))
                .Select(value => value!)
                .OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
                .ToArray();

    private static string? NormalizeDirtyText(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static string? BuildBrowserFileState(IBrowserFile? file, string? fallbackFileName = null)
    {
        if (file is null)
        {
            return NormalizeDirtyText(fallbackFileName);
        }

        return $"{NormalizeDirtyText(file.Name)}|{file.Size}|{NormalizeDirtyText(file.ContentType)}";
    }

    private static string BuildEffectiveSlug(string? slug, string? displayName)
    {
        var source = string.IsNullOrWhiteSpace(slug) ? displayName : slug;
        if (string.IsNullOrWhiteSpace(source))
        {
            return string.Empty;
        }

        var lowerInvariant = source.Trim().ToLowerInvariant();
        lowerInvariant = System.Text.RegularExpressions.Regex.Replace(lowerInvariant, "[^a-z0-9]+", "-");
        lowerInvariant = System.Text.RegularExpressions.Regex.Replace(lowerInvariant, "-{2,}", "-");
        return lowerInvariant.Trim('-');
    }

    private sealed class CharacterEditorModel
    {
        public Guid? CharacterId { get; set; }
        public string DisplayName { get; set; } = string.Empty;
        public string Slug { get; set; } = string.Empty;
        public string CharacterCategory { get; set; } = "ander";
        public string Status { get; set; } = "draft";
        public int SortOrder { get; set; }
        public int UnlockThresholdSeconds { get; set; } = 30;
        public string? Tagline { get; set; }
        public string? Species { get; set; }
        public string? Habitat { get; set; }
        public string? Catchphrase { get; set; }
        public string? FavoriteThing { get; set; }
        public string? CharacterTrait { get; set; }
        public string? GoldenLesson { get; set; }
        public string? CoreValue { get; set; }
        public string? FirstAppearance { get; set; }
        public HashSet<string> FriendSlugs { get; set; } = new(StringComparer.OrdinalIgnoreCase);
        public string ManualFriends { get; set; } = string.Empty;
        public string? ReflectionQuestion { get; set; }
        public string? ChallengeText { get; set; }
        public string? ImagePath { get; set; }
        public string? MysteryImagePath { get; set; }
        public string? ImageDriveFileId { get; set; }
        public string? MysteryImageDriveFileId { get; set; }
        public string? UnlockStorySlug { get; set; }
        public HashSet<string> RelatedStorySlugs { get; set; } = new(StringComparer.OrdinalIgnoreCase);
        public List<UnlockRuleEditorItem> UnlockRules { get; set; } = [];
        public List<CharacterAudioClipEditorItem> AudioClips { get; set; } = [];
        public IBrowserFile? MainImageFile { get; set; }
        public IBrowserFile? MysteryImageFile { get; set; }
        public string MainImagePreviewPath { get; set; } = "/branding/schink-logo-green.png";
        public string MysteryImagePreviewPath { get; set; } = "/branding/schink-logo-green.png";
        public string SlugPreview => string.IsNullOrWhiteSpace(Slug) ? BuildEffectiveSlug(null, DisplayName) : Slug;

        public static CharacterEditorModel CreateEmpty() =>
            new()
            {
                CharacterCategory = "ander",
                Status = "draft",
                UnlockThresholdSeconds = 30,
                SortOrder = 0
            };

        public static CharacterEditorModel FromRecord(AdminCharacterRecord record, IReadOnlyList<AdminCharacterRecord> characters)
        {
            var (friendSlugs, manualFriends) = ParseFriendSelection(record.Friends, characters, record.CharacterId);

            return new CharacterEditorModel
            {
                CharacterId = record.CharacterId,
                DisplayName = record.DisplayName,
                Slug = record.Slug,
                CharacterCategory = string.IsNullOrWhiteSpace(record.CharacterCategory) ? "ander" : record.CharacterCategory,
                Status = string.IsNullOrWhiteSpace(record.Status) ? "draft" : record.Status,
                SortOrder = record.SortOrder,
                UnlockThresholdSeconds = record.UnlockThresholdSeconds,
                Tagline = record.Tagline,
                Species = record.Species,
                Habitat = record.Habitat,
                Catchphrase = record.Catchphrase,
                FavoriteThing = record.FavoriteThing,
                CharacterTrait = record.CharacterTrait,
                GoldenLesson = record.GoldenLesson,
                CoreValue = record.CoreValue,
                FirstAppearance = record.FirstAppearance,
                FriendSlugs = friendSlugs,
                ManualFriends = manualFriends,
                ReflectionQuestion = record.ReflectionQuestion,
                ChallengeText = record.ChallengeText,
                ImagePath = record.ImagePath,
                MysteryImagePath = record.MysteryImagePath,
                ImageDriveFileId = record.ImageDriveFileId,
                MysteryImageDriveFileId = record.MysteryImageDriveFileId,
                UnlockStorySlug = record.UnlockStorySlug,
                RelatedStorySlugs = new HashSet<string>(record.RelatedStorySlugs, StringComparer.OrdinalIgnoreCase),
                UnlockRules = record.UnlockRules
                    .Select(UnlockRuleEditorItem.FromRecord)
                    .ToList(),
                AudioClips = record.AudioClips
                    .OrderBy(item => item.SortOrder)
                    .ThenBy(item => item.Title, StringComparer.OrdinalIgnoreCase)
                    .Select(item => new CharacterAudioClipEditorItem
                    {
                        StreamSlug = item.StreamSlug,
                        Title = item.Title,
                        AudioProvider = item.AudioProvider,
                        AudioObjectKey = item.AudioObjectKey,
                        AudioContentType = item.AudioContentType,
                        SortOrder = item.SortOrder,
                        FileName = Path.GetFileName(item.AudioObjectKey)
                    })
                    .ToList(),
                MainImagePreviewPath = ResolveBrowserImagePath(record.ImagePath),
                MysteryImagePreviewPath = ResolveBrowserImagePath(record.MysteryImagePath)
            };
        }
    }

    private sealed class UnlockRuleEditorItem
    {
        public string RuleType { get; set; } = CharacterUnlockEvaluator.RuleTypeStoryListenSeconds;
        public string TargetMatchMode { get; set; } = CharacterUnlockEvaluator.MatchModeAny;
        public string TargetSlugsText { get; set; } = string.Empty;
        public int MinimumCount { get; set; }
        public int MinimumSeconds { get; set; } = 30;

        public CharacterUnlockRuleItem ToRecord()
        {
            var targetSlugs = string.IsNullOrWhiteSpace(TargetSlugsText)
                ? Array.Empty<string>()
                : TargetSlugsText
                    .Split([',', ';', '\r', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .Where(value => !string.IsNullOrWhiteSpace(value))
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .ToArray();

            return new CharacterUnlockRuleItem(
                RuleType: RuleType,
                TargetSlugs: targetSlugs,
                TargetMatchMode: TargetMatchMode,
                MinimumCount: MinimumCount,
                MinimumSeconds: MinimumSeconds);
        }

        public static UnlockRuleEditorItem FromRecord(CharacterUnlockRuleItem rule) =>
            new()
            {
                RuleType = rule.RuleType,
                TargetMatchMode = rule.TargetMatchMode,
                TargetSlugsText = string.Join(", ", rule.TargetSlugs),
                MinimumCount = rule.MinimumCount,
                MinimumSeconds = rule.MinimumSeconds
            };
    }

