                SortOrder = record.SortOrder,
                UnlockThresholdSeconds = record.UnlockThresholdSeconds,
                Tagline = record.Tagline,
                Species = record.Species,
                Habitat = record.Habitat,
                Catchphrase = record.Catchphrase,
                FavoriteThing = record.FavoriteThing,
                CharacterTrait = record.CharacterTrait,
                GoldenLesson = record.GoldenLesson,
                CoreValue = record.CoreValue,
                FirstAppearance = record.FirstAppearance,
                Friends = record.Friends,
                ReflectionQuestion = record.ReflectionQuestion,
