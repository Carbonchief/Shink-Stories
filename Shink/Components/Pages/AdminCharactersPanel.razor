@using System.Globalization
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Options
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ICharacterAdminService CharacterAdminService
@inject IAdminManagementService AdminManagementService
@inject IStoryMediaStorageService StoryMediaStorageService
@inject IWebHostEnvironment WebHostEnvironment
@inject ILogger<AdminCharactersPanel> Logger
@inject IOptions<CloudflareR2Options> CloudflareR2OptionsAccessor

<section class="admin-section">
    <div class="admin-section-head">
        <h2>@T("Karakters", "Characters")</h2>
        <div class="admin-search">
            <input class="characters-admin-search"
                   type="search"
                   @bind="CharacterSearch"
                   @bind:event="oninput"
                   placeholder="@T("Soek naam of slug", "Search name or slug")" />
            <button type="button" class="characters-admin-btn" @onclick="BeginCreateCharacter">
                @T("Nuwe karakter", "New character")
            </button>
            <button type="button" class="characters-admin-btn characters-admin-btn-secondary" @onclick="ReloadAsync">
                @T("Herlaai", "Refresh")
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <p class="admin-feedback is-error">@ErrorMessage</p>
    }
    else if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <p class="admin-feedback is-success">@StatusMessage</p>
    }

    @if (IsLoading)
    {
        <section class="admin-state">
            <h2>@T("Laai karakters...", "Loading characters...")</h2>
        </section>
    }
    else
    {
        <div class="characters-admin-layout">
            <aside class="characters-admin-list">
                <div class="characters-admin-list-header">
                    <span>@FilteredCharacters.Count @T("karakters", "characters")</span>
                </div>

                @if (FilteredCharacters.Count == 0)
                {
                    <p class="characters-admin-empty">@T("Geen karakters pas by jou soektog nie.", "No characters match your search.")</p>
                }
                else
                {
                    @foreach (var character in FilteredCharacters)
                    {
                        var isSelected = Editor?.CharacterId == character.CharacterId;
                        <button type="button"
                                class="characters-admin-list-item @(isSelected ? "is-selected" : null)"
                                @onclick="() => SelectCharacter(character)">
                            <span class="characters-admin-list-copy">
                                <span class="characters-admin-list-title">@character.DisplayName</span>
                                <span class="characters-admin-list-meta">@character.Slug</span>
                                <span class="characters-admin-list-status">@BuildStatusLabel(character.Status)</span>
                            </span>
                            <img class="characters-admin-list-preview"
                                 src="@ResolveCharacterListPreviewPath(character)"
                                 alt=""
                                 loading="lazy"
                                 decoding="async"
                                 onerror="this.onerror=null;this.src='/branding/schink-logo-green.png';" />
                        </button>
                    }
                }
            </aside>

            <section class="characters-admin-editor">
                @if (Editor is null)
                {
                    <div class="characters-admin-empty-state">
                        <h3>@T("Kies 'n karakter", "Choose a character")</h3>
                        <p>@T("Maak links 'n bestaande karakter oop of skep 'n nuwe een.", "Open an existing character on the left or create a new one.")</p>
                    </div>
                }
                else
                {
                    <div class="characters-admin-editor-head">
                        <div>
                            <h3>@(IsNewCharacter ? T("Nuwe karakter", "New character") : Editor.DisplayName)</h3>
                            <p>@Editor.SlugPreview</p>
                        </div>
                        <button type="button"
                                class="characters-admin-btn"
                                @onclick="SaveCharacterAsync"
                                disabled="@IsSaving">
                            @(IsSaving ? T("Stoor...", "Saving...") : T("Stoor karakter", "Save character"))
                        </button>
                    </div>

                    <div class="characters-admin-form-grid">
                        <section class="characters-admin-card">
                            <h4>@T("Basies", "Basics")</h4>

                            <label class="characters-admin-field">
                                <span>@T("Naam", "Name")</span>
                                <input type="text" @bind="Editor.DisplayName" />
                            </label>

                            <label class="characters-admin-field">
                                <span>@T("Slug", "Slug")</span>
                                <input type="text" @bind="Editor.Slug" />
                            </label>

                            <label class="characters-admin-field">
                                <span>@T("Kort beskrywing", "Short description")</span>
                                <textarea rows="3" @bind="Editor.Tagline"></textarea>
                            </label>

                            <div class="characters-admin-field-row">
                                <label class="characters-admin-field">
                                    <span>@T("Status", "Status")</span>
                                    <select @bind="Editor.Status">
                                        <option value="draft">@T("Konsep", "Draft")</option>
                                        <option value="published">@T("Gepubliseer", "Published")</option>
                                        <option value="archived">@T("Geargiveer", "Archived")</option>
                                    </select>
                                </label>

                                <label class="characters-admin-field">
                                    <span>@T("Sorteer", "Sort order")</span>
                                    <input type="number" @bind="Editor.SortOrder" />
                                </label>

                                <label class="characters-admin-field">
                                    <span>@T("Ontsluit na (sekondes)", "Unlock after (seconds)")</span>
                                    <input type="number" min="1" max="3600" @bind="Editor.UnlockThresholdSeconds" />
                                </label>
                            </div>
                        </section>

                        <section class="characters-admin-card">
                            <h4>@T("Profiel", "Profile")</h4>

                            <div class="characters-admin-field-row">
                                <label class="characters-admin-field">
                                    <span>@T("Tipe", "Type")</span>
                                    <input type="text" @bind="Editor.Species" />
                                </label>

                                <label class="characters-admin-field">
                                    <span>@T("Blyplek", "Habitat")</span>
                                    <input type="text" @bind="Editor.Habitat" />
                                </label>
                            </div>

                            <label class="characters-admin-field">
                                <span>@T("Sê-ding", "Catchphrase")</span>
                                <textarea rows="2" @bind="Editor.Catchphrase"></textarea>
                            </label>

                            <label class="characters-admin-field">
                                <span>@T("Gunsteling-ding", "Favorite thing")</span>
                                <textarea rows="2" @bind="Editor.FavoriteThing"></textarea>
                            </label>

                            <label class="characters-admin-field">
                                <span>@T("Kenmerk", "Trait")</span>
                                <textarea rows="2" @bind="Editor.CharacterTrait"></textarea>
                            </label>

                            <div class="characters-admin-field-row">
                                <label class="characters-admin-field">
                                    <span>@T("Goue Les", "Golden lesson")</span>
                                    <input type="text" @bind="Editor.GoldenLesson" />
                                </label>

                                <label class="characters-admin-field">
                                    <span>@T("Kernwaarde", "Core value")</span>
                                    <input type="text" @bind="Editor.CoreValue" />
                                </label>
                            </div>

                            <label class="characters-admin-field">
                                <span>@T("Eerste verskyning", "First appearance")</span>
                                <input type="text" @bind="Editor.FirstAppearance" />
                            </label>

                            <label class="characters-admin-field">
                                <span>@T("Maats", "Friends")</span>
                                <textarea rows="2" @bind="Editor.Friends"></textarea>
                            </label>

                            <label class="characters-admin-field">
                                <span>@T("Vragie", "Reflection question")</span>
                                <textarea rows="3" @bind="Editor.ReflectionQuestion"></textarea>
                            </label>

                            <label class="characters-admin-field">
                                <span>@T("Uitdaging vir jou", "Challenge")</span>
                                <textarea rows="3" @bind="Editor.ChallengeText"></textarea>
                            </label>
                        </section>

                        <section class="characters-admin-card">
                            <h4>@T("Ontsluit stories", "Unlock stories")</h4>

                            <label class="characters-admin-field">
                                <span>@T("Hoofstory vir ontsluit", "Primary unlock story")</span>
                                <select @bind="Editor.UnlockStorySlug">
                                    <option value="">@T("Kies 'n storie", "Choose a story")</option>
                                    @foreach (var story in StoryOptions)
                                    {
                                        <option value="@story.Slug">@story.Title</option>
                                    }
                                </select>
                            </label>

                            <label class="characters-admin-field">
                                <span>@T("Soek stories vir hierdie karakter", "Search stories for this character")</span>
                                <input type="search"
                                       @bind="RelatedStorySearch"
                                       @bind:event="oninput"
                                       placeholder="@T("Soek titel of slug", "Search title or slug")" />
                            </label>

                            <div class="characters-admin-story-picker">
                                @foreach (var story in FilteredStoryOptions)
                                {
                                    var isSelected = Editor.RelatedStorySlugs.Contains(story.Slug);
                                    <label class="characters-admin-story-option @(isSelected ? "is-selected" : null)">
                                        <input type="checkbox"
                                               checked="@isSelected"
                                               @onchange="args => ToggleRelatedStory(story.Slug, args)" />
                                        <span>@story.Title</span>
                                        <small>@story.Slug</small>
                                    </label>
                                }
                            </div>
                        </section>

                        <section class="characters-admin-card">
                            <h4>@T("Karakterklanke", "Character audio")</h4>

                            <label class="characters-admin-file-picker">
                                <span>@T("Laai karakterklanke op", "Upload character audio")</span>
                                <InputFile OnChange="OnAudioFilesSelectedAsync" multiple accept=".mp3,.mpeg,.m4a,.wav,.ogg,audio/*" />
                            </label>

                            @if (Editor.AudioClips.Count == 0)
                            {
                                <p class="characters-admin-empty">@T("Nog geen karakterklanke opgelaai nie.", "No character audio uploaded yet.")</p>
                            }
                            else
                            {
                                <div class="characters-admin-audio-list">
                                    @foreach (var clip in Editor.AudioClips.OrderBy(item => item.SortOrder).ThenBy(item => item.Title, StringComparer.OrdinalIgnoreCase))
                                    {
                                        <article class="characters-admin-audio-item">
                                            <div class="characters-admin-field-row characters-admin-field-row-audio">
                                                <label class="characters-admin-field">
                                                    <span>@T("Titel", "Title")</span>
                                                    <input type="text" @bind="clip.Title" />
                                                </label>

                                                <label class="characters-admin-field">
                                                    <span>@T("Sorteer", "Sort order")</span>
                                                    <input type="number" @bind="clip.SortOrder" />
                                                </label>
                                            </div>

                                            <label class="characters-admin-field">
                                                <span>@T("Stream slug", "Stream slug")</span>
                                                <input type="text" value="@clip.StreamSlugPreview" readonly />
                                            </label>

                                            <p class="characters-admin-audio-meta">
                                                @(clip.IsPendingUpload
                                                    ? T($"Wag om op te laai: {clip.FileName}", $"Waiting to upload: {clip.FileName}")
                                                    : T($"Gestoorde pad: {clip.AudioObjectKey}", $"Stored path: {clip.AudioObjectKey}"))
                                            </p>

                                            <button type="button"
                                                    class="characters-admin-btn characters-admin-btn-secondary"
                                                    @onclick="() => RemoveAudioClip(clip)">
                                                @T("Verwyder klank", "Remove audio")
                                            </button>
                                        </article>
                                    }
                                </div>
                            }
                        </section>

                        <section class="characters-admin-card">
                            <h4>@T("Prente", "Images")</h4>

                            <div class="characters-admin-image-grid">
                                <div class="characters-admin-image-panel">
                                    <img src="@Editor.MainImagePreviewPath"
                                         alt="@T("Hoofprent voorskou", "Main image preview")"
                                         onerror="this.onerror=null;this.src='/branding/schink-logo-green.png';" />
                                    <label class="characters-admin-field">
                                        <span>@T("Hoofprent URL of pad", "Main image URL or path")</span>
                                        <input type="text" @bind="Editor.ImagePath" />
                                    </label>
                                    <label class="characters-admin-field">
                                        <span>@T("Hoofprent Google Drive ID", "Main image Google Drive ID")</span>
                                        <input type="text" @bind="Editor.ImageDriveFileId" />
                                    </label>
                                    <label class="characters-admin-file-picker">
                                        <span>@T("Laai nuwe hoofprent op", "Upload new main image")</span>
                                        <InputFile OnChange="OnMainImageSelectedAsync" accept="image/png,image/jpeg,image/webp" />
                                    </label>
                                </div>

                                <div class="characters-admin-image-panel">
                                    <img src="@Editor.MysteryImagePreviewPath"
                                         alt="@T("Mysterieprent voorskou", "Mystery image preview")"
                                         onerror="this.onerror=null;this.src='/branding/schink-logo-green.png';" />
                                    <label class="characters-admin-field">
                                        <span>@T("Mysterieprent URL of pad", "Mystery image URL or path")</span>
                                        <input type="text" @bind="Editor.MysteryImagePath" />
                                    </label>
                                    <label class="characters-admin-field">
                                        <span>@T("Mysterieprent Google Drive ID", "Mystery image Google Drive ID")</span>
                                        <input type="text" @bind="Editor.MysteryImageDriveFileId" />
                                    </label>
                                    <label class="characters-admin-file-picker">
                                        <span>@T("Laai nuwe mysterieprent op", "Upload new mystery image")</span>
                                        <InputFile OnChange="OnMysteryImageSelectedAsync" accept="image/png,image/jpeg,image/webp" />
                                    </label>
                                </div>
                            </div>
                        </section>
                    </div>
                }
            </section>
        </div>
    }
</section>

@code {
    private const long MaxImageUploadBytes = 10 * 1024 * 1024;
    private const long MaxAudioUploadBytes = 256 * 1024 * 1024;

    [Parameter]
    public string CurrentLanguageCode { get; set; } = "af";

    private bool IsLoading { get; set; } = true;
    private bool IsSaving { get; set; }
    private string CharacterSearch { get; set; } = string.Empty;
    private string RelatedStorySearch { get; set; } = string.Empty;
    private string? SignedInEmail { get; set; }
    private string? ErrorMessage { get; set; }
    private string? StatusMessage { get; set; }
    private IReadOnlyList<AdminCharacterRecord> Characters { get; set; } = Array.Empty<AdminCharacterRecord>();
    private IReadOnlyList<AdminStoryRecord> StoryOptions { get; set; } = Array.Empty<AdminStoryRecord>();
    private CharacterEditorModel? Editor { get; set; }
    private bool IsNewCharacter => Editor?.CharacterId is null;
    private bool IsR2UploadConfigured =>
        !string.IsNullOrWhiteSpace(CloudflareR2OptionsAccessor.Value.AccountId) &&
        !string.IsNullOrWhiteSpace(CloudflareR2OptionsAccessor.Value.BucketName) &&
        !string.IsNullOrWhiteSpace(CloudflareR2OptionsAccessor.Value.AccessKeyId) &&
        !string.IsNullOrWhiteSpace(CloudflareR2OptionsAccessor.Value.SecretAccessKey) &&
        !string.IsNullOrWhiteSpace(CloudflareR2OptionsAccessor.Value.PublicBaseUrl);

    private IReadOnlyList<AdminCharacterRecord> FilteredCharacters =>
        string.IsNullOrWhiteSpace(CharacterSearch)
            ? Characters
            : Characters
                .Where(character =>
                    character.DisplayName.Contains(CharacterSearch, StringComparison.OrdinalIgnoreCase) ||
                    character.Slug.Contains(CharacterSearch, StringComparison.OrdinalIgnoreCase))
                .ToArray();

    private IReadOnlyList<AdminStoryRecord> FilteredStoryOptions =>
        string.IsNullOrWhiteSpace(RelatedStorySearch)
            ? StoryOptions.Take(24).ToArray()
            : StoryOptions
                .Where(story =>
                    story.Title.Contains(RelatedStorySearch, StringComparison.OrdinalIgnoreCase) ||
                    story.Slug.Contains(RelatedStorySearch, StringComparison.OrdinalIgnoreCase))
                .Take(24)
                .ToArray();

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        IsLoading = true;
        ErrorMessage = null;
        StatusMessage = null;

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            SignedInEmail = authState.User.FindFirst(ClaimTypes.Email)?.Value
                            ?? authState.User.Identity?.Name;

            var charactersTask = CharacterAdminService.GetCharactersAsync(SignedInEmail);
            var storiesTask = AdminManagementService.GetStoriesAsync(SignedInEmail);
            await Task.WhenAll(charactersTask, storiesTask);

            Characters = charactersTask.Result;
            StoryOptions = storiesTask.Result
                .OrderByDescending(story => story.PublishedAt ?? DateTimeOffset.MinValue)
                .ThenBy(story => story.Title, StringComparer.OrdinalIgnoreCase)
                .ToArray();

            if (Editor?.CharacterId is Guid selectedCharacterId)
            {
                var refreshed = Characters.FirstOrDefault(character => character.CharacterId == selectedCharacterId);
                if (refreshed is not null)
                {
                    Editor = CharacterEditorModel.FromRecord(refreshed);
                }
            }
            else if (Editor is not null && !string.IsNullOrWhiteSpace(Editor.Slug))
            {
                var refreshed = Characters.FirstOrDefault(character =>
                    string.Equals(character.Slug, Editor.Slug, StringComparison.OrdinalIgnoreCase));
                if (refreshed is not null)
                {
                    Editor = CharacterEditorModel.FromRecord(refreshed);
                }
            }
        }
        catch (Exception exception)
        {
            Logger.LogWarning(exception, "Failed to reload admin characters.");
            ErrorMessage = T("Kon nie nou karakters laai nie.", "Could not load characters right now.");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void BeginCreateCharacter()
    {
        ErrorMessage = null;
        StatusMessage = null;
        RelatedStorySearch = string.Empty;
        Editor = CharacterEditorModel.CreateEmpty();
    }

    private void SelectCharacter(AdminCharacterRecord character)
    {
        ErrorMessage = null;
        StatusMessage = null;
        RelatedStorySearch = string.Empty;
        Editor = CharacterEditorModel.FromRecord(character);
    }

    private async Task OnMainImageSelectedAsync(InputFileChangeEventArgs args)
    {
        if (Editor is null)
        {
            return;
        }

        var file = args.File;
        if (file is null || file.Size <= 0 || file.Size > MaxImageUploadBytes)
        {
            ErrorMessage = T("Die hoofprent is te groot of leeg.", "The main image is too large or empty.");
            return;
        }

        Editor.MainImageFile = file;
        Editor.MainImagePreviewPath = await BuildPreviewDataUrlAsync(file);
    }

    private async Task OnMysteryImageSelectedAsync(InputFileChangeEventArgs args)
    {
        if (Editor is null)
        {
            return;
        }

        var file = args.File;
        if (file is null || file.Size <= 0 || file.Size > MaxImageUploadBytes)
        {
            ErrorMessage = T("Die mysterieprent is te groot of leeg.", "The mystery image is too large or empty.");
            return;
        }

        Editor.MysteryImageFile = file;
        Editor.MysteryImagePreviewPath = await BuildPreviewDataUrlAsync(file);
    }

    private Task OnAudioFilesSelectedAsync(InputFileChangeEventArgs args)
    {
        if (Editor is null)
        {
            return Task.CompletedTask;
        }

        foreach (var file in args.GetMultipleFiles())
        {
            if (file.Size <= 0 || file.Size > MaxAudioUploadBytes)
            {
                ErrorMessage = T(
                    $"Die klanklêer {file.Name} is te groot of leeg.",
                    $"The audio file {file.Name} is too large or empty.");
                continue;
            }

            var nextSortOrder = Editor.AudioClips.Count == 0
                ? 0
                : Editor.AudioClips.Max(item => item.SortOrder) + 10;

            Editor.AudioClips.Add(new CharacterAudioClipEditorItem
            {
                Title = BuildAudioTitleFromFileName(file.Name),
                SortOrder = nextSortOrder,
                File = file,
                FileName = file.Name,
                AudioContentType = NormalizeAudioContentType(file)
            });
        }

        return Task.CompletedTask;
    }

    private void ToggleRelatedStory(string slug, ChangeEventArgs args)
    {
        if (Editor is null)
        {
            return;
        }

        var isChecked = args.Value switch
        {
            bool boolValue => boolValue,
            string stringValue when bool.TryParse(stringValue, out var parsed) => parsed,
            _ => false
        };

        if (isChecked)
        {
            Editor.RelatedStorySlugs.Add(slug);
        }
        else
        {
            Editor.RelatedStorySlugs.RemoveWhere(value => string.Equals(value, slug, StringComparison.OrdinalIgnoreCase));
        }
    }

    private void RemoveAudioClip(CharacterAudioClipEditorItem clip)
    {
        if (Editor is null)
        {
            return;
        }

        Editor.AudioClips.Remove(clip);
    }

    private async Task SaveCharacterAsync()
    {
        if (Editor is null || IsSaving)
        {
            return;
        }

        IsSaving = true;
        ErrorMessage = null;
        StatusMessage = null;

        try
        {
            var effectiveSlug = BuildEffectiveSlug(Editor.Slug, Editor.DisplayName);
            if (string.IsNullOrWhiteSpace(effectiveSlug))
            {
                ErrorMessage = T("Voeg asseblief eers 'n naam by.", "Please add a name first.");
                return;
            }

            var imagePath = Editor.ImagePath;
            var mysteryImagePath = Editor.MysteryImagePath;
            var effectiveAudioClips = await SaveCharacterAudioClipsAsync(effectiveSlug, Editor.AudioClips);

            if (Editor.MainImageFile is not null)
            {
                imagePath = await SaveCharacterImageAsync(effectiveSlug, "main", Editor.MainImageFile, StoryImageKind.Cover);
            }

            if (Editor.MysteryImageFile is not null)
            {
                mysteryImagePath = await SaveCharacterImageAsync(effectiveSlug, "mystery", Editor.MysteryImageFile, StoryImageKind.Thumbnail);
            }

            var saveRequest = new AdminCharacterSaveRequest(
                CharacterId: Editor.CharacterId,
                Slug: effectiveSlug,
                DisplayName: Editor.DisplayName,
                Tagline: Editor.Tagline,
                Species: Editor.Species,
                Habitat: Editor.Habitat,
                Catchphrase: Editor.Catchphrase,
                FavoriteThing: Editor.FavoriteThing,
                CharacterTrait: Editor.CharacterTrait,
                GoldenLesson: Editor.GoldenLesson,
                CoreValue: Editor.CoreValue,
                FirstAppearance: Editor.FirstAppearance,
                Friends: Editor.Friends,
                ReflectionQuestion: Editor.ReflectionQuestion,
                ChallengeText: Editor.ChallengeText,
                ImagePath: imagePath,
                MysteryImagePath: mysteryImagePath,
                ImageDriveFileId: Editor.ImageDriveFileId,
                MysteryImageDriveFileId: Editor.MysteryImageDriveFileId,
                UnlockStorySlug: Editor.UnlockStorySlug,
                RelatedStorySlugs: Editor.RelatedStorySlugs.ToArray(),
                AudioClips: effectiveAudioClips,
                UnlockThresholdSeconds: Editor.UnlockThresholdSeconds,
                Status: Editor.Status,
                SortOrder: Editor.SortOrder);

            var result = await CharacterAdminService.SaveCharacterAsync(SignedInEmail, saveRequest);
            if (!result.IsSuccess)
            {
                ErrorMessage = result.ErrorMessage ?? T("Kon nie nou karakter stoor nie.", "Could not save the character right now.");
                return;
            }

            var successMessage = T("Karakter suksesvol gestoor.", "Character saved successfully.");
            await ReloadAsync();
            StatusMessage = successMessage;

            if (result.EntityId is Guid entityId)
            {
                var savedCharacter = Characters.FirstOrDefault(character => character.CharacterId == entityId);
                if (savedCharacter is not null)
                {
                    Editor = CharacterEditorModel.FromRecord(savedCharacter);
                }
            }
        }
        catch (Exception exception)
        {
            Logger.LogWarning(exception, "Failed to save character.");
            ErrorMessage = T("Kon nie nou karakter stoor nie.", "Could not save the character right now.");
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task<string> SaveCharacterImageAsync(
        string slug,
        string kind,
        IBrowserFile file,
        StoryImageKind imageKind)
    {
        if (IsR2UploadConfigured)
        {
            await using var stream = file.OpenReadStream(MaxImageUploadBytes);
            var uploaded = await StoryMediaStorageService.UploadImageAsync(
                $"characters-{slug}",
                imageKind,
                file.Name,
                file.ContentType,
                stream);
            return uploaded.PublicUrl;
        }

        var localUpload = await SaveCharacterImageToLocalAsync(slug, kind, file);
        return localUpload.PublicPath;
    }

    private async Task<(string PublicPath, string PhysicalPath)> SaveCharacterImageToLocalAsync(
        string slug,
        string kind,
        IBrowserFile file)
    {
        var extension = ResolveSafeImageExtension(file.Name);
        var safeSlug = BuildEffectiveSlug(slug, slug);
        var year = DateTime.UtcNow.ToString("yyyy", CultureInfo.InvariantCulture);
        var month = DateTime.UtcNow.ToString("MM", CultureInfo.InvariantCulture);
        var fileSuffix = Guid.NewGuid().ToString("N")[..10];
        var fileName = $"{safeSlug}-{kind}-{DateTime.UtcNow:yyyyMMddHHmmss}-{fileSuffix}{extension}";
        var relativeDirectory = Path.Combine("branding", "uploaded", "characters", year, month);
        var physicalDirectory = Path.Combine(WebHostEnvironment.WebRootPath, relativeDirectory);
        Directory.CreateDirectory(physicalDirectory);

        var physicalPath = Path.Combine(physicalDirectory, fileName);
        await using var sourceStream = file.OpenReadStream(MaxImageUploadBytes);
        await using var destinationStream = File.Create(physicalPath);
        await sourceStream.CopyToAsync(destinationStream);

        var publicPath = $"/branding/uploaded/characters/{year}/{month}/{fileName}";
        return (publicPath, physicalPath);
    }

    private async Task<IReadOnlyList<CharacterAudioClipItem>> SaveCharacterAudioClipsAsync(
        string characterSlug,
        IList<CharacterAudioClipEditorItem> clips)
    {
        var savedClips = new List<CharacterAudioClipItem>();
        var usedStreamSlugs = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var orderedClips = clips
            .OrderBy(item => item.SortOrder)
            .ThenBy(item => item.Title, StringComparer.OrdinalIgnoreCase)
            .ToArray();

        for (var index = 0; index < orderedClips.Length; index++)
        {
            var clip = orderedClips[index];
            var title = string.IsNullOrWhiteSpace(clip.Title)
                ? BuildAudioTitleFromFileName(clip.FileName)
                : clip.Title.Trim();
            var streamSlug = BuildUniqueAudioStreamSlug(
                characterSlug,
                clip.StreamSlug,
                title,
                index + 1,
                usedStreamSlugs);

            var audioProvider = clip.AudioProvider;
            var audioObjectKey = clip.AudioObjectKey;
            var audioContentType = clip.AudioContentType;

            if (clip.File is not null)
            {
                var upload = await SaveCharacterAudioAsync(characterSlug, streamSlug, clip.File);
                audioProvider = upload.AudioProvider;
                audioObjectKey = upload.AudioObjectKey;
                audioContentType = upload.AudioContentType;
            }

            if (string.IsNullOrWhiteSpace(audioProvider) || string.IsNullOrWhiteSpace(audioObjectKey))
            {
                continue;
            }

            clip.Title = title;
            clip.StreamSlug = streamSlug;
            clip.AudioProvider = audioProvider;
            clip.AudioObjectKey = audioObjectKey;
            clip.AudioContentType = audioContentType;
            clip.File = null;

            savedClips.Add(new CharacterAudioClipItem(
                StreamSlug: streamSlug,
                Title: title,
                AudioProvider: audioProvider,
                AudioObjectKey: audioObjectKey,
                AudioContentType: audioContentType,
                SortOrder: clip.SortOrder));
        }

        return savedClips;
    }

    private async Task<CharacterAudioUploadResult> SaveCharacterAudioAsync(
        string characterSlug,
        string streamSlug,
        IBrowserFile file)
    {
        var normalizedContentType = NormalizeAudioContentType(file);

        if (IsR2UploadConfigured)
        {
            await using var stream = file.OpenReadStream(MaxAudioUploadBytes);
            var uploaded = await StoryMediaStorageService.UploadAudioAsync(
                $"character-{characterSlug}-{streamSlug}",
                file.Name,
                normalizedContentType,
                stream);

            return new CharacterAudioUploadResult(
                AudioProvider: "r2",
                AudioObjectKey: uploaded.ObjectKey,
                AudioContentType: uploaded.ContentType);
        }

        var localUpload = await SaveCharacterAudioToLocalAsync(streamSlug, file, normalizedContentType);
        return new CharacterAudioUploadResult(
            AudioProvider: "local",
            AudioObjectKey: localUpload.ObjectKey,
            AudioContentType: localUpload.ContentType);
    }

    private async Task<(string ObjectKey, string ContentType)> SaveCharacterAudioToLocalAsync(
        string streamSlug,
        IBrowserFile file,
        string normalizedContentType)
    {
        var extension = ResolveSafeAudioExtension(file.Name, normalizedContentType);
        var year = DateTime.UtcNow.ToString("yyyy", CultureInfo.InvariantCulture);
        var month = DateTime.UtcNow.ToString("MM", CultureInfo.InvariantCulture);
        var fileSuffix = Guid.NewGuid().ToString("N")[..10];
        var fileName = $"{streamSlug}-{DateTime.UtcNow:yyyyMMddHHmmss}-{fileSuffix}{extension}";
        var relativeDirectory = Path.Combine("characters", year, month);
        var physicalDirectory = Path.Combine(WebHostEnvironment.ContentRootPath, "Stories", relativeDirectory);
        Directory.CreateDirectory(physicalDirectory);

        var physicalPath = Path.Combine(physicalDirectory, fileName);
        await using var sourceStream = file.OpenReadStream(MaxAudioUploadBytes);
        await using var destinationStream = File.Create(physicalPath);
        await sourceStream.CopyToAsync(destinationStream);

        var objectKey = $"characters/{year}/{month}/{fileName}";
        return (objectKey, normalizedContentType);
    }

    private static string ResolveSafeImageExtension(string fileName)
    {
        var extension = Path.GetExtension(fileName)?.Trim().ToLowerInvariant();
        return extension switch
        {
            ".jpg" or ".jpeg" => extension,
            ".png" => ".png",
            ".webp" => ".webp",
            _ => ".png"
        };
    }

    private static string ResolveSafeAudioExtension(string fileName, string contentType)
    {
        var extension = Path.GetExtension(fileName)?.Trim().ToLowerInvariant();
        if (extension is ".mp3" or ".mpeg" or ".m4a" or ".wav" or ".ogg")
        {
            return extension == ".mpeg" ? ".mp3" : extension;
        }

        return contentType switch
        {
            "audio/mpeg" => ".mp3",
            "audio/mp4" => ".m4a",
            "audio/wav" => ".wav",
            "audio/ogg" => ".ogg",
            _ => ".mp3"
        };
    }

    private static string NormalizeAudioContentType(IBrowserFile file) =>
        file.ContentType?.Trim().ToLowerInvariant() switch
        {
            "audio/mpeg" or "audio/mp3" => "audio/mpeg",
            "audio/mp4" or "audio/x-m4a" => "audio/mp4",
            "audio/wav" or "audio/x-wav" or "audio/wave" => "audio/wav",
            "audio/ogg" => "audio/ogg",
            _ => Path.GetExtension(file.Name).Trim().ToLowerInvariant() switch
            {
                ".mp3" or ".mpeg" => "audio/mpeg",
                ".m4a" => "audio/mp4",
                ".wav" => "audio/wav",
                ".ogg" => "audio/ogg",
                _ => file.ContentType ?? "audio/mpeg"
            }
        };

    private static string BuildAudioTitleFromFileName(string? fileName)
    {
        var title = Path.GetFileNameWithoutExtension(fileName ?? string.Empty)
            .Replace("-", " ", StringComparison.Ordinal)
            .Replace("_", " ", StringComparison.Ordinal)
            .Trim();

        return string.IsNullOrWhiteSpace(title) ? "Klankgreep" : title;
    }

    private static string BuildUniqueAudioStreamSlug(
        string characterSlug,
        string? currentStreamSlug,
        string title,
        int fallbackIndex,
        ISet<string> usedStreamSlugs)
    {
        var preferredSlug = BuildEffectiveSlug(currentStreamSlug, currentStreamSlug);
        if (!string.IsNullOrWhiteSpace(preferredSlug) && usedStreamSlugs.Add(preferredSlug))
        {
            return preferredSlug;
        }

        var baseSlug = BuildEffectiveSlug(null, title);
        if (string.IsNullOrWhiteSpace(baseSlug))
        {
            baseSlug = $"klank-{fallbackIndex}";
        }

        var candidate = BuildEffectiveSlug(null, $"karakter-{characterSlug}-{baseSlug}");
        var uniqueSlug = candidate;
        var suffix = 2;

        while (!usedStreamSlugs.Add(uniqueSlug))
        {
            uniqueSlug = $"{candidate}-{suffix++}";
        }

        return uniqueSlug;
    }

    private static async Task<string> BuildPreviewDataUrlAsync(IBrowserFile file)
    {
        await using var stream = file.OpenReadStream(MaxImageUploadBytes);
        await using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);
        var base64 = Convert.ToBase64String(memoryStream.ToArray());
        var contentType = string.IsNullOrWhiteSpace(file.ContentType) ? "image/png" : file.ContentType;
        return $"data:{contentType};base64,{base64}";
    }

    private string T(string afrikaans, string english) =>
        string.Equals(CurrentLanguageCode, "en", StringComparison.OrdinalIgnoreCase) ? english : afrikaans;

    private string BuildStatusLabel(string status) =>
        status switch
        {
            "published" => T("Gepubliseer", "Published"),
            "archived" => T("Geargiveer", "Archived"),
            _ => T("Konsep", "Draft")
        };

    private static string ResolveCharacterListPreviewPath(AdminCharacterRecord character) =>
        !string.IsNullOrWhiteSpace(character.ImagePath)
            ? character.ImagePath
            : !string.IsNullOrWhiteSpace(character.MysteryImagePath)
                ? character.MysteryImagePath
                : "/branding/schink-logo-green.png";

    private static string BuildEffectiveSlug(string? slug, string? displayName)
    {
        var source = string.IsNullOrWhiteSpace(slug) ? displayName : slug;
        if (string.IsNullOrWhiteSpace(source))
        {
            return string.Empty;
        }

        var lowerInvariant = source.Trim().ToLowerInvariant();
        lowerInvariant = System.Text.RegularExpressions.Regex.Replace(lowerInvariant, "[^a-z0-9]+", "-");
        lowerInvariant = System.Text.RegularExpressions.Regex.Replace(lowerInvariant, "-{2,}", "-");
        return lowerInvariant.Trim('-');
    }

