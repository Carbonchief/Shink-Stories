    private async Task<bool> ConfirmDiscardDialogChangesAsync(bool isDirty)
    {
        if (!isDirty)
        {
            return true;
        }

        try
        {
            return await JSRuntime.InvokeAsync<bool>(
                "confirm",
                T(
                    "Jy het ongestoorde veranderinge. Is jy seker jy wil sluit en dit verloor?",
                    "You have unsaved changes. Are you sure you want to close and lose them?"));
        }
        catch (Exception exception)
        {
            Logger.LogWarning(exception, "Character discard confirmation could not be displayed.");
            return false;
        }
    }

    private async Task CleanupReplacedImageAssetAsync(string? originalPath, string? updatedPath)
    {
        if (AdminManagedImageAssetHelper.AreEquivalent(originalPath, updatedPath))
        {
            return;
        }

        await DeleteManagedImageAssetAsync(originalPath);
    }

    private async Task DeleteManagedImageAssetAsync(string? imagePath)
    {
        var r2ObjectKey = AdminManagedImageAssetHelper.TryResolveR2ObjectKey(
            imagePath,
            CloudflareR2OptionsAccessor.Value.PublicBaseUrl);
        if (!string.IsNullOrWhiteSpace(r2ObjectKey))
        {
            await StoryMediaStorageService.DeleteObjectIfExistsAsync(r2ObjectKey);
            return;
        }

        var localFilePath = AdminManagedImageAssetHelper.TryResolveLocalUploadedFilePath(
            imagePath,
            WebHostEnvironment.WebRootPath);
        if (string.IsNullOrWhiteSpace(localFilePath))
        {
            return;
        }

        try
        {
            if (File.Exists(localFilePath))
            {
                File.Delete(localFilePath);
            }
        }
        catch (Exception exception) when (exception is IOException or UnauthorizedAccessException)
        {
            Logger.LogWarning(exception, "Failed to delete managed character image asset {ImagePath}.", imagePath);
        }
    }

    private bool IsCharacterEditorDirty() =>
        Editor is not null &&
        !string.IsNullOrEmpty(CharacterEditorStateSignature) &&
        !string.Equals(
            CharacterEditorStateSignature,
            BuildCharacterEditorStateSignature(Editor),
            StringComparison.Ordinal);

    private static string BuildCharacterEditorStateSignature(CharacterEditorModel editor)
    {
        return JsonSerializer.Serialize(new
        {
            editor.CharacterId,
            DisplayName = NormalizeDirtyText(editor.DisplayName),
            Slug = NormalizeDirtyText(editor.Slug),
            CharacterCategory = NormalizeDirtyText(editor.CharacterCategory),
            Status = NormalizeDirtyText(editor.Status),
            editor.SortOrder,
            editor.UnlockThresholdSeconds,
            Tagline = NormalizeDirtyText(editor.Tagline),
            Species = NormalizeDirtyText(editor.Species),
            Habitat = NormalizeDirtyText(editor.Habitat),
            Catchphrase = NormalizeDirtyText(editor.Catchphrase),
            FavoriteThing = NormalizeDirtyText(editor.FavoriteThing),
            CharacterTrait = NormalizeDirtyText(editor.CharacterTrait),
            GoldenLesson = NormalizeDirtyText(editor.GoldenLesson),
            CoreValue = NormalizeDirtyText(editor.CoreValue),
            FirstAppearance = NormalizeDirtyText(editor.FirstAppearance),
            FriendSlugs = NormalizeDirtyTextValues(editor.FriendSlugs),
            ManualFriends = NormalizeDirtyText(editor.ManualFriends),
            ReflectionQuestion = NormalizeDirtyText(editor.ReflectionQuestion),
            ChallengeText = NormalizeDirtyText(editor.ChallengeText),
            ImagePath = NormalizeDirtyText(editor.ImagePath),
            MysteryImagePath = NormalizeDirtyText(editor.MysteryImagePath),
            ImageDriveFileId = NormalizeDirtyText(editor.ImageDriveFileId),
            MysteryImageDriveFileId = NormalizeDirtyText(editor.MysteryImageDriveFileId),
            UnlockStorySlug = NormalizeDirtyText(editor.UnlockStorySlug),
            RelatedStorySlugs = NormalizeDirtyTextValues(editor.RelatedStorySlugs),
            UnlockRules = editor.UnlockRules.Select(rule => new
            {
                RuleType = NormalizeDirtyText(rule.RuleType),
                TargetMatchMode = NormalizeDirtyText(rule.TargetMatchMode),
                TargetSlugsText = NormalizeDirtyText(rule.TargetSlugsText),
                rule.MinimumCount,
                rule.MinimumSeconds
            }),
            AudioClips = editor.AudioClips.Select(clip => new
            {
                StreamSlug = NormalizeDirtyText(clip.StreamSlug),
                Title = NormalizeDirtyText(clip.Title),
                AudioProvider = NormalizeDirtyText(clip.AudioProvider),
                AudioObjectKey = NormalizeDirtyText(clip.AudioObjectKey),
                AudioContentType = NormalizeDirtyText(clip.AudioContentType),
                clip.SortOrder,
                FileName = NormalizeDirtyText(clip.FileName),
                PendingFile = BuildBrowserFileState(clip.File, clip.FileName)
            }),
            MainImage = BuildBrowserFileState(editor.MainImageFile),
            MysteryImage = BuildBrowserFileState(editor.MysteryImageFile)
