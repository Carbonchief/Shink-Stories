@page "/luister/speellys/{PlaylistSlug}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using System.Text.Json
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@inject IAudioAccessService AudioAccessService
@inject IStoryCatalogService StoryCatalogService
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISubscriptionLedgerService SubscriptionLedgerService
@inject IStoryFavoriteService StoryFavoriteService
@inject IHttpContextAccessor HttpContextAccessor
@implements IAsyncDisposable

<PageTitle>@PageTitleText</PageTitle>
<HeadContent>
    <link rel="canonical" href="@PlaylistCanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@ShareTitle" />
    <meta property="og:description" content="@ShareDescription" />
    <meta property="og:url" content="@CurrentShareUrl" />
    <meta property="og:image" content="@ShareImageUrl" />
    <meta property="og:image:type" content="@ShareImageMimeType" />
    <meta property="og:image:alt" content="@ShareImageAlt" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@ShareTitle" />
    <meta name="twitter:description" content="@ShareDescription" />
    <meta name="twitter:image" content="@ShareImageUrl" />
    <meta name="twitter:image:alt" content="@ShareImageAlt" />
    <JsonLdScript Json="@PlaylistJsonLd" />
</HeadContent>

@if (IsRedirectingToOpsies)
{
    <section class="playlist-empty-state">
        <h1>Hierdie speellys is nog gesluit.</h1>
        <p>Teken in of kies 'n plan om met hierdie speellys voort te gaan.</p>
        <a href="@StoryAccessPopupPrimaryHref">Gaan voort</a>
    </section>
}
else if (IsLoadingPlaylist && CurrentPlaylist is null)
{
    <section class="playlist-loading-state" aria-live="polite" aria-busy="true">
    </section>
}
else if (!AllowEmptyState && (CurrentPlaylist is null || CurrentStory is null || AccessibleStories.Count == 0))
{
    <section class="playlist-loading-state" aria-live="polite" aria-busy="true">
    </section>
}
else if (CurrentPlaylist is null)
{
    <section class="playlist-empty-state">
        <h1>Ons kon nie daardie speellys kry nie.</h1>
        <p>Gaan terug na Luister om 'n ander speellys te kies.</p>
        <a href="/luister">Terug na luister</a>
    </section>
}
else if (CurrentStory is null || AccessibleStories.Count == 0)
{
    <section class="playlist-empty-state">
        <h1>Hierdie speellys is nie nou beskikbaar nie.</h1>
        <p>Probeer asseblief later weer of kies 'n ander speellys.</p>
        <a href="/luister">Terug na luister</a>
    </section>
}
else
{
    <section class="playlist-page story-player-page @(IsManualFullscreenFocus ? "manual-fullscreen-focus" : null)">
        <header class="playlist-header">
            <h1>@CurrentPlaylist.Title</h1>
            @if (!string.IsNullOrWhiteSpace(CurrentPlaylist.Description))
            {
                <p class="playlist-description">@CurrentPlaylist.Description</p>
            }           
        </header>

        <div class="playlist-content-stack">
            <div class="playlist-player-card">
                <div class="story-player-content"
                     data-autoplay-enabled="@(AutoplayEnabled ? "true" : "false")"
                     oncontextmenu="return false;">
                    <div class="playlist-player-grid">
                        <div class="story-cover-wrap">
                            <img src="@CurrentStory.ThumbnailPath"
                                 srcset="@($"{CurrentStory.ThumbnailPath} 640w, {CurrentStory.ImagePath} 1024w")"
                                 sizes="(max-width: 920px) calc(100vw - 2rem), 900px"
                                 alt="Voorblad van @CurrentStory.Title"
                                 class="story-cover"
                                 role="button"
                                 tabindex="0"
                                 aria-label="Speel of pouse storie"
                                 aria-pressed="false"
                                 title="Speel of pouse storie"
                                 width="640"
                                 height="485"
                                 loading="eager"
                                 fetchpriority="high"
                                 decoding="async" />
                            <span class="story-cover-play" aria-hidden="true">
                                <i class="story-cover-play-icon fa-solid fa-play" aria-hidden="true"></i>
                            </span>

                            <button type="button"
                                    class="story-fullscreen-toggle"
                                    @onclick="ToggleFullscreenFocusAsync"
                                    aria-pressed="@IsManualFullscreenFocus"
                                    aria-label="@(IsManualFullscreenFocus ? "Verlaat volskerm speler" : "Volskerm speler")"
                                    title="@(IsManualFullscreenFocus ? "Verlaat volskerm speler" : "Volskerm speler")">
                                <i class="fa-solid fa-expand" aria-hidden="true"></i>
                                <span class="sr-only">@(IsManualFullscreenFocus ? "Verlaat volskerm speler" : "Volskerm speler")</span>
                            </button>

                            <button type="button"
                                    class="story-favorite-toggle @(IsStoryFavorite(CurrentStory.Slug) ? "is-favorite" : null)"
                                    @onclick="() => ToggleStoryFavoriteAsync(CurrentStory)"
                                    aria-label="@(IsStoryFavorite(CurrentStory.Slug) ? $"Verwyder {CurrentStory.Title} uit jou gunstelinge" : $"Voeg {CurrentStory.Title} by jou gunstelinge")"
                                    title="@(IsStoryFavorite(CurrentStory.Slug) ? "Verwyder uit gunstelinge" : "Voeg by gunstelinge")"
                                    aria-pressed="@IsStoryFavorite(CurrentStory.Slug)"
                                    disabled="@IsFavoriteBusy(CurrentStory.Slug)">
                                <i class="fa-@(IsStoryFavorite(CurrentStory.Slug) ? "solid" : "regular") fa-heart" aria-hidden="true"></i>
                            </button>
                        </div>

                        <div class="playlist-player-main">
                            <p class="playlist-current-label text-center">
                                <span class="playlist-current-title">@CurrentStory.Title</span>
                                <span class="playlist-current-separator" aria-hidden="true">•</span>
                                <span>Storie @CurrentTrackNumber van @AccessibleStories.Count</span>
                            </p>

                            <audio controls
                                   controlslist="nodownload noplaybackrate"
                                   disablepictureinpicture
                                   preload="auto"
                                   class="story-audio story-audio-native"
                                   playsinline
                                   webkit-playsinline="true"
                                   autoplay="@PendingTrackAutoplay"
                                   src="@AudioUrl"
                                   data-story-slug="@CurrentStory.Slug"
                                   data-story-title="@CurrentStory.Title"
                                   data-story-artist="Schink Stories"
                                   data-story-image="@StoryArtworkUrl"
                                   data-story-image-type="@StoryArtworkMimeType"
                                   data-share-url="@CurrentShareUrl"
                                   data-autoplay-requested="@(PendingTrackAutoplay ? "true" : "false")"
                                   oncontextmenu="return false;">
                                Jou blaaier ondersteun nie die oudioplayer nie.
                            </audio>

                            <div class="story-custom-player" role="group" aria-label="@($"{CurrentPlaylist.Title} speler")">
                                <div class="story-progress-wrap">
                                    <input class="story-progress-slider"
                                           type="range"
                                           min="0"
                                           max="100"
                                           step="0.1"
                                           value="0"
                                           aria-label="Storie vordering" />
                                    <div class="story-time-row">
                                        <span class="story-time-current">0:00</span>
                                        <span class="story-time-total">0:00</span>
                                    </div>
                                </div>

                                <div class="story-player-controls">
                                    <button type="button"
                                            class="story-control-btn story-story-prev"
                                            aria-label="@(PreviousStory is null ? "Geen vorige storie beskikbaar" : $"Vorige storie: {PreviousStory.Title}")"
                                            title="@(PreviousStory is null ? "Geen vorige storie beskikbaar" : "Vorige storie")"
                                            disabled="@(PreviousStory is null)">
                                        <i class="fa-solid fa-backward-step" aria-hidden="true"></i>
                                        <span class="sr-only">Vorige storie</span>
                                    </button>
                                    <button type="button" class="story-control-btn story-play-toggle" aria-label="Speel storie" title="Speel/Pouse">
                                        <i class="story-play-icon fa-solid fa-play" aria-hidden="true"></i>
                                        <span class="sr-only">Speel storie</span>
                                    </button>
                                    <button type="button"
                                            class="story-control-btn story-story-next"
                                            aria-label="@(NextStory is null ? "Geen volgende storie beskikbaar" : $"Volgende storie: {NextStory.Title}")"
                                            title="@(NextStory is null ? "Geen volgende storie beskikbaar" : "Volgende storie")"
                                            disabled="@(NextStory is null)">
                                        <i class="fa-solid fa-forward-step" aria-hidden="true"></i>
                                        <span class="sr-only">Volgende storie</span>
                                    </button>
                                </div>

                                <div class="story-secondary-controls">
                                    <button type="button" class="story-mini-btn story-mute-toggle" aria-label="Demp klank" title="Demp/ontdemp">
                                        <i class="story-mute-icon fa-solid fa-volume-high" aria-hidden="true"></i>
                                        <span class="sr-only">Demp klank</span>
                                    </button>
                                    <input class="story-volume-slider"
                                           type="range"
                                           min="0"
                                           max="1"
                                           step="0.01"
                                           value="1"
                                           aria-label="Volume" />
                                    <button type="button" class="story-mini-btn story-speed-toggle" aria-label="Verander spoed" title="Spoed">
                                        <span class="story-speed-label">1.0x</span>
                                    </button>
                                    <button type="button"
                                            class="story-mini-btn story-shuffle-toggle @(ShuffleEnabled ? "is-active" : null)"
                                            @onclick="ToggleShuffle"
                                            aria-pressed="@ShuffleEnabled"
                                            aria-label="@(ShuffleEnabled ? "Skommel speel aan" : "Skommel speel af")"
                                            title="@(ShuffleEnabled ? "Skakel skommel speel af" : "Skakel skommel speel aan")"
                                            disabled="@(AccessibleStories.Count < 2)">
                                        <i class="fa-solid fa-shuffle" aria-hidden="true"></i>
                                        <span class="sr-only">@(ShuffleEnabled ? "Skommel speel aan" : "Skommel speel af")</span>
                                    </button>
                                    <div class="story-autoplay-split-control">
                                        <button type="button"
                                                class="story-mini-btn story-autoplay-toggle"
                                                @onclick="ToggleAutoplay"
                                                aria-pressed="@AutoplayEnabled"
                                                aria-label="@(AutoplayEnabled ? "Autospeel aan" : "Autospeel af")"
                                                title="@(AutoplayEnabled ? "Skakel autospeel af" : "Skakel autospeel aan")">
                                            <i class="story-autoplay-icon fa-solid @(AutoplayEnabled ? "fa-toggle-on" : "fa-toggle-off")" aria-hidden="true"></i>
                                            <span class="sr-only">@(AutoplayEnabled ? "Autospeel aan" : "Autospeel af")</span>
                                        </button>
                                        <label class="story-autoplay-control @(HasAutoplayLimitSelection ? "has-short-label" : "is-empty")"
                                               data-short-label="@AutoplayCapShortLabel"
                                               for="playlist-autoplay-mode">
                                            <span class="sr-only">Kies 'n autospeel limiet</span>
                                            <select id="playlist-autoplay-mode"
                                                    class="story-autoplay-mode-select"
                                                    value="@AutoplayCapValue"
                                                    @onchange="HandleAutoplayModeChanged"
                                                    aria-label="Kies 'n autospeel limiet">
                                                <option value="none">Geen limiet</option>
                                                <option value="3">Stop na 3 stories</option>
                                                <option value="5">Stop na 5 stories</option>
                                            </select>
                                        </label>
                                    </div>
                                    <button type="button" class="story-mini-btn story-share-toggle" aria-label="Deel speellys" title="Deel speellys">
                                        <i class="fa-solid fa-share-nodes" aria-hidden="true"></i>
                                        <span class="sr-only">Deel speellys</span>
                                    </button>
                                </div>
                            </div>

                            <div class="story-nav-proxies" hidden aria-hidden="true">
                                @if (PreviousStory is not null)
                                {
                                    <a class="story-nav-prev"
                                       href="@BuildPlaylistHref(CurrentPlaylist.Slug, PreviousStory.Slug)"
                                       @onclick="SelectPreviousTrackAsync"
                                       @onclick:preventDefault="true"
                                       tabindex="-1"
                                       aria-label="@($"Vorige storie: {PreviousStory.Title}")"
                                       title="Vorige storie">
                                        <span class="sr-only">Vorige storie</span>
                                    </a>
                                }

                                @if (NextStory is not null)
                                {
                                    <a class="story-nav-next"
                                       href="@BuildPlaylistHref(CurrentPlaylist.Slug, NextStory.Slug)"
                                       @onclick="SelectNextTrackAsync"
                                       @onclick:preventDefault="true"
                                       tabindex="-1"
                                       aria-label="@($"Volgende storie: {NextStory.Title}")"
                                       title="Volgende storie">
                                        <span class="sr-only">Volgende storie</span>
                                    </a>
                                }
                            </div>

                            <details class="playlist-story-summary">
                                <summary class="playlist-story-summary-toggle">
                                    <span>Waaroor gaan hierdie storie?</span>
                                    <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                                </summary>
                                <p>@CurrentStory.Description</p>
                            </details>
                        </div>
                    </div>
                </div>
            </div>

            <section class="playlist-tracklist-card" aria-label="Volledige speellys">
                <ol class="playlist-tracklist">
                    @for (var index = 0; index < AccessibleStories.Count; index++)
                    {
                        var story = AccessibleStories[index];
                        var isActive = string.Equals(story.Slug, CurrentStory.Slug, StringComparison.OrdinalIgnoreCase);

                        <li class="playlist-track-item @(isActive ? "is-active" : null)">
                            <div class="playlist-track-button">
                                <button type="button"
                                        class="playlist-track-main"
                                        @onclick="() => SelectTrackAsync(story.Slug, true)"
                                        aria-pressed="@(isActive ? "true" : "false")"
                                        aria-current="@(isActive ? "true" : null)">
                                    <span class="playlist-track-index">@(index + 1)</span>
                                    <img class="playlist-track-image"
                                         src="@story.ThumbnailPath"
                                         srcset="@($"{story.ThumbnailPath} 640w, {story.ImagePath} 1024w")"
                                         sizes="64px"
                                         alt=""
                                         width="64"
                                         height="64"
                                         loading="eager"
                                         decoding="async" />
                                    <span class="playlist-track-copy">
                                        <span class="playlist-track-title">@story.Title</span>
                                        <span class="playlist-track-status">@(isActive ? "Speel nou" : "Speel in speellys")</span>
                                    </span>
                                </button>
                                <button type="button"
                                        class="playlist-track-favorite-toggle @(IsStoryFavorite(story.Slug) ? "is-favorite" : null)"
                                        @onclick="() => ToggleStoryFavoriteAsync(story)"
                                        aria-label="@(IsStoryFavorite(story.Slug) ? $"Verwyder {story.Title} uit jou gunstelinge" : $"Voeg {story.Title} by jou gunstelinge")"
                                        title="@(IsStoryFavorite(story.Slug) ? "Verwyder uit gunstelinge" : "Voeg by gunstelinge")"
                                        aria-pressed="@IsStoryFavorite(story.Slug)"
                                        disabled="@IsFavoriteBusy(story.Slug)">
                                    <i class="fa-@(IsStoryFavorite(story.Slug) ? "solid" : "regular") fa-heart" aria-hidden="true"></i>
                                </button>
                                <span class="playlist-track-action" aria-hidden="true">
                                    <i class="fa-solid @(isActive ? "fa-volume-high" : "fa-play")"></i>
                                </span>
                            </div>
                        </li>
                    }
                </ol>
            </section>
        </div>
    </section>
}

<StoryAccessPopup IsOpen="@ShowStoryAccessPopup"
                  PrimaryActionHref="@StoryAccessPopupPrimaryHref"
                  PlanActionHref="@StoryAccessPopupPlanHref"
                  OnClose="CloseStoryAccessPopupAsync" />

@code {
    [Parameter]
    public string? PlaylistSlug { get; set; }

    [SupplyParameterFromQuery(Name = "storie")]
    public string? StorySlug { get; set; }

    private StoryPlaylist? CurrentPlaylist { get; set; }
    private IReadOnlyList<StoryItem> AccessibleStories { get; set; } = Array.Empty<StoryItem>();
    private StoryItem? CurrentStory { get; set; }
    private StoryItem? PreviousStory { get; set; }
    private StoryItem? NextStory { get; set; }
    private string? AudioUrl { get; set; }
    private IJSObjectReference? _mediaSessionModule;
    private DotNetObjectReference<LuisterPlaylist>? _dotNetRef;
    private bool _mediaSessionModuleLoadFailed;
    private bool IsManualFullscreenFocus { get; set; }
    private bool IsRedirectingToOpsies { get; set; }
    private bool IsLoadingPlaylist { get; set; } = true;
    private bool AllowEmptyState { get; set; }
    private bool AutoplayEnabled { get; set; } = true;
    private bool ShuffleEnabled { get; set; }
    private bool PendingTrackAutoplay { get; set; }
    private int? AutoplayLimitStories { get; set; }
    private int AutoplayStoriesPlayedInRun { get; set; }
    private List<string> ShuffledPlaybackOrder { get; } = [];
    private HashSet<string> FavoriteStorySlugs { get; } = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> FavoriteStoryBusySlugs { get; } = new(StringComparer.OrdinalIgnoreCase);
    private string? SignedInEmail { get; set; }
    private bool ShowStoryAccessPopup { get; set; }
    private string PendingLockedStoryPath { get; set; } = "/luister";
    private CancellationTokenSource? _emptyStateDelayCts;

    private string PageTitleText =>
        CurrentPlaylist is null ? "Speellys nie gevind nie" : $"{CurrentPlaylist.Title} | Schink Stories";
    private bool IsSignedIn => !string.IsNullOrWhiteSpace(SignedInEmail);
    private string StoryAccessPopupPrimaryHref =>
        IsSignedIn
            ? BuildOpsiesHref(PendingLockedStoryPath)
            : $"/teken-in?returnUrl={Uri.EscapeDataString(PendingLockedStoryPath)}";
    private string StoryAccessPopupPlanHref => BuildOpsiesHref(PendingLockedStoryPath);

    private string StoryCountLabel =>
        AccessibleStories.Count == 1 ? "1 storie beskikbaar" : $"{AccessibleStories.Count} stories beskikbaar";

    private string AutoplayCapValue => AutoplayLimitStories?.ToString() ?? "none";
    private bool HasAutoplayLimitSelection => AutoplayLimitStories.HasValue;
    private string AutoplayCapShortLabel => AutoplayLimitStories?.ToString() ?? string.Empty;

    private int CurrentTrackNumber =>
        CurrentStory is null
            ? 0
            : GetPlaylistTrackNumber(CurrentStory.Slug);

    private string PlaylistCanonicalUrl =>
        NavigationManager.ToAbsoluteUri(GetPlaylistPath(CurrentPlaylist?.Slug ?? PlaylistSlug)).ToString();

    private string CurrentShareUrl =>
        NavigationManager.ToAbsoluteUri(BuildPlaylistHref(CurrentPlaylist?.Slug ?? PlaylistSlug, CurrentStory?.Slug)).ToString();

    private string? StoryArtworkUrl =>
        CurrentStory is null ? null : NavigationManager.ToAbsoluteUri(CurrentStory.ImagePath).ToString();

    private string StoryArtworkMimeType =>
        CurrentStory is null ? "image/jpeg" : GetImageMimeType(CurrentStory.ImageFileName);

    private string ShareTitle =>
        CurrentPlaylist is null ? "Schink Stories | Speellys" : $"{CurrentPlaylist.Title} | Schink Stories";

    private string ShareDescription =>
        !string.IsNullOrWhiteSpace(CurrentPlaylist?.Description)
            ? CurrentPlaylist.Description!
            : "Luister na Afrikaanse kinderstories op Schink Stories.";

    private string ShareImageUrl =>
        CurrentStory is null
            ? NavigationManager.ToAbsoluteUri("/branding/DIS_STORIETYD.png").ToString()
            : NavigationManager.ToAbsoluteUri(CurrentStory.ImagePath).ToString();

    private string ShareImageMimeType =>
        CurrentStory is null ? "image/png" : GetImageMimeType(CurrentStory.ImageFileName);

    private string ShareImageAlt =>
        CurrentStory is null
            ? "Schink Stories luister speellys"
            : $"Voorblad van {CurrentStory.Title}";

    private MarkupString PlaylistJsonLd => new(JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "CollectionPage",
        ["headline"] = ShareTitle,
        ["description"] = ShareDescription,
        ["url"] = PlaylistCanonicalUrl,
        ["inLanguage"] = "af-ZA",
        ["image"] = new[] { ShareImageUrl },
        ["isPartOf"] = new Dictionary<string, object?>
        {
            ["@type"] = "WebSite",
            ["name"] = "Schink Stories",
            ["url"] = NavigationManager.ToAbsoluteUri("/").ToString()
        },
        ["mainEntity"] = CurrentPlaylist is null
            ? null
            : new Dictionary<string, object?>
            {
                ["@type"] = "ItemList",
                ["name"] = CurrentPlaylist.Title,
                ["numberOfItems"] = AccessibleStories.Count,
                ["itemListElement"] = AccessibleStories.Select((story, index) => new Dictionary<string, object?>
                {
                    ["@type"] = "ListItem",
                    ["position"] = index + 1,
                    ["name"] = story.Title,
                    ["url"] = NavigationManager.ToAbsoluteUri($"/luister/{story.Slug}").ToString()
                }).ToArray()
            }
    }));

    protected override async Task OnParametersSetAsync()
    {
        IsLoadingPlaylist = true;
        CancelEmptyStateDelay();
        AllowEmptyState = false;
        ShowStoryAccessPopup = false;
        IsRedirectingToOpsies = false;
        IsManualFullscreenFocus = false;
        ResetPlaybackOrder();
        CurrentPlaylist = null;
        AccessibleStories = Array.Empty<StoryItem>();
        CurrentStory = null;
        AudioUrl = null;
        PreviousStory = null;
        NextStory = null;

        try
        {
            var isSocialPreviewRequest = SocialPreviewRequestDetector.IsSocialPreviewRequest(HttpContextAccessor.HttpContext);
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            SignedInEmail = authState.User.Identity?.IsAuthenticated == true
                ? authState.User.FindFirst(ClaimTypes.Email)?.Value ?? authState.User.Identity?.Name
                : null;

            if (authState.User.Identity?.IsAuthenticated != true)
            {
                ClearFavoriteState();
                IsRedirectingToOpsies = true;
                PendingTrackAutoplay = false;
                PendingLockedStoryPath = GetCurrentPathAndQuery();
                ShowStoryAccessPopup = !isSocialPreviewRequest;

                var previewPlaylists = await StoryCatalogService.GetLuisterPlaylistsAsync();
                CurrentPlaylist = previewPlaylists.FirstOrDefault(playlist =>
                    string.Equals(playlist.Slug, PlaylistSlug, StringComparison.OrdinalIgnoreCase));

                if (CurrentPlaylist is null)
                {
                    AccessibleStories = Array.Empty<StoryItem>();
                    CurrentStory = null;
                    AudioUrl = null;
                    PreviousStory = null;
                    NextStory = null;
                    return;
                }

                AccessibleStories = CurrentPlaylist.Stories;
                var requestedPreviewStory = AccessibleStories.FirstOrDefault(story =>
                    string.Equals(story.Slug, StorySlug, StringComparison.OrdinalIgnoreCase));
                CurrentStory = requestedPreviewStory ?? GetPreferredPlaylistStory(AccessibleStories);
                AudioUrl = null;
                ResolveAdjacentStories();
                return;
            }

            IsRedirectingToOpsies = false;
            PendingTrackAutoplay = false;
            var signedInEmail = authState.User.FindFirst(ClaimTypes.Email)?.Value
                               ?? authState.User.Identity?.Name;

            var playlists = await StoryCatalogService.GetLuisterPlaylistsAsync(signedInEmail);
            CurrentPlaylist = playlists.FirstOrDefault(playlist =>
                string.Equals(playlist.Slug, PlaylistSlug, StringComparison.OrdinalIgnoreCase));

            if (CurrentPlaylist is null)
            {
                AccessibleStories = Array.Empty<StoryItem>();
                CurrentStory = null;
                AudioUrl = null;
                PreviousStory = null;
                NextStory = null;
                ClearFavoriteState();
                return;
            }

            var accessProfile = await ResolveLuisterAccessProfileAsync(authState.User);
            AccessibleStories = CurrentPlaylist.Stories
                .Where(story => HasAccessToStory(story, accessProfile))
                .ToArray();

            if (AccessibleStories.Count == 0)
            {
                ClearFavoriteState();
                IsRedirectingToOpsies = true;
                PendingLockedStoryPath = GetCurrentPathAndQuery();
                ShowStoryAccessPopup = true;
                return;
            }

            var requestedStory = CurrentPlaylist.Stories.FirstOrDefault(story =>
                string.Equals(story.Slug, StorySlug, StringComparison.OrdinalIgnoreCase));

            if (requestedStory is not null &&
                !AccessibleStories.Any(story => string.Equals(story.Slug, requestedStory.Slug, StringComparison.OrdinalIgnoreCase)))
            {
                ClearFavoriteState();
                IsRedirectingToOpsies = true;
                PendingLockedStoryPath = GetCurrentPathAndQuery();
                ShowStoryAccessPopup = true;
                return;
            }

            CurrentStory = requestedStory is not null
                ? AccessibleStories.FirstOrDefault(story =>
                    string.Equals(story.Slug, requestedStory.Slug, StringComparison.OrdinalIgnoreCase))
                : GetPreferredPlaylistStory(AccessibleStories);

            if (CurrentStory is null)
            {
                CurrentStory = GetPreferredPlaylistStory(AccessibleStories);
            }

            if (CurrentStory is null)
            {
                return;
            }

            _ = LoadFavoriteStorySlugsInBackgroundAsync();
            AudioUrl = AudioAccessService.CreateSignedAudioUrl(CurrentStory.Slug);
            ResolveAdjacentStories();
            ShowStoryAccessPopup = false;
        }
        finally
        {
            IsLoadingPlaylist = false;
            await UpdateEmptyStateVisibilityAsync();
        }
    }

    private async Task UpdateEmptyStateVisibilityAsync()
    {
        CancelEmptyStateDelay();
        AllowEmptyState = false;

        if (IsRedirectingToOpsies || (CurrentPlaylist is not null && CurrentStory is not null && AccessibleStories.Count > 0))
        {
            return;
        }

        var delayCts = new CancellationTokenSource();
        _emptyStateDelayCts = delayCts;

        try
        {
            await Task.Delay(450, delayCts.Token);
            AllowEmptyState = true;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException)
        {
        }
    }

    private StoryItem? GetPreferredPlaylistStory(IReadOnlyList<StoryItem> stories)
    {
        if (stories.Count == 0)
        {
            return null;
        }

        var showcaseSlug = CurrentPlaylist?.ShowcaseStorySlug;
        if (!string.IsNullOrWhiteSpace(showcaseSlug))
        {
            var showcaseStory = stories.FirstOrDefault(story =>
                string.Equals(story.Slug, showcaseSlug, StringComparison.OrdinalIgnoreCase));
            if (showcaseStory is not null)
            {
                return showcaseStory;
            }
        }

        return stories[0];
    }

    private void CancelEmptyStateDelay()
    {
        _emptyStateDelayCts?.Cancel();
        _emptyStateDelayCts?.Dispose();
        _emptyStateDelayCts = null;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (CurrentStory is null || IsRedirectingToOpsies)
        {
            return;
        }

        var module = await TryGetStoryPlayerModuleAsync();
        if (module is null)
        {
            return;
        }

        _dotNetRef ??= DotNetObjectReference.Create(this);
        try
        {
            await module.InvokeVoidAsync("initializeStoryMediaSession", _dotNetRef);
            await module.InvokeVoidAsync("initializeStoryPlayerFullscreenExperience", _dotNetRef);

            if (!IsManualFullscreenFocus)
            {
                var shouldResumeFullscreen = await module.InvokeAsync<bool>("consumePendingStoryPlayerFullscreenIntent");
                if (shouldResumeFullscreen)
                {
                    IsManualFullscreenFocus = true;
                    await module.InvokeVoidAsync("setStoryPlayerFullscreenIntent", true);
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (JSException)
        {
            _mediaSessionModuleLoadFailed = true;
            PendingTrackAutoplay = false;
            return;
        }

        if (PendingTrackAutoplay)
        {
            PendingTrackAutoplay = false;
        }
    }

    private async Task SelectTrackAsync(string slug, bool shouldAutoplay)
        => await SelectTrackAsync(slug, shouldAutoplay, isAutoplayAdvance: false);

    private async Task SelectTrackAsync(string slug, bool shouldAutoplay, bool isAutoplayAdvance)
    {
        var nextStory = AccessibleStories.FirstOrDefault(story =>
            string.Equals(story.Slug, slug, StringComparison.OrdinalIgnoreCase));
        if (nextStory is null)
        {
            return;
        }

        if (CurrentStory is not null &&
            string.Equals(CurrentStory.Slug, nextStory.Slug, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        await PrepareForTrackChangeAsync();

        CurrentStory = nextStory;
        AudioUrl = AudioAccessService.CreateSignedAudioUrl(nextStory.Slug);
        PendingTrackAutoplay = shouldAutoplay;
        UpdateAutoplayProgressForTrackChange(isAutoplayAdvance);
        ResolveAdjacentStories();
        await InvokeAsync(StateHasChanged);
    }

    private Task SelectPreviousTrackAsync() =>
        PreviousStory is null
            ? Task.CompletedTask
            : SelectTrackAsync(PreviousStory.Slug, true);

    private Task SelectNextTrackAsync() =>
        NextStory is null
            ? Task.CompletedTask
            : SelectTrackAsync(NextStory.Slug, true);

    private void ToggleAutoplay()
    {
        AutoplayEnabled = !AutoplayEnabled;
        ResetAutoplayProgress();
    }

    private void ToggleShuffle()
    {
        if (AccessibleStories.Count < 2)
        {
            ShuffleEnabled = false;
            ShuffledPlaybackOrder.Clear();
            ResolveAdjacentStories();
            return;
        }

        ShuffleEnabled = !ShuffleEnabled;
        if (ShuffleEnabled)
        {
            CreateShuffledPlaybackOrder(CurrentStory?.Slug);
        }
        else
        {
            ShuffledPlaybackOrder.Clear();
        }

        ResolveAdjacentStories();
    }

    private void HandleAutoplayModeChanged(ChangeEventArgs args)
    {
        var selectedValue = args.Value?.ToString();
        switch (selectedValue)
        {
            case "3":
                AutoplayLimitStories = 3;
                break;
            case "5":
                AutoplayLimitStories = 5;
                break;
            default:
                AutoplayLimitStories = null;
                break;
        }

        ResetAutoplayProgress();
    }

    private bool IsStoryFavorite(string slug) => FavoriteStorySlugs.Contains(slug);

    private bool IsFavoriteBusy(string slug) => FavoriteStoryBusySlugs.Contains(slug);

    private async Task ToggleStoryFavoriteAsync(StoryItem story)
    {
        if (string.IsNullOrWhiteSpace(story.Slug))
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(SignedInEmail))
        {
            PendingLockedStoryPath = GetCurrentPathAndQuery();
            ShowStoryAccessPopup = true;
            return;
        }

        var normalizedSlug = story.Slug.Trim();
        if (!FavoriteStoryBusySlugs.Add(normalizedSlug))
        {
            return;
        }

        var isCurrentlyFavorite = FavoriteStorySlugs.Contains(normalizedSlug);
        try
        {
            var updated = await StoryFavoriteService.SetStoryFavoriteAsync(
                SignedInEmail,
                new StoryFavoriteMutationRequest(
                    StorySlug: normalizedSlug,
                    StoryPath: $"/luister/{Uri.EscapeDataString(normalizedSlug)}",
                    Source: "luister",
                    IsFavorite: !isCurrentlyFavorite,
                    PlaylistSlug: CurrentPlaylist?.Slug));

            if (updated)
            {
                if (isCurrentlyFavorite)
                {
                    FavoriteStorySlugs.Remove(normalizedSlug);
                }
                else
                {
                    FavoriteStorySlugs.Add(normalizedSlug);
                }
            }
        }
        finally
        {
            FavoriteStoryBusySlugs.Remove(normalizedSlug);
        }
    }

    private Task CloseStoryAccessPopupAsync()
    {
        ShowStoryAccessPopup = false;
        return Task.CompletedTask;
    }

    private async Task ToggleFullscreenFocusAsync()
    {
        IsManualFullscreenFocus = !IsManualFullscreenFocus;

        var module = await TryGetStoryPlayerModuleAsync();
        if (module is null)
        {
            return;
        }

        try
        {
            await module.InvokeVoidAsync("setStoryPlayerFullscreenIntent", IsManualFullscreenFocus);
        }
        catch (JSException)
        {
            _mediaSessionModuleLoadFailed = true;
            IsManualFullscreenFocus = false;
        }
    }

    private async Task<IJSObjectReference?> TryGetStoryPlayerModuleAsync()
    {
        if (_mediaSessionModuleLoadFailed)
        {
            return null;
        }

        if (_mediaSessionModule is not null)
        {
            return _mediaSessionModule;
        }

        try
        {
            _mediaSessionModule = await JS.InvokeAsync<IJSObjectReference>("import", "/Components/Pages/GratisStory.razor.js");
            return _mediaSessionModule;
        }
        catch (JSException)
        {
            _mediaSessionModuleLoadFailed = true;
            return null;
        }
        catch (JSDisconnectedException)
        {
            return null;
        }
    }

    private async Task PrepareForTrackChangeAsync()
    {
        if (_mediaSessionModule is null)
        {
            return;
        }

        try
        {
            using var stopCts = new CancellationTokenSource(TimeSpan.FromMilliseconds(250));
            await _mediaSessionModule.InvokeVoidAsync("prepareStoryAudioForSourceSwap", stopCts.Token);
        }
        catch (OperationCanceledException)
        {
            // Do not block track changes when cleanup takes too long.
        }
        catch (JSException)
        {
            // Ignore browser-specific cleanup failures.
        }
        catch (JSDisconnectedException)
        {
            // Ignore cleanup when browser connection is gone.
        }
    }

    [JSInvokable]
    public Task HandleFullscreenExitedFromBrowser()
    {
        if (!IsManualFullscreenFocus)
        {
            return Task.CompletedTask;
        }

        IsManualFullscreenFocus = false;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task HandleJsPreviousTrackRequest() => SelectPreviousTrackAsync();

    [JSInvokable]
    public Task HandleJsNextTrackRequest() => SelectNextTrackAsync();

    [JSInvokable]
    public Task HandleJsAutoplayNextTrackRequest()
    {
        if (!AutoplayEnabled || NextStory is null)
        {
            return Task.CompletedTask;
        }

        if (AutoplayLimitStories.HasValue &&
            AutoplayStoriesPlayedInRun >= AutoplayLimitStories.Value)
        {
            return Task.CompletedTask;
        }

        return SelectTrackAsync(NextStory.Slug, true, isAutoplayAdvance: true);
    }

    public async ValueTask DisposeAsync()
    {
        CancelEmptyStateDelay();

        try
        {
            if (_mediaSessionModule is not null)
            {
                await PrepareForTrackChangeAsync();

                using var disposeUiCts = new CancellationTokenSource(TimeSpan.FromMilliseconds(250));
                await _mediaSessionModule.InvokeVoidAsync("disposeStoryPlayerFullscreenExperience", disposeUiCts.Token);

                await _mediaSessionModule.DisposeAsync().AsTask().WaitAsync(TimeSpan.FromMilliseconds(250));
            }
        }
        catch (TimeoutException)
        {
            // Ignore slow JS module disposal so route transitions stay responsive.
        }
        catch (OperationCanceledException)
        {
            // Ignore cancellation during route transitions and disposal races.
        }
        catch (JSException)
        {
            // Ignore browser-specific disposal failures on older Safari/WebKit.
        }
        catch (JSDisconnectedException)
        {
            // Ignore disposal errors when the browser connection is already closed.
        }
        finally
        {
            _dotNetRef?.Dispose();
        }
    }

    private async Task<LuisterAccessProfile> ResolveLuisterAccessProfileAsync(ClaimsPrincipal user)
    {
        var email = user.FindFirst(ClaimTypes.Email)?.Value
                    ?? user.Identity?.Name;
        if (string.IsNullOrWhiteSpace(email))
        {
            return new LuisterAccessProfile(false, false);
        }

        var storyCornerTask = SubscriptionLedgerService.HasActiveSubscriptionForTierAsync(email, StoryAccessPolicy.StoryCornerMonthlyTierCode);
        var allStoriesMonthlyTask = SubscriptionLedgerService.HasActiveSubscriptionForTierAsync(email, StoryAccessPolicy.AllStoriesMonthlyTierCode);
        var allStoriesYearlyTask = SubscriptionLedgerService.HasActiveSubscriptionForTierAsync(email, StoryAccessPolicy.AllStoriesYearlyTierCode);

        await Task.WhenAll(storyCornerTask, allStoriesMonthlyTask, allStoriesYearlyTask);

        var hasAllStories = allStoriesMonthlyTask.Result || allStoriesYearlyTask.Result;
        return new LuisterAccessProfile(
            HasStoryCornerOrAll: storyCornerTask.Result || hasAllStories,
            HasAllStories: hasAllStories);
    }

    private static bool HasAccessToStory(StoryItem story, LuisterAccessProfile accessProfile)
    {
        var requirement = StoryAccessPolicy.ResolveRequirement("luister", story);
        return requirement switch
        {
            StoryAccessRequirement.Free => true,
            StoryAccessRequirement.StoryCornerOrAllStories => accessProfile.HasStoryCornerOrAll,
            StoryAccessRequirement.AllStoriesOnly => accessProfile.HasAllStories,
            _ => false
        };
    }

    private void ResolveAdjacentStories()
    {
        PreviousStory = null;
        NextStory = null;

        var playbackStories = GetPlaybackStories();
        if (CurrentStory is null || playbackStories.Count < 2)
        {
            return;
        }

        var index = playbackStories
            .Select((story, idx) => new { story.Slug, idx })
            .FirstOrDefault(x => string.Equals(x.Slug, CurrentStory.Slug, StringComparison.OrdinalIgnoreCase))
            ?.idx ?? -1;

        if (index < 0)
        {
            return;
        }

        if (index > 0)
        {
            PreviousStory = playbackStories[index - 1];
        }

        if (index < playbackStories.Count - 1)
        {
            NextStory = playbackStories[index + 1];
        }
    }

    private int GetPlaylistTrackNumber(string? storySlug)
    {
        if (string.IsNullOrWhiteSpace(storySlug))
        {
            return 0;
        }

        for (var index = 0; index < AccessibleStories.Count; index++)
        {
            if (string.Equals(AccessibleStories[index].Slug, storySlug, StringComparison.OrdinalIgnoreCase))
            {
                return index + 1;
            }
        }

        return 0;
    }

    private IReadOnlyList<StoryItem> GetPlaybackStories()
    {
        if (!ShuffleEnabled || AccessibleStories.Count < 2)
        {
            return AccessibleStories;
        }

        EnsureShuffledPlaybackOrder();
        if (ShuffledPlaybackOrder.Count == 0)
        {
            return AccessibleStories;
        }

        var storiesBySlug = AccessibleStories.ToDictionary(story => story.Slug, StringComparer.OrdinalIgnoreCase);
        var orderedStories = new List<StoryItem>(AccessibleStories.Count);
        var includedSlugs = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        foreach (var slug in ShuffledPlaybackOrder)
        {
            if (!storiesBySlug.TryGetValue(slug, out var story) || !includedSlugs.Add(slug))
            {
                continue;
            }

            orderedStories.Add(story);
        }

        foreach (var story in AccessibleStories)
        {
            if (includedSlugs.Add(story.Slug))
            {
                orderedStories.Add(story);
            }
        }

        return orderedStories;
    }

    private void EnsureShuffledPlaybackOrder()
    {
        if (!ShuffleEnabled || AccessibleStories.Count < 2)
        {
            return;
        }

        var accessibleSlugs = new HashSet<string>(
            AccessibleStories.Select(story => story.Slug),
            StringComparer.OrdinalIgnoreCase);

        if (ShuffledPlaybackOrder.Count == AccessibleStories.Count &&
            ShuffledPlaybackOrder.All(accessibleSlugs.Contains))
        {
            return;
        }

        CreateShuffledPlaybackOrder(CurrentStory?.Slug);
    }

    private void CreateShuffledPlaybackOrder(string? anchorSlug)
    {
        ShuffledPlaybackOrder.Clear();

        if (AccessibleStories.Count == 0)
        {
            return;
        }

        var normalizedAnchorSlug = string.IsNullOrWhiteSpace(anchorSlug) ? null : anchorSlug.Trim();
        var remainingSlugs = AccessibleStories
            .Where(story => !string.Equals(story.Slug, normalizedAnchorSlug, StringComparison.OrdinalIgnoreCase))
            .Select(story => story.Slug)
            .ToList();

        for (var index = remainingSlugs.Count - 1; index > 0; index--)
        {
            var swapIndex = Random.Shared.Next(index + 1);
            (remainingSlugs[index], remainingSlugs[swapIndex]) = (remainingSlugs[swapIndex], remainingSlugs[index]);
        }

        if (!string.IsNullOrWhiteSpace(normalizedAnchorSlug) &&
            AccessibleStories.Any(story => string.Equals(story.Slug, normalizedAnchorSlug, StringComparison.OrdinalIgnoreCase)))
        {
            ShuffledPlaybackOrder.Add(normalizedAnchorSlug);
        }

        ShuffledPlaybackOrder.AddRange(remainingSlugs);
    }

    private void ResetPlaybackOrder()
    {
        ShuffleEnabled = false;
        ShuffledPlaybackOrder.Clear();
    }

    private void ResetAutoplayProgress()
    {
        if (!AutoplayEnabled || !AutoplayLimitStories.HasValue || CurrentStory is null)
        {
            AutoplayStoriesPlayedInRun = 0;
            return;
        }

        AutoplayStoriesPlayedInRun = 1;
    }

    private void UpdateAutoplayProgressForTrackChange(bool isAutoplayAdvance)
    {
        if (!AutoplayEnabled || !AutoplayLimitStories.HasValue || CurrentStory is null)
        {
            AutoplayStoriesPlayedInRun = 0;
            return;
        }

        if (!isAutoplayAdvance)
        {
            AutoplayStoriesPlayedInRun = 1;
            return;
        }

        AutoplayStoriesPlayedInRun = Math.Max(1, AutoplayStoriesPlayedInRun + 1);
    }

    private string GetCurrentPathAndQuery()
    {
        var currentUri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var pathAndQuery = $"{currentUri.AbsolutePath}{currentUri.Query}";
        return string.IsNullOrWhiteSpace(pathAndQuery) ? "/luister" : pathAndQuery;
    }

    private static string BuildOpsiesHref(string returnPath)
    {
        var safePath = string.IsNullOrWhiteSpace(returnPath) ? "/luister" : returnPath;
        return $"/opsies?returnUrl={Uri.EscapeDataString(safePath)}";
    }

    private async Task LoadFavoriteStorySlugsAsync()
    {
        FavoriteStorySlugs.Clear();
        FavoriteStoryBusySlugs.Clear();

        if (string.IsNullOrWhiteSpace(SignedInEmail))
        {
            return;
        }

        var favoriteSlugs = await StoryFavoriteService.GetFavoriteStorySlugsAsync(SignedInEmail, "luister");
        foreach (var favoriteSlug in favoriteSlugs)
        {
            FavoriteStorySlugs.Add(favoriteSlug);
        }
    }

    private async Task LoadFavoriteStorySlugsInBackgroundAsync()
    {
        try
        {
            await LoadFavoriteStorySlugsAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // Keep the page responsive if favorites fail to load.
        }
    }

    private void ClearFavoriteState()
    {
        FavoriteStorySlugs.Clear();
        FavoriteStoryBusySlugs.Clear();
    }

    private static string GetImageMimeType(string fileName)
    {
        var extension = Path.GetExtension(fileName).ToLowerInvariant();
        return extension switch
        {
            ".png" => "image/png",
            ".webp" => "image/webp",
            ".jpg" => "image/jpeg",
            ".jpeg" => "image/jpeg",
            _ => "image/jpeg"
        };
    }

    private static string GetPlaylistPath(string? playlistSlug) =>
        string.IsNullOrWhiteSpace(playlistSlug)
            ? "/luister"
            : $"/luister/speellys/{Uri.EscapeDataString(playlistSlug.Trim())}";

    private static string BuildPlaylistHref(string? playlistSlug, string? storySlug)
    {
        var path = GetPlaylistPath(playlistSlug);
        if (string.IsNullOrWhiteSpace(storySlug))
        {
            return path;
        }

        return $"{path}?storie={Uri.EscapeDataString(storySlug.Trim())}";
    }

    private static string GetStoryHref(string? playlistSlug, string? playlistTitle, string slug)
    {
        var path = $"/luister/{Uri.EscapeDataString(slug)}";

        if (string.IsNullOrWhiteSpace(playlistSlug) || string.IsNullOrWhiteSpace(playlistTitle))
        {
            return path;
        }

        return QueryHelpers.AddQueryString(path, new Dictionary<string, string?>
        {
            ["playlist"] = playlistSlug.Trim(),
            ["playlistName"] = playlistTitle.Trim()
        });
    }

    private sealed record LuisterAccessProfile(bool HasStoryCornerOrAll, bool HasAllStories);
