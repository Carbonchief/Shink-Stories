@page "/luister/speellys/{PlaylistSlug}/stories"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using System.Text.Json
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.JSInterop
@inject IStoryCatalogService StoryCatalogService
@inject ICharacterCatalogService CharacterCatalogService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISubscriptionLedgerService SubscriptionLedgerService
@inject IStoryFavoriteService StoryFavoriteService
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>@PageTitleText</PageTitle>
<HeadContent>
    <link rel="canonical" href="@ShowcaseCanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@ShareTitle" />
    <meta property="og:description" content="@ShareDescription" />
    <meta property="og:url" content="@ShowcaseCanonicalUrl" />
    <meta property="og:image" content="@ShareImageUrl" />
    <meta property="og:image:type" content="@ShareImageMimeType" />
    <meta property="og:image:alt" content="@ShareImageAlt" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@ShareTitle" />
    <meta name="twitter:description" content="@ShareDescription" />
    <meta name="twitter:image" content="@ShareImageUrl" />
    <meta name="twitter:image:alt" content="@ShareImageAlt" />
    <JsonLdScript Json="@ShowcaseJsonLd" />
</HeadContent>

@if (IsLoadingShowcase && CurrentPlaylist is null)
{
    <section class="playlist-showcase-loading-state" aria-live="polite" aria-busy="true">
    </section>
}
else if (!AllowEmptyState && (CurrentPlaylist is null || CurrentPlaylistStories.Count == 0))
{
    <section class="playlist-showcase-loading-state" aria-live="polite" aria-busy="true">
    </section>
}
else if (CurrentPlaylist is null)
{
    <section class="playlist-showcase-empty-state">
        <h1>Ons kon nie daardie speellys kry nie.</h1>
        <p>Gaan terug na Luister om 'n ander speellys te kies.</p>
        <a href="/luister">Terug na luister</a>
    </section>
}
else if (CurrentPlaylistStories.Count == 0)
{
    <section class="playlist-showcase-empty-state">
        <h1>Hierdie speellys is nie nou beskikbaar nie.</h1>
        <p>Probeer asseblief later weer of kies 'n ander speellys.</p>
        <a href="/luister">Terug na luister</a>
    </section>
}
else
{
    <section class="playlist-showcase-page">
        <header class="playlist-showcase-splash">
            <img class="@BackdropImageClass"
                 src="@BackdropImagePath"
                 srcset="@($"{BackdropImagePath} 640w, {BackdropImagePath} 1200w, {BackdropImagePath} 1920w")"
                 sizes="100vw"
                 alt="@BackdropImageAlt"
                 width="1920"
                 height="1080"
                 loading="eager"
                 fetchpriority="high"
                 decoding="async" />
            @if (!string.IsNullOrWhiteSpace(LogoImagePath))
            {
                <img class="playlist-showcase-splash-logo"
                     src="@LogoImagePath"
                     srcset="@($"{LogoImagePath} 512w, {LogoImagePath} 1024w")"
                     sizes="(max-width: 1024px) 92vw, 920px"
                     alt="@LogoImageAlt"
                     width="1024"
                     height="1024"
                     loading="eager"
                     fetchpriority="high"
                     decoding="async" />
            }
            <h1 class="sr-only">@CurrentPlaylist.Title</h1>
            <div class="playlist-showcase-action-bar" aria-label="Speellys aksies">
                <a class="playlist-showcase-playlist-link" href="@GetPlaylistPlayerHref(CurrentPlaylist.Slug)">
                    Speel Speellys
                </a>
                <a class="playlist-showcase-secondary-link"
                   href="@StoriesAnchorHref"
                   data-scroll-target="playlist-showcase-grid">
                    Kies 'n Storie
                </a>
            </div>
        </header>

        <div class="playlist-showcase-body">
            <section class="playlist-showcase-intro" aria-label="Speellys oorsig">
                @if (!string.IsNullOrWhiteSpace(CurrentPlaylist.Description))
                {
                    <p class="playlist-showcase-intro-description">@CurrentPlaylist.Description</p>
                }
                <p class="playlist-showcase-intro-count">@StoryCountLabel</p>
            </section>

            @if (ShowcaseStory is not null)
            {
                <section class="playlist-showcase-feature" aria-label="Showcase storie">
                    <article class="playlist-showcase-feature-card">
                        <div class="playlist-showcase-feature-shell">
                            <a class="playlist-showcase-feature-link"
                               href="@BuildStoryHref(ShowcaseStory)"
                               @onclick="() => HandleStoryCardClickAsync(ShowcaseStory)"
                               @onclick:preventDefault="true"
                               aria-label="Luister na @ShowcaseStory.Title">
                                <span class="playlist-showcase-feature-cover">
                                    <img class="playlist-showcase-feature-image"
                                         src="@ShowcaseStory.ThumbnailPath"
                                         srcset="@($"{ShowcaseStory.ThumbnailPath} 640w, {ShowcaseStory.ImagePath} 1024w")"
                                         sizes="(max-width: 720px) 88vw, 420px"
                                         alt="Voorblad van @ShowcaseStory.Title"
                                         width="640"
                                         height="485"
                                         loading="eager"
                                         decoding="async" />
                                    <span class="playlist-showcase-feature-play" aria-hidden="true">
                                        <i class="playlist-showcase-feature-play-icon fa-solid fa-play" aria-hidden="true"></i>
                                    </span>
                                </span>
                                <span class="playlist-showcase-feature-copy">
                                    <span class="playlist-showcase-feature-title">@ShowcaseStory.Title</span>
                                    <span class="playlist-showcase-feature-description">@ShowcaseStory.Description</span>
                                </span>
                            </a>
                            <button type="button"
                                    class="story-favorite-toggle @(IsStoryFavorite(ShowcaseStory.Slug) ? "is-favorite" : null)"
                                    @onclick="() => ToggleStoryFavoriteAsync(ShowcaseStory)"
                                    aria-label="@(IsStoryFavorite(ShowcaseStory.Slug) ? $"Verwyder {ShowcaseStory.Title} uit jou gunstelinge" : $"Voeg {ShowcaseStory.Title} by jou gunstelinge")"
                                    title="@(IsStoryFavorite(ShowcaseStory.Slug) ? "Verwyder uit gunstelinge" : "Voeg by gunstelinge")"
                                    aria-pressed="@IsStoryFavorite(ShowcaseStory.Slug)"
                                    disabled="@IsFavoriteBusy(ShowcaseStory.Slug)">
                                <i class="fa-@(IsStoryFavorite(ShowcaseStory.Slug) ? "solid" : "regular") fa-heart" aria-hidden="true"></i>
                            </button>
                        </div>
                    </article>
                </section>
            }

            <section class="playlist-showcase-stories" aria-labelledby="playlist-showcase-stories-heading">
                <h2 id="playlist-showcase-stories-heading">Stories in hierdie speellys</h2>
                <div id="playlist-showcase-grid" class="playlist-showcase-grid" role="list">
                    @foreach (var story in CurrentPlaylistStories)
                    {
                        var isHighlighted = string.Equals(story.Slug, EffectiveHighlightStorySlug, StringComparison.OrdinalIgnoreCase);

                        <article class="playlist-showcase-card @(isHighlighted ? "is-highlighted" : null)" role="listitem">
                            <div class="playlist-showcase-card-shell">
                                <a class="playlist-showcase-card-link"
                                   href="@BuildStoryHref(story)"
                                   @onclick="() => HandleStoryCardClickAsync(story)"
                                   @onclick:preventDefault="true"
                                   aria-label="Luister na @story.Title">
                                    <span class="playlist-showcase-card-cover">
                                        <img class="playlist-showcase-card-image"
                                             src="@story.ThumbnailPath"
                                             srcset="@($"{story.ThumbnailPath} 640w, {story.ImagePath} 1024w")"
                                             sizes="(max-width: 560px) 88vw, (max-width: 980px) 42vw, (max-width: 1200px) 30vw, 240px"
                                             alt="Voorblad van @story.Title"
                                             width="640"
                                             height="485"
                                             loading="eager"
                                             decoding="async" />
                                        <span class="playlist-showcase-card-play" aria-hidden="true">
                                            <i class="playlist-showcase-card-play-icon fa-solid fa-play" aria-hidden="true"></i>
                                        </span>
                                    </span>
                                    <span class="playlist-showcase-card-copy">
                                        <span class="playlist-showcase-card-title">@story.Title</span>
                                    </span>
                                </a>
                                <button type="button"
                                        class="story-favorite-toggle @(IsStoryFavorite(story.Slug) ? "is-favorite" : null)"
                                        @onclick="() => ToggleStoryFavoriteAsync(story)"
                                        aria-label="@(IsStoryFavorite(story.Slug) ? $"Verwyder {story.Title} uit jou gunstelinge" : $"Voeg {story.Title} by jou gunstelinge")"
                                        title="@(IsStoryFavorite(story.Slug) ? "Verwyder uit gunstelinge" : "Voeg by gunstelinge")"
                                        aria-pressed="@IsStoryFavorite(story.Slug)"
                                        disabled="@IsFavoriteBusy(story.Slug)">
                                    <i class="fa-@(IsStoryFavorite(story.Slug) ? "solid" : "regular") fa-heart" aria-hidden="true"></i>
                                </button>
                            </div>
                        </article>
                    }
                </div>
            </section>
        </div>
    </section>
}

<StoryAccessPopup IsOpen="@ShowStoryAccessPopup"
                  PrimaryActionHref="@StoryAccessPopupPrimaryHref"
                  PlanActionHref="@StoryAccessPopupPlanHref"
                  OnClose="CloseStoryAccessPopupAsync" />

@code {
    [Parameter]
    public string? PlaylistSlug { get; set; }

    [SupplyParameterFromQuery(Name = "storie")]
    public string? HighlightStorySlug { get; set; }

    private StoryPlaylist? CurrentPlaylist { get; set; }
    private IReadOnlyList<StoryItem> CurrentPlaylistStories { get; set; } = Array.Empty<StoryItem>();
    private HashSet<string> FavoriteStorySlugs { get; } = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> FavoriteStoryBusySlugs { get; } = new(StringComparer.OrdinalIgnoreCase);
    private string? SignedInEmail { get; set; }
    private LuisterAccessProfile AccessProfile { get; set; } = new(false, false);
    private bool ShowStoryAccessPopup { get; set; }
    private bool IsLoadingShowcase { get; set; } = true;
    private bool AllowEmptyState { get; set; }
    private string PendingLockedStoryPath { get; set; } = "/luister";
    private string? FallbackCharacterLogoImagePath { get; set; }
    private CancellationTokenSource? _emptyStateDelayCts;

    private string PageTitleText =>
        CurrentPlaylist is null
            ? "Speellys nie gevind nie"
            : $"{CurrentPlaylist.Title} stories | Schink Stories";
    private string StoryCountLabel =>
        CurrentPlaylistStories.Count == 1
            ? "1 Storie om te Luister"
            : $"{CurrentPlaylistStories.Count} Stories om te Luister";

    private string ShowcaseCanonicalUrl =>
        NavigationManager.ToAbsoluteUri(GetShowcasePath(CurrentPlaylist?.Slug ?? PlaylistSlug)).ToString();
    private string StoriesAnchorHref =>
        $"{NavigationManager.ToAbsoluteUri(GetShowcasePath(CurrentPlaylist?.Slug ?? PlaylistSlug)).ToString()}#playlist-showcase-grid";
    private string? EffectiveHighlightStorySlug =>
        !string.IsNullOrWhiteSpace(HighlightStorySlug)
            ? HighlightStorySlug
            : CurrentPlaylist?.ShowcaseStorySlug;
    private StoryItem? ShowcaseStory => CurrentPlaylist?.ShowcaseStory;
    private bool IsSignedIn => !string.IsNullOrWhiteSpace(SignedInEmail);
    private string StoryAccessPopupPrimaryHref =>
        IsSignedIn
            ? BuildOpsiesHref(PendingLockedStoryPath)
            : $"/teken-in?returnUrl={Uri.EscapeDataString(PendingLockedStoryPath)}";
    private string StoryAccessPopupPlanHref => BuildOpsiesHref(PendingLockedStoryPath);

    private string ShareTitle =>
        CurrentPlaylist is null
            ? "Schink Stories | Speellys"
            : $"{CurrentPlaylist.Title} stories | Schink Stories";

    private string ShareDescription =>
        !string.IsNullOrWhiteSpace(CurrentPlaylist?.Description)
            ? CurrentPlaylist.Description!
            : "Verken stories in hierdie Schink speellys.";

    private string ShareImageUrl => NavigationManager.ToAbsoluteUri(BackdropImagePath).ToString();

    private string ShareImageMimeType => GetImageMimeType(BackdropImagePath);

    private string ShareImageAlt =>
        CurrentPlaylist is null
            ? "Schink Stories speellys"
            : $"Agtergrond vir {CurrentPlaylist.Title}";

    private string BackdropImagePath =>
        ResolveBackdropImagePath();

    private string BackdropImageClass =>
        IsUsingFirstStoryBackdropFallback
            ? "playlist-showcase-splash-backdrop is-first-story-fallback"
            : "playlist-showcase-splash-backdrop";

    private string BackdropImageAlt =>
        CurrentPlaylist is null
            ? "Schink Stories speellys agtergrond"
            : $"{CurrentPlaylist.Title} speellys agtergrond";

    private bool IsUsingFirstStoryBackdropFallback =>
        CurrentPlaylist is not null &&
        !HasConfiguredBackdrop(CurrentPlaylist) &&
        !HasConfiguredLogo(CurrentPlaylist) &&
        CurrentPlaylistStories.FirstOrDefault() is not null;

    private string? LogoImagePath =>
        ResolveLogoImagePath();

    private string LogoImageAlt =>
        CurrentPlaylist is null
            ? "Schink Stories logo"
            : HasConfiguredLogo(CurrentPlaylist)
                ? $"{CurrentPlaylist.Title} logo"
                : !string.IsNullOrWhiteSpace(FallbackCharacterLogoImagePath)
                    ? $"Karakter illustrasie vir {CurrentPlaylistStories.FirstOrDefault()?.Title ?? CurrentPlaylist.Title}"
                    : $"{CurrentPlaylist.Title} beeld";

    private MarkupString ShowcaseJsonLd => new(JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "CollectionPage",
        ["headline"] = ShareTitle,
        ["description"] = ShareDescription,
        ["url"] = ShowcaseCanonicalUrl,
        ["inLanguage"] = "af-ZA",
        ["image"] = new[] { ShareImageUrl },
        ["isPartOf"] = new Dictionary<string, object?>
        {
            ["@type"] = "WebSite",
            ["name"] = "Schink Stories",
            ["url"] = NavigationManager.ToAbsoluteUri("/").ToString()
        },
        ["mainEntity"] = CurrentPlaylist is null
            ? null
            : new Dictionary<string, object?>
            {
                ["@type"] = "ItemList",
                ["name"] = CurrentPlaylist.Title,
                ["numberOfItems"] = CurrentPlaylistStories.Count,
                ["itemListElement"] = CurrentPlaylistStories.Select((story, index) => new Dictionary<string, object?>
                {
                    ["@type"] = "ListItem",
                    ["position"] = index + 1,
                    ["name"] = story.Title,
                    ["url"] = NavigationManager.ToAbsoluteUri($"/luister/{story.Slug}").ToString()
                }).ToArray()
            }
    }));

    protected override async Task OnParametersSetAsync()
    {
        IsLoadingShowcase = true;
        CancelEmptyStateDelay();
        AllowEmptyState = false;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        SignedInEmail = authState.User.Identity?.IsAuthenticated == true
            ? authState.User.FindFirst(ClaimTypes.Email)?.Value ?? authState.User.Identity?.Name
            : null;
        AccessProfile = await ResolveLuisterAccessProfileAsync(authState.User);

        CurrentPlaylist = null;
        CurrentPlaylistStories = Array.Empty<StoryItem>();
        FallbackCharacterLogoImagePath = null;

        if (string.IsNullOrWhiteSpace(PlaylistSlug))
        {
            IsLoadingShowcase = false;
            return;
        }

        try
        {
            try
            {
                var playlists = await StoryCatalogService.GetLuisterPlaylistsAsync(SignedInEmail);
                CurrentPlaylist = playlists.FirstOrDefault(playlist =>
                    string.Equals(playlist.Slug, PlaylistSlug, StringComparison.OrdinalIgnoreCase));

                CurrentPlaylistStories = CurrentPlaylist?.Stories ?? Array.Empty<StoryItem>();
            }
            catch
            {
                CurrentPlaylist = null;
                CurrentPlaylistStories = Array.Empty<StoryItem>();
            }

            await Task.WhenAll(
                LoadShowcaseFallbackAssetsAsync(),
                LoadFavoriteStorySlugsAsync());
        }
        finally
        {
            IsLoadingShowcase = false;
            await UpdateEmptyStateVisibilityAsync();
        }
    }

    private async Task UpdateEmptyStateVisibilityAsync()
    {
        CancelEmptyStateDelay();
        AllowEmptyState = false;

        if (CurrentPlaylist is not null && CurrentPlaylistStories.Count > 0)
        {
            return;
        }

        var delayCts = new CancellationTokenSource();
        _emptyStateDelayCts = delayCts;

        try
        {
            await Task.Delay(450, delayCts.Token);
            AllowEmptyState = true;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void CancelEmptyStateDelay()
    {
        _emptyStateDelayCts?.Cancel();
        _emptyStateDelayCts?.Dispose();
        _emptyStateDelayCts = null;
    }

    private static string GetShowcasePath(string? playlistSlug) =>
        string.IsNullOrWhiteSpace(playlistSlug)
            ? "/luister"
            : $"/luister/speellys/{Uri.EscapeDataString(playlistSlug.Trim())}/stories";

    private static string GetPlaylistPlayerHref(string playlistSlug) =>
        QueryHelpers.AddQueryString(
            $"/luister/speellys/{Uri.EscapeDataString(playlistSlug.Trim())}",
            "playlistView",
            "showcase");

    private async Task LoadShowcaseFallbackAssetsAsync()
    {
        FallbackCharacterLogoImagePath = null;

        if (CurrentPlaylist is null ||
            !HasConfiguredBackdrop(CurrentPlaylist) ||
            HasConfiguredLogo(CurrentPlaylist))
        {
            return;
        }

        try
        {
            var firstStory = CurrentPlaylistStories.FirstOrDefault();
            if (firstStory is null || string.IsNullOrWhiteSpace(firstStory.Slug))
            {
                return;
            }

            var characters = await CharacterCatalogService.GetPublishedCharactersAsync();
            var matchingCharacter = characters.FirstOrDefault(character =>
                !string.IsNullOrWhiteSpace(character.ImagePath) &&
                CharacterUnlockEvaluator.GetRelevantStorySlugs(character).Any(slug =>
                    string.Equals(slug, firstStory.Slug, StringComparison.OrdinalIgnoreCase)));

            FallbackCharacterLogoImagePath = ResolveCharacterImagePath(matchingCharacter);
        }
        catch
        {
            FallbackCharacterLogoImagePath = null;
        }
    }

    private bool IsStoryFavorite(string slug) => FavoriteStorySlugs.Contains(slug);

    private bool IsFavoriteBusy(string slug) => FavoriteStoryBusySlugs.Contains(slug);

    private async Task ToggleStoryFavoriteAsync(StoryItem story)
    {
        if (string.IsNullOrWhiteSpace(story.Slug))
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(SignedInEmail))
        {
            RedirectToOpsies();
            return;
        }

        var normalizedSlug = story.Slug.Trim();
        if (!FavoriteStoryBusySlugs.Add(normalizedSlug))
        {
            return;
        }

        var isCurrentlyFavorite = FavoriteStorySlugs.Contains(normalizedSlug);
        try
        {
            var updated = await StoryFavoriteService.SetStoryFavoriteAsync(
                SignedInEmail,
                new StoryFavoriteMutationRequest(
                    StorySlug: normalizedSlug,
                    StoryPath: $"/luister/{Uri.EscapeDataString(normalizedSlug)}",
                    Source: "luister",
                    IsFavorite: !isCurrentlyFavorite,
                    PlaylistSlug: CurrentPlaylist?.Slug));

            if (updated)
            {
                if (isCurrentlyFavorite)
                {
                    FavoriteStorySlugs.Remove(normalizedSlug);
                }
                else
                {
                    FavoriteStorySlugs.Add(normalizedSlug);
                }
            }
        }
        finally
        {
            FavoriteStoryBusySlugs.Remove(normalizedSlug);
        }
    }

    private Task HandleStoryCardClickAsync(StoryItem story)
    {
        var storyPath = BuildStoryHref(story);
        if (string.IsNullOrWhiteSpace(story.Slug))
        {
            NavigationManager.NavigateTo(storyPath);
            return Task.CompletedTask;
        }

        if (HasAccessToStory(story))
        {
            NavigationManager.NavigateTo(storyPath);
            return Task.CompletedTask;
        }

        PendingLockedStoryPath = storyPath;
        ShowStoryAccessPopup = true;
        return Task.CompletedTask;
    }

    private Task CloseStoryAccessPopupAsync()
    {
        ShowStoryAccessPopup = false;
        return Task.CompletedTask;
    }

    private bool HasAccessToStory(StoryItem story)
    {
        var requirement = StoryAccessPolicy.ResolveRequirement("luister", story);
        return requirement switch
        {
            StoryAccessRequirement.Free => true,
            StoryAccessRequirement.StoryCornerOrAllStories => AccessProfile.HasStoryCornerOrAll,
            StoryAccessRequirement.AllStoriesOnly => AccessProfile.HasAllStories,
            _ => false
        };
    }

    private async Task<LuisterAccessProfile> ResolveLuisterAccessProfileAsync(ClaimsPrincipal user)
    {
        var email = user.FindFirst(ClaimTypes.Email)?.Value
                    ?? user.Identity?.Name;
        if (string.IsNullOrWhiteSpace(email))
        {
            return new LuisterAccessProfile(false, false);
        }

        var storyCornerTask = SubscriptionLedgerService.HasActiveSubscriptionForTierAsync(email, StoryAccessPolicy.StoryCornerMonthlyTierCode);
        var allStoriesMonthlyTask = SubscriptionLedgerService.HasActiveSubscriptionForTierAsync(email, StoryAccessPolicy.AllStoriesMonthlyTierCode);
        var allStoriesYearlyTask = SubscriptionLedgerService.HasActiveSubscriptionForTierAsync(email, StoryAccessPolicy.AllStoriesYearlyTierCode);

        await Task.WhenAll(storyCornerTask, allStoriesMonthlyTask, allStoriesYearlyTask);

        var hasAllStories = allStoriesMonthlyTask.Result || allStoriesYearlyTask.Result;
        return new LuisterAccessProfile(
            HasStoryCornerOrAll: storyCornerTask.Result || hasAllStories,
            HasAllStories: hasAllStories);
    }

    private async Task LoadFavoriteStorySlugsAsync()
    {
        FavoriteStorySlugs.Clear();
        FavoriteStoryBusySlugs.Clear();

        if (string.IsNullOrWhiteSpace(SignedInEmail))
        {
            return;
        }

        var favoriteSlugs = await StoryFavoriteService.GetFavoriteStorySlugsAsync(SignedInEmail, "luister");
        foreach (var favoriteSlug in favoriteSlugs)
        {
            FavoriteStorySlugs.Add(favoriteSlug);
        }
    }

    private void RedirectToOpsies()
    {
        var currentUri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var currentPathAndQuery = $"{currentUri.AbsolutePath}{currentUri.Query}";
        var returnPath = string.IsNullOrWhiteSpace(currentPathAndQuery)
            ? "/luister"
            : currentPathAndQuery;
        var returnUrl = Uri.EscapeDataString(returnPath);
        NavigationManager.NavigateTo($"/opsies?returnUrl={returnUrl}");
    }

    private static string BuildOpsiesHref(string returnPath)
    {
        var safePath = string.IsNullOrWhiteSpace(returnPath) ? "/luister" : returnPath;
        return $"/opsies?returnUrl={Uri.EscapeDataString(safePath)}";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var module = await TryGetShowcaseModuleAsync();
        if (module is null)
        {
            return;
        }

        try
        {
            await module.InvokeVoidAsync("initializePlaylistShowcaseScroll");
        }
        catch (JSException)
        {
            _showcaseModuleLoadFailed = true;
        }
    }

    private async Task<IJSObjectReference?> TryGetShowcaseModuleAsync()
    {
        if (_showcaseModuleLoadFailed)
        {
            return null;
        }

        if (_showcaseModule is not null)
        {
            return _showcaseModule;
        }

        try
        {
            _showcaseModule = await JS.InvokeAsync<IJSObjectReference>("import", "/Components/Pages/LuisterPlaylistShowcase.razor.js");
            return _showcaseModule;
        }
        catch (JSException)
        {
            _showcaseModuleLoadFailed = true;
            return null;
        }
        catch (JSDisconnectedException)
        {
            return null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        CancelEmptyStateDelay();

        if (_showcaseModule is null)
        {
            return;
        }

        try
        {
            await _showcaseModule.InvokeVoidAsync("disposePlaylistShowcaseScroll");
            await _showcaseModule.DisposeAsync();
        }
        catch (JSException)
        {
            // Ignore browser-specific teardown failures on older engines.
        }
        catch (JSDisconnectedException)
        {
            // Ignore JS disconnects during teardown.
        }
    }

    private string BuildStoryHref(StoryItem story)
    {
        if (string.IsNullOrWhiteSpace(story.Slug))
        {
            return GetShowcasePath(CurrentPlaylist?.Slug ?? PlaylistSlug);
        }

        var path = $"/luister/{Uri.EscapeDataString(story.Slug.Trim())}";
        if (CurrentPlaylist is null)
        {
            return path;
        }

        return QueryHelpers.AddQueryString(path, new Dictionary<string, string?>
        {
            ["playlist"] = CurrentPlaylist.Slug,
            ["playlistName"] = CurrentPlaylist.Title,
            ["playlistView"] = "showcase"
        });
    }

    private static string GetImageMimeType(string fileName)
    {
        var extension = Path.GetExtension(fileName).ToLowerInvariant();
        return extension switch
        {
            ".png" => "image/png",
            ".webp" => "image/webp",
            ".jpg" => "image/jpeg",
            ".jpeg" => "image/jpeg",
            _ => "image/jpeg"
        };
    }

    private string ResolveBackdropImagePath()
    {
        if (CurrentPlaylist is null)
        {
            return StoryPlaylist.DefaultBackdropImagePath;
        }

        var configuredBackdrop = NormalizeOptionalImagePath(CurrentPlaylist.BackdropImagePath);
        if (!string.IsNullOrWhiteSpace(configuredBackdrop))
        {
            return configuredBackdrop;
        }

        if (HasConfiguredLogo(CurrentPlaylist))
        {
            return StoryPlaylist.DefaultBackdropImagePath;
        }

        return CurrentPlaylistStories.FirstOrDefault()?.ImagePath ?? StoryPlaylist.DefaultBackdropImagePath;
    }

    private string? ResolveLogoImagePath()
    {
        if (CurrentPlaylist is null)
        {
            return null;
        }

        var configuredLogo = NormalizeOptionalImagePath(CurrentPlaylist.LogoImagePath);
        if (!string.IsNullOrWhiteSpace(configuredLogo))
        {
            return configuredLogo;
        }

        return HasConfiguredBackdrop(CurrentPlaylist)
            ? FallbackCharacterLogoImagePath
            : null;
    }

    private static bool HasConfiguredLogo(StoryPlaylist playlist) =>
        !string.IsNullOrWhiteSpace(NormalizeOptionalImagePath(playlist.LogoImagePath));

    private static bool HasConfiguredBackdrop(StoryPlaylist playlist) =>
        !string.IsNullOrWhiteSpace(NormalizeOptionalImagePath(playlist.BackdropImagePath));

    private static string? NormalizeOptionalImagePath(string? path) =>
        string.IsNullOrWhiteSpace(path) ? null : StoryItem.RewriteImagePathForBrowser(path);

    private static string? ResolveCharacterImagePath(StoryCharacterItem? character)
    {
        var imagePath = NormalizeOptionalImagePath(character?.ImagePath);
        if (string.IsNullOrWhiteSpace(imagePath))
        {
            return null;
        }

        if (character?.UpdatedAt is null)
        {
            return imagePath;
        }

        var separator = imagePath.Contains('?', StringComparison.Ordinal) ? '&' : '?';
        return $"{imagePath}{separator}v={character.UpdatedAt.Value.ToUnixTimeSeconds()}";
    }

    private IJSObjectReference? _showcaseModule;
    private bool _showcaseModuleLoadFailed;

    private sealed record LuisterAccessProfile(bool HasStoryCornerOrAll, bool HasAllStories);
}
