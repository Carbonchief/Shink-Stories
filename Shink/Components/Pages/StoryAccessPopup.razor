@if (IsOpen)
{
    <div class="story-access-popup-backdrop" role="presentation" @onclick="HandleCloseAsync">
        <section class="story-access-popup-card"
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="story-access-popup-title"
                 @onclick:stopPropagation="true">
            <button type="button"
                    class="story-access-popup-close"
                    @onclick="HandleCloseAsync"
                    aria-label="Maak toe">
                <i class="fa-solid fa-xmark" aria-hidden="true"></i>
            </button>

            <img class="story-access-popup-image"
                 src="/media/imported/misc/2024/09/404_Rammetjie.png"
                 alt="Rammetjie"
                 width="220"
                 height="220"
                 loading="lazy"
                 decoding="async" />

            <h2 id="story-access-popup-title">
                Oeps!
                <br />
                Hierdie stories is nog gesluit <i class="fa-solid fa-lock" aria-hidden="true"></i>
            </h2>

            <p>
                Kry toegang tot die volle storiewêreld - alle stories, enige tyd.
            </p>

            <div class="story-access-popup-actions">
                <a class="story-access-popup-button story-access-popup-button-primary" href="@PrimaryActionHref">
                   👉 Kry toegang
                </a>
                <a class="story-access-popup-button story-access-popup-button-secondary" href="@PlanActionHref">
                   👉 Kies 'n plan
                </a>
            </div>
        </section>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public string PrimaryActionHref { get; set; } = "/teken-in";

    [Parameter]
    public string PlanActionHref { get; set; } = "/opsies";

    [Parameter]
    public EventCallback OnClose { get; set; }

    private Task HandleCloseAsync() => OnClose.InvokeAsync();
}
