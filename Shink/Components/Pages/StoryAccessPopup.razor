@if (IsOpen)
{
    <div class="story-access-popup-backdrop" role="presentation" @onclick="HandleCloseAsync">
        <section class="story-access-popup-card"
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="story-access-popup-title"
                 @onclick:stopPropagation="true">
            @if (ShowCloseButton)
            {
                <button type="button"
                        class="story-access-popup-close"
                        @onclick="HandleCloseAsync"
                        aria-label="Maak toe">
                    <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                </button>
            }

            <img class="story-access-popup-image"
                 src="@ImageSrc"
                 alt="@ImageAlt"
                 width="220"
                 height="220"
                 loading="lazy"
                 decoding="async" />

            <h2 id="story-access-popup-title">
                @Title
                @if (!string.IsNullOrWhiteSpace(Subtitle))
                {
                    <br />
                    @Subtitle
                    @if (ShowSubtitleLockIcon)
                    {
                        <i class="fa-solid fa-lock" aria-hidden="true"></i>
                    }
                }
            </h2>

            <p>
                @Message
            </p>

            <div class="story-access-popup-actions">
                @if (PrimaryActionUsesPost)
                {
                    <form method="post" action="@PrimaryActionHref" data-enhance="false">
                        <button type="submit" class="story-access-popup-button story-access-popup-button-primary">
                            @PrimaryActionText
                        </button>
                    </form>
                }
                else
                {
                    <a class="story-access-popup-button story-access-popup-button-primary" href="@PrimaryActionHref">
                        @PrimaryActionText
                    </a>
                }
                @if (!string.IsNullOrWhiteSpace(PlanActionHref))
                {
                    @if (PlanActionUsesPost)
                    {
                        <form method="post" action="@PlanActionHref" data-enhance="false">
                            <button type="submit" class="story-access-popup-button story-access-popup-button-secondary">
                                @PlanActionText
                            </button>
                        </form>
                    }
                    else
                    {
                        <a class="story-access-popup-button story-access-popup-button-secondary" href="@PlanActionHref">
                            @PlanActionText
                        </a>
                    }
                }
            </div>
        </section>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public string PrimaryActionHref { get; set; } = "/teken-in";

    [Parameter]
    public string PrimaryActionText { get; set; } = "👉 Kry toegang";

    [Parameter]
    public bool PrimaryActionUsesPost { get; set; }

    [Parameter]
    public string PlanActionHref { get; set; } = "/opsies";

    [Parameter]
    public string PlanActionText { get; set; } = "👉 Kies 'n plan";

    [Parameter]
    public bool PlanActionUsesPost { get; set; }

    [Parameter]
    public string ImageSrc { get; set; } = "/media/imported/misc/2024/09/404_Rammetjie.png";

    [Parameter]
    public string ImageAlt { get; set; } = "Rammetjie";

    [Parameter]
    public string Title { get; set; } = "Oeps!";

    [Parameter]
    public string? Subtitle { get; set; } = "Hierdie stories is nog gesluit";

    [Parameter]
    public bool ShowSubtitleLockIcon { get; set; } = true;

    [Parameter]
    public bool ShowCloseButton { get; set; } = true;

    [Parameter]
    public string Message { get; set; } = "Kry toegang tot die volle storiewêreld - alle stories, enige tyd.";

    [Parameter]
    public EventCallback OnClose { get; set; }

    private Task HandleCloseAsync() => OnClose.InvokeAsync();
}
