@page "/herstel-wagwoord"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject NavigationManager NavigationManager

<PageTitle>Schink Stories | Herstel wagwoord</PageTitle>
<HeadContent>
    <link href="/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <meta name="description" content="Herstel jou Schink Stories wagwoord veilig met 'n eenmalige herstel-skakel." />
    <meta name="robots" content="noindex, follow, noarchive, nosnippet" />
    <link rel="canonical" href="@NavigationManager.ToAbsoluteUri("/herstel-wagwoord").ToString()" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Schink Stories | Herstel wagwoord" />
    <meta property="og:description" content="Herstel jou Schink Stories wagwoord veilig met 'n eenmalige herstel-skakel." />
    <meta property="og:url" content="@NavigationManager.ToAbsoluteUri("/herstel-wagwoord").ToString()" />
    <meta property="og:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:secure_url" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content="Schink Stories logo" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Schink Stories | Herstel wagwoord" />
    <meta name="twitter:description" content="Herstel jou Schink Stories wagwoord veilig met 'n eenmalige herstel-skakel." />
    <meta name="twitter:image" content="@NavigationManager.ToAbsoluteUri("/branding/schink-logo-green.png").ToString()" />
    <meta name="twitter:image:alt" content="Schink Stories logo" />
</HeadContent>

<section class="auth-shell">
    <div class="auth-frame">
        <aside class="auth-aside" aria-label="Herstel inligting">
            <img class="auth-logo" src="/branding/schink_stories_logo_turqoise.png" alt="Schink" />
            <p class="auth-kicker">Veilige toegang</p>
            <h1>@PageHeading</h1>
            <p class="auth-intro">
                @PageIntro
            </p>
            <ul class="auth-points" aria-label="Herstel stappe">
                <li>Ons stuur 'n veilige herstel-skakel na jou e-posadres.</li>
                <li>Gebruik die skakel om jou nuwe wagwoord te kies.</li>
                <li>Teken daarna weer veilig in op selfoon of rekenaar.</li>
            </ul>
        </aside>

        <article class="auth-card">
            @if (IsRecoveryStatePending)
            {
                <p class="login-kicker">Herstel wagwoord</p>
                <p class="login-intro">Ons verifieer jou herstel-skakel...</p>
            }
            else if (HasRecoverySession)
            {
                <p class="login-kicker">Nuwe wagwoord</p>
                <p class="login-intro">
                    Kies nou 'n nuwe wagwoord vir jou rekening.
                </p>

                <EditForm FormName="complete-password-reset-form"
                          class="login-form"
                          EditContext="CompleteResetEditContext"
                          OnSubmit="HandleCompleteResetSubmitAsync"
                          aria-busy="@IsSubmitting">
                    <DataAnnotationsValidator />

                    <div class="login-field">
                        <label class="form-label" for="reset-password">Nuwe wagwoord</label>
                        <InputText id="reset-password"
                                   class="form-control"
                                   type="password"
                                   autocomplete="new-password"
                                   @bind-Value="CompleteResetForm.Password" />
                        <ValidationMessage class="invalid-feedback d-block" For="@(() => CompleteResetForm.Password)" />
                    </div>

                    <div class="login-field">
                        <label class="form-label" for="reset-password-confirm">Bevestig nuwe wagwoord</label>
                        <InputText id="reset-password-confirm"
                                   class="form-control"
                                   type="password"
                                   autocomplete="new-password"
                                   @bind-Value="CompleteResetForm.ConfirmPassword" />
                        <ValidationMessage class="invalid-feedback d-block" For="@(() => CompleteResetForm.ConfirmPassword)" />
                    </div>

                    <div class="reset-actions">
                        <button type="submit" class="login-submit" disabled="@IsSubmitting">
                            @(IsSubmitting ? "Besig..." : "Stoor nuwe wagwoord")
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(StatusMessage))
                    {
                        <p class="@($"login-status {(StatusIsSuccess ? "login-status-success" : "login-status-error")}")"
                           role="@(StatusIsSuccess ? "status" : "alert")"
                           aria-live="polite">
                            @StatusMessage
                        </p>
                    }
                </EditForm>
            }
            else
            {
                <p class="login-kicker">Herstel wagwoord</p>
                <p class="login-intro">
                    Vul jou e-posadres in en ons stuur vir jou 'n herstel-skakel.
                </p>

                <EditForm FormName="request-password-reset-form"
                          class="login-form"
                          EditContext="RequestResetEditContext"
                          OnSubmit="HandleRequestResetSubmitAsync"
                          aria-busy="@IsSubmitting">
                    <DataAnnotationsValidator />

                    <div class="login-field">
                        <label class="form-label" for="reset-email">E-pos</label>
                        <InputText id="reset-email"
                                   class="form-control"
                                   type="email"
                                   autocomplete="email"
                                   @bind-Value="RequestResetForm.Email" />
                        <ValidationMessage class="invalid-feedback d-block" For="@(() => RequestResetForm.Email)" />
                    </div>

                    <div class="reset-actions">
                        <button type="submit" class="login-submit" disabled="@IsSubmitting">
                            @(IsSubmitting ? "Besig..." : "Stuur herstel-skakel")
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(StatusMessage))
                    {
                        <p class="@($"login-status {(StatusIsSuccess ? "login-status-success" : "login-status-error")}")"
                           role="@(StatusIsSuccess ? "status" : "alert")"
                           aria-live="polite">
                            @StatusMessage
                        </p>
                    }
                </EditForm>
            }

            <div class="reset-links">
                <a class="login-link" href="@SignInHref">Terug na teken in</a>
                <a class="login-link" href="@SignUpHref">Skep rekening</a>
            </div>
        </article>
    </div>
</section>

@code {
    private RequestPasswordResetFormModel RequestResetForm { get; set; } = new();
    private CompletePasswordResetFormModel CompleteResetForm { get; set; } = new();
    private EditContext RequestResetEditContext { get; set; } = default!;
    private EditContext CompleteResetEditContext { get; set; } = default!;
    private IJSObjectReference? _authModule;
    private bool IsRecoveryStatePending { get; set; } = true;
    private bool HasRecoverySession { get; set; }
    private bool IsSubmitting { get; set; }
    private bool StatusIsSuccess { get; set; }
    private string? StatusMessage { get; set; }
    private string? RecoveryAccessToken { get; set; }
    private string? RecoveryRefreshToken { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private string SignInHref =>
        GetSafeReturnUrl(ReturnUrl) is { } safeReturnUrl
            ? $"/teken-in?returnUrl={Uri.EscapeDataString(safeReturnUrl)}"
            : "/teken-in";

    private string SignUpHref =>
        GetSafeReturnUrl(ReturnUrl) is { } safeReturnUrl
            ? $"/teken-op?returnUrl={Uri.EscapeDataString(safeReturnUrl)}"
            : "/teken-op";

    private string PageHeading =>
        HasRecoverySession
            ? "Kies 'n nuwe wagwoord"
            : "Herstel jou wagwoord";

    private string PageIntro =>
        HasRecoverySession
            ? "Jou herstel-skakel is bevestig. Stoor nou 'n nuwe wagwoord om weer toegang te kry."
            : "As jy jou wagwoord vergeet het, stuur ons vir jou 'n eenmalige herstel-skakel per e-pos.";

    protected override void OnInitialized()
    {
        RequestResetEditContext = new EditContext(RequestResetForm);
        CompleteResetEditContext = new EditContext(CompleteResetForm);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            var authModule = await EnsureAuthModuleAsync();
            var recoveryState = await authModule.InvokeAsync<RecoveryBrowserState>("readSupabaseRecoveryState");

            var hasRecoveryType = string.IsNullOrWhiteSpace(recoveryState.Type) ||
                                  string.Equals(recoveryState.Type, "recovery", StringComparison.OrdinalIgnoreCase);
            var hasTokens = !string.IsNullOrWhiteSpace(recoveryState.AccessToken) &&
                            !string.IsNullOrWhiteSpace(recoveryState.RefreshToken);

            if (hasRecoveryType && hasTokens)
            {
                HasRecoverySession = true;
                RecoveryAccessToken = recoveryState.AccessToken;
                RecoveryRefreshToken = recoveryState.RefreshToken;
                StatusMessage = null;
            }
            else if (!string.IsNullOrWhiteSpace(recoveryState.ErrorDescription))
            {
                StatusIsSuccess = false;
                StatusMessage = recoveryState.ErrorDescription.Trim();
            }
        }
        catch
        {
            // Keep the email request form available even if the browser helper fails.
        }
        finally
        {
            IsRecoveryStatePending = false;
            StateHasChanged();
        }
    }

    private async Task HandleRequestResetSubmitAsync(EditContext editContext)
    {
        await SyncRequestInputsFromDomAsync();

        if (!editContext.Validate())
        {
            return;
        }

        if (IsSubmitting)
        {
            return;
        }

        IsSubmitting = true;
        StatusMessage = null;
        StatusIsSuccess = false;
        await ShowSubmittingStateAsync();

        try
        {
            var authModule = await EnsureAuthModuleAsync();
            var response = await authModule.InvokeAsync<AuthBrowserResponse>(
                "postAuthJson",
                "/api/auth/password-reset/request",
                new RequestPasswordResetPayload(RequestResetForm.Email.Trim(), GetSafeReturnUrl(ReturnUrl)));

            StatusIsSuccess = response.Ok;
            StatusMessage = response.Message ?? (response.Ok
                ? "As daardie e-pos by Schink geregistreer is, het ons vir jou 'n herstel-skakel gestuur."
                : "Kon nie nou 'n herstel-skakel stuur nie. Probeer asseblief weer.");
        }
        catch
        {
            StatusIsSuccess = false;
            StatusMessage = "Kon nie nou 'n herstel-skakel stuur nie. Probeer asseblief weer.";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task HandleCompleteResetSubmitAsync(EditContext editContext)
    {
        await SyncCompleteInputsFromDomAsync();

        if (!editContext.Validate())
        {
            return;
        }

        if (IsSubmitting)
        {
            return;
        }

        IsSubmitting = true;
        StatusMessage = null;
        StatusIsSuccess = false;
        await ShowSubmittingStateAsync();

        try
        {
            var authModule = await EnsureAuthModuleAsync();
            var response = await authModule.InvokeAsync<AuthBrowserResponse>(
                "postAuthJson",
                "/api/auth/password-reset/complete",
                new CompletePasswordResetPayload(
                    RecoveryAccessToken,
                    RecoveryRefreshToken,
                    CompleteResetForm.Password));

            if (response.Ok)
            {
                StatusIsSuccess = true;
                StatusMessage = response.Message ?? "Jou wagwoord is suksesvol opgedateer.";
                await RedirectToTargetAsync(BuildPostResetSignInHref());
                return;
            }

            StatusIsSuccess = false;
            StatusMessage = response.Message ?? "Kon nie jou wagwoord nou opdateer nie. Probeer asseblief weer.";
        }
        catch
        {
            StatusIsSuccess = false;
            StatusMessage = "Kon nie jou wagwoord nou opdateer nie. Probeer asseblief weer.";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task SyncRequestInputsFromDomAsync()
    {
        try
        {
            var authModule = await EnsureAuthModuleAsync();
            var values = await authModule.InvokeAsync<Dictionary<string, string>>(
                "readInputValues",
                new[] { "reset-email" });

            if (values.TryGetValue("reset-email", out var emailValue))
            {
                RequestResetForm.Email = emailValue?.Trim() ?? string.Empty;
            }
        }
        catch
        {
            // Keep existing bound values if DOM reads fail.
        }
    }

    private async Task SyncCompleteInputsFromDomAsync()
    {
        try
        {
            var authModule = await EnsureAuthModuleAsync();
            var values = await authModule.InvokeAsync<Dictionary<string, string>>(
                "readInputValues",
                new[] { "reset-password", "reset-password-confirm" });

            if (values.TryGetValue("reset-password", out var passwordValue))
            {
                CompleteResetForm.Password = passwordValue ?? string.Empty;
            }

            if (values.TryGetValue("reset-password-confirm", out var confirmPasswordValue))
            {
                CompleteResetForm.ConfirmPassword = confirmPasswordValue ?? string.Empty;
            }
        }
        catch
        {
            // Keep existing bound values if DOM reads fail.
        }
    }

    private async Task ShowSubmittingStateAsync()
    {
        StateHasChanged();
        await Task.Yield();
    }

    private string BuildPostResetSignInHref()
    {
        var queryValues = new Dictionary<string, string?>
        {
            ["reset"] = "success"
        };

        if (GetSafeReturnUrl(ReturnUrl) is { } safeReturnUrl)
        {
            queryValues["returnUrl"] = safeReturnUrl;
        }

        return QueryHelpers.AddQueryString("/teken-in", queryValues);
    }

    private async Task RedirectToTargetAsync(string target)
    {
        var safeTarget = string.IsNullOrWhiteSpace(target) ? "/teken-in?reset=success" : target;

        try
        {
            var authModule = await EnsureAuthModuleAsync();
            await authModule.InvokeVoidAsync("redirectTo", safeTarget);
        }
        catch
        {
            NavigationManager.NavigateTo(safeTarget, forceLoad: true);
        }
    }

    private async Task<IJSObjectReference> EnsureAuthModuleAsync()
    {
        if (_authModule is not null)
        {
            return _authModule;
        }

        _authModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/auth-browser.js");
        return _authModule;
    }

    private static string? GetSafeReturnUrl(string? returnUrl)
    {
        var normalizedReturnUrl = NormalizeReturnUrl(returnUrl);
        if (string.IsNullOrWhiteSpace(normalizedReturnUrl))
        {
            return null;
        }

        if (!normalizedReturnUrl.StartsWith("/", StringComparison.Ordinal) ||
            normalizedReturnUrl.StartsWith("//", StringComparison.Ordinal) ||
            IsAuthEntryPath(normalizedReturnUrl))
        {
            return null;
        }

        return normalizedReturnUrl;
    }

    private static bool IsAuthEntryPath(string path) =>
        path.StartsWith("/teken-in", StringComparison.OrdinalIgnoreCase) ||
        path.StartsWith("/teken-op", StringComparison.OrdinalIgnoreCase) ||
        path.StartsWith("/herstel-wagwoord", StringComparison.OrdinalIgnoreCase);

    private static string? NormalizeReturnUrl(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var candidate = value.Trim();
        for (var index = 0; index < 2; index++)
        {
            if (candidate.StartsWith("/", StringComparison.Ordinal))
            {
                break;
            }

            if (!candidate.Contains('%', StringComparison.Ordinal))
            {
                break;
            }

            try
            {
                candidate = Uri.UnescapeDataString(candidate);
            }
            catch
            {
                break;
            }
        }

        return candidate;
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_authModule is not null)
            {
                await _authModule.DisposeAsync();
            }
        }
        catch
        {
            // Ignore module disposal failures.
        }
    }

    private sealed record RecoveryBrowserState(
        string? AccessToken,
        string? RefreshToken,
        string? Type,
        string? ErrorCode,
        string? ErrorDescription);

    private sealed record AuthBrowserResponse(bool Ok, int Status, string? Message, string? RedirectPath);

    private sealed record RequestPasswordResetPayload(string Email, string? ReturnUrl);

    private sealed record CompletePasswordResetPayload(string? AccessToken, string? RefreshToken, string Password);

    private sealed class RequestPasswordResetFormModel
    {
        [Required(ErrorMessage = "Vul asseblief jou e-pos in.")]
        [EmailAddress(ErrorMessage = "Gebruik asseblief 'n geldige e-posadres.")]
        [StringLength(254)]
        public string Email { get; set; } = string.Empty;
    }

    private sealed class CompletePasswordResetFormModel
    {
        [Required(ErrorMessage = "Vul asseblief jou nuwe wagwoord in.")]
        [StringLength(200, MinimumLength = 6, ErrorMessage = "Jou wagwoord moet tussen 6 en 200 karakters wees.")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Bevestig asseblief jou nuwe wagwoord.")]
        [Compare(nameof(Password), ErrorMessage = "Die wagwoorde stem nie ooreen nie.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
