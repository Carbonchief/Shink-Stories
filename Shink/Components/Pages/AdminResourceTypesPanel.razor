<section class="admin-section">
    <div class="admin-section-head">
        <div class="admin-search">
            <input class="resource-types-admin-search"
                   type="search"
                   @bind="ResourceTypeSearch"
                   @bind:event="oninput"
                   placeholder="@T("Soek naam of slug", "Search name or slug")" />
            <MudButton Class="admin-btn admin-btn-secondary admin-icon-btn resource-types-admin-new-action-btn"
                       Variant="Variant.Outlined"
                       Color="Color.Primary"
                       OnClick="BeginCreateResourceType"
                       aria-label='@T("Nuwe tipe", "New type")'
                       title='@T("Nuwe tipe", "New type")'>
                <i class="fa-solid fa-plus" aria-hidden="true"></i>
            </MudButton>
            <MudButton Class="admin-btn admin-btn-secondary admin-icon-btn"
                       Variant="Variant.Outlined"
                       Color="Color.Primary"
                       OnClick="@(() => ReloadAsync())"
                       aria-label='@T("Herlaai", "Refresh")'
                       title='@T("Herlaai", "Refresh")'>
                <i class="fa-solid fa-arrows-rotate" aria-hidden="true"></i>
                <span class="sr-only">@T("Herlaai", "Refresh")</span>
            </MudButton>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <p class="admin-feedback is-error">@ErrorMessage</p>
    }
    else if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <p class="admin-feedback is-success">@StatusMessage</p>
    }

    @if (IsLoading)
    {
        <section class="admin-state">
            <h2>@T("Laai hulpbronne...", "Loading resources...")</h2>
        </section>
    }
    else
    {
        <div class="resource-types-admin-layout">
            <aside class="resource-types-admin-list">
                <div class="resource-types-admin-list-header">
                    <span>@FilteredResourceTypes.Count @T("tipes", "types")</span>
                </div>

                @if (FilteredResourceTypes.Count == 0)
                {
                    <p class="resource-types-admin-empty">@T("Geen hulpbron tipes pas by jou soektog nie.", "No resource types match your search.")</p>
                }
                else
                {
                    @foreach (var resourceType in FilteredResourceTypes)
                    {
                        var isSelected = Editor?.ResourceTypeId == resourceType.ResourceTypeId;
                        <button type="button"
                                class="resource-types-admin-list-item @(isSelected ? "is-selected" : null)"
                                @onclick="() => SelectResourceTypeAsync(resourceType)">
                            <span class="resource-types-admin-list-copy">
                                <span class="resource-types-admin-list-title">@resourceType.Name</span>
                                <span class="resource-types-admin-list-meta">@resourceType.Slug</span>
                                <span class="resource-types-admin-list-status">
                                    @(resourceType.IsEnabled ? T("Aktief", "Enabled") : T("Af", "Disabled"))
                                    ·
                                    @(resourceType.DocumentCount == 1
                                        ? T("1 dokument", "1 document")
                                        : T($"{resourceType.DocumentCount} dokumente", $"{resourceType.DocumentCount} documents"))
                                </span>
                            </span>
                        </button>
                    }
                }
            </aside>

            <section class="resource-types-admin-editor">
                @if (Editor is null)
                {
                    <div class="resource-types-admin-empty-state">
                        <h3>@T("Kies 'n tipe", "Choose a type")</h3>
                        <p>@T("Maak links 'n bestaande tipe oop of skep 'n nuwe een.", "Open an existing type on the left or create a new one.")</p>
                    </div>
                }
                else
                {
                    <div class="resource-types-admin-editor-head">
                        <div>
                            <h3>@(IsNewResourceType ? T("Nuwe hulpbron tipe", "New resource type") : Editor.Name)</h3>
                            <p>@Editor.SlugPreview</p>
                        </div>
                        <div class="resource-types-admin-editor-actions">
                            @if (!IsNewResourceType)
                            {
                                <button type="button"
                                        class="resource-types-admin-btn resource-types-admin-btn-danger resource-types-admin-btn-icon"
                                        @onclick="DeleteResourceTypeAsync"
                                        disabled="@IsDeleting"
                                        aria-label="@(IsDeleting ? T("Verwyder tipe...", "Deleting type...") : T("Verwyder tipe", "Delete type"))"
                                        title="@(IsDeleting ? T("Verwyder tipe...", "Deleting type...") : T("Verwyder tipe", "Delete type"))">
                                    @if (IsDeleting)
                                    {
                                        <i class="fa-solid fa-spinner fa-spin" aria-hidden="true"></i>
                                        <span class="sr-only">@T("Verwyder tipe...", "Deleting type...")</span>
                                    }
                                    else
                                    {
                                        <i class="fa-solid fa-trash-can" aria-hidden="true"></i>
                                        <span class="sr-only">@T("Verwyder tipe", "Delete type")</span>
                                    }
                                </button>
                            }
                            <button type="button"
                                    class="resource-types-admin-btn resource-types-admin-btn-icon"
                                    @onclick="SaveResourceTypeAsync"
                                    disabled="@IsSaving"
                                    aria-label="@(IsSaving ? T("Stoor tipe...", "Saving type...") : T("Stoor tipe", "Save type"))"
                                    title="@(IsSaving ? T("Stoor tipe...", "Saving type...") : T("Stoor tipe", "Save type"))">
                                @if (IsSaving)
                                {
                                    <i class="fa-solid fa-spinner fa-spin" aria-hidden="true"></i>
                                    <span class="sr-only">@T("Stoor tipe...", "Saving type...")</span>
                                }
                                else
                                {
                                    <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                                    <span class="sr-only">@T("Stoor tipe", "Save type")</span>
                                }
                            </button>
                        </div>
                    </div>

                    <div class="resource-types-admin-form-grid">
                        <section class="resource-types-admin-card">
                            <h4>@T("Basies", "Basics")</h4>

                            <label class="resource-types-admin-field">
                                <span>@T("Naam", "Name")</span>
                                <input type="text" @bind="Editor.Name" />
                            </label>

                            <label class="resource-types-admin-field">
                                <span>@T("Slug", "Slug")</span>
                                <input type="text" @bind="Editor.Slug" />
                            </label>

                            <label class="resource-types-admin-field">
                                <span>@T("Beskrywing", "Description")</span>
                                <textarea rows="3" @bind="Editor.Description"></textarea>
                            </label>

                            <div class="resource-types-admin-field-row">
                                <label class="resource-types-admin-field">
                                    <span>@T("Sorteer", "Sort order")</span>
                                    <input type="number" @bind="Editor.SortOrder" />
                                </label>

                                <label class="resource-types-admin-checkbox">
                                    <input type="checkbox" @bind="Editor.IsEnabled" />
                                    <span>@T("Wys op hulpbronne blad", "Show on resources page")</span>
                                </label>
                            </div>
                        </section>

                        <section class="resource-types-admin-card">
                            <h4>@T("Opsomming", "Summary")</h4>

                            <dl class="resource-types-admin-summary">
                                <div>
                                    <dt>@T("Dokumente", "Documents")</dt>
                                    <dd>@(Editor.DocumentCount == 1 ? T("1 dokument", "1 document") : T($"{Editor.DocumentCount} dokumente", $"{Editor.DocumentCount} documents"))</dd>
                                </div>
                                <div>
                                    <dt>@T("Blad skakel", "Page link")</dt>
                                    <dd>/resources?tipe=@Editor.SlugPreview</dd>
                                </div>
                                <div>
                                    <dt>@T("Stoorlaag", "Storage layer")</dt>
                                    <dd>@T("Cloudflare R2 + Supabase metadata", "Cloudflare R2 + Supabase metadata")</dd>
                                </div>
                            </dl>

                            <p class="resource-types-admin-hint">
                                @T("Laai PDF's per hulpbron tipe op. Die lêers word in Cloudflare R2 gestoor en die metadata word in Supabase gehou vir vinniger soek en bestuur.",
                                    "Upload PDFs per resource type. Files are stored in Cloudflare R2 and the metadata is kept in Supabase for easier search and management.")
                            </p>
                        </section>

                        <section class="resource-types-admin-card resource-types-admin-card-full">
                            <div class="resource-types-admin-card-head">
                                <div>
                                    <h4>@T("Laai hulpbronne op", "Upload resources")</h4>
                                    <p class="resource-types-admin-hint">
                                        @T("Kies een of meer PDF's vir hierdie tipe. Hierdie bulk upload stoor elke dokument se metadata ook in Supabase.",
                                            "Choose one or more PDFs for this type. This bulk upload also stores each document's metadata in Supabase.")
                                    </p>
                                </div>
                                <div class="resource-types-admin-upload-actions">
                                    <button type="button"
                                            class="resource-types-admin-btn resource-types-admin-btn-icon"
                                            @onclick="UploadSelectedDocumentsAsync"
                                            disabled="@(IsUploading || !CanUploadDocuments)"
                                            aria-label='@(IsUploading ? T("Laai PDFs op...", "Uploading PDFs...") : T("Laai gekose PDFs op", "Upload selected PDFs"))'
                                            title='@(IsUploading ? T("Laai PDFs op...", "Uploading PDFs...") : T("Laai gekose PDFs op", "Upload selected PDFs"))'>
                                        @if (IsUploading)
                                        {
                                            <i class="fa-solid fa-spinner fa-spin" aria-hidden="true"></i>
                                            <span class="sr-only">@T("Laai PDFs op...", "Uploading PDFs...")</span>
                                        }
                                        else
                                        {
                                            <i class="fa-solid fa-cloud-arrow-up" aria-hidden="true"></i>
                                            <span class="sr-only">@T("Laai gekose PDFs op", "Upload selected PDFs")</span>
                                        }
                                    </button>
                                    <button type="button"
                                            class="resource-types-admin-btn resource-types-admin-btn-secondary resource-types-admin-btn-icon"
                                            @onclick="ClearSelectedFiles"
                                            disabled="@(IsUploading || SelectedFiles.Count == 0)"
                                            aria-label='@T("Maak skoon", "Clear")'
                                            title='@T("Maak skoon", "Clear")'>
                                        <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                                        <span class="sr-only">@T("Maak skoon", "Clear")</span>
                                    </button>
                                </div>
                            </div>

                            @if (IsNewResourceType)
                            {
                                <div class="resource-types-admin-empty-state resource-types-admin-inline-empty">
                                    <h3>@T("Stoor eers die tipe", "Save the type first")</h3>
                                    <p>@T("Jy kan dokumente begin oplaai sodra die hulpbron tipe eers gestoor is.", "You can start uploading documents as soon as the resource type has been saved first.")</p>
                                </div>
                            }
                            else
                            {
                                <label class="resource-types-admin-upload-btn">
                                    @T("Kies PDF's", "Choose PDFs")
                                    <InputFile class="resource-types-admin-file-input"
                                               OnChange="OnResourceFilesSelected"
                                               accept=".pdf,application/pdf"
                                               multiple />
                                </label>
                                <p class="resource-types-admin-upload-hint">@BuildSelectedFilesHint()</p>

                                @if (SelectedFiles.Count > 0)
                                {
                                    <ul class="resource-types-admin-file-list">
                                        @foreach (var file in SelectedFiles)
                                        {
                                            <li>@file.Name <span>@FormatFileSize(file.Size)</span></li>
                                        }
                                    </ul>
                                }
                            }
                        </section>

                        <section class="resource-types-admin-card resource-types-admin-card-full">
                            <div class="resource-types-admin-card-head">
                                <div>
                                    <h4>@T("Dokumente", "Documents")</h4>
                                    <p class="resource-types-admin-hint">
                                        @(Editor.DocumentCount == 1
                                            ? T("1 dokument in hierdie tipe.", "1 document in this type.")
                                            : T($"{Editor.DocumentCount} dokumente in hierdie tipe.", $"{Editor.DocumentCount} documents in this type."))
                                    </p>
                                </div>
                                <input class="resource-types-admin-document-search"
                                       type="search"
                                       @bind="DocumentSearch"
                                       @bind:event="oninput"
                                       placeholder="@T("Soek titel, slug of file", "Search title, slug or file")"
                                       disabled="@IsNewResourceType" />
                            </div>

                            @if (IsNewResourceType)
                            {
                                <div class="resource-types-admin-empty-state resource-types-admin-inline-empty">
                                    <h3>@T("Nog geen dokumente nie", "No documents yet")</h3>
                                    <p>@T("Hierdie lys word beskikbaar sodra die tipe gestoor is.", "This list becomes available once the type has been saved.")</p>
                                </div>
                            }
                            else if (IsLoadingDocuments)
                            {
                                <div class="resource-types-admin-empty-state resource-types-admin-inline-empty">
                                    <h3>@T("Laai dokumente...", "Loading documents...")</h3>
                                </div>
                            }
                            else if (FilteredDocuments.Count == 0)
                            {
                                <div class="resource-types-admin-empty-state resource-types-admin-inline-empty">
                                    <h3>@T("Nog geen dokumente nie", "No documents yet")</h3>
                                    <p>@T("Laai jou eerste PDF vir hierdie tipe op, of pas die dokument-soektog aan.", "Upload your first PDF for this type, or adjust the document search.")</p>
                                </div>
                            }
                            else
                            {
                                <div class="resource-types-admin-documents">
                                    @foreach (var document in FilteredDocuments)
                                    {
                                        var isDeletingDocument = DeletingDocumentIds.Contains(document.ResourceDocumentId);
                                        var isUpdatingDocumentTier = UpdatingDocumentTierIds.Contains(document.ResourceDocumentId);
                                        var isDocumentBusy = isDeletingDocument || isUpdatingDocumentTier;
                                        <article class="resource-types-admin-document-item">
                                            <div class="resource-types-admin-document-copy">
                                                <h5>@document.Title</h5>
                                                <p>@document.FileName</p>
                                                <span>@BuildDocumentMeta(document)</span>
                                            </div>
                                            <div class="resource-types-admin-document-actions">
                                                <label class="resource-types-admin-document-tier-field">
                                                    <span>@T("Toegangsvlak", "Access tier")</span>
                                                    <select value="@ResolveDocumentTierSelectionValue(document.RequiredTierCode)"
                                                            @onchange="args => UpdateDocumentAccessTierAsync(document, args.Value?.ToString())"
                                                            disabled="@isDocumentBusy">
                                                        @foreach (var option in BuildDocumentTierOptions(document))
                                                        {
                                                            <option value="@option.Value">@option.Label</option>
                                                        }
                                                    </select>
                                                </label>
                                                <span class="resource-types-admin-status-tag @(document.IsEnabled ? "is-enabled" : "is-disabled")"
                                                      role="status"
                                                      aria-label="@(document.IsEnabled ? T("Aktief", "Enabled") : T("Af", "Disabled"))"
                                                      title="@(document.IsEnabled ? T("Aktief", "Enabled") : T("Af", "Disabled"))">
                                                    <i class="fa-solid @(document.IsEnabled ? "fa-circle-check" : "fa-circle-xmark")" aria-hidden="true"></i>
                                                    <span class="sr-only">@(document.IsEnabled ? T("Aktief", "Enabled") : T("Af", "Disabled"))</span>
                                                </span>
                                                <button type="button"
                                                        class="resource-types-admin-btn resource-types-admin-btn-danger resource-types-admin-btn-icon"
                                                        @onclick="() => DeleteDocumentAsync(document)"
                                                        disabled="@isDocumentBusy"
                                                        aria-label="@(isDeletingDocument ? T("Verwyder dokument...", "Deleting document...") : T("Verwyder dokument", "Delete document"))"
                                                        title="@(isDeletingDocument ? T("Verwyder dokument...", "Deleting document...") : T("Verwyder dokument", "Delete document"))">
                                                    @if (isDeletingDocument)
                                                    {
                                                        <i class="fa-solid fa-spinner fa-spin" aria-hidden="true"></i>
                                                        <span class="sr-only">@T("Verwyder dokument...", "Deleting document...")</span>
                                                    }
                                                    else
                                                    {
                                                        <i class="fa-solid fa-trash-can" aria-hidden="true"></i>
                                                        <span class="sr-only">@T("Verwyder dokument", "Delete document")</span>
                                                    }
                                                </button>
                                            </div>
                                        </article>
                                    }
                                </div>
                            }
                        </section>
                    </div>
                }
            </section>
        </div>
    }
</section>
