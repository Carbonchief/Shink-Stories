<script type="module" src="@Assets["Components/Layout/MainLayout.razor.js"]"></script>

<div id="blazor-error-ui" data-nosnippet>
    <strong class="blazor-error-title" data-blazor-error-title>An unhandled error has occurred.</strong>
    <p class="blazor-error-detail" data-blazor-error-detail hidden></p>
    <details class="blazor-error-diagnostics" data-blazor-error-diagnostics hidden>
        <summary>Diagnostics</summary>
        <pre data-blazor-error-pre></pre>
    </details>
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    private string LoginHref
    {
        get
        {
            var currentUri = new Uri(NavigationManager.Uri);
            var currentPathAndQuery = currentUri.PathAndQuery;
            if (string.Equals(currentPathAndQuery, "/teken-in", StringComparison.OrdinalIgnoreCase) ||
                currentPathAndQuery.StartsWith("/teken-in?", StringComparison.OrdinalIgnoreCase))
            {
                return "/teken-in";
            }

            if (string.Equals(currentPathAndQuery, "/", StringComparison.Ordinal))
            {
                return "/teken-in";
            }

            return $"/teken-in?returnUrl={Uri.EscapeDataString(currentPathAndQuery)}";
        }
    }

    private bool IsStoryRoute
    {
        get
        {
