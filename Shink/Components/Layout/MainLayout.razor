@inherits LayoutComponentBase

<div class="site-shell">
    <header class="site-header">
        <div class="site-container nav-wrap">
            <a class="brand-link" href="/">
                <img class="brand-wordmark" src="/branding/schink-logo-text.png" alt="Schink Stories" />
            </a>
            <nav class="site-nav" aria-label="Main navigation">
                <NavLink href="/meer-oor-ons">Meer oor Ons</NavLink>
                <NavLink href="/gratis">Gratis stories</NavLink>
            </nav>
        </div>
    </header>

    <main class="site-main">
        <div class="site-container">
            @Body
        </div>
    </main>

    <footer class="site-footer">
        <div class="site-container footer-wrap">
            <a class="footer-brand" href="/">
                <img class="brand-wordmark" src="/branding/schink-logo-text.png" alt="Schink Stories" />
            </a>
            <nav class="footer-socials" aria-label="Social links">
                <a href="https://www.facebook.com/SchinkPublishing" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M13.5 21v-8h2.7l.4-3h-3.1V8.1c0-.9.3-1.5 1.6-1.5h1.7V3.9c-.3 0-1.3-.1-2.4-.1-2.4 0-4 1.5-4 4.2V10H8v3h2.4v8h3.1Z" />
                    </svg>
                </a>
                <a href="https://www.instagram.com/schinkpublishing/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9a5.5 5.5 0 0 1-5.5 5.5h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2Zm0 2A3.5 3.5 0 0 0 4 7.5v9A3.5 3.5 0 0 0 7.5 20h9a3.5 3.5 0 0 0 3.5-3.5v-9A3.5 3.5 0 0 0 16.5 4h-9Zm9.75 1.5a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z" />
                    </svg>
                </a>
            </nav>
            <p>© 2023 Schink</p>
        </div>
    </footer>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

