                            <form class="site-search-form" role="search" action="/soek" method="get" data-search-form>
                                <button type="button"
                                        class="site-search-toggle"
                                        data-search-toggle
                                        aria-expanded="false"
                                        aria-controls="site-nav-search-auth"
                                        aria-label="Soek op die webwerf"
                                        title="Soek op die webwerf">
                                    <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                                    <span class="sr-only">Soek op die webwerf</span>
                                </button>
                                <div class="site-search-fields">
                                    <label class="sr-only" for="site-nav-search-auth">Soek op die webwerf</label>
                                    <input id="site-nav-search-auth"
                                           class="site-search-input"
                                           data-search-input
                                           type="search"
                                           name="q"
                                           placeholder="Soek op die webwerf"
