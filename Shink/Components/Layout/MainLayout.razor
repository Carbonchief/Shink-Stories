@using Microsoft.AspNetCore.Components.Authorization
@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<div class="site-shell @(IsStoryRoute ? "story-route" : null) @(IsHomeRoute ? "home-route" : null)">
    <a class="skip-link" href="#main-content">Spring na inhoud</a>
    <header class="site-header">
        <div class="site-container nav-wrap">
            <AuthorizeView>
                <Authorized>
                    <a class="brand-link" href="/?home=1">
                        <img class="brand-wordmark" src="/branding/schink-logo-text.png" alt="Schink Stories"
                             width="199" height="99" loading="eager" decoding="async" />
                    </a>
                </Authorized>
                <NotAuthorized>
                    <a class="brand-link" href="/">
                        <img class="brand-wordmark" src="/branding/schink-logo-text.png" alt="Schink Stories"
                             width="199" height="99" loading="eager" decoding="async" />
                    </a>
                </NotAuthorized>
            </AuthorizeView>
            <AuthorizeView>
                <Authorized>
                    <div class="nav-controls">
                        <button type="button" class="nav-menu-toggle" data-nav-menu-toggle
                                aria-controls="main-site-nav" aria-expanded="false"
                                aria-label="Maak navigasie oop"
                                title="Maak navigasie oop">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M4 7h16v2H4V7zm0 4h16v2H4v-2zm0 4h16v2H4v-2z" />
                            </svg>
                            <span class="sr-only" data-nav-menu-toggle-label>Maak navigasie oop</span>
                        </button>
                        <nav id="main-site-nav"
                             class="site-nav"
                             aria-label="Hoofnavigasie">
                            <NavLink href="/meer-oor-ons">Meer oor Ons</NavLink>
                            <NavLink href="/gratis">Gratis stories</NavLink>
                            <NavLink href="/luister">Alle stories</NavLink>
                            <NavLink href="/opsies">Opsies</NavLink>
                            <NavLink href="/teken-uit">Teken uit</NavLink>
                        </nav>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <a class="header-signin-btn" href="@LoginHref">Teken in</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </header>

    <main id="main-content" class="site-main" tabindex="-1">
        <div class="site-container">
            @Body
        </div>
    </main>

    <footer class="site-footer">
        <div class="site-container footer-wrap">
            <a class="footer-brand" href="/">
                <img class="brand-wordmark" src="/branding/schink-logo-text.png" alt="Schink Stories"
                     width="199" height="99" loading="lazy" decoding="async" />
            </a>
            <p class="footer-tagline">Motiveer. Leer. Inspireer.</p>
            <nav class="footer-socials" aria-label="Sosiale skakels">
                <a href="https://www.facebook.com/SchinkPublishing" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M13.5 21v-8h2.7l.4-3h-3.1V8.1c0-.9.3-1.5 1.6-1.5h1.7V3.9c-.3 0-1.3-.1-2.4-.1-2.4 0-4 1.5-4 4.2V10H8v3h2.4v8h3.1Z" />
                    </svg>
                </a>
                <a href="https://www.instagram.com/schinkpublishing/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9a5.5 5.5 0 0 1-5.5 5.5h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2Zm0 2A3.5 3.5 0 0 0 4 7.5v9A3.5 3.5 0 0 0 7.5 20h9a3.5 3.5 0 0 0 3.5-3.5v-9A3.5 3.5 0 0 0 16.5 4h-9Zm9.75 1.5a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z" />
                    </svg>
                </a>
            </nav>
            <p>© 2023 Schink</p>
        </div>
    </footer>
</div>

<script type="module" src="@Assets["Components/Layout/MainLayout.razor.js"]"></script>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    private string LoginHref
    {
        get
        {
            var currentUri = new Uri(NavigationManager.Uri);
            var currentPathAndQuery = currentUri.PathAndQuery;
            if (string.Equals(currentPathAndQuery, "/teken-in", StringComparison.OrdinalIgnoreCase) ||
                currentPathAndQuery.StartsWith("/teken-in?", StringComparison.OrdinalIgnoreCase))
            {
                return "/teken-in";
            }

            if (string.Equals(currentPathAndQuery, "/", StringComparison.Ordinal))
            {
                return "/teken-in";
            }

            return $"/teken-in?returnUrl={Uri.EscapeDataString(currentPathAndQuery)}";
        }
    }

    private bool IsStoryRoute
    {
        get
        {
            var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Trim('/');
            return relativePath.StartsWith("gratis/", StringComparison.OrdinalIgnoreCase) ||
                   relativePath.StartsWith("luister/", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool IsHomeRoute
    {
        get
        {
            var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Trim('/');
            return string.IsNullOrWhiteSpace(relativePath);
        }
    }
}
