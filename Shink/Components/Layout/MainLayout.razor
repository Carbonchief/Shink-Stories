@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.WebUtilities
@inherits LayoutComponentBase
@using System.Security.Claims
@inject NavigationManager NavigationManager

<div class="site-shell @(IsStoryRoute ? "story-route" : null) @(IsHomeRoute ? "home-route" : null) @(IsLuisterRoute ? "luister-route" : null) @(IsMeerOorOnsRoute ? "about-route" : null) @((IsWinkelRoute || IsBlogRoute || IsResourcesRoute) ? "store-route" : null) @(IsAdminRoute ? "admin-route" : null) @(IsFloatingPlaylistRoute ? "playlist-nav-route" : null) @(IsLuisterPlaylistShowcaseRoute ? "playlist-showcase-route" : null)">
    <a class="skip-link" href="#main-content">Spring na inhoud</a>
    @if (!IsFloatingPlaylistRoute)
    {
    <header class="site-header">
        @if (IsStoryRoute)
        {
            <div class="site-container story-header-wrap">
                <a class="story-header-back"
                   href="@StoryHeaderBackHref"
                   data-enhance-nav="false"
                   aria-label="@StoryHeaderBackLabel"
                   title="@StoryHeaderBackLabel">
                    <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
                    <span class="sr-only">@StoryHeaderBackLabel</span>
                </a>
                <div class="story-header-title">@StoryHeaderTitle</div>
                @if (IsLuisterStoryRoute)
                {
                    <AuthorizeView>
                        <Authorized>
                            <div class="story-header-menu nav-controls">
                                <form class="site-search-form" role="search" action="/soek" method="get" data-search-form>
                                    <button type="button"
                                            class="site-search-toggle"
                                            data-search-toggle
                                            aria-expanded="false"
                                            aria-controls="site-nav-search-story-auth"
                                            aria-label="Soek op die webwerf"
                                            title="Soek op die webwerf">
                                        <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                                        <span class="sr-only">Soek op die webwerf</span>
                                    </button>
                                    <div class="site-search-fields">
                                        <label class="sr-only" for="site-nav-search-story-auth">Soek op die webwerf</label>
                                        <input id="site-nav-search-story-auth"
                                               class="site-search-input"
                                               data-search-input
                                               type="search"
                                               name="q"
                                               placeholder="Soek op die webwerf"
                                               autocomplete="off" />
                                    </div>
                                    <span class="site-search-loader" data-search-loader hidden aria-live="polite">
                                        <span class="site-search-spinner" aria-hidden="true"></span>
                                        <span class="site-search-loader-text">Soek...</span>
                                    </span>
                                    <section class="site-search-suggestions" data-search-suggestions hidden aria-label="Soek voorstelle">
                                        <div class="site-search-suggestions-list" data-search-suggestions-list></div>
                                    </section>
                                </form>
                                <button type="button"
                                        class="nav-menu-toggle"
                                        data-nav-menu-toggle
                                        aria-controls="story-site-nav"
                                        aria-expanded="false"
                                        onclick="return window.toggleSchinkNavMenu?.(this);"
                                        aria-label="Maak navigasie oop"
                                        title="Maak navigasie oop">
                                    <i class="fa-solid fa-bars" aria-hidden="true"></i>
                                    <span class="sr-only" data-nav-menu-toggle-label>Maak navigasie oop</span>
                                </button>
                                <nav id="story-site-nav"
                                     class="site-nav"
                                     aria-label="Hoofnavigasie">
                                    <NavLink href="/luister">Alle stories</NavLink>
                                    <NavLink href="/karakters">Karakters</NavLink>
                                    <NavLink href="/resources">Hulpbronne</NavLink>
                                    <NavLink href="/blog">Blog</NavLink>
                                    <NavLink href="/meer-oor-ons">Meer oor Ons</NavLink>
                                    <NavLink href="/winkel">Winkel</NavLink>
                                    <NavLink href="/my-stories">My stories</NavLink>
                                </nav>
                            </div>
                        </Authorized>
                        <NotAuthorized>
                            <div class="story-header-menu nav-controls">
                                <form class="site-search-form" role="search" action="/soek" method="get" data-search-form>
                                    <button type="button"
                                            class="site-search-toggle"
                                            data-search-toggle
                                            aria-expanded="false"
                                            aria-controls="site-nav-search-story-guest"
                                            aria-label="Soek op die webwerf"
                                            title="Soek op die webwerf">
                                        <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                                        <span class="sr-only">Soek op die webwerf</span>
                                    </button>
                                    <div class="site-search-fields">
                                        <label class="sr-only" for="site-nav-search-story-guest">Soek op die webwerf</label>
                                        <input id="site-nav-search-story-guest"
                                               class="site-search-input"
                                               data-search-input
                                               type="search"
                                               name="q"
                                               placeholder="Soek op die webwerf"
                                               autocomplete="off" />
                                    </div>
                                    <span class="site-search-loader" data-search-loader hidden aria-live="polite">
                                        <span class="site-search-spinner" aria-hidden="true"></span>
                                        <span class="site-search-loader-text">Soek...</span>
                                    </span>
                                    <section class="site-search-suggestions" data-search-suggestions hidden aria-label="Soek voorstelle">
                                        <div class="site-search-suggestions-list" data-search-suggestions-list></div>
                                    </section>
                                </form>
                                <button type="button"
                                        class="nav-menu-toggle"
                                        data-nav-menu-toggle
                                        aria-controls="story-site-nav"
                                        aria-expanded="false"
                                        onclick="return window.toggleSchinkNavMenu?.(this);"
                                        aria-label="Maak navigasie oop"
                                        title="Maak navigasie oop">
                                    <i class="fa-solid fa-bars" aria-hidden="true"></i>
                                    <span class="sr-only" data-nav-menu-toggle-label>Maak navigasie oop</span>
                                </button>
                                <nav id="story-site-nav"
                                     class="site-nav"
                                     aria-label="Hoofnavigasie">
                                    <NavLink href="/luister">Alle stories</NavLink>
                                    <NavLink href="/karakters">Karakters</NavLink>
                                    <NavLink href="/resources">Hulpbronne</NavLink>
                                    <NavLink href="/blog">Blog</NavLink>
                                    <NavLink href="/meer-oor-ons">Meer oor Ons</NavLink>
                                    <NavLink href="/winkel">Winkel</NavLink>
                                    <NavLink href="/opsies">Opsies</NavLink>
                                    <NavLink href="@LoginHref">Teken in</NavLink>
                                </nav>
                            </div>
                        </NotAuthorized>
                    </AuthorizeView>
                }
                else
                {
                    <div class="story-header-spacer" aria-hidden="true"></div>
                }
            </div>
        }
        else
        {
            <div class="site-container nav-wrap">
                <AuthorizeView>
                    <Authorized>
                        <a class="brand-link" href="/luister">
                            <img class="brand-wordmark" src="/branding/schink-logo-text.png" alt="Schink Stories"
                                 width="199" height="99" loading="eager" decoding="async" />
                        </a>
                    </Authorized>
                    <NotAuthorized>
                        <a class="brand-link" href="/">
                            <img class="brand-wordmark" src="/branding/schink-logo-text.png" alt="Schink Stories"
                                 width="199" height="99" loading="eager" decoding="async" />
                        </a>
                    </NotAuthorized>
                </AuthorizeView>
                <AuthorizeView>
                    <Authorized Context="authState">
