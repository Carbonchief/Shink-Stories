            return relativePath.StartsWith("gratis/", StringComparison.OrdinalIgnoreCase) ||
                   relativePath.StartsWith("luister/", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool IsHomeRoute
    {
        get
        {
            var relativePath = GetCurrentRelativePathWithoutQuery();
            return string.IsNullOrWhiteSpace(relativePath);
        }
    }

    private bool IsLuisterRoute
    {
        get
        {
            var relativePath = GetCurrentRelativePathWithoutQuery();
            return string.Equals(relativePath, "luister", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool IsMeerOorOnsRoute
    {
        get
        {
