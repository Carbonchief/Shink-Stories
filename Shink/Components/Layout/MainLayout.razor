                                    <span class="site-search-spinner" aria-hidden="true"></span>
                                    <span class="site-search-loader-text">Soek...</span>
                                </span>
                                <section class="site-search-suggestions" data-search-suggestions hidden aria-label="Soek voorstelle">
                                    <div class="site-search-suggestions-list" data-search-suggestions-list></div>
                                </section>
                            </form>
                            <div class="notification-center" data-notification-center-root>
                                <button type="button"
                                        class="notification-toggle"
                                        data-notification-toggle
                                        aria-expanded="false"
                                        aria-controls="header-notification-panel"
                                        aria-label="Kennisgewings"
                                        title="Kennisgewings">
                                    <span class="notification-toggle-icon" aria-hidden="true">
                                        <i class="fa-solid fa-bell" aria-hidden="true"></i>
                                        <span class="notification-badge" data-notification-count hidden>0</span>
                                    </span>
                                    <span class="sr-only">Maak kennisgewings oop</span>
                                </button>
                                <section id="header-notification-panel"
                                         class="notification-panel"
                                         data-notification-panel
                                         aria-label="Kennisgewings"
                                         hidden>
                                    <div class="notification-panel-header">
                                        <div class="notification-panel-header-copy">
                                            <strong>Kennisgewings</strong>
                                            <span class="notification-panel-count" data-notification-panel-count hidden></span>
                                        </div>
                                        <button type="button"
                                                class="notification-panel-clear"
                                                data-notification-clear
                                                hidden>
                                            Maak skoon
                                        </button>
                                    </div>
                                    <p class="notification-panel-status" data-notification-loading hidden>Laai kennisgewings...</p>
                                    <div class="notification-list" data-notification-list></div>
                                    <div class="notification-panel-footer" data-notification-footer hidden>
                                        <button type="button"
                                                class="notification-panel-load-more"
                                                data-notification-load-more
                                                hidden>
                                            Wys vorige kennisgewings
                                        </button>
                                    </div>
                                </section>
                            </div>
                            <div class="account-menu" data-account-menu-root>
                                @{
                                    var profileImageUrl = ResolveProfileImageUrl(authState.User);
                                    var profileInitials = BuildProfileInitials(authState.User);
                                }
                                <button type="button"
                                        class="account-toggle"
                                        data-account-toggle
                                        aria-expanded="false"
                                        aria-controls="header-account-dropdown"
                                        aria-label="Jou rekening"
                                        title="Jou rekening">
                                    <span class="account-avatar" aria-hidden="true">
                                        @if (!string.IsNullOrWhiteSpace(profileImageUrl))
                                        {
                                            <img class="account-avatar-image" src="@profileImageUrl" alt="" loading="lazy" decoding="async" />
                                        }
                                        else
                                        {
                                            <span class="account-avatar-initials">@profileInitials</span>
                                        }
                                    </span>
                                    <i class="fa-solid fa-caret-down account-caret" aria-hidden="true"></i>
                                    <span class="sr-only">Maak jou rekening menu oop</span>
                                </button>
                                <section id="header-account-dropdown"
                                         class="account-dropdown"
                                         data-account-dropdown
                                         aria-label="Jou rekening menu">
                                    <a href="/my-stories" class="account-link">
                                        <i class="fa-solid fa-book-open" aria-hidden="true"></i>
                                        <span>My stories</span>
                                    </a>
                                    <a href="/intekening-en-betaling" class="account-link">
                                        <i class="fa-solid fa-credit-card" aria-hidden="true"></i>
                                        <span>Intekening en betaling</span>
                                    </a>
                                    <a href="/meer-oor-ons" class="account-link">
                                        <i class="fa-solid fa-circle-question" aria-hidden="true"></i>
                                        <span>Hulp sentrum</span>
                                    </a>
                                    <div class="account-divider" role="presentation"></div>
                                    <a href="/teken-uit" class="account-signout">
                                        <span>Teken uit</span>
                                    </a>
                                </section>
                            </div>
                            <button type="button" class="nav-menu-toggle" data-nav-menu-toggle
                                    aria-controls="main-site-nav" aria-expanded="false"
                                    onclick="return window.toggleSchinkNavMenu?.(this);"
                                    aria-label="Maak navigasie oop"
                                    title="Maak navigasie oop">
                                <i class="fa-solid fa-bars" aria-hidden="true"></i>
                                <span class="sr-only" data-nav-menu-toggle-label>Maak navigasie oop</span>
                            </button>
                            <nav id="main-site-nav"
                                 class="site-nav"
                                 aria-label="Hoofnavigasie">
                                <NavLink href="/luister" class="nav-panel-link">
                                    <i class="fa-solid fa-headphones" aria-hidden="true"></i>
                                    <span>Alle stories</span>
                                </NavLink>
                                <NavLink href="/karakters" class="nav-panel-link">
                                    <i class="fa-solid fa-people-group" aria-hidden="true"></i>
                                    <span>Karakters</span>
                                </NavLink>
                                <NavLink href="/resources" class="nav-panel-link">
                                    <i class="fa-solid fa-file-lines" aria-hidden="true"></i>
                                    <span>Hulpbronne</span>
                                </NavLink>
                                <NavLink href="/blog" class="nav-panel-link">
                                    <i class="fa-solid fa-pen-nib" aria-hidden="true"></i>
                                    <span>Blog</span>
                                </NavLink>
                                <NavLink href="/meer-oor-ons" class="nav-panel-link">
                                    <i class="fa-solid fa-circle-question" aria-hidden="true"></i>
                                    <span>Meer oor Ons</span>
                                </NavLink>
                                <NavLink href="/winkel" class="nav-panel-link">
                                    <i class="fa-solid fa-bag-shopping" aria-hidden="true"></i>
                                    <span>Winkel</span>
                                </NavLink>
                            </nav>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <div class="guest-controls">
                            <form class="site-search-form" role="search" action="/soek" method="get" data-search-form>
                                <button type="button"
                                        class="site-search-toggle"
                                        data-search-toggle
                                        aria-expanded="false"
                                        aria-controls="site-nav-search-guest"
                                        aria-label="Soek op die webwerf"
                                        title="Soek op die webwerf">
                                    <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                                    <span class="sr-only">Soek op die webwerf</span>
                                </button>
                                <div class="site-search-fields">
                                    <label class="sr-only" for="site-nav-search-guest">Soek op die webwerf</label>
                                    <input id="site-nav-search-guest"
                                           class="site-search-input"
                                           data-search-input
                                           type="search"
                                           name="q"
                                           placeholder="Soek op die webwerf"
                                           autocomplete="off" />
                                </div>
                                <span class="site-search-loader" data-search-loader hidden aria-live="polite">
                                    <span class="site-search-spinner" aria-hidden="true"></span>
                                    <span class="site-search-loader-text">Soek...</span>
                                </span>
                                <section class="site-search-suggestions" data-search-suggestions hidden aria-label="Soek voorstelle">
                                    <div class="site-search-suggestions-list" data-search-suggestions-list></div>
                                </section>
                            </form>
                            <a class="header-signin-btn" href="@LoginHref">Teken in</a>
                            <button type="button" class="nav-menu-toggle" data-nav-menu-toggle
                                    aria-controls="main-site-nav" aria-expanded="false"
                                    onclick="return window.toggleSchinkNavMenu?.(this);"
                                    aria-label="Maak navigasie oop"
                                    title="Maak navigasie oop">
                                <i class="fa-solid fa-bars" aria-hidden="true"></i>
                                <span class="sr-only" data-nav-menu-toggle-label>Maak navigasie oop</span>
                            </button>
                            <nav id="main-site-nav"
                                 class="site-nav"
                                 aria-label="Hoofnavigasie">
                                <NavLink href="/luister" class="nav-panel-link">
                                    <i class="fa-solid fa-headphones" aria-hidden="true"></i>
                                    <span>Alle stories</span>
                                </NavLink>
                                <NavLink href="/karakters" class="nav-panel-link">
                                    <i class="fa-solid fa-people-group" aria-hidden="true"></i>
                                    <span>Karakters</span>
                                </NavLink>
                                <NavLink href="/resources" class="nav-panel-link">
                                    <i class="fa-solid fa-file-lines" aria-hidden="true"></i>
                                    <span>Hulpbronne</span>
                                </NavLink>
                                <NavLink href="/blog" class="nav-panel-link">
                                    <i class="fa-solid fa-pen-nib" aria-hidden="true"></i>
                                    <span>Blog</span>
                                </NavLink>
                                <NavLink href="/meer-oor-ons" class="nav-panel-link">
                                    <i class="fa-solid fa-circle-question" aria-hidden="true"></i>
                                    <span>Meer oor Ons</span>
                                </NavLink>
                                <NavLink href="/winkel" class="nav-panel-link">
                                    <i class="fa-solid fa-bag-shopping" aria-hidden="true"></i>
                                    <span>Winkel</span>
                                </NavLink>
                                <NavLink href="/opsies" class="nav-panel-link">
                                    <i class="fa-solid fa-sliders" aria-hidden="true"></i>
                                    <span>Opsies</span>
                                </NavLink>
                            </nav>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        }
    </header>
    }

    @if (IsFloatingPlaylistRoute)
    {
        <a class="showcase-floating-back"
           href="@StoryHeaderBackHref"
           data-enhance-nav="false"
           aria-label="@StoryHeaderBackLabel"
           title="@StoryHeaderBackLabel">
            <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
            <span class="sr-only">@StoryHeaderBackLabel</span>
        </a>
        <AuthorizeView>
            <Authorized>
                <div class="showcase-floating-menu nav-controls">
                    <button type="button"
                            class="nav-menu-toggle"
                            data-nav-menu-toggle
                            aria-controls="showcase-site-nav"
                            aria-expanded="false"
                            onclick="return window.toggleSchinkNavMenu?.(this);"
                            aria-label="Maak navigasie oop"
                            title="Maak navigasie oop">
                        <i class="fa-solid fa-bars" aria-hidden="true"></i>
                        <span class="sr-only" data-nav-menu-toggle-label>Maak navigasie oop</span>
