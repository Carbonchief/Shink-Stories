    private bool IsLuisterPlaylistShowcaseRoute
    {
        get
        {
            var relativePath = GetCurrentRelativePathWithoutQuery();
            var segments = relativePath.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            return segments.Length == 4 &&
                   string.Equals(segments[0], "luister", StringComparison.OrdinalIgnoreCase) &&
                   string.Equals(segments[1], "speellys", StringComparison.OrdinalIgnoreCase) &&
                   string.Equals(segments[3], "stories", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool IsLuisterPlaylistRoute
    {
        get
        {
            var relativePath = GetCurrentRelativePathWithoutQuery();
            var segments = relativePath.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            return segments.Length == 3 &&
                   string.Equals(segments[0], "luister", StringComparison.OrdinalIgnoreCase) &&
                   string.Equals(segments[1], "speellys", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool IsFloatingPlaylistRoute => IsLuisterPlaylistRoute || IsLuisterPlaylistShowcaseRoute;

    private bool IsLuisterStoryRoute
    {
        get
        {
            var relativePath = GetCurrentRelativePathWithoutQuery();
            var segments = relativePath.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            return segments.Length == 2 &&
                   string.Equals(segments[0], "luister", StringComparison.OrdinalIgnoreCase);
        }
    }

    private string GetCurrentRelativePathWithoutQuery()
    {
        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var queryOrFragmentIndex = relativePath.IndexOfAny(['?', '#']);
        if (queryOrFragmentIndex >= 0)
        {
            relativePath = relativePath[..queryOrFragmentIndex];
        }

        return relativePath.Trim('/');
    }

    private string StoryHeaderBackHref
    {
        get
        {
            var relativePath = GetCurrentRelativePathWithoutQuery();
            if (relativePath.StartsWith("gratis/", StringComparison.OrdinalIgnoreCase))
            {
                return "/gratis";
            }

            if (relativePath.StartsWith("luister/speellys/", StringComparison.OrdinalIgnoreCase))
            {
                var showcaseBackHref = BuildShowcaseBackHrefForPlaylistRoute(relativePath);
                if (!string.IsNullOrWhiteSpace(showcaseBackHref))
                {
                    return showcaseBackHref;
                }

                return "/luister";
            }

            if (relativePath.StartsWith("luister/", StringComparison.OrdinalIgnoreCase))
            {
                var playlistBackHref = BuildPlaylistContextBackHref(relativePath);
                if (!string.IsNullOrWhiteSpace(playlistBackHref))
                {
                    return playlistBackHref;
                }

                return "/luister";
            }

            return "/";
        }
    }

    private string StoryHeaderBackLabel
    {
        get
        {
            var relativePath = GetCurrentRelativePathWithoutQuery();
            if (relativePath.StartsWith("gratis/", StringComparison.OrdinalIgnoreCase))
            {
                return "Terug na gratis stories";
            }

            if (relativePath.StartsWith("luister/speellys/", StringComparison.OrdinalIgnoreCase))
            {
                var showcaseBackHref = BuildShowcaseBackHrefForPlaylistRoute(relativePath);
                if (!string.IsNullOrWhiteSpace(showcaseBackHref))
                {
                    return "Terug na speellys stories";
                }

                return "Terug na luister";
            }

            if (relativePath.StartsWith("luister/", StringComparison.OrdinalIgnoreCase))
            {
                var playlistTitle = GetCurrentQueryValue("playlistName");
                if (!string.IsNullOrWhiteSpace(playlistTitle))
                {
                    return $"Terug na {playlistTitle.Trim()}";
                }

                return "Terug na luister";
            }

            return "Terug";
        }
    }

    private string StoryHeaderTitle
    {
        get
        {
            var relativePath = GetCurrentRelativePathWithoutQuery();

            if (!relativePath.StartsWith("luister/", StringComparison.OrdinalIgnoreCase)) return "Schink Stories";
            var playlistTitle = GetCurrentQueryValue("playlistName");
            return !string.IsNullOrWhiteSpace(playlistTitle) ? playlistTitle.Trim() : "Schink Stories";
        }
    }

    private string? BuildPlaylistContextBackHref(string relativePath)
    {
        var playlistSlug = GetCurrentQueryValue("playlist");
        if (string.IsNullOrWhiteSpace(playlistSlug))
        {
            return null;
        }

        var playlistView = GetCurrentQueryValue("playlistView");
        var path = string.Equals(playlistView, "showcase", StringComparison.OrdinalIgnoreCase)
            ? $"/luister/speellys/{Uri.EscapeDataString(playlistSlug.Trim())}/stories"
            : $"/luister/speellys/{Uri.EscapeDataString(playlistSlug.Trim())}";
        var storySlug = GetLuisterStorySlug(relativePath);
        if (string.IsNullOrWhiteSpace(storySlug))
        {
            return path;
        }

        return $"{path}?storie={Uri.EscapeDataString(storySlug.Trim())}";
    }

    private string? GetCurrentQueryValue(string key)
    {
        var currentUri = new Uri(NavigationManager.Uri);
        var query = currentUri.Query.TrimStart('?');
        if (string.IsNullOrWhiteSpace(query))
        {
            return null;
        }

        foreach (var segment in query.Split('&', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            var parts = segment.Split('=', 2);
            if (!string.Equals(parts[0], key, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            var value = parts.Length > 1 ? parts[1] : string.Empty;
            return Uri.UnescapeDataString(value.Replace('+', ' '));
        }

        return null;
    }

    private static string? GetLuisterStorySlug(string relativePath)
    {
        if (!relativePath.StartsWith("luister/", StringComparison.OrdinalIgnoreCase) ||
            relativePath.StartsWith("luister/speellys/", StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        var segments = relativePath.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return segments.Length >= 2 ? Uri.UnescapeDataString(segments[1]) : null;
    }

    private string? BuildShowcaseBackHrefForPlaylistRoute(string relativePath)
    {
        var playlistView = GetCurrentQueryValue("playlistView");
        if (!string.Equals(playlistView, "showcase", StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        var playlistSlug = GetPlaylistSlugFromRoute(relativePath);
        if (string.IsNullOrWhiteSpace(playlistSlug))
        {
            return null;
        }

        var showcasePath = $"/luister/speellys/{Uri.EscapeDataString(playlistSlug.Trim())}/stories";
        var currentStorySlug = GetCurrentQueryValue("storie");
        if (string.IsNullOrWhiteSpace(currentStorySlug))
        {
            return showcasePath;
        }

        return QueryHelpers.AddQueryString(showcasePath, "storie", currentStorySlug.Trim());
    }

    private static string? GetPlaylistSlugFromRoute(string relativePath)
    {
        var segments = relativePath.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (segments.Length < 3 ||
            !string.Equals(segments[0], "luister", StringComparison.OrdinalIgnoreCase) ||
            !string.Equals(segments[1], "speellys", StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        return Uri.UnescapeDataString(segments[2]);
    }

    private static string? ResolveProfileImageUrl(ClaimsPrincipal user)
    {
        if (user.Identity?.IsAuthenticated != true)
        {
            return null;
        }

        var claimValue = user.FindFirst("picture")?.Value
            ?? user.FindFirst("avatar_url")?.Value
            ?? user.FindFirst("profile_image_url")?.Value
            ?? user.FindFirst("photo_url")?.Value;

        if (string.IsNullOrWhiteSpace(claimValue))
        {
            return null;
        }

        var trimmed = claimValue.Trim();
        if (trimmed.StartsWith("/", StringComparison.Ordinal))
        {
            return trimmed;
        }

        if (!Uri.TryCreate(trimmed, UriKind.Absolute, out var parsed))
        {
            return null;
        }

        return string.Equals(parsed.Scheme, Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase) ||
               string.Equals(parsed.Scheme, Uri.UriSchemeHttp, StringComparison.OrdinalIgnoreCase)
            ? parsed.ToString()
            : null;
    }

    private static string BuildProfileInitials(ClaimsPrincipal user)
    {
        var givenName = user.FindFirst(ClaimTypes.GivenName)?.Value;
        var surname = user.FindFirst(ClaimTypes.Surname)?.Value;
        var fromSeparateNames = BuildInitials(givenName, surname);
        if (!string.IsNullOrWhiteSpace(fromSeparateNames))
        {
            return fromSeparateNames;
        }

        var displayName = user.FindFirst(ClaimTypes.Name)?.Value
            ?? user.FindFirst(ClaimTypes.Email)?.Value
            ?? user.Identity?.Name
            ?? "Schink";

        var localName = displayName.Contains('@', StringComparison.Ordinal)
            ? displayName[..displayName.IndexOf('@')]
            : displayName;

        var tokens = localName
            .Split([' ', '.', '_', '-'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(token => token.Length > 0)
            .Take(2)
            .ToArray();

        if (tokens.Length >= 2)
        {
            return string.Concat(
                char.ToUpperInvariant(tokens[0][0]),
                char.ToUpperInvariant(tokens[1][0]));
        }

        if (tokens.Length == 1)
        {
            var token = tokens[0];
            if (token.Length >= 2)
            {
                return string.Concat(
                    char.ToUpperInvariant(token[0]),
                    char.ToUpperInvariant(token[1]));
            }

            return char.ToUpperInvariant(token[0]).ToString();
        }

        return "S";
    }

    private static string? BuildInitials(string? first, string? last)
    {
        var firstInitial = string.IsNullOrWhiteSpace(first)
            ? null
            : char.ToUpperInvariant(first.Trim()[0]).ToString();
        var lastInitial = string.IsNullOrWhiteSpace(last)
            ? null
            : char.ToUpperInvariant(last.Trim()[0]).ToString();

        if (firstInitial is null && lastInitial is null)
        {
            return null;
        }

        return $"{firstInitial}{lastInitial}".Trim();
    }

}
