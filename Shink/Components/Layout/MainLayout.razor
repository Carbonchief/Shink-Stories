                            <i class="fa-solid fa-headphones" aria-hidden="true"></i>
                            <span>Alle stories</span>
                        </NavLink>
                        <NavLink href="/karakters" class="nav-panel-link">
                            <i class="fa-solid fa-people-group" aria-hidden="true"></i>
                            <span>Karakters</span>
                        </NavLink>
                        <NavLink href="/resources" class="nav-panel-link">
                            <i class="fa-solid fa-file-lines" aria-hidden="true"></i>
                            <span>Hulpbronne</span>
                        </NavLink>
                        <NavLink href="/blog" class="nav-panel-link">
                            <i class="fa-solid fa-pen-nib" aria-hidden="true"></i>
                            <span>Blog</span>
                        </NavLink>
                        <NavLink href="/meer-oor-ons" class="nav-panel-link">
                            <i class="fa-solid fa-circle-question" aria-hidden="true"></i>
                            <span>Meer oor Ons</span>
                        </NavLink>
                        <NavLink href="/winkel" class="nav-panel-link">
